local function rebuildSortOrder(targetContent)
    local sorted = {}
    for _, data in pairs(scriptButtons) do
        if data.btn.Parent == targetContent then
            table.insert(sorted, data)
        end
    end
    table.sort(sorted, function(a, b)
        local aFav = favorites[a.info.file or a.info.url] or false
        local bFav = favorites[b.info.file or b.info.url] or false
        if aFav ~= bFav then return aFav end
        return a.info.name:lower() < b.info.name:lower()
    end)
    for i, data in ipairs(sorted) do
        data.btn.LayoutOrder = i
    end
end

