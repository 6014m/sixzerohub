local knownFiles = {}
local function buildKnownFiles()
    for _, s in ipairs(UNI_SCRIPTS) do if s.file then knownFiles[s.file] = true end end
    for _, s in ipairs(DEV_SCRIPTS) do if s.file then knownFiles[s.file] = true end end
    for _, s in ipairs(SPEC_SCRIPTS) do if s.file then knownFiles[s.file] = true end end
    knownFiles["Gui"] = true -- hub itself
end
buildKnownFiles()

local typeMap = {
    ["[Uni]"] = { source = "uni", label = "Uni", content = uniContent, list = UNI_SCRIPTS },
    ["[Dev]"] = { source = "dev", label = "Dev", content = devContent, list = DEV_SCRIPTS },
    ["[Spec]"] = { source = "spec", label = "Spec", content = specContent, list = SPEC_SCRIPTS },
}

local function getScriptTypeInfo(fileName)
    for prefix, info in pairs(typeMap) do
        if fileName:sub(1, #prefix) == prefix then
            return info, prefix
        end
    end
    return nil
end

task.spawn(function()
    task.wait(8)
    while screenGui and screenGui.Parent do
        local ok, response = pcall(function()
            return game:HttpGet("https://api.github.com/repos/6014m/sixzerohub/contents", true)
        end)
        if ok and response then
            for name in response:gmatch('"name"%s*:%s*"([^"]+)"') do
                local typeInfo, prefix = getScriptTypeInfo(name)
                if not knownFiles[name] and typeInfo then
                    local displayName = name:sub(#prefix + 1):gsub("_", " ")
                    knownFiles[name] = true

                    -- add to script list and create button in menu
                    local newInfo = { name = displayName, file = name }
                    table.insert(typeInfo.list, newInfo)
                    createScriptButton(newInfo, typeInfo.content, typeInfo.source)
                    rebuildSortOrder(typeInfo.content)

                    showNotification(
                        "Update/Release",
                        "[" .. typeInfo.label .. "] " .. displayName .. " has been added",
                        "dismiss"
                    )
                end
            end
        end
        task.wait(UPDATE_CHECK_INTERVAL)
    end
end)

