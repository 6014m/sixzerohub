---------- GUI OFFSET MANAGEMENT ----------

local movedScreenGuis = {}
local GUI_OFFSET = SIDEBAR_WIDTH + 16

local function shiftGameGuis(show)
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= screenGui and gui ~= toggleGui then
            if show then
                if not movedScreenGuis[gui] then
                    movedScreenGuis[gui] = gui.Position
                end
                gui.Position = UDim2.new(0, GUI_OFFSET, 0, 0)
            elseif movedScreenGuis[gui] then
                gui.Position = movedScreenGuis[gui]
                movedScreenGuis[gui] = nil
            end
        end
    end
end

local chatMoved = false

local function findAndMoveChat(show)
    -- search PlayerGui and CoreGui for chat GUIs
    local searchIn = {playerGui}
    pcall(function() table.insert(searchIn, game:GetService("CoreGui")) end)

    for _, parent in ipairs(searchIn) do
        pcall(function()
            for _, gui in ipairs(parent:GetChildren()) do
                if gui:IsA("ScreenGui") and gui ~= screenGui and gui ~= toggleGui then
                    local n = gui.Name:lower()
                    if n:find("chat") or n == "experiencechat" then
                        if show then
                            if not movedScreenGuis[gui] then
                                movedScreenGuis[gui] = gui.Position
                            end
                            gui.Position = UDim2.new(0, GUI_OFFSET, 0, 0)
                        elseif movedScreenGuis[gui] then
                            gui.Position = movedScreenGuis[gui]
                            movedScreenGuis[gui] = nil
                        end
                    end
                end
            end
        end)
    end
end

local function moveChat(show)
    task.spawn(function()
        -- try SetCore first (legacy chat)
        for _ = 1, 10 do
            local ok = pcall(function()
                if show then
                    StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, GUI_OFFSET, 0, 4))
                else
                    StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, 0, 0, 0))
                end
            end)
            if ok then
                chatMoved = true
                break
            end
            task.wait(0.5)
        end

        -- also directly move chat ScreenGuis (works for TextChatService)
        findAndMoveChat(show)

        -- retry a few times in case chat GUI loads late
        if show then
            for _ = 1, 5 do
                task.wait(1)
                findAndMoveChat(true)
            end
        end
    end)
end

---------- TOGGLE VISIBILITY ----------

local function toggleGuiVisibility()
    guiVisible = not guiVisible

    eyeBtn.TextTransparency = guiVisible and 0 or 0.5

    if guiVisible then
        topBar.Visible = true
        sidebar.Visible = true
        slantClip.Visible = true
        TweenService:Create(topBar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0)
        }):Play()
        TweenService:Create(sidebar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, TOPBAR_HEIGHT + 1)
        }):Play()
        moveChat(true)
        shiftGameGuis(true)
    else
        TweenService:Create(topBar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, 0, 0, -TOPBAR_HEIGHT)
        }):Play()
        local t = TweenService:Create(sidebar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, -SIDEBAR_WIDTH, 0, TOPBAR_HEIGHT + 1)
        })
        t:Play()
        t.Completed:Connect(function()
            if not guiVisible then
                topBar.Visible = false
                sidebar.Visible = false
                slantClip.Visible = false
            end
        end)
        moveChat(false)
        shiftGameGuis(false)
        closeUniMenu()
        closeActiveMenu()
    end
end

eyeBtn.MouseButton1Click:Connect(toggleGuiVisibility)

