local REPO_BASE = "https://raw.githubusercontent.com/6014m/sixzerohub/main/"
local SCRIPTS = {
    { name = "Horizontal Density", file = "[Uni]horizontal_density" },
    { name = "Damage Block Dodger", file = "[Uni]damage_block_dodger" },
