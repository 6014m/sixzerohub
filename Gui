function refreshActiveList()
    for _, child in ipairs(activeContent:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local count = 0
    for fileKey, data in pairs(activeScripts) do
        count = count + 1

        local row = Instance.new("Frame")
        row.Name = fileKey
        row.Size = UDim2.new(1, -8, 0, 36)
        row.BackgroundColor3 = COLORS.hover
        row.BorderSizePixel = 0
        row.Parent = activeContent

        local rowCorner = Instance.new("UICorner")
        rowCorner.CornerRadius = UDim.new(0, 6)
        rowCorner.Parent = row

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, -90, 1, 0)
        nameLabel.Position = UDim2.new(0, 10, 0, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = data.name
        nameLabel.TextColor3 = Color3.fromRGB(87, 242, 135)
        nameLabel.TextSize = 14
        nameLabel.Font = Enum.Font.Gotham
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.Parent = row

        local deactivateBtn = Instance.new("TextButton")
        deactivateBtn.Name = "Deactivate"
        deactivateBtn.Size = UDim2.new(0, 75, 0, 24)
        deactivateBtn.Position = UDim2.new(1, -82, 0.5, -12)
        deactivateBtn.BackgroundColor3 = Color3.fromRGB(237, 66, 69)
        deactivateBtn.BorderSizePixel = 0
        deactivateBtn.Text = "Deactivate"
        deactivateBtn.TextColor3 = COLORS.text
        deactivateBtn.TextSize = 11
        deactivateBtn.Font = Enum.Font.GothamBold
        deactivateBtn.AutoButtonColor = false
        deactivateBtn.Parent = row

        local deactivateCorner = Instance.new("UICorner")
        deactivateCorner.CornerRadius = UDim.new(0, 4)
        deactivateCorner.Parent = deactivateBtn

        deactivateBtn.MouseEnter:Connect(function()
            TweenService:Create(deactivateBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
        end)
        deactivateBtn.MouseLeave:Connect(function()
            TweenService:Create(deactivateBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(237, 66, 69)}):Play()
        end)

        deactivateBtn.MouseButton1Click:Connect(function()
            if data.cleanup then
                pcall(data.cleanup)
            end
            activeScripts[fileKey] = nil
            loadedScripts[fileKey] = nil
            -- reset uni menu status
            if uniContent then
                local uniBtn_ref = uniContent:FindFirstChild(fileKey)
                if uniBtn_ref then
                    local statusLabel = uniBtn_ref:FindFirstChild("Status")
                    if statusLabel then statusLabel.Text = "" end
                end
            end
            refreshActiveList()
        end)
    end

    activeEmptyLabel.Visible = (count == 0)
end

-- make active menu draggable
local activeDragging, activeDragStart, activeStartPos
activeMenuHeader.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        activeDragging = true
        activeDragStart = input.Position
        activeStartPos = activeMenu.Position
    end
end)
activeMenuHeader.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        activeDragging = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if activeDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - activeDragStart
        activeMenu.Position = UDim2.new(
            activeStartPos.X.Scale, activeStartPos.X.Offset + delta.X,
            activeStartPos.Y.Scale, activeStartPos.Y.Offset + delta.Y
        )
    end
end)

local function toggleActiveMenu()
    activeMenuOpen = not activeMenuOpen
    if activeMenuOpen then
        refreshActiveList()
        activeMenu.Visible = true
        activeMenu.Size = UDim2.new(0, 400, 0, 0)
        TweenService:Create(activeMenu, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 400, 0, 300)
        }):Play()
    else
        local tween = TweenService:Create(activeMenu, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 400, 0, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            activeMenu.Visible = false
        end)
    end
end

activeCloseBtn.MouseButton1Click:Connect(function()
    if activeMenuOpen then toggleActiveMenu() end
