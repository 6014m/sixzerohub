local function shiftGameGuis(show)
    -- ScreenGui has no Position property; toggle Enabled instead
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= screenGui and gui ~= toggleGui then
