        empty.TextColor3 = COLORS.textMuted
        empty.TextSize = 14
        empty.Font = Enum.Font.Gotham
        empty.Parent = favGamesContent
        return
    end

    -- shared drag logic for both game rows and dividers
    local function setupDrag(row, dragHandle, i)
        local rowDragging = false
        local dragStartY = 0
        local origOrder = 0

        dragHandle.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                rowDragging = true
                dragStartY = input.Position.Y
                origOrder = row.LayoutOrder
                row.BackgroundColor3 = COLORS.sidebar
                row.ZIndex = 5
                for _, ch in ipairs(row:GetChildren()) do
                    if ch:IsA("GuiObject") then ch.ZIndex = 5 end
                end
            end
        end)

        local dragInputConn
        dragInputConn = UserInputService.InputChanged:Connect(function(input)
            if not rowDragging then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end

            local deltaY = input.Position.Y - dragStartY
            local rowHeight = 50
            local shift = math.floor(deltaY / rowHeight + 0.5)
            local newOrder = math.clamp(origOrder + shift, 1, #favGamesList)

            if newOrder ~= row.LayoutOrder then
                local oldIdx = row.LayoutOrder
                if oldIdx >= 1 and oldIdx <= #favGamesList and newOrder >= 1 and newOrder <= #favGamesList then
                    local item = table.remove(favGamesList, oldIdx)
                    table.insert(favGamesList, newOrder, item)
                    saveFavGames()
                    refreshFavGamesList()
                    rowDragging = false
                end
            end
        end)

        local dragEndConn
        dragEndConn = UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if rowDragging then
                    rowDragging = false
                    row.BackgroundColor3 = row:GetAttribute("DefaultBG") and Color3.new(row:GetAttribute("DefaultBG")) or COLORS.hover
                    row.ZIndex = 1
                    for _, ch in ipairs(row:GetChildren()) do
                        if ch:IsA("GuiObject") then ch.ZIndex = 1 end
                    end
                end
            end
        end)

        row.Destroying:Connect(function()
            if dragInputConn then dragInputConn:Disconnect() end
            if dragEndConn then dragEndConn:Disconnect() end
        end)
    end

    for i, entry in ipairs(favGamesList) do
        if entry.type == "divider" then
            -- DIVIDER ROW
