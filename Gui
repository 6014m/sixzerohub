    local all = {}
    for _, s in ipairs(UNI_SCRIPTS) do table.insert(all, {info = s, source = "uni"}) end
    for _, s in ipairs(DEV_SCRIPTS) do table.insert(all, {info = s, source = "dev"}) end
    for _, s in ipairs(SPEC_SCRIPTS) do table.insert(all, {info = s, source = "spec"}) end
    return all
end

task.spawn(function()
    task.wait(3) -- initial delay before first check
    while screenGui and screenGui.Parent do
        local allScripts = getAllScriptLists()
        for _, entry in ipairs(allScripts) do
            local info = entry.info
            local source = entry.source
            local fileKey = info.file or info.url
            if not loadedScripts[fileKey] then continue end

            local apiUrl = getGitApiUrl(info)
            if not apiUrl then continue end

            local newSHA = fetchSHA(apiUrl)
            if not newSHA then continue end

            if scriptSHAs[fileKey] and scriptSHAs[fileKey] ~= newSHA then
                -- script has changed, fetch the new content
                local scriptUrl = info.url or (REPO_BASE .. info.file)
                local contentOk, newContent = pcall(function()
                    return game:HttpGet(scriptUrl .. "?v=" .. newSHA, true)
                end)

                if contentOk and newContent then
                    local answer = showNotification(
                        info.name .. " has updated",
                        "Would you like to swap to the most recent version?",
                        "yesno"
                    )
                    if answer == "yes" then
                        -- deactivate old
                        local data = activeScripts[fileKey]
                        if data and data.cleanup then
                            pcall(data.cleanup)
                        end
                        activeScripts[fileKey] = nil
                        loadedScripts[fileKey] = nil

                        -- re-execute
                        pcall(function()
                            loadstring(newContent)()
                        end)
                        loadedScripts[fileKey] = true

                        -- log the update
                        _logUpdate(info.name)

                        -- reload compat if needed
                        if info.compat then
                            task.delay(1, function()
                                pcall(function()
                                    loadstring(game:HttpGet(info.compat))()
                                end)
                            end)
                        end

                        -- auto-register if script doesn't self-register
                        task.delay(2, function()
                            if not activeScripts[fileKey] then
                                _G.SixZeroHubRegister(info.name, fileKey, nil, source)
                            end
                        end)

                        -- update status in script buttons
                        local btnData = scriptButtons[fileKey]
                        if btnData then
                            btnData.status.Text = "running"
                            btnData.status.TextColor3 = Color3.fromRGB(87, 242, 135)
                        end
                    end
                end
                scriptSHAs[fileKey] = newSHA
            elseif not scriptSHAs[fileKey] then
                scriptSHAs[fileKey] = newSHA
            end

            task.wait(0.3) -- stagger checks between scripts
        end
        task.wait(UPDATE_CHECK_INTERVAL)
    end
end)

