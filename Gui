        if type(decoded) == "table" then
            -- restore placeIds from strings back to numbers
            for _, entry in ipairs(decoded) do
                if entry.type ~= "divider" and entry.placeId then
                    entry.placeId = tonumber(entry.placeId) or entry.placeId
                end
            end
            favGamesList = decoded
        end
    end
end)

local function saveFavGames()
    local ok, err = pcall(function()
        if not writefile then return end
        -- sanitize for JSON: convert placeId to string to avoid precision loss
        local toSave = {}
        for _, entry in ipairs(favGamesList) do
            if entry.type == "divider" then
                table.insert(toSave, { type = "divider", name = entry.name or "Section" })
            else
                table.insert(toSave, {
                    placeId = tostring(entry.placeId),
                    gameName = entry.gameName or "",
                    vipLink = entry.vipLink,
                })
            end
        end
        writefile(FAV_GAMES_FILE, HttpService:JSONEncode(toSave))
    end)
    if not ok then warn("[SixZeroHub] Failed to save fav games: " .. tostring(err)) end
end

