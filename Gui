local function toggleGui()
    guiVisible = not guiVisible

    if guiVisible then
        -- show panel
        panel.Visible = true
        persistentToggle.Visible = false
        TweenService:Create(panel, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0)
        }):Play()
        moveChat(true)
        shiftGameGuis(PANEL_WIDTH)
    else
        -- hide panel
        persistentToggle.Visible = true
        local tween = TweenService:Create(panel, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, -PANEL_WIDTH, 0, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            if not guiVisible then
                panel.Visible = false
            end
        end)
        moveChat(false)
        shiftGameGuis(-PANEL_WIDTH)
        -- close uni menu if open
        if uniMenuOpen then toggleUniMenu() end
    end
end

toggleBtn.MouseButton1Click:Connect(toggleGui)
persistentToggle.MouseButton1Click:Connect(toggleGui)

