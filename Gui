-- make uni menu draggable
local dragging, dragStart, startPos
uniMenuHeader.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = uniMenu.Position
    end
end)

uniMenuHeader.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        uniMenu.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- toggle uni menu
local function toggleUniMenu()
    uniMenuOpen = not uniMenuOpen
    if uniMenuOpen then
        uniMenu.Visible = true
        uniMenu.Size = UDim2.new(0, 400, 0, 0)
        TweenService:Create(uniMenu, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 400, 0, 300)
        }):Play()
    else
        local tween = TweenService:Create(uniMenu, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 400, 0, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            uniMenu.Visible = false
        end)
    end
end

uniBtn.MouseButton1Click:Connect(toggleUniMenu)
uniCloseBtn.MouseButton1Click:Connect(function()
    if uniMenuOpen then toggleUniMenu() end
end)

---------- GUI OFFSET MANAGEMENT ----------

local originalChatPosition = nil
local movedGameGuis = {} -- {gui = originalPosition}

local function getChatFrame()
    local ok, result = pcall(function()
        return playerGui:FindFirstChild("Chat") or CoreGui:FindFirstChild("Chat")
    end)
    return ok and result or nil
end

local function offsetGuiElement(gui, offset)
    if gui:IsA("ScreenGui") then
        for _, child in ipairs(gui:GetChildren()) do
            if child:IsA("GuiObject") then
                if not movedGameGuis[child] then
                    movedGameGuis[child] = child.Position
                end
                child.Position = UDim2.new(
                    child.Position.X.Scale, child.Position.X.Offset + offset,
                    child.Position.Y.Scale, child.Position.Y.Offset
                )
            end
        end
    end
end

local function restoreGuiElement(child)
    if movedGameGuis[child] then
        child.Position = movedGameGuis[child]
        movedGameGuis[child] = nil
    end
end

local function shiftGameGuis(offset)
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= screenGui and gui.Name ~= "SixZeroHub" then
            for _, child in ipairs(gui:GetChildren()) do
                if child:IsA("GuiObject") then
                    -- only move elements on the left side of the screen
                    local absX = child.AbsolutePosition.X
                    if absX < PANEL_WIDTH then
                        if offset > 0 then
                            if not movedGameGuis[child] then
                                movedGameGuis[child] = child.Position
                            end
                            child.Position = UDim2.new(
                                child.Position.X.Scale, child.Position.X.Offset + offset,
                                child.Position.Y.Scale, child.Position.Y.Offset
                            )
                        else
                            restoreGuiElement(child)
                        end
                    end
                end
            end
        end
    end
end

local function moveChat(show)
    pcall(function()
        if show then
            StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, PANEL_WIDTH + 4, 0, 0))
        else
            StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, 0, 0, 0))
        end
    end)
end

