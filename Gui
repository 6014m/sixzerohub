local function showSettingsPanel(fileKey)
    if not settingsPanel then buildSettingsPanel() end

    local defs = scriptSettingsDefs[fileKey]
    if not defs then return end

    -- init values table if needed
    if not scriptSettingsValues[fileKey] then
        scriptSettingsValues[fileKey] = {}
    end
    local values = scriptSettingsValues[fileKey]

    -- set defaults for any missing values
    for _, def in ipairs(defs) do
        if values[def.name] == nil then
            values[def.name] = def.default
        end
    end

    -- clear old content
    for _, child in ipairs(settingsPanelContent:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    -- set title
    settingsPanel.Header.Title.Text = (defs._title or fileKey) .. " Settings"

    -- build controls
    for i, def in ipairs(defs) do
        local row = Instance.new("Frame")
        row.Name = def.name
        row.Size = UDim2.new(1, 0, 0, 30)
        row.BackgroundTransparency = 1
        row.LayoutOrder = i
        row.Parent = settingsPanelContent

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.55, 0, 1, 0)
        label.Position = UDim2.new(0, 4, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = def.label or def.name
        label.TextColor3 = COLORS.text
        label.TextSize = 13
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextTruncate = Enum.TextTruncate.AtEnd
        label.Parent = row

        if def.type == "toggle" then
            local toggleBtn = Instance.new("TextButton")
            toggleBtn.Size = UDim2.new(0, 40, 0, 22)
            toggleBtn.Position = UDim2.new(1, -48, 0, 4)
            toggleBtn.BorderSizePixel = 0
            toggleBtn.Font = Enum.Font.GothamBold
            toggleBtn.TextSize = 11
            toggleBtn.AutoButtonColor = false
            toggleBtn.Parent = row
            Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 4)

            local function updateToggle()
                local val = values[def.name]
                toggleBtn.Text = val and "ON" or "OFF"
                toggleBtn.BackgroundColor3 = val and Color3.fromRGB(87, 242, 135) or COLORS.hover
                toggleBtn.TextColor3 = val and COLORS.darker or COLORS.text
            end
            updateToggle()

            toggleBtn.MouseButton1Click:Connect(function()
                values[def.name] = not values[def.name]
                updateToggle()
                if def.onChange then pcall(def.onChange, values[def.name]) end
                saveSettingsToFile()
            end)

        elseif def.type == "slider" then
            local min = def.min or 0
            local max = def.max or 100
            local step = def.step or 1

            local valLabel = Instance.new("TextLabel")
            valLabel.Size = UDim2.new(0, 35, 1, 0)
            valLabel.Position = UDim2.new(1, -40, 0, 0)
            valLabel.BackgroundTransparency = 1
            valLabel.TextColor3 = COLORS.textMuted
            valLabel.TextSize = 12
            valLabel.Font = Enum.Font.Gotham
            valLabel.Text = tostring(values[def.name] or min)
            valLabel.Parent = row

            local sliderBar = Instance.new("Frame")
            sliderBar.Size = UDim2.new(0.35, 0, 0, 6)
            sliderBar.Position = UDim2.new(0.55, 4, 0.5, -3)
            sliderBar.BackgroundColor3 = COLORS.hover
            sliderBar.BorderSizePixel = 0
            sliderBar.Parent = row
            Instance.new("UICorner", sliderBar).CornerRadius = UDim.new(0, 3)

            local knob = Instance.new("Frame")
            knob.Size = UDim2.new(0, 12, 0, 16)
            knob.AnchorPoint = Vector2.new(0.5, 0.5)
            knob.BackgroundColor3 = COLORS.accent
            knob.BorderSizePixel = 0
            knob.Parent = sliderBar
            Instance.new("UICorner", knob).CornerRadius = UDim.new(0, 3)

            local function updateSlider()
                local val = values[def.name] or min
                local pct = (val - min) / (max - min)
                knob.Position = UDim2.new(pct, 0, 0.5, 0)
                valLabel.Text = tostring(math.floor(val / step + 0.5) * step)
            end
            updateSlider()

            local dragging = false
            sliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local relX = math.clamp((input.Position.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
                    local raw = min + (max - min) * relX
                    local stepped = math.floor(raw / step + 0.5) * step
                    values[def.name] = math.clamp(stepped, min, max)
                    updateSlider()
                    if def.onChange then pcall(def.onChange, values[def.name]) end
                    saveSettingsToFile()
                end
            end)

        elseif def.type == "dropdown" then
            local options = def.options or {}

            local dropBtn = Instance.new("TextButton")
            dropBtn.Size = UDim2.new(0.4, -8, 0, 22)
            dropBtn.Position = UDim2.new(0.6, 0, 0, 4)
            dropBtn.BackgroundColor3 = COLORS.hover
            dropBtn.BorderSizePixel = 0
            dropBtn.Text = tostring(values[def.name] or options[1] or "")
            dropBtn.TextColor3 = COLORS.text
            dropBtn.TextSize = 12
            dropBtn.Font = Enum.Font.Gotham
            dropBtn.AutoButtonColor = false
            dropBtn.TextTruncate = Enum.TextTruncate.AtEnd
            dropBtn.Parent = row
            Instance.new("UICorner", dropBtn).CornerRadius = UDim.new(0, 4)

            local optIdx = table.find(options, values[def.name]) or 1

            dropBtn.MouseButton1Click:Connect(function()
                optIdx = optIdx % #options + 1
                values[def.name] = options[optIdx]
                dropBtn.Text = tostring(values[def.name])
                if def.onChange then pcall(def.onChange, values[def.name]) end
                saveSettingsToFile()
            end)
        end
    end

    settingsPanelKey = fileKey
    settingsPanelOpen = true
    settingsPanel.Visible = true
end

_G.SixZeroHubRegisterSettings = function(fileKey, defs)
    scriptSettingsDefs[fileKey] = defs
    -- init defaults
    if not scriptSettingsValues[fileKey] then
        scriptSettingsValues[fileKey] = {}
    end
    for _, def in ipairs(defs) do
        if scriptSettingsValues[fileKey][def.name] == nil then
            scriptSettingsValues[fileKey][def.name] = def.default
        end
    end
    -- fire onChange for all current values so scripts apply their saved state
    for _, def in ipairs(defs) do
        if def.onChange and scriptSettingsValues[fileKey][def.name] ~= nil then
            pcall(def.onChange, scriptSettingsValues[fileKey][def.name])
        end
    end
    -- show cog button if it exists
    local btnData = scriptButtons[fileKey]
    if btnData and btnData.updateCog then
        btnData.updateCog()
    end
    -- refresh panel if it's currently showing this script
    if settingsPanelOpen and settingsPanelKey == fileKey then
        showSettingsPanel(fileKey)
    end
end

