local function getGameName(placeId)
    local ok, info = pcall(function()
        return MarketplaceService:GetProductInfo(placeId)
    end)
    if ok and info and info.Name then
        return info.Name
    end
    return "Place " .. tostring(placeId)
end

local function formatTimeSince(timestamp)
    local diff = os.time() - timestamp
    if diff < 60 then return "just now" end
    if diff < 3600 then return math.floor(diff / 60) .. "m ago" end
    if diff < 86400 then return math.floor(diff / 3600) .. "h ago" end
    return math.floor(diff / 86400) .. "d ago"
end

local function cleanServerHistory()
    local now = os.time()
    local cleaned = {}
    for _, entry in ipairs(serverHistory) do
        if now - entry.time < SERVER_MAX_AGE then
            table.insert(cleaned, entry)
        end
    end
    serverHistory = cleaned
    saveServerHistory()
end

local function recordCurrentServer()
    local jobId = game.JobId
    local placeId = game.PlaceId
    if jobId == "" then return end

    for i = #serverHistory, 1, -1 do
        if serverHistory[i].jobId == jobId then
            table.remove(serverHistory, i)
        end
    end

    local gameName = getGameName(placeId)
    table.insert(serverHistory, 1, {
        jobId = jobId,
        placeId = placeId,
        gameName = gameName,
        time = os.time(),
    })

    while #serverHistory > MAX_SERVERS do
        table.remove(serverHistory)
    end

    saveServerHistory()
end

