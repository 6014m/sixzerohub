    favBtn.Font = Enum.Font.Gotham
    favBtn.Parent = btn
    updateFavIcon(favBtn, fileKey)

    favBtn.MouseButton1Click:Connect(function()
        favorites[fileKey] = not favorites[fileKey]
        if not favorites[fileKey] then favorites[fileKey] = nil end
        saveFavorites(favorites)
        updateFavIcon(favBtn, fileKey)
        for _, data in pairs(scriptButtons) do
            data.btn.LayoutOrder = getLayoutOrder(data.info)
        end
    end)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = COLORS.sidebar}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = COLORS.hover}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        if loadedScripts[fileKey] then
            status.Text = "already loaded"
            status.TextColor3 = COLORS.textMuted
            return
        end

        status.Text = "loading..."
        status.TextColor3 = Color3.fromRGB(255, 200, 50)

        task.spawn(function()
            local ok, err = pcall(function()
                local scriptUrl = info.url or (REPO_BASE .. info.file)
                loadstring(game:HttpGet(scriptUrl))()
            end)

            if ok then
                loadedScripts[fileKey] = true
                status.Text = "running"
                status.TextColor3 = Color3.fromRGB(87, 242, 135)

                -- if script didn't self-register, register it from here
                task.delay(1, function()
                    if not activeScripts[fileKey] then
                        _G.SixZeroHubRegister(info.name, fileKey, nil)
                    end
                end)
            else
                status.Text = "error"
                status.TextColor3 = Color3.fromRGB(237, 66, 69)
                warn("[SixZeroHub] Failed to load " .. info.name .. ": " .. tostring(err))
            end
        end)
    end)

    scriptButtons[fileKey] = { btn = btn, favBtn = favBtn, status = status, info = info }
end

for _, scriptInfo in ipairs(SCRIPTS) do
    createScriptButton(scriptInfo)
end

-- make uni menu draggable
local dragging, dragStart, startPos
uniMenuHeader.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = uniMenu.Position
    end
end)
uniMenuHeader.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        uniMenu.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

local function toggleUniMenu()
    uniMenuOpen = not uniMenuOpen
    if uniMenuOpen then
        uniMenu.Visible = true
        uniMenu.Size = UDim2.new(0, 400, 0, 0)
        TweenService:Create(uniMenu, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 400, 0, 300)
        }):Play()
    else
        local tween = TweenService:Create(uniMenu, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 400, 0, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            uniMenu.Visible = false
        end)
    end
end

uniBtn.MouseButton1Click:Connect(toggleUniMenu)
uniCloseBtn.MouseButton1Click:Connect(function()
    if uniMenuOpen then toggleUniMenu() end
end)

---------- GUI OFFSET MANAGEMENT ----------

local movedScreenGuis = {}

local function shiftGameGuis(show)
    -- offset = sidebar width + a bit extra so roblox GUI text doesn't overlap
    local offset = SIDEBAR_WIDTH + 8
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= screenGui and gui.Name ~= "SixZeroHub" then
            if show then
                if not movedScreenGuis[gui] then
                    movedScreenGuis[gui] = gui.Position or UDim2.new(0, 0, 0, 0)
                end
                gui.Position = UDim2.new(0, offset, 0, 0)
            else
                if movedScreenGuis[gui] then
                    gui.Position = movedScreenGuis[gui]
                    movedScreenGuis[gui] = nil
                end
            end
        end
    end
end

local function moveChat(show)
    task.spawn(function()
        for i = 1, 20 do
            local ok = pcall(function()
                if show then
                    StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, SIDEBAR_WIDTH + 8, 0, 4))
                else
                    StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, 0, 0, 0))
                end
            end)
            if ok then break end
            task.wait(0.5)
        end
    end)
end

---------- TOGGLE VISIBILITY ----------

local function toggleGui()
    guiVisible = not guiVisible

    -- update eye icon
    if guiVisible then
        eyeBtn.TextTransparency = 0
    else
        eyeBtn.TextTransparency = 0.5
    end

    if guiVisible then
        topBar.Visible = true
        sidebar.Visible = true
        TweenService:Create(topBar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0)
        }):Play()
        TweenService:Create(sidebar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, TOPBAR_HEIGHT + 1)
        }):Play()
        moveChat(true)
        shiftGameGuis(true)
    else
        local t1 = TweenService:Create(topBar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, 0, 0, -TOPBAR_HEIGHT)
        })
        local t2 = TweenService:Create(sidebar, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, -SIDEBAR_WIDTH, 0, TOPBAR_HEIGHT + 1)
        })
        t1:Play()
        t2:Play()
        t2.Completed:Connect(function()
            if not guiVisible then
                topBar.Visible = false
                sidebar.Visible = false
            end
        end)
        moveChat(false)
        shiftGameGuis(false)
        if uniMenuOpen then toggleUniMenu() end
        if activeMenuOpen then toggleActiveMenu() end
    end
end

eyeBtn.MouseButton1Click:Connect(toggleGui)

