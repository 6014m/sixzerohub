showSettingsPanel = function(fileKey)
    if not settingsPanel then buildSettingsPanel() end

    local defs = scriptSettingsDefs[fileKey]
    if not defs then return end

    -- init values table if needed
    if not scriptSettingsValues[fileKey] then
        scriptSettingsValues[fileKey] = {}
    end
    local values = scriptSettingsValues[fileKey]

    -- set defaults for any missing values
    for _, def in ipairs(defs) do
        if values[def.name] == nil then
            values[def.name] = def.default
        end
    end

    -- clear old content
    for _, child in ipairs(settingsPanelContent:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    -- set title
    settingsPanel.Header.Title.Text = (defs._title or fileKey) .. " Settings"

    -- build controls
    for i, def in ipairs(defs) do
        local row = Instance.new("Frame")
        row.Name = def.name
        row.Size = UDim2.new(1, 0, 0, 30)
        row.BackgroundTransparency = 1
        row.LayoutOrder = i
        row.Parent = settingsPanelContent

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.55, 0, 1, 0)
        label.Position = UDim2.new(0, 4, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = def.label or def.name
        label.TextColor3 = COLORS.text
        label.TextSize = 13
        label.Font = Enum.Font.Gotham
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextTruncate = Enum.TextTruncate.AtEnd
        label.Parent = row

        if def.type == "toggle" then
            local toggleBtn = Instance.new("TextButton")
