playerGui.ChildAdded:Connect(function(child)
    if child:IsA("ScreenGui") and child ~= screenGui and child ~= toggleGui and guiVisible then
        task.wait(0.1)
        -- chat GUIs get moved via moveChat, all others get offset
        local n = child.Name:lower()
        if n:find("chat") or child.Name == "ExperienceChat" then
            findAndMoveChat(true)
        else
            if not movedScreenGuis[child] then
                movedScreenGuis[child] = child.Position
            end
            child.Position = UDim2.new(0, GUI_OFFSET, 0, 0)
        end
    end
end)
