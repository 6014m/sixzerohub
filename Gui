            dropBtn.Font = Enum.Font.Gotham
            dropBtn.AutoButtonColor = false
            dropBtn.TextTruncate = Enum.TextTruncate.AtEnd
            dropBtn.Parent = row
            Instance.new("UICorner", dropBtn).CornerRadius = UDim.new(0, 4)

            local optIdx = table.find(options, values[def.name]) or 1

            dropBtn.MouseButton1Click:Connect(function()
                optIdx = optIdx % #options + 1
                values[def.name] = options[optIdx]
                dropBtn.Text = tostring(values[def.name])
                if def.onChange then pcall(def.onChange, values[def.name]) end
                saveSettingsToFile()
            end)

        elseif def.type == "button" then
            local actionBtn = Instance.new("TextButton")
            actionBtn.Size = UDim2.new(0.4, -8, 0, 22)
            actionBtn.Position = UDim2.new(0.6, 0, 0, 4)
            actionBtn.BackgroundColor3 = COLORS.accent
            actionBtn.BorderSizePixel = 0
            actionBtn.Text = def.buttonText or "Run"
            actionBtn.TextColor3 = Color3.new(1, 1, 1)
            actionBtn.TextSize = 12
            actionBtn.Font = Enum.Font.GothamBold
            actionBtn.AutoButtonColor = true
            actionBtn.Parent = row
            Instance.new("UICorner", actionBtn).CornerRadius = UDim.new(0, 4)

            actionBtn.MouseButton1Click:Connect(function()
                if def.onClick then pcall(def.onClick) end
                actionBtn.Text = "Done"
                actionBtn.BackgroundColor3 = Color3.fromRGB(87, 242, 135)
                task.delay(1, function()
                    if actionBtn.Parent then
                        actionBtn.Text = def.buttonText or "Run"
                        actionBtn.BackgroundColor3 = COLORS.accent
                    end
                end)
            end)
        end
    end

    settingsPanelKey = fileKey
    settingsPanelOpen = true
    settingsPanel.Visible = true
end

_G.SixZeroHubRegisterSettings = function(fileKey, defs)
    scriptSettingsDefs[fileKey] = defs
    -- init defaults
    if not scriptSettingsValues[fileKey] then
        scriptSettingsValues[fileKey] = {}
    end
    for _, def in ipairs(defs) do
        if scriptSettingsValues[fileKey][def.name] == nil then
            scriptSettingsValues[fileKey][def.name] = def.default
        end
    end
    -- fire onChange for all current values so scripts apply their saved state
    for _, def in ipairs(defs) do
        if def.onChange and scriptSettingsValues[fileKey][def.name] ~= nil then
            pcall(def.onChange, scriptSettingsValues[fileKey][def.name])
        end
    end
    -- show cog button if it exists
    local btnData = scriptButtons[fileKey]
    if btnData and btnData.updateCog then
        btnData.updateCog()
    end
    -- refresh panel if it's currently showing this script
    if settingsPanelOpen and settingsPanelKey == fileKey then
        showSettingsPanel(fileKey)
    end
end

