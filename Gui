---------- EXTERNAL GUI OFFSET (LOCK-ON) ----------

local EXT_OFFSET = 70
local originalPositions = {} -- [GuiObject] = original UDim2 position
local watchedLockOnGuis = {} -- [ScreenGui] = ChildAdded connection

local function shiftChild(child)
    if not child:IsA("GuiObject") then return end
    if originalPositions[child] then return end -- already shifted
    originalPositions[child] = child.Position
    child.Position = UDim2.new(
        child.Position.X.Scale,
        child.Position.X.Offset + EXT_OFFSET,
        child.Position.Y.Scale,
        child.Position.Y.Offset
    )
end

local function unshiftChild(child)
    if not child:IsA("GuiObject") then return end
    if not originalPositions[child] then return end
    child.Position = originalPositions[child]
    originalPositions[child] = nil
end

local function watchLockOnGui(gui)
    if watchedLockOnGuis[gui] then return end

    -- shift existing children if hub is visible
    if guiVisible then
        for _, child in ipairs(gui:GetChildren()) do
            pcall(function() shiftChild(child) end)
        end
    end

    -- watch for new children added later (lock-on builds GUI incrementally)
    local conn = gui.ChildAdded:Connect(function(child)
        if guiVisible then
            task.defer(function()
                pcall(function() shiftChild(child) end)
            end)
        end
    end)
    watchedLockOnGuis[gui] = conn
end

local function findAndWatchLockOnGuis()
    local function searchIn(parent)
        pcall(function()
            for _, child in ipairs(parent:GetChildren()) do
                if child:IsA("ScreenGui") and child ~= screenGui and child ~= toggleGui then
                    if child.Name:find("LockOn") then
                        watchLockOnGui(child)
                    end
                end
            end
        end)
    end
    searchIn(playerGui)
    pcall(function() searchIn(game:GetService("CoreGui")) end)
    pcall(function() if gethui then searchIn(gethui()) end end)
end

local function shiftAllLockOnChildren()
    for gui, _ in pairs(watchedLockOnGuis) do
        pcall(function()
            for _, child in ipairs(gui:GetChildren()) do
                pcall(function() shiftChild(child) end)
            end
        end)
    end
end

local function unshiftAllLockOnChildren()
    for gui, _ in pairs(watchedLockOnGuis) do
        pcall(function()
            for _, child in ipairs(gui:GetChildren()) do
                pcall(function() unshiftChild(child) end)
            end
        end)
    end
end

-- poll for new LockOn ScreenGuis (ChildAdded on gethui is unreliable on some executors)
task.spawn(function()
    while screenGui and screenGui.Parent do
        if guiVisible then
            findAndWatchLockOnGuis()
            shiftAllLockOnChildren()
        end
        task.wait(2)
    end
end)

