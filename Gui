local function getLayoutOrder(info)
    local isFav = favorites[info.file] or false
    -- favorited: 0-999 (alphabetical), unfavorited: 1000+ (alphabetical)
    local base = isFav and 0 or 1000
    -- use byte values of name for alphabetical sorting
    local nameOrder = 0
    for i = 1, math.min(#info.name, 4) do
        nameOrder = nameOrder + string.byte(info.name, i) * (256 ^ (4 - i))
    end
    return base + nameOrder
end

local function updateFavIcon(favBtn, fileKey)
    if favorites[fileKey] then
        favBtn.Text = "\226\152\133" -- filled star
        favBtn.TextColor3 = Color3.fromRGB(255, 200, 50)
    else
        favBtn.Text = "\226\152\134" -- empty star
        favBtn.TextColor3 = COLORS.textMuted
    end
end

local function createScriptButton(info)
    local btn = Instance.new("TextButton")
    btn.Name = info.file
    btn.Size = UDim2.new(1, -8, 0, 36)
    btn.BackgroundColor3 = COLORS.hover
    btn.BorderSizePixel = 0
    btn.Text = "     " .. info.name
    btn.TextColor3 = COLORS.text
    btn.TextSize = 14
    btn.Font = Enum.Font.Gotham
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false
    btn.LayoutOrder = getLayoutOrder(info)
    btn.Parent = uniContent

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn

    -- favorite star button (left side)
    local favBtn = Instance.new("TextButton")
    favBtn.Name = "Favorite"
    favBtn.Size = UDim2.new(0, 28, 0, 28)
    favBtn.Position = UDim2.new(0, 4, 0.5, -14)
    favBtn.BackgroundTransparency = 1
    favBtn.TextSize = 16
    favBtn.Font = Enum.Font.Gotham
    favBtn.Parent = btn
    updateFavIcon(favBtn, info.file)

    favBtn.MouseButton1Click:Connect(function()
        favorites[info.file] = not favorites[info.file]
        if not favorites[info.file] then favorites[info.file] = nil end
        updateFavIcon(favBtn, info.file)
        -- update sort order for all buttons
        for fileKey, data in pairs(scriptButtons) do
            data.btn.LayoutOrder = getLayoutOrder(data.info)
        end
    end)

    -- status indicator (right side)
    local status = Instance.new("TextLabel")
    status.Name = "Status"
    status.Size = UDim2.new(0, 60, 1, 0)
    status.Position = UDim2.new(1, -65, 0, 0)
    status.BackgroundTransparency = 1
    status.Text = ""
    status.TextColor3 = COLORS.textMuted
    status.TextSize = 11
    status.Font = Enum.Font.Gotham
    status.TextXAlignment = Enum.TextXAlignment.Right
    status.Parent = btn

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = COLORS.sidebar}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = COLORS.hover}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        if loadedScripts[info.file] then
            status.Text = "already loaded"
            status.TextColor3 = COLORS.textMuted
            return
        end

        status.Text = "loading..."
        status.TextColor3 = Color3.fromRGB(255, 200, 50)

        task.spawn(function()
            local ok, err = pcall(function()
                loadstring(game:HttpGet(REPO_BASE .. info.file))()
            end)

            if ok then
                loadedScripts[info.file] = true
                status.Text = "running"
                status.TextColor3 = Color3.fromRGB(87, 242, 135) -- green
            else
                status.Text = "error"
                status.TextColor3 = Color3.fromRGB(237, 66, 69) -- red
                warn("[SixZeroHub] Failed to load " .. info.name .. ": " .. tostring(err))
            end
        end)
    end)

    scriptButtons[info.file] = { btn = btn, favBtn = favBtn, status = status, info = info }
end

for _, scriptInfo in ipairs(SCRIPTS) do
    createScriptButton(scriptInfo)
end

-- make uni menu draggable
local dragging, dragStart, startPos
uniMenuHeader.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = uniMenu.Position
    end
end)

uniMenuHeader.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        uniMenu.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

-- toggle uni menu
local function toggleUniMenu()
    uniMenuOpen = not uniMenuOpen
    if uniMenuOpen then
        uniMenu.Visible = true
        uniMenu.Size = UDim2.new(0, 400, 0, 0)
        TweenService:Create(uniMenu, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 400, 0, 300)
        }):Play()
    else
        local tween = TweenService:Create(uniMenu, TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 400, 0, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            uniMenu.Visible = false
        end)
    end
end

uniBtn.MouseButton1Click:Connect(toggleUniMenu)
uniCloseBtn.MouseButton1Click:Connect(function()
    if uniMenuOpen then toggleUniMenu() end
end)

---------- GUI OFFSET MANAGEMENT ----------

local originalChatPosition = nil
local movedGameGuis = {} -- {gui = originalPosition}

local function getChatFrame()
    local ok, result = pcall(function()
        return playerGui:FindFirstChild("Chat") or CoreGui:FindFirstChild("Chat")
    end)
    return ok and result or nil
end

local function offsetGuiElement(gui, offset)
    if gui:IsA("ScreenGui") then
        for _, child in ipairs(gui:GetChildren()) do
            if child:IsA("GuiObject") then
                if not movedGameGuis[child] then
                    movedGameGuis[child] = child.Position
                end
                child.Position = UDim2.new(
                    child.Position.X.Scale, child.Position.X.Offset + offset,
                    child.Position.Y.Scale, child.Position.Y.Offset
                )
            end
        end
    end
end

local function restoreGuiElement(child)
    if movedGameGuis[child] then
        child.Position = movedGameGuis[child]
        movedGameGuis[child] = nil
    end
end

local function shiftGameGuis(offset)
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= screenGui and gui.Name ~= "SixZeroHub" then
            for _, child in ipairs(gui:GetChildren()) do
                if child:IsA("GuiObject") then
                    -- only move elements on the left side of the screen
                    local absX = child.AbsolutePosition.X
                    if absX < PANEL_WIDTH then
                        if offset > 0 then
                            if not movedGameGuis[child] then
                                movedGameGuis[child] = child.Position
                            end
                            child.Position = UDim2.new(
                                child.Position.X.Scale, child.Position.X.Offset + offset,
                                child.Position.Y.Scale, child.Position.Y.Offset
                            )
                        else
                            restoreGuiElement(child)
                        end
                    end
                end
            end
        end
    end
end

local function moveChat(show)
    pcall(function()
        if show then
            StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, PANEL_WIDTH + 4, 0, 0))
        else
            StarterGui:SetCore("ChatWindowPosition", UDim2.new(0, 0, 0, 0))
        end
    end)
end

---------- TOGGLE VISIBILITY ----------

local function toggleGui()
    guiVisible = not guiVisible

    -- update eye icon
    if topbarEyeLabel then
        topbarEyeLabel.Image = guiVisible and EYE_OPEN or EYE_CLOSED
    end

    if guiVisible then
        -- show panel
        panel.Visible = true
        TweenService:Create(panel, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, 0, 0, 0)
        }):Play()
        moveChat(true)
        shiftGameGuis(PANEL_WIDTH)
    else
        -- hide panel
        local tween = TweenService:Create(panel, TweenInfo.new(TWEEN_SPEED, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, -PANEL_WIDTH, 0, 0)
        })
        tween:Play()
        tween.Completed:Connect(function()
            if not guiVisible then
                panel.Visible = false
            end
        end)
        moveChat(false)
        shiftGameGuis(-PANEL_WIDTH)
        -- close uni menu if open
        if uniMenuOpen then toggleUniMenu() end
    end
end

