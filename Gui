            toggleBtn.TextSize = 11
            toggleBtn.AutoButtonColor = false
            toggleBtn.Parent = row
            Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0, 4)

            local function updateToggle()
                local val = values[def.name]
                toggleBtn.Text = val and "ON" or "OFF"
                toggleBtn.BackgroundColor3 = val and Color3.fromRGB(87, 242, 135) or COLORS.hover
                toggleBtn.TextColor3 = val and COLORS.darker or COLORS.text
            end
            updateToggle()

            toggleBtn.MouseButton1Click:Connect(function()
                values[def.name] = not values[def.name]
                updateToggle()
                if def.onChange then pcall(def.onChange, values[def.name]) end
                saveSettingsToFile()
            end)

        elseif def.type == "slider" then
            local min = def.min or 0
            local max = def.max or 100
            local step = def.step or 1

            local valLabel = Instance.new("TextLabel")
            valLabel.Size = UDim2.new(0, 35, 1, 0)
            valLabel.Position = UDim2.new(1, -40, 0, 0)
            valLabel.BackgroundTransparency = 1
            valLabel.TextColor3 = COLORS.textMuted
            valLabel.TextSize = 12
            valLabel.Font = Enum.Font.Gotham
            valLabel.Text = tostring(values[def.name] or min)
            valLabel.Parent = row

            local sliderBar = Instance.new("Frame")
            sliderBar.Size = UDim2.new(0.35, 0, 0, 6)
            sliderBar.Position = UDim2.new(0.55, 4, 0.5, -3)
            sliderBar.BackgroundColor3 = COLORS.hover
            sliderBar.BorderSizePixel = 0
            sliderBar.Parent = row
            Instance.new("UICorner", sliderBar).CornerRadius = UDim.new(0, 3)

            local knob = Instance.new("Frame")
            knob.Size = UDim2.new(0, 12, 0, 16)
            knob.AnchorPoint = Vector2.new(0.5, 0.5)
            knob.BackgroundColor3 = COLORS.accent
            knob.BorderSizePixel = 0
            knob.Parent = sliderBar
            Instance.new("UICorner", knob).CornerRadius = UDim.new(0, 3)

            local function updateSlider()
                local val = values[def.name] or min
                local pct = (val - min) / (max - min)
                knob.Position = UDim2.new(pct, 0, 0.5, 0)
                valLabel.Text = tostring(math.floor(val / step + 0.5) * step)
            end
            updateSlider()

            local dragging = false
            sliderBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local relX = math.clamp((input.Position.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
                    local raw = min + (max - min) * relX
                    local stepped = math.floor(raw / step + 0.5) * step
                    values[def.name] = math.clamp(stepped, min, max)
                    updateSlider()
                    if def.onChange then pcall(def.onChange, values[def.name]) end
                    saveSettingsToFile()
                end
            end)

        elseif def.type == "dropdown" then
            local options = def.options or {}

