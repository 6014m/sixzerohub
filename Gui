    if child:IsA("ScreenGui") and child ~= screenGui and guiVisible then
        task.wait(0.1)
        for _, obj in ipairs(child:GetChildren()) do
            if obj:IsA("GuiObject") and obj.AbsolutePosition.X < PANEL_WIDTH then
                if not movedGameGuis[obj] then
                    movedGameGuis[obj] = obj.Position
                end
                obj.Position = UDim2.new(
                    obj.Position.X.Scale, obj.Position.X.Offset + PANEL_WIDTH,
                    obj.Position.Y.Scale, obj.Position.Y.Offset
                )
            end
        end
    end
end)
