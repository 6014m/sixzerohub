---------- TELEPORT PERSISTENCE ----------

local HUB_URL = "https://raw.githubusercontent.com/6014m/sixzerohub/main/Gui"

local queueteleport = queue_on_teleport
    or (syn and syn.queue_on_teleport)
    or (fluxus and fluxus.queue_on_teleport)
    or (krnl and krnl.queue_on_teleport)
    or (getgenv and getgenv().queue_on_teleport)

if queueteleport then
    local genv = getgenv and getgenv() or _G
    if not genv.SIXZEROHUB_TP_QUEUED then
        genv.SIXZEROHUB_TP_QUEUED = true
        pcall(function()
            queueteleport([[
                repeat task.wait() until game:IsLoaded()
                task.wait(2)
                pcall(function()
                    loadstring(game:HttpGet("]] .. HUB_URL .. [[", true))()
                end)
            ]])
        end)
    end
end

---------- CLEANUP OLD INSTANCE ----------

local SCRIPT_KEY = "SIXZEROHUB_INSTANCE"

do
    local genv = getgenv and getgenv() or _G
    if genv[SCRIPT_KEY] then
        local old = genv[SCRIPT_KEY]

        -- deactivate all running scripts first
        if old.ActiveScripts then
            for fileKey, data in pairs(old.ActiveScripts) do
                if data.cleanup then
                    pcall(data.cleanup)
                end
            end
        end

        if old.Gui then pcall(function() old.Gui:Destroy() end) end
        if old.ToggleGui then pcall(function() old.ToggleGui:Destroy() end) end
        if old.NotifGui then pcall(function() old.NotifGui:Destroy() end) end
        if old.Connections then
            for _, conn in ipairs(old.Connections) do
                pcall(function() conn:Disconnect() end)
            end
        end
        genv[SCRIPT_KEY] = nil
    end

    -- also destroy any lingering SixZeroHub GUIs
    pcall(function()
        for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do
            if gui:IsA("ScreenGui") and (gui.Name == "SixZeroHub" or gui.Name == "SixZeroHubNotifs") then gui:Destroy() end
        end
    end)
    pcall(function()
        for _, gui in ipairs(player:WaitForChild("PlayerGui"):GetChildren()) do
            if gui:IsA("ScreenGui") and (gui.Name == "SixZeroHub" or gui.Name == "SixZeroHubToggle" or gui.Name == "SixZeroHubNotifs") then gui:Destroy() end
        end
    end)
end

