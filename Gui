                    end
                end)
            else
                status.Text = "error"
                status.TextColor3 = Color3.fromRGB(237, 66, 69)
                warn("[SixZeroHub] Failed to load " .. info.name .. ": " .. tostring(err))
            end
        end)
    end)

    scriptButtons[fileKey] = { btn = btn, favBtn = favBtn, cogBtn = cogBtn, updateCog = updateCogVisibility, status = status, info = info }
end

