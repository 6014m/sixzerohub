}

local FAVORITES_FILE = "SixZeroHub_favorites.json"

local function loadFavorites()
    local ok, data = pcall(function()
        if isfile and isfile(FAVORITES_FILE) then
            return HttpService:JSONDecode(readfile(FAVORITES_FILE))
        end
    end)
    return (ok and data) or {}
end

local function saveFavorites(favs)
    pcall(function()
        writefile(FAVORITES_FILE, HttpService:JSONEncode(favs))
    end)
end

local favorites = loadFavorites()
local scriptButtons = {}

-- sort scripts: favorites first (alphabetically), then non-favorites (alphabetically)
local function rebuildSortOrder()
    local sorted = {}
    for _, data in pairs(scriptButtons) do
        table.insert(sorted, data)
    end
    table.sort(sorted, function(a, b)
        local aFav = favorites[a.info.file or a.info.url] or false
        local bFav = favorites[b.info.file or b.info.url] or false
        if aFav ~= bFav then return aFav end
        return a.info.name:lower() < b.info.name:lower()
    end)
    for i, data in ipairs(sorted) do
        data.btn.LayoutOrder = i
    end
end

local function updateFavIcon(favBtn, fileKey)
    if favorites[fileKey] then
        favBtn.Text = "\226\152\133"
        favBtn.TextColor3 = Color3.fromRGB(255, 200, 50)
    else
        favBtn.Text = "\226\152\134"
        favBtn.TextColor3 = COLORS.textMuted
    end
end

local function createScriptButton(info)
    local fileKey = info.file or info.url

    local btn = Instance.new("TextButton")
    btn.Name = fileKey
    btn.Size = UDim2.new(1, -8, 0, 36)
    btn.BackgroundColor3 = COLORS.hover
    btn.BorderSizePixel = 0
    btn.Text = "  " .. info.name
    btn.TextColor3 = COLORS.text
    btn.TextSize = 14
    btn.Font = Enum.Font.Gotham
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.AutoButtonColor = false
    btn.LayoutOrder = 0
    btn.Parent = uniContent

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    -- status indicator (before star)
    local status = Instance.new("TextLabel")
    status.Name = "Status"
    status.Size = UDim2.new(0, 55, 1, 0)
    status.Position = UDim2.new(1, -90, 0, 0)
    status.BackgroundTransparency = 1
    status.Text = ""
    status.TextColor3 = COLORS.textMuted
    status.TextSize = 11
    status.Font = Enum.Font.Gotham
    status.TextXAlignment = Enum.TextXAlignment.Right
    status.Parent = btn

    -- favorite star (far right)
    local favBtn = Instance.new("TextButton")
    favBtn.Name = "Favorite"
    favBtn.Size = UDim2.new(0, 28, 0, 28)
    favBtn.Position = UDim2.new(1, -30, 0.5, -14)
    favBtn.BackgroundTransparency = 1
    favBtn.TextSize = 16
    favBtn.Font = Enum.Font.Gotham
    favBtn.Parent = btn
    updateFavIcon(favBtn, fileKey)

    favBtn.MouseButton1Click:Connect(function()
        favorites[fileKey] = not favorites[fileKey]
        if not favorites[fileKey] then favorites[fileKey] = nil end
        saveFavorites(favorites)
        updateFavIcon(favBtn, fileKey)
        rebuildSortOrder()
    end)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = COLORS.sidebar}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = COLORS.hover}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        if loadedScripts[fileKey] then
            status.Text = "already loaded"
            status.TextColor3 = COLORS.textMuted
            return
        end

        status.Text = "loading..."
        status.TextColor3 = Color3.fromRGB(255, 200, 50)

        task.spawn(function()
            local ok, err = pcall(function()
                local scriptUrl = info.url or (REPO_BASE .. info.file)
                loadstring(game:HttpGet(scriptUrl))()
            end)

            if ok then
                loadedScripts[fileKey] = true
                status.Text = "running"
                status.TextColor3 = Color3.fromRGB(87, 242, 135)

                -- auto-register external scripts that don't self-register
                task.delay(1, function()
                    if not activeScripts[fileKey] then
                        _G.SixZeroHubRegister(info.name, fileKey, nil)
                    end
                end)
            else
                status.Text = "error"
                status.TextColor3 = Color3.fromRGB(237, 66, 69)
                warn("[SixZeroHub] Failed to load " .. info.name .. ": " .. tostring(err))
            end
        end)
    end)

    scriptButtons[fileKey] = { btn = btn, favBtn = favBtn, status = status, info = info }
end

