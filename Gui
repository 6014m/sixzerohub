function refreshActiveList()
    for _, child in ipairs(activeContent:GetChildren()) do
        if child:IsA("Frame") or (child:IsA("TextLabel") and child.Name ~= "Empty") then
            child:Destroy()
        end
    end

    -- group scripts by source
    local groups = {}
    local sourceOrder = { "uni", "dev", "spec", "other" }

    for fileKey, data in pairs(activeScripts) do
        local src = data.source or "other"
        if not groups[src] then groups[src] = {} end
        table.insert(groups[src], { key = fileKey, data = data })
    end

    local count = 0
    local layoutIdx = 0

    for _, srcKey in ipairs(sourceOrder) do
        local items = groups[srcKey]
        if items and #items > 0 then
            -- add divider
            layoutIdx = layoutIdx + 1
            createDivider(activeContent, srcKey, layoutIdx)

            for _, item in ipairs(items) do
                count = count + 1
                layoutIdx = layoutIdx + 1

                local fileKey = item.key
                local data = item.data

                local row = Instance.new("Frame")
                row.Name = fileKey
                row.Size = UDim2.new(1, -8, 0, 36)
                row.BackgroundColor3 = COLORS.hover
                row.BorderSizePixel = 0
                row.LayoutOrder = layoutIdx
                row.Parent = activeContent

                Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)

                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -90, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = data.name
                nameLabel.TextColor3 = Color3.fromRGB(87, 242, 135)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.Gotham
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = row

                local deactivateBtn = Instance.new("TextButton")
                deactivateBtn.Name = "Deactivate"
                deactivateBtn.Size = UDim2.new(0, 75, 0, 24)
                deactivateBtn.Position = UDim2.new(1, -82, 0.5, -12)
                deactivateBtn.BackgroundColor3 = Color3.fromRGB(237, 66, 69)
                deactivateBtn.BorderSizePixel = 0
                deactivateBtn.Text = "Deactivate"
                deactivateBtn.TextColor3 = COLORS.text
                deactivateBtn.TextSize = 11
                deactivateBtn.Font = Enum.Font.GothamBold
                deactivateBtn.AutoButtonColor = false
                deactivateBtn.Parent = row

                Instance.new("UICorner", deactivateBtn).CornerRadius = UDim.new(0, 4)

                deactivateBtn.MouseEnter:Connect(function()
                    TweenService:Create(deactivateBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(200, 50, 50)}):Play()
                end)
                deactivateBtn.MouseLeave:Connect(function()
                    TweenService:Create(deactivateBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(237, 66, 69)}):Play()
                end)

                deactivateBtn.MouseButton1Click:Connect(function()
                    -- look up current data at click time, not capture time
                    local current = activeScripts[fileKey]
                    if current and current.cleanup then
                        local ok, err = pcall(current.cleanup)
                        if not ok then warn("[SixZeroHub] Cleanup error for " .. fileKey .. ": " .. tostring(err)) end
                    end
                    activeScripts[fileKey] = nil
                    loadedScripts[fileKey] = nil
                    -- clear status in whichever content list it came from
                    for _, contentFrame in ipairs({uniContent, devContent, specContent}) do
                        if contentFrame then
                            local ref = contentFrame:FindFirstChild(fileKey)
                            if ref then
                                local s = ref:FindFirstChild("Status")
                                if s then s.Text = "" end
                            end
                        end
                    end
                    refreshActiveList()
                end)
            end
        end
    end

    activeEmptyLabel.Visible = (count == 0)
end

