-- favorites persist to file
local FAVORITES_FILE = "SixZeroHub_favorites.json"

local function loadFavorites()
    local ok, data = pcall(function()
        if isfile and isfile(FAVORITES_FILE) then
            return HttpService:JSONDecode(readfile(FAVORITES_FILE))
        end
    end)
    return (ok and data) or {}
end

local function saveFavorites(favs)
    pcall(function()
        writefile(FAVORITES_FILE, HttpService:JSONEncode(favs))
    end)
end

local favorites = loadFavorites()
local scriptButtons = {}

local function getLayoutOrder(info)
    local key = info.file or info.url
    local isFav = favorites[key] or false
    local base = isFav and 0 or 1000
    local nameOrder = 0
    for i = 1, math.min(#info.name, 4) do
        nameOrder = nameOrder + string.byte(info.name, i) * (256 ^ (4 - i))
    end
    return base + nameOrder
end

local function updateFavIcon(favBtn, fileKey)
    if favorites[fileKey] then
        favBtn.Text = "\226\152\133"
        favBtn.TextColor3 = Color3.fromRGB(255, 200, 50)
    else
        favBtn.Text = "\226\152\134"
        favBtn.TextColor3 = COLORS.textMuted
    end
end

