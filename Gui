---------- UPDATE CHECKER ----------

local scriptSHAs = {} -- [fileKey] = last known git SHA
local UPDATE_CHECK_INTERVAL = 1

-- map fileKey to its GitHub API path for SHA checking
local function getGitApiUrl(info)
    if info.file then
        -- files in sixzerohub repo
        local encoded = info.file:gsub("%[", "%%5B"):gsub("%]", "%%5D")
        return "https://api.github.com/repos/6014m/sixzerohub/contents/" .. encoded
    elseif info.url then
        -- external repos: parse owner/repo/branch/path from raw URL
        local owner, repo, branch, path = info.url:match("raw%.githubusercontent%.com/([^/]+)/([^/]+)/([^/]+)/(.+)")
        if owner and repo and path then
            return "https://api.github.com/repos/" .. owner .. "/" .. repo .. "/contents/" .. path .. "?ref=" .. branch
        end
    end
    return nil
end

local function fetchSHA(apiUrl)
    local ok, response = pcall(function()
        return game:HttpGet(apiUrl, true)
    end)
    if not ok or not response then return nil end
    local sha = response:match('"sha"%s*:%s*"([a-f0-9]+)"')
    return sha
end

