    startLoop("freereach", 0.1, function()
        local char = getChar()
        if not char then return end
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then return end
        local handle = tool:FindFirstChild("Handle")
        if not handle then return end
        local root = myRoot()
        if not root then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local tRoot = getRoot(p.Character)
                if tRoot and (tRoot.Position - root.Position).Magnitude <= range then
                    if firetouchinterest then
                        pcall(firetouchinterest, handle, tRoot, 0)
                        task.wait()
                        pcall(firetouchinterest, handle, tRoot, 1)
                    end
                end
            end
        end
