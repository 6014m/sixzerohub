addcmd("nametags", {"ntags"}, "Show custom nametags above all players", function(args)
    local function applyTag(p)
        if p == player then return end
        if not p.Character then return end
        local head = p.Character:FindFirstChild("Head")
        if not head then return end
        if head:FindFirstChild("CZ_Nametag") then return end
        local bb = Instance.new("BillboardGui")
        bb.Name = "CZ_Nametag"
        bb.Size = UDim2.new(0, 200, 0, 40)
        bb.StudsOffset = Vector3.new(0, 2.5, 0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = math.huge
        bb.Parent = head
        local nameL = Instance.new("TextLabel", bb)
        nameL.Size = UDim2.new(1, 0, 0, 20)
        nameL.BackgroundTransparency = 1
        nameL.Text = p.DisplayName
        nameL.TextColor3 = Color3.new(1, 1, 1)
        nameL.TextStrokeTransparency = 0.5
        nameL.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameL.Font = Enum.Font.GothamBold
        nameL.TextSize = 14
        local distL = Instance.new("TextLabel", bb)
        distL.Size = UDim2.new(1, 0, 0, 16)
        distL.Position = UDim2.new(0, 0, 0, 18)
        distL.BackgroundTransparency = 1
        distL.TextColor3 = Color3.fromRGB(180, 180, 180)
        distL.TextStrokeTransparency = 0.6
        distL.Font = Enum.Font.Gotham
        distL.TextSize = 11
        distL.Name = "Dist"
        table.insert(espObjects, bb)
    end
    for _, p in ipairs(Players:GetPlayers()) do pcall(applyTag, p) end
    connect(Players.PlayerAdded, function(p) p.CharacterAdded:Connect(function() task.wait(1); pcall(applyTag, p) end) end)
    startLoop("nametags", 0.5, function()
        local mRoot = myRoot()
        if not mRoot then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local head = p.Character:FindFirstChild("Head")
                if head then
                    local bb = head:FindFirstChild("CZ_Nametag")
                    if bb then
                        local dist = bb:FindFirstChild("Dist")
                        local tRoot = getRoot(p.Character)
                        if dist and tRoot then
                            dist.Text = "[" .. math.floor((tRoot.Position - mRoot.Position).Magnitude) .. " studs]"
                        end
                    end
                end
            end
        end
    end)
    notify("Nametags", "Enabled")
end)

addcmd("unnametags", {"unntags"}, "Remove custom nametags", function(args)
    stopLoop("nametags")
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            local head = p.Character:FindFirstChild("Head")
            if head then
                local bb = head:FindFirstChild("CZ_Nametag")
