addcmd("earthquake", {}, "Shake the screen like an earthquake", function(args)
    local intensity = parseNumber(args[1], 5)
    local duration = parseNumber(args[2], 5)
    task.spawn(function()
        local start = tick()
        while tick() - start < duration do
            local cam = workspace.CurrentCamera
            if cam then
                cam.CFrame = cam.CFrame * CFrame.new(
                    (math.random() - 0.5) * intensity * 0.05,
                    (math.random() - 0.5) * intensity * 0.05,
                    0
                ) * CFrame.Angles(
                    (math.random() - 0.5) * intensity * 0.002,
                    (math.random() - 0.5) * intensity * 0.002,
                    0
                )
            end
            RunService.RenderStepped:Wait()
        end
    end)
end)

