addcmd("tracers", {}, "Draw lines to all players", function(args)
    startLoop("tracers", 0, function() end)
    notify("Tracers", "Enabled (visual in 3D via beams)")
    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        task.spawn(function()
            while loopStates["tracers"] do
                local tRoot = getRoot(p.Character)
                local mRoot = myRoot()
                if tRoot and mRoot then
                    local beam = Instance.new("Part")
                    beam.Name = "CZ_Tracer"
                    beam.Anchored = true
                    beam.CanCollide = false
                    beam.Material = Enum.Material.Neon
                    beam.Color = Color3.fromRGB(0, 170, 255)
                    beam.Transparency = 0.5
                    local dist = (tRoot.Position - mRoot.Position).Magnitude
                    beam.Size = Vector3.new(0.1, 0.1, dist)
                    beam.CFrame = CFrame.new(mRoot.Position, tRoot.Position) * CFrame.new(0, 0, -dist / 2)
                    beam.Parent = workspace
                    task.wait(0.1)
                    beam:Destroy()
                else
                    task.wait(0.5)
                end
            end
        end)
    end
end)

