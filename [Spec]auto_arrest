-- [Spec] Auto Arrest
-- IY-style tween to targets, arrest with handcuffs
-- Priority: keycard holders > criminals > inmates
-- Cycles through targets to work around cooldown

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local connections = {}
local active = true
local tweenSpeed = -1

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function getPriority(plr)
    local team = getTeamName(plr)
    local isCriminal = team:find("criminal")
    local isInmate = team:find("inmate") or team:find("prisoner")
    if not isCriminal and not isInmate then return nil end
    if hasKeycard(plr) then return 1 end
    if isCriminal then return 2 end
    return 3
end

local function getRoot(char)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getTorso(plr)
    if not plr.Character then return nil end
    return plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
end

-- IY exact tween
local function tweenTo(targetRoot)
    local root = getRoot(player.Character)
    if not root or not targetRoot or not targetRoot.Parent then return end

    pcall(function()
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.SeatPart then
            hum.Sit = false
            task.wait(0.1)
        end
    end)

    local tween = TweenService:Create(
        root,
        TweenInfo.new(tweenSpeed, Enum.EasingStyle.Linear),
        {CFrame = targetRoot.CFrame + Vector3.new(3, 1, 0)}
    )
    tween:Play()
    tween.Completed:Wait()

    pcall(function()
        root.Velocity = Vector3.new(0, 0, 0)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)
end

local VIM = game:GetService("VirtualInputManager")

local function arrestTarget(targetPlr)
    local torso = getTorso(targetPlr)
    if not torso then return end

    local cam = workspace.CurrentCamera
    local screenPos, onScreen = cam:WorldToScreenPoint(torso.Position)
    if not onScreen then return end

    local x = screenPos.X
    local y = screenPos.Y + 36 -- gui inset offset

    -- method 1: VirtualInputManager (most reliable click emulation)
    pcall(function()
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait()
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end)

    -- method 2: mousemoveabs + mouse1click
    pcall(function()
        if mousemoveabs and mouse1click then
            mousemoveabs(x, y)
            task.wait()
            mouse1click()
        end
    end)

    -- method 3: remote as last resort
    pcall(function()
        ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso)
    end)
end

local function isArrested(plr)
    -- player is arrested if they switched off criminal/inmate team
    if not plr.Parent then return true end
    local team = getTeamName(plr)
    if team:find("criminal") or team:find("inmate") or team:find("prisoner") then
        return false
    end
    return true
end

local function waitForArrest(plr, timeout)
    local start = os.clock()
    while os.clock() - start < timeout do
        if isArrested(plr) then return true end
        task.wait(0.1)
    end
    return isArrested(plr)
end

local function resetCharacter()
    pcall(function()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    local ok, newChar = pcall(function()
        return player.CharacterAdded:Wait()
    end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

-- main loop: cycle through all targets repeatedly
-- cycling means by the time we get back to the first target, cooldown has passed
task.spawn(function()
    while active do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            local pri = getPriority(plr)
            if pri then
                local root = getRoot(plr.Character)
                if root then
                    table.insert(targets, { player = plr, root = root, priority = pri })
                end
            end
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            task.wait(1)
            continue
        end

        equipHandcuffs()

        for _, target in ipairs(targets) do
            if not active then break end
            if not target.player.Parent then continue end
            if not target.root or not target.root.Parent then continue end
            if not getPriority(target.player) then continue end

            -- keep tweening and arresting until confirmed or give up
            for attempt = 1, 15 do
                if not active then break end
                if isArrested(target.player) then break end

                -- re-grab their root each attempt since they're moving
                local freshRoot = getRoot(target.player.Character)
                if not freshRoot or not freshRoot.Parent then break end

                tweenTo(freshRoot)
                task.wait(0.05)

                arrestTarget(target.player)

                if waitForArrest(target.player, 0.3) then
                    break
                end
            end

            -- only reset if we confirmed the arrest
            if isArrested(target.player) then
                resetCharacter()
                equipHandcuffs()
            end
        end

        task.wait(0.5)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end
