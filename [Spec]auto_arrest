-- [Spec] Auto Arrest
-- Tweens to targets, arrests with handcuffs, resets after each
-- Priority: keycard holders > criminals > inmates

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()
local connections = {}
local active = true

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

local function getHandcuffs()
    local char = player.Character
    if not char then return nil end
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("cuff") then
            return child
        end
    end
    return nil
end

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function getPriority(plr)
    local team = getTeamName(plr)
    local isCriminal = team:find("criminal")
    local isInmate = team:find("inmate") or team:find("prisoner")
    if not isCriminal and not isInmate then return nil end
    if hasKeycard(plr) then return 1 end
    if isCriminal then return 2 end
    return 3
end

local function getTorso(plr)
    if not plr.Character then return nil end
    return plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
end

local function getRoot()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local currentTween = nil

local function tweenTo(targetPart)
    local root = getRoot()
    if not root or not targetPart or not targetPart.Parent then return false end

    local targetCF = targetPart.CFrame * CFrame.new(0, 0, 3)

    if currentTween then
        pcall(function() currentTween:Cancel() end)
    end

    local ok, err = pcall(function()
        local tweenInfo = TweenInfo.new(0, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
        currentTween = TweenService:Create(root, tweenInfo, {CFrame = targetCF})
        currentTween:Play()
        currentTween.Completed:Wait()
    end)
    currentTween = nil

    if not ok then
        -- fallback: direct CFrame set
        pcall(function()
            root.CFrame = targetCF
        end)
    end
    return true
end

local function clickOnTarget(targetPart)
    -- method 1: mousemoveabs + mouse1click (most executors)
    local done = false
    pcall(function()
        if mousemoveabs and mouse1click then
            local cam = workspace.CurrentCamera
            local screenPos, onScreen = cam:WorldToScreenPoint(targetPart.Position)
            if onScreen then
                mousemoveabs(screenPos.X, screenPos.Y + 36)
                task.wait()
                mouse1click()
                done = true
            end
        end
    end)

    -- method 2: activate the tool directly
    if not done then
        pcall(function()
            local tool = getHandcuffs()
            if tool then
                tool:Activate()
            end
        end)
    end
end

local function resetCharacter()
    pcall(function()
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)

    local ok, newChar = pcall(function()
        return player.CharacterAdded:Wait()
    end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

-- main loop
task.spawn(function()
    while active do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            local pri = getPriority(plr)
            if pri then
                local torso = getTorso(plr)
                if torso then
                    table.insert(targets, { player = plr, torso = torso, priority = pri })
                end
            end
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            task.wait(1)
            continue
        end

        for _, target in ipairs(targets) do
            if not active then break end
            if not target.player.Parent then continue end
            if not target.torso or not target.torso.Parent then continue end
            if not getPriority(target.player) then continue end

            equipHandcuffs()
            task.wait(0.1)

            tweenTo(target.torso)
            task.wait(0.1)

            clickOnTarget(target.torso)
            task.wait(0.2)

            resetCharacter()

            equipHandcuffs()
        end

        task.wait(0.5)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    if currentTween then pcall(function() currentTween:Cancel() end) end
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end
