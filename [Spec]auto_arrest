-- [Spec] Auto Arrest
-- Tween to target, lock-on to face them, rapid arrest, tween away, reset

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local connections = {}
local active = true
local tweenSpeed = -1
local killBind = Enum.KeyCode.P
local lockedTarget = nil

---------- KEYBIND ----------

local keybindConn = UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == killBind then
        active = false
        lockedTarget = nil
        pcall(function()
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            UserInputService.MouseIconEnabled = true
            local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.AutoRotate = true end
            player.CameraMinZoomDistance = 0.5
            player.CameraMaxZoomDistance = 128
        end)
    end
end)
table.insert(connections, keybindConn)

---------- LOCK-ON ----------

local lockAlign = nil
local lockAttachment = nil

local function updateLock()
    if not active or not lockedTarget then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then return end

    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    UserInputService.MouseIconEnabled = false
    hum.AutoRotate = false

    local targetChar = lockedTarget.Character
    if not targetChar then return end
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end

    -- face target: character CFrame
    local toTarget = targetRoot.Position - root.Position
    local flat = Vector3.new(toTarget.X, 0, toTarget.Z)
    if flat.Magnitude > 0.1 then
        root.CFrame = CFrame.lookAt(root.Position, root.Position + flat)
    end

    -- face target: camera
    local cam = workspace.CurrentCamera
    if cam then
        local camPos = cam.CFrame.Position
        local lookAt = targetRoot.Position
        local dir = lookAt - camPos
        if dir.Magnitude > 0.5 then
            cam.CFrame = CFrame.new(camPos, camPos + dir)
        end
    end

    -- AlignOrientation constraint (survives physics/dashes)
    if not lockAttachment or not lockAttachment.Parent then
        lockAttachment = Instance.new("Attachment")
        lockAttachment.Name = "ArrestLockAttach"
        lockAttachment.Parent = root
    end
    if not lockAlign or not lockAlign.Parent then
        lockAlign = Instance.new("AlignOrientation")
        lockAlign.Name = "ArrestLockAlign"
        lockAlign.Mode = Enum.OrientationAlignmentMode.OneAttachment
        lockAlign.Attachment0 = lockAttachment
        lockAlign.RigidityEnabled = true
        lockAlign.Responsiveness = 200
        lockAlign.MaxTorque = math.huge
        lockAlign.Parent = root
    end
    lockAlign.Enabled = true
    lockAlign.CFrame = CFrame.lookAt(Vector3.zero, flat)
end

-- bind at multiple priorities so nothing overrides the rotation
local LOCK_BIND_1 = "AutoArrestLock1"
local LOCK_BIND_2 = "AutoArrestLock2"
RunService:BindToRenderStep(LOCK_BIND_1, Enum.RenderPriority.Camera.Value + 1, updateLock)
RunService:BindToRenderStep(LOCK_BIND_2, Enum.RenderPriority.Camera.Value + 200, updateLock)

local lockConn = RunService.Heartbeat:Connect(updateLock)
table.insert(connections, lockConn)

local function lockOn(plr)
    lockedTarget = plr
    pcall(function()
        player.CameraMinZoomDistance = 5
        player.CameraMaxZoomDistance = 5
    end)
end

local function lockOff()
    lockedTarget = nil
    pcall(function()
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate = true end
        player.CameraMinZoomDistance = 0.5
        player.CameraMaxZoomDistance = 128
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid") or nil
        player.DevEnableMouseLock = true
        pcall(function()
            UserSettings():GetService("UserGameSettings").ControlMode = Enum.ControlMode.MouseLockSwitch
        end)
    end)
    if lockAlign then pcall(function() lockAlign.Enabled = false end) end
end

---------- NOCLIP DURING TWEEN ----------

local savedCollision = {}

local function setNoclip(char, on)
    if not char then return end
    if on then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                savedCollision[part] = part.CanCollide
                part.CanCollide = false
            end
        end
    else
        for part, val in pairs(savedCollision) do
            pcall(function() part.CanCollide = val end)
        end
        savedCollision = {}
    end
end

---------- TOOLS ----------

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

---------- PLAYER CHECKS ----------

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function isCriminal(plr)
    return getTeamName(plr):find("criminal") ~= nil
end

local function isInmateArrestable(plr)
    if not plr.Character then return false end
    for _, desc in ipairs(plr.Character:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            local ok, text = pcall(function() return desc.Text end)
            if ok and text and text:find("\xF0\x9F\x94\x97") then return true end
        end
    end
    return false
end

local function hasForceField(plr)
    return plr.Character and plr.Character:FindFirstChildOfClass("ForceField") ~= nil
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function isArrested(plr)
    if not plr.Parent then return true end
    local team = getTeamName(plr)
    -- if they switched to guard/inmate (non-criminal), they got arrested
    if not (team:find("criminal") or team:find("inmate") or team:find("prisoner")) then return true end
    return false
end

---------- MOVEMENT ----------

local function getRoot(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getTorso(plr)
    return plr.Character and (plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso"))
end

local function tweenTo(targetCF)
    local root = getRoot(player.Character)
    if not root then return end
    pcall(function()
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Sit then hum.Sit = false end
    end)
    setNoclip(player.Character, true)
    local tween = TweenService:Create(root, TweenInfo.new(tweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetCF})
    tween:Play()
    tween.Completed:Wait()
    setNoclip(player.Character, false)
    pcall(function()
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end)
end

---------- ARREST ----------

local function fireRemote(plr)
    pcall(function()
        local torso = getTorso(plr)
        if torso then ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso) end
    end)
end

---------- RESET ----------

local function resetCharacter()
    pcall(function()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    local ok, newChar = pcall(function() return player.CharacterAdded:Wait() end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

---------- MAIN LOOP ----------

task.spawn(function()
    while active do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == player or not plr.Character then continue end
            if isArrested(plr) or hasForceField(plr) then continue end

            local crim = isCriminal(plr)
            local inm = not crim and isInmateArrestable(plr)
            if not crim and not inm then continue end

            local root = getRoot(plr.Character)
            if not root then continue end

            local pri = 10
            if crim and hasKeycard(plr) then pri = 1
            elseif crim then pri = 2 end

            table.insert(targets, { player = plr, priority = pri, isCriminal = crim })
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            task.wait(0.3)
            continue
        end

        equipHandcuffs()

        for _, target in ipairs(targets) do
            if not active then break end
            if isArrested(target.player) or hasForceField(target.player) then continue end
            if not target.isCriminal and not isInmateArrestable(target.player) then continue end

            lockOn(target.player)

            -- wait for target to stop moving before approaching
            local waitStart = tick()
            while active and tick() - waitStart < 15 do
                if isArrested(target.player) then break end
                local tRoot = getRoot(target.player.Character)
                if not tRoot then break end
                local hum = target.player.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.MoveDirection.Magnitude < 0.1 then break end
                task.wait(0.1)
            end

            local arrested = false
            for attempt = 1, 25 do
                if not active then break end
                if isArrested(target.player) then arrested = true; break end

                local targetRoot = getRoot(target.player.Character)
                if not targetRoot then break end

                -- check they're still standing still, bail if they started running
                local tHum = target.player.Character:FindFirstChildOfClass("Humanoid")
                if tHum and tHum.MoveDirection.Magnitude > 0.1 then break end

                -- tween right behind target, very close
                local behindOffset = -targetRoot.CFrame.LookVector * 1 + Vector3.new(0, 0.5, 0)
                tweenTo(CFrame.new(targetRoot.Position + behindOffset, targetRoot.Position))

                -- rapid-fire the arrest remote
                for _ = 1, 3 do
                    fireRemote(target.player)
                    task.wait(0.05)
                end

                task.wait(0.1)
            end

            lockOff()

            if arrested then
                local myRoot = getRoot(player.Character)
                if myRoot then
                    tweenTo(CFrame.new(myRoot.Position.X, myRoot.Position.Y - 200, myRoot.Position.Z))
                end
                task.wait(0.3)
                resetCharacter()
                equipHandcuffs()
            end
        end

        task.wait(0.3)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    lockOff()
    setNoclip(player.Character, false)
    pcall(function() RunService:UnbindFromRenderStep(LOCK_BIND_1) end)
    pcall(function() RunService:UnbindFromRenderStep(LOCK_BIND_2) end)
    pcall(function() if lockAlign then lockAlign:Destroy(); lockAlign = nil end end)
    pcall(function() if lockAttachment then lockAttachment:Destroy(); lockAttachment = nil end end)
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end

task.delay(2, function()
    if _G.SixZeroHubRegisterSettings then
        _G.SixZeroHubRegisterSettings("[Spec]auto_arrest", {
            _title = "Auto Arrest",
            {
                name = "kill_bind",
                label = "Stop Keybind",
                type = "dropdown",
                default = "P",
                options = {"P", "K", "L", "M", "F5", "F6", "F7", "F8", "Backslash", "RightBracket", "Semicolon"},
                onChange = function(val)
                    local ok, key = pcall(function() return Enum.KeyCode[val] end)
                    if ok and key then killBind = key end
                end,
            },
        })
    end
end)
