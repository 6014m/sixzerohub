-- [Spec] Auto Arrest
-- Flips upside down (head underground to hide nametag), detaches accessories
-- Tweens to targets, arrests, resets after confirmed

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local connections = {}
local active = true
local tweenSpeed = -1
local hidden = false
local noclipEnabled = false
local killBind = Enum.KeyCode.P

local skipList = {}
local SKIP_DURATION = 20

---------- NOCLIP ----------

local noclipConn = RunService.Stepped:Connect(function()
    if not active or not noclipEnabled then return end
    local char = player.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end)
table.insert(connections, noclipConn)

---------- KEYBIND ----------

local keybindConn = UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == killBind then
        active = false
        hidden = false
        noclipEnabled = false
        pcall(function()
            local cam = workspace.CurrentCamera
            cam.CameraType = Enum.CameraType.Custom
            cam.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid") or nil
        end)
    end
end)
table.insert(connections, keybindConn)

---------- TWEEN HELPER ----------

local function tweenCFrame(root, targetCF)
    if not root or not root.Parent then return end
    local tween = TweenService:Create(
        root,
        TweenInfo.new(tweenSpeed, Enum.EasingStyle.Linear),
        {CFrame = targetCF}
    )
    tween:Play()
    tween.Completed:Wait()
    pcall(function()
        root.Velocity = Vector3.new(0, 0, 0)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)
end

---------- HIDE: FLIP UPSIDE DOWN + DETACH ACCESSORIES ----------

local function detachAccessories()
    pcall(function()
        local char = player.Character
        if not char then return end
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("Accessory") then
                for _, p in ipairs(v:GetDescendants()) do
                    if p:IsA("Weld") then
                        p:Destroy()
                    end
                end
            end
        end
    end)
end

local function hideCharacter()
    if hidden then return end
    detachAccessories()
    noclipEnabled = true
    hidden = true
end

local function unhideCharacter()
    hidden = false
    noclipEnabled = false
end

-- find the ACTUAL terrain/baseplate ground, not roofs or thin floors above us
-- casts from very high up to find the lowest thick surface
local function getGroundY(position)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local filterList = {}
    if player.Character then table.insert(filterList, player.Character) end
    params.FilterDescendantsInstances = filterList

    -- cast from way up to find the ground
    local origin = Vector3.new(position.X, 500, position.Z)
    local hits = {}

    -- do multiple raycasts to find ALL surfaces, pick the lowest solid one
    local currentY = 500
    for _ = 1, 10 do
        local result = workspace:Raycast(Vector3.new(position.X, currentY, position.Z), Vector3.new(0, -600, 0), params)
        if not result then break end

        local hitPart = result.Instance
        local hitY = result.Position.Y
        local normal = result.Normal

        -- check if this is actual ground (thick part, terrain, or baseplate)
        local isGround = false
        if hitPart:IsA("Terrain") then
            isGround = true
        elseif hitPart.Size.Y >= 1 then
            -- thick enough to be a real floor, not a thin ceiling
            isGround = true
        end

        if isGround then
            table.insert(hits, { y = hitY, normal = normal })
        end

        -- continue casting below this hit
        currentY = hitY - 0.1
        if currentY < -100 then break end
    end

    if #hits > 0 then
        -- use the lowest ground hit (most likely actual terrain, not a roof)
        local lowest = hits[1]
        for _, h in ipairs(hits) do
            if h.y < lowest.y then lowest = h end
        end
        return lowest.y, lowest.normal
    end

    return position.Y - 3, Vector3.new(0, 1, 0)
end

-- keep character flipped and head buried in ground + prevent sitting
local flipConn = RunService.Heartbeat:Connect(function()
    if not active or not hidden then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- prevent sitting
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum and hum.Sit then
        hum.Sit = false
    end

    -- raycast for real ground (terrain/baseplate, not roofs)
    local groundY, normal = getGroundY(root.Position)

    -- align to ground slope using the surface normal
    -- flipped: head hangs ~2.5 studs below HRP. Place HRP at ground+1 so head is 1.5 studs INTO ground
    local upVec = -normal -- we're flipped, so "up" for us is the negative of the ground normal
    local lookVec = Vector3.new(1, 0, 0) -- arbitrary forward
    if math.abs(upVec.Y) > 0.99 then
        -- flat ground, just flip on Z
        root.CFrame = CFrame.new(root.Position.X, groundY + 1, root.Position.Z) * CFrame.Angles(0, 0, math.rad(180))
    else
        -- slanted ground, align to slope
        local rightVec = lookVec:Cross(upVec).Unit
        local fwd = upVec:Cross(rightVec).Unit
        root.CFrame = CFrame.fromMatrix(Vector3.new(root.Position.X, groundY + 1, root.Position.Z), rightVec, upVec, -fwd)
    end
end)
table.insert(connections, flipConn)

---------- CAMERA ----------

local function detachCamera()
    pcall(function()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
    end)
end

local function pointCameraAbove(targetPos)
    pcall(function()
        local cam = workspace.CurrentCamera

        -- find a clear camera position: start close above, move up until no obstruction
        local bestPos = targetPos + Vector3.new(0, 8, 0)

        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        local filterList = {}
        if player.Character then table.insert(filterList, player.Character) end
        params.FilterDescendantsInstances = filterList

        -- check if there's a ceiling between camera and target
        for height = 8, 40, 4 do
            local testPos = targetPos + Vector3.new(0, height, 0)
            local result = workspace:Raycast(testPos, (targetPos - testPos), params)
            if not result then
                -- clear line of sight
                bestPos = testPos
                break
            end
            bestPos = testPos + Vector3.new(0, 4, 0)
        end

        cam.CFrame = CFrame.new(bestPos, targetPos)
    end)
end

local function resetCamera()
    pcall(function()
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid") or nil
    end)
end

---------- TOOLS ----------

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

---------- PLAYER CHECKS ----------

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function isCriminal(plr)
    return getTeamName(plr):find("criminal") ~= nil
end

local function isInmate(plr)
    local team = getTeamName(plr)
    return (team:find("inmate") or team:find("prisoner")) ~= nil
end

-- check if a prisoner has the 🔗 chain before their display name (overhead BillboardGui)
local function isInmateArrestable(plr)
    if not plr.Character then return false end
    -- check all BillboardGuis and TextLabels on the character for the chain emoji
    for _, desc in ipairs(plr.Character:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            local ok, text = pcall(function() return desc.Text end)
            if ok and text and text:find("\xF0\x9F\x94\x97") then -- 🔗
                return true
            end
        end
    end
    return false
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function hasForceField(plr)
    if not plr.Character then return false end
    return plr.Character:FindFirstChildOfClass("ForceField") ~= nil
end

local function isSkipped(plr)
    local t = skipList[plr.Name]
    return t and os.clock() - t < SKIP_DURATION
end

local function isArrested(plr)
    if not plr.Parent then return true end
    local team = getTeamName(plr)
    if not (team:find("criminal") or team:find("inmate") or team:find("prisoner")) then
        return true
    end
    if plr.Character then
        local head = plr.Character:FindFirstChild("Head")
        if head then
            for _, child in ipairs(head:GetChildren()) do
                if child:IsA("BillboardGui") then return true end
            end
        end
        for _, child in ipairs(plr.Character:GetChildren()) do
            if child:IsA("BillboardGui") and child.Name ~= "NameTag" then
                return true
            end
        end
    end
    return false
end

---------- MOVEMENT ----------

local function getRoot(char)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getTorso(plr)
    if not plr.Character then return nil end
    return plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
end

local function tweenToTarget(targetRoot)
    local root = getRoot(player.Character)
    if not root or not targetRoot or not targetRoot.Parent then return end

    -- unseat
    pcall(function()
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Sit = false end
    end)

    -- raycast to find actual ground at target's position
    local targetPos = targetRoot.Position
    local groundY = getGroundY(targetPos)

    -- flipped upside down: place HRP at ground+1 so head hangs below ground
    tweenCFrame(root, CFrame.new(targetPos.X + 3, groundY + 1, targetPos.Z) * CFrame.Angles(0, 0, math.rad(180)))
end

---------- ARREST ----------

local function clickOnPlayer(plr)
    local torso = getTorso(plr)
    if not torso then return end
    local cam = workspace.CurrentCamera
    local screenPos, onScreen = cam:WorldToScreenPoint(torso.Position)
    if not onScreen then return end
    pcall(function()
        VIM:SendMouseButtonEvent(screenPos.X, screenPos.Y + 36, 0, true, game, 1)
        task.wait()
        VIM:SendMouseButtonEvent(screenPos.X, screenPos.Y + 36, 0, false, game, 1)
    end)
    pcall(function()
        if mousemoveabs and mouse1click then
            mousemoveabs(screenPos.X, screenPos.Y + 36)
            task.wait()
            mouse1click()
        end
    end)
end

local function fireArrestRemote(plr)
    pcall(function()
        local torso = getTorso(plr)
        if torso then
            ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso)
        end
    end)
end

local function tryArrestProbe(plr)
    fireArrestRemote(plr)
    task.wait(0.3)
    return isArrested(plr)
end

---------- HIDE BEFORE RESET ----------

-- tween far away and underground so nobody sees the reset
local function tweenToHiddenSpot()
    local root = getRoot(player.Character)
    if not root then return end

    -- find a spot far from all players
    local bestPos = root.Position + Vector3.new(200, 0, 200)

    -- raycast to find ground there
    local groundY = getGroundY(bestPos)

    -- tween underground at that spot
    tweenCFrame(root, CFrame.new(bestPos.X, groundY - 10, bestPos.Z))
end

---------- RESET ----------

local function resetCharacter()
    hidden = false
    pcall(function()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    local ok, newChar = pcall(function()
        return player.CharacterAdded:Wait()
    end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

---------- MAIN LOOP ----------

task.spawn(function()
    while active do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == player or not plr.Character then continue end
            if isSkipped(plr) or isArrested(plr) or hasForceField(plr) then continue end

            local crim = isCriminal(plr)
            local inm = isInmate(plr)
            if not crim and not inm then continue end

            local root = getRoot(plr.Character)
            if not root then continue end

            if crim then
                local pri = hasKeycard(plr) and 1 or 2
                table.insert(targets, { player = plr, root = root, priority = pri, isCriminal = true })
            elseif inm and isInmateArrestable(plr) then
                -- only target inmates with 🔗 on their display name
                table.insert(targets, { player = plr, root = root, priority = 10, isCriminal = false })
            end
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            task.wait(1)
            continue
        end

        -- hide: flip upside down + noclip + detach hats + detach camera
        hideCharacter()
        detachCamera()
        equipHandcuffs()

        for _, target in ipairs(targets) do
            if not active then break end
            if not target.player.Parent then continue end
            if isArrested(target.player) or hasForceField(target.player) then continue end

            -- pursue and arrest
            local arrested = false
            local maxAttempts = target.isCriminal and 15 or 8
            for attempt = 1, maxAttempts do
                if not active then break end
                if isArrested(target.player) then
                    arrested = true
                    break
                end
                if hasForceField(target.player) then break end
                -- if inmate, recheck chain each attempt in case it disappeared
                if not target.isCriminal and not isInmateArrestable(target.player) then break end

                local freshRoot = getRoot(target.player.Character)
                if not freshRoot or not freshRoot.Parent then break end

                tweenToTarget(freshRoot)
                pointCameraAbove(freshRoot.Position)
                task.wait(0.05)

                clickOnPlayer(target.player)
                task.wait(0.1)
                fireArrestRemote(target.player)

                task.wait(0.3)
                if isArrested(target.player) then
                    arrested = true
                    break
                end
            end

            if arrested then
                tweenToHiddenSpot()
                unhideCharacter()
                resetCamera()
                resetCharacter()
                hideCharacter()
                detachCamera()
                equipHandcuffs()
            end
        end

        task.wait(0.5)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    hidden = false
    noclipEnabled = false
    resetCamera()
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end

task.delay(2, function()
    if _G.SixZeroHubRegisterSettings then
        _G.SixZeroHubRegisterSettings("[Spec]auto_arrest", {
            _title = "Auto Arrest",
            {
                name = "kill_bind",
                label = "Stop Keybind",
                type = "dropdown",
                default = "P",
                options = {"P", "K", "L", "M", "F5", "F6", "F7", "F8", "Backslash", "RightBracket", "Semicolon"},
                onChange = function(val)
                    local ok, key = pcall(function() return Enum.KeyCode[val] end)
                    if ok and key then killBind = key end
                end,
            },
        })
    end
end)
