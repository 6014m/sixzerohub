-- [Spec] Auto Arrest
-- Hides underground below targets, noclip + detached camera
-- Reads activity from HUD to know when inmates are arrestable
-- Priority: keycard holders > criminals > out-of-place inmates

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local connections = {}
local active = true
local tweenSpeed = -1
local noclipEnabled = false

local skipList = {}

---------- NOCLIP ----------

local function setNoclip(state)
    noclipEnabled = state
end

local noclipConn = RunService.Stepped:Connect(function()
    if not active then return end
    if not noclipEnabled then return end
    local char = player.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end)
table.insert(connections, noclipConn)

---------- ACTIVITY DETECTION ----------

local function getCurrentActivity()
    local ok, text = pcall(function()
        return player.PlayerGui.Home.hud.Topbar.titleBar.Title.Text
    end)
    if ok and text then
        return text:lower()
    end
    return ""
end

-- Prison Life schedule zones:
-- "yard" = inmates must be in yard area
-- "lunch" / "eat" = inmates must be in cafeteria
-- "lights out" / "night" / "bed" / "sleep" = inmates must be in cells
-- "roll call" / "morning" = inmates must be at roll call area
-- "free time" / "leisure" = inmates can roam most indoor areas
-- If an inmate is NOT where they should be during these, they can be arrested

local function isRestrictiveTime()
    local activity = getCurrentActivity()
    -- during these activities, inmates have specific required locations
    -- so more of them will be out of place and arrestable
    if activity:find("yard") then return true, "yard" end
    if activity:find("lunch") or activity:find("eat") or activity:find("dinner") or activity:find("breakfast") then return true, "cafeteria" end
    if activity:find("night") or activity:find("lights") or activity:find("bed") or activity:find("sleep") then return true, "cells" end
    if activity:find("roll") or activity:find("morning") then return true, "rollcall" end
    return false, "free"
end

---------- TOOLS ----------

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

---------- PLAYER CHECKS ----------

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function isCriminal(plr)
    return getTeamName(plr):find("criminal") ~= nil
end

local function isInmate(plr)
    local team = getTeamName(plr)
    return (team:find("inmate") or team:find("prisoner")) ~= nil
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function hasWeapon(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") then
            local n = child.Name:lower()
            if n:find("gun") or n:find("knife") or n:find("ak") or n:find("m4")
                or n:find("pistol") or n:find("shotgun") or n:find("remington") then
                return true
            end
        end
    end
    return false
end

local function getPriority(plr)
    if plr == player then return nil end
    if not plr.Character then return nil end

    local crim = isCriminal(plr)
    local inm = isInmate(plr)
    if not crim and not inm then return nil end

    -- skip inmates we recently failed on
    if inm and not crim then
        local skipTime = skipList[plr.Name]
        if skipTime and os.clock() - skipTime < 15 then
            return nil
        end
    end

    if hasKeycard(plr) then return 1 end
    if crim then return 2 end
    if hasWeapon(plr) then return 3 end

    -- during restrictive times, inmates are more likely arrestable
    local restrictive = isRestrictiveTime()
    if restrictive then return 4 end

    -- during free time, only try inmates who look suspicious (near exits, outside, etc)
    return 5
end

---------- MOVEMENT ----------

local function getRoot(char)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getTorso(plr)
    if not plr.Character then return nil end
    return plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
end

-- IY tween but go UNDERGROUND below the target
local function tweenUnder(targetRoot)
    local root = getRoot(player.Character)
    if not root or not targetRoot or not targetRoot.Parent then return end

    pcall(function()
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.SeatPart then
            hum.Sit = false
            task.wait(0.1)
        end
    end)

    -- position underground below target
    local targetCF = CFrame.new(
        targetRoot.Position.X + 3,
        targetRoot.Position.Y - 15,
        targetRoot.Position.Z
    )

    local tween = TweenService:Create(
        root,
        TweenInfo.new(tweenSpeed, Enum.EasingStyle.Linear),
        {CFrame = targetCF}
    )
    tween:Play()
    tween.Completed:Wait()

    pcall(function()
        root.Velocity = Vector3.new(0, 0, 0)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)
end

---------- ARREST ----------

local function isArrested(plr)
    if not plr.Parent then return true end
    local team = getTeamName(plr)
    if not (team:find("criminal") or team:find("inmate") or team:find("prisoner")) then
        return true
    end
    -- check for arrest timer billboard gui
    if plr.Character then
        local head = plr.Character:FindFirstChild("Head")
        if head then
            for _, child in ipairs(head:GetChildren()) do
                if child:IsA("BillboardGui") then return true end
            end
        end
        for _, child in ipairs(plr.Character:GetChildren()) do
            if child:IsA("BillboardGui") and child.Name ~= "NameTag" then
                return true
            end
        end
    end
    return false
end

local function clickAt(x, y)
    pcall(function()
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait()
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end)
    pcall(function()
        if mousemoveabs and mouse1click then
            mousemoveabs(x, y)
            task.wait()
            mouse1click()
        end
    end)
end

local function arrestTarget(targetPlr)
    local torso = getTorso(targetPlr)
    if not torso then return end

    local cam = workspace.CurrentCamera
    local screenPos, onScreen = cam:WorldToScreenPoint(torso.Position)
    if not onScreen then return end

    clickAt(screenPos.X, screenPos.Y + 36)
end

local function resetCharacter()
    setNoclip(false)
    pcall(function()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    local ok, newChar = pcall(function()
        return player.CharacterAdded:Wait()
    end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

---------- CAMERA CONTROL ----------

-- detach camera so it stays at a good viewing angle while character is underground
local function setupCamera()
    pcall(function()
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Scriptable
    end)
end

local function pointCameraAt(targetPos)
    pcall(function()
        local cam = workspace.CurrentCamera
        -- position camera above and slightly behind the target for good view
        local camPos = targetPos + Vector3.new(0, 15, 15)
        cam.CFrame = CFrame.new(camPos, targetPos)
    end)
end

local function resetCamera()
    pcall(function()
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid") or nil
    end)
end

---------- MAIN LOOP ----------

task.spawn(function()
    while active do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            local pri = getPriority(plr)
            if pri then
                local root = getRoot(plr.Character)
                if root then
                    table.insert(targets, { player = plr, root = root, priority = pri })
                end
            end
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            setNoclip(false)
            resetCamera()
            task.wait(1)
            continue
        end

        equipHandcuffs()

        for _, target in ipairs(targets) do
            if not active then break end
            if not target.player.Parent then continue end
            if not target.root or not target.root.Parent then continue end
            if not getPriority(target.player) then continue end

            local isCrim = isCriminal(target.player)
            local maxAttempts = isCrim and 15 or 3

            -- enable noclip and detach camera
            setNoclip(true)
            setupCamera()

            local arrested = false
            for attempt = 1, maxAttempts do
                if not active then break end
                if isArrested(target.player) then
                    arrested = true
                    break
                end

                local freshRoot = getRoot(target.player.Character)
                if not freshRoot or not freshRoot.Parent then break end

                -- go underground below them
                tweenUnder(freshRoot)
                task.wait(0.05)

                -- point camera at target so click lands on them
                pointCameraAt(freshRoot.Position)
                task.wait(0.05)

                arrestTarget(target.player)
                task.wait(0.3)

                if isArrested(target.player) then
                    arrested = true
                    break
                end
            end

            -- restore camera between targets
            resetCamera()
            setNoclip(false)

            if arrested then
                resetCharacter()
                equipHandcuffs()
                setNoclip(false)
            elseif not isCrim then
                skipList[target.player.Name] = os.clock()
            end
        end

        task.wait(0.5)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    setNoclip(false)
    resetCamera()
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end
