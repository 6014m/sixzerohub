-- [Spec] Auto Arrest
-- Hides underground, noclip + detached camera
-- Uses InvokeServer return to verify arrest is possible before committing
-- Reads activity from HUD, only pursues inmates the server confirms are arrestable

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local connections = {}
local active = true
local tweenSpeed = -1
local noclipEnabled = false

-- inmates confirmed not arrestable right now, skip for a while
local skipList = {} -- [playerName] = os.clock()
local SKIP_DURATION = 20

---------- NOCLIP ----------

local noclipConn = RunService.Stepped:Connect(function()
    if not active or not noclipEnabled then return end
    local char = player.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end)
table.insert(connections, noclipConn)

---------- ACTIVITY ----------

local function getCurrentActivity()
    local ok, text = pcall(function()
        return player.PlayerGui.Home.hud.Topbar.titleBar.Title.Text
    end)
    return ok and text and text:lower() or ""
end

---------- TOOLS ----------

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

---------- PLAYER CHECKS ----------

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function isCriminal(plr)
    return getTeamName(plr):find("criminal") ~= nil
end

local function isInmate(plr)
    local team = getTeamName(plr)
    return (team:find("inmate") or team:find("prisoner")) ~= nil
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function isSkipped(plr)
    local t = skipList[plr.Name]
    if t and os.clock() - t < SKIP_DURATION then return true end
    return false
end

local function isArrested(plr)
    if not plr.Parent then return true end
    local team = getTeamName(plr)
    if not (team:find("criminal") or team:find("inmate") or team:find("prisoner")) then
        return true
    end
    if plr.Character then
        local head = plr.Character:FindFirstChild("Head")
        if head then
            for _, child in ipairs(head:GetChildren()) do
                if child:IsA("BillboardGui") then return true end
            end
        end
        for _, child in ipairs(plr.Character:GetChildren()) do
            if child:IsA("BillboardGui") and child.Name ~= "NameTag" then
                return true
            end
        end
    end
    return false
end

---------- ARREST PROBE ----------

-- try the remote once and check if it actually did anything
-- InvokeServer returns a value - if arrest fails the server tells us
local function tryArrestRemote(plr)
    local torso = plr.Character and (plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso"))
    if not torso then return false end

    local result = nil
    local ok = pcall(function()
        result = ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso)
    end)

    -- give it a moment to register
    task.wait(0.3)

    -- check if arrest actually went through
    return isArrested(plr)
end

---------- MOVEMENT ----------

local function getRoot(char)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function tweenUnder(targetRoot)
    local root = getRoot(player.Character)
    if not root or not targetRoot or not targetRoot.Parent then return end

    pcall(function()
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.SeatPart then
            hum.Sit = false
            task.wait(0.1)
        end
    end)

    local targetCF = CFrame.new(
        targetRoot.Position.X + 3,
        targetRoot.Position.Y - 15,
        targetRoot.Position.Z
    )

    local tween = TweenService:Create(
        root,
        TweenInfo.new(tweenSpeed, Enum.EasingStyle.Linear),
        {CFrame = targetCF}
    )
    tween:Play()
    tween.Completed:Wait()

    pcall(function()
        root.Velocity = Vector3.new(0, 0, 0)
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)
end

---------- CLICK ----------

local function clickAt(x, y)
    pcall(function()
        VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait()
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end)
    pcall(function()
        if mousemoveabs and mouse1click then
            mousemoveabs(x, y)
            task.wait()
            mouse1click()
        end
    end)
end

local function clickOnPlayer(plr)
    local torso = plr.Character and (plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso"))
    if not torso then return end
    local cam = workspace.CurrentCamera
    local screenPos, onScreen = cam:WorldToScreenPoint(torso.Position)
    if not onScreen then return end
    clickAt(screenPos.X, screenPos.Y + 36)
end

---------- CAMERA ----------

local function setupCamera()
    pcall(function()
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
    end)
end

local function pointCameraAt(targetPos)
    pcall(function()
        local camPos = targetPos + Vector3.new(0, 15, 15)
        workspace.CurrentCamera.CFrame = CFrame.new(camPos, targetPos)
    end)
end

local function resetCamera()
    pcall(function()
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid") or nil
    end)
end

---------- RESET ----------

local function resetCharacter()
    noclipEnabled = false
    resetCamera()
    pcall(function()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    local ok, newChar = pcall(function()
        return player.CharacterAdded:Wait()
    end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

---------- MAIN LOOP ----------

task.spawn(function()
    while active do
        -- build target list
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == player then continue end
            if not plr.Character then continue end
            if isSkipped(plr) then continue end
            if isArrested(plr) then continue end

            local crim = isCriminal(plr)
            local inm = isInmate(plr)
            if not crim and not inm then continue end

            local root = getRoot(plr.Character)
            if not root then continue end

            -- criminals always go in, with priority
            if crim then
                local pri = hasKeycard(plr) and 1 or 2
                table.insert(targets, { player = plr, root = root, priority = pri, isCriminal = true })
            elseif inm then
                -- for inmates: probe with remote first to see if server allows arrest
                -- only add if the probe succeeds
                table.insert(targets, { player = plr, root = root, priority = 10, isCriminal = false, needsProbe = true })
            end
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            noclipEnabled = false
            resetCamera()
            task.wait(1)
            continue
        end

        equipHandcuffs()

        for _, target in ipairs(targets) do
            if not active then break end
            if not target.player.Parent then continue end
            if isArrested(target.player) then continue end

            -- for inmates, probe first: tween close, try remote once
            -- if server says no, skip them
            if target.needsProbe then
                noclipEnabled = true
                local freshRoot = getRoot(target.player.Character)
                if not freshRoot then continue end

                tweenUnder(freshRoot)
                task.wait(0.1)

                local probeWorked = tryArrestRemote(target.player)
                if not probeWorked then
                    -- server didn't arrest them, they're in a safe zone
                    skipList[target.player.Name] = os.clock()
                    noclipEnabled = false
                    continue
                else
                    -- probe arrested them! confirm and reset
                    noclipEnabled = false
                    resetCamera()
                    resetCharacter()
                    equipHandcuffs()
                    continue
                end
            end

            -- criminals: full pursuit
            noclipEnabled = true
            setupCamera()

            local arrested = false
            for attempt = 1, 15 do
                if not active then break end
                if isArrested(target.player) then
                    arrested = true
                    break
                end

                local freshRoot = getRoot(target.player.Character)
                if not freshRoot or not freshRoot.Parent then break end

                tweenUnder(freshRoot)
                task.wait(0.05)

                pointCameraAt(freshRoot.Position)
                task.wait(0.05)

                -- click + remote
                clickOnPlayer(target.player)
                task.wait(0.1)
                pcall(function()
                    local torso = target.player.Character:FindFirstChild("Torso") or target.player.Character:FindFirstChild("UpperTorso")
                    if torso then
                        ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso)
                    end
                end)

                task.wait(0.3)
                if isArrested(target.player) then
                    arrested = true
                    break
                end
            end

            noclipEnabled = false
            resetCamera()

            if arrested then
                resetCharacter()
                equipHandcuffs()
            end
        end

        task.wait(0.5)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    noclipEnabled = false
    resetCamera()
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end
