-- [Spec] Auto Arrest
-- Tween to target, lock-on shiftlock to face them, arrest, tween away, reset

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local connections = {}
local active = true
local tweenSpeed = -1
local killBind = Enum.KeyCode.P
local lockedTarget = nil -- the player we're locking onto

---------- KEYBIND ----------

local keybindConn = UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == killBind then
        active = false
        lockedTarget = nil
        pcall(function()
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
            UserInputService.MouseIconEnabled = true
            local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.AutoRotate = true end
            player.CameraMinZoomDistance = 0.5
            player.CameraMaxZoomDistance = 128
        end)
    end
end)
table.insert(connections, keybindConn)

---------- LOCK-ON SHIFTLOCK (from lockon ShiftLockModule) ----------

local lockConn = RunService.RenderStepped:Connect(function()
    if not active or not lockedTarget then return end
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end
    if hum.Health <= 0 then return end

    -- lock mouse to center
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    UserInputService.MouseIconEnabled = false
    hum.AutoRotate = false

    -- face the target (character only, don't touch camera — let Roblox handle it)
    local targetRoot = lockedTarget.Character and lockedTarget.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return end

    local look = (targetRoot.Position - root.Position)
    local flatLook = Vector3.new(look.X, 0, look.Z)
    if flatLook.Magnitude > 0 then
        root.CFrame = CFrame.lookAt(root.Position, root.Position + flatLook)
    end
end)
table.insert(connections, lockConn)

local function lockOn(plr)
    lockedTarget = plr
    pcall(function()
        player.CameraMinZoomDistance = 5
        player.CameraMaxZoomDistance = 5
    end)
end

local function lockOff()
    lockedTarget = nil
    pcall(function()
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        UserInputService.MouseIconEnabled = true
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.AutoRotate = true end
        player.CameraMinZoomDistance = 0.5
        player.CameraMaxZoomDistance = 128
        -- restore camera to follow player
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Custom
        cam.CameraSubject = player.Character and player.Character:FindFirstChildOfClass("Humanoid") or nil
        -- re-enable game's built-in shiftlock
        player.DevEnableMouseLock = true
        pcall(function()
            UserSettings():GetService("UserGameSettings").ControlMode = Enum.ControlMode.MouseLockSwitch
        end)
    end)
end

---------- ACCESSORIES ----------

local function detachAccessories()
    pcall(function()
        for _, v in ipairs(player.Character:GetDescendants()) do
            if v:IsA("Accessory") then
                for _, p in ipairs(v:GetDescendants()) do
                    if p:IsA("Weld") then p:Destroy() end
                end
            end
        end
    end)
end

---------- TOOLS ----------

local function equipHandcuffs()
    pcall(function()
        local char = player.Character
        if not char then return end
        local held = char:FindFirstChildOfClass("Tool")
        if held and held.Name:lower():find("cuff") then return end
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("cuff") then
                    tool.Parent = char
                    return
                end
            end
        end
    end)
end

---------- PLAYER CHECKS ----------

local function getTeamName(plr)
    local name = ""
    pcall(function() name = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return name
end

local function isCriminal(plr)
    return getTeamName(plr):find("criminal") ~= nil
end

local function isInmateArrestable(plr)
    if not plr.Character then return false end
    for _, desc in ipairs(plr.Character:GetDescendants()) do
        if desc:IsA("TextLabel") or desc:IsA("TextButton") then
            local ok, text = pcall(function() return desc.Text end)
            if ok and text and text:find("\xF0\x9F\x94\x97") then return true end
        end
    end
    return false
end

local function hasForceField(plr)
    return plr.Character and plr.Character:FindFirstChildOfClass("ForceField") ~= nil
end

local function hasKeycard(plr)
    if not plr.Character then return false end
    for _, child in ipairs(plr.Character:GetChildren()) do
        if child:IsA("Tool") and child.Name:lower():find("key") then return true end
    end
    if plr:FindFirstChild("Backpack") then
        for _, child in ipairs(plr.Backpack:GetChildren()) do
            if child:IsA("Tool") and child.Name:lower():find("key") then return true end
        end
    end
    return false
end

local function isArrested(plr)
    if not plr.Parent then return true end
    local team = getTeamName(plr)
    if not (team:find("criminal") or team:find("inmate") or team:find("prisoner")) then return true end
    if plr.Character then
        for _, child in ipairs(plr.Character:GetDescendants()) do
            if child:IsA("BillboardGui") and child.Name ~= "NameTag" then return true end
        end
    end
    return false
end

---------- MOVEMENT ----------

local function getRoot(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getTorso(plr)
    return plr.Character and (plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso"))
end

local function tweenTo(targetCF)
    local root = getRoot(player.Character)
    if not root then return end
    pcall(function()
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Sit then hum.Sit = false end
    end)
    local tween = TweenService:Create(root, TweenInfo.new(tweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetCF})
    tween:Play()
    tween.Completed:Wait()
    pcall(function()
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)
end

---------- ARREST ----------

local function clickCenter()
    local cam = workspace.CurrentCamera
    local vs = cam.ViewportSize
    local x, y = vs.X / 2, vs.Y / 2
    pcall(function() VIM:SendMouseButtonEvent(x, y, 0, true, game, 1); task.wait(); VIM:SendMouseButtonEvent(x, y, 0, false, game, 1) end)
    pcall(function() if mousemoveabs and mouse1click then mousemoveabs(x, y); task.wait(); mouse1click() end end)
end

local function fireRemote(plr)
    pcall(function()
        local torso = getTorso(plr)
        if torso then ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso) end
    end)
end

---------- RESET ----------

local function resetCharacter()
    pcall(function()
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end)
    local ok, newChar = pcall(function() return player.CharacterAdded:Wait() end)
    if ok and newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

---------- MAIN LOOP ----------

task.spawn(function()
    while active do
        local targets = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == player or not plr.Character then continue end
            if isArrested(plr) or hasForceField(plr) then continue end

            local crim = isCriminal(plr)
            local inm = not crim and isInmateArrestable(plr)
            if not crim and not inm then continue end

            local root = getRoot(plr.Character)
            if not root then continue end

            local pri = 10
            if crim and hasKeycard(plr) then pri = 1
            elseif crim then pri = 2 end

            table.insert(targets, { player = plr, priority = pri, isCriminal = crim })
        end

        table.sort(targets, function(a, b) return a.priority < b.priority end)

        if #targets == 0 then
            task.wait(1)
            continue
        end

        detachAccessories()
        equipHandcuffs()

        for _, target in ipairs(targets) do
            if not active then break end
            if isArrested(target.player) or hasForceField(target.player) then continue end
            if not target.isCriminal and not isInmateArrestable(target.player) then continue end

            -- lock on to target
            lockOn(target.player)

            local arrested = false
            for attempt = 1, 15 do
                if not active then break end
                if isArrested(target.player) then arrested = true; break end

                local targetRoot = getRoot(target.player.Character)
                if not targetRoot then break end

                -- tween next to them
                tweenTo(targetRoot.CFrame + Vector3.new(3, 1, 0))

                -- click center screen (lockon keeps them centered)
                clickCenter()
                fireRemote(target.player)

                task.wait(0.15)
            end

            lockOff()

            if arrested then
                -- tween far away then reset
                local myRoot = getRoot(player.Character)
                if myRoot then
                    tweenTo(CFrame.new(myRoot.Position.X + 200, myRoot.Position.Y, myRoot.Position.Z + 200))
                end
                resetCharacter()
                detachAccessories()
                equipHandcuffs()
            end
        end

        task.wait(0.5)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    lockOff()
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end

task.delay(2, function()
    if _G.SixZeroHubRegisterSettings then
        _G.SixZeroHubRegisterSettings("[Spec]auto_arrest", {
            _title = "Auto Arrest",
            {
                name = "kill_bind",
                label = "Stop Keybind",
                type = "dropdown",
                default = "P",
                options = {"P", "K", "L", "M", "F5", "F6", "F7", "F8", "Backslash", "RightBracket", "Semicolon"},
                onChange = function(val)
                    local ok, key = pcall(function() return Enum.KeyCode[val] end)
                    if ok and key then killBind = key end
                end,
            },
        })
    end
end)
