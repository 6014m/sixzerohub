-- [Spec] Auto Arrest
-- Automatically arrests all criminals and inmates

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local connections = {}
local active = true
local ARREST_COOLDOWN = 0.5

local function getTargets()
    local targets = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local teamName = ""
            pcall(function() teamName = tostring(plr.Team and plr.Team.Name or ""):lower() end)
            if teamName:find("criminal") or teamName:find("inmate") or teamName:find("prisoner") then
                local torso = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
                if torso then
                    table.insert(targets, { player = plr, torso = torso, name = plr.Name })
                end
            end
        end
    end
    return targets
end

local function teleportTo(targetCFrame)
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    root.CFrame = targetCFrame
end

local function arrest(torso)
    local ok, err = pcall(function()
        ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso)
    end)
    return ok
end

local function respawn()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = 0
    end
    -- wait for respawn
    if not player.CharacterAdded:Wait() then return end
    task.wait(1)
    -- wait for humanoid to be ready
    local newChar = player.Character
    if newChar then
        newChar:WaitForChild("HumanoidRootPart", 5)
        task.wait(0.5)
    end
end

-- main loop
task.spawn(function()
    while active do
        local targets = getTargets()

        if #targets == 0 then
            task.wait(2)
            continue
        end

        for _, target in ipairs(targets) do
            if not active then break end

            -- check target still valid
            if not target.player.Parent then continue end
            if not target.torso or not target.torso.Parent then continue end

            -- check still on criminal/inmate team
            local teamName = ""
            pcall(function() teamName = tostring(target.player.Team and target.player.Team.Name or ""):lower() end)
            if not (teamName:find("criminal") or teamName:find("inmate") or teamName:find("prisoner")) then
                continue
            end

            -- teleport to target
            teleportTo(target.torso.CFrame * CFrame.new(0, 0, 3))
            task.wait(0.2)

            -- attempt arrest
            arrest(target.torso)
            task.wait(ARREST_COOLDOWN)

            -- respawn to reset cooldown
            respawn()
        end

        task.wait(1)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end
