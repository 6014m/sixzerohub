-- [Spec] Auto Arrest
-- Spam-arrests all criminals/inmates nearby, no teleporting

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local connections = {}
local active = true
local ARREST_DELAY = 0.15

local function isTarget(plr)
    if plr == player or not plr.Character then return false end
    local teamName = ""
    pcall(function() teamName = tostring(plr.Team and plr.Team.Name or ""):lower() end)
    return teamName:find("criminal") or teamName:find("inmate") or teamName:find("prisoner")
end

local function getTorso(plr)
    if not plr.Character then return nil end
    return plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
end

local conn = RunService.Heartbeat:Connect(function()
    if not active then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if not active then break end
        if isTarget(plr) then
            local torso = getTorso(plr)
            if torso then
                pcall(function()
                    ReplicatedStorage.Remotes.InteractWithItem:InvokeServer(torso)
                end)
            end
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Arrest", "[Spec]auto_arrest", cleanup, "spec")
end
