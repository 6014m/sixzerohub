-- [Spec] Evil Plate Game - Auto Crate
-- Automatically clicks/prompts airdrop crates when in range

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true
local CLICK_RANGE = 32
local clicked = false -- prevent spam within the same crate appearance

local conn = RunService.Heartbeat:Connect(function()
    if not active then return end
    local char = localPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local airdrop = workspace:FindFirstChild("Airdrop")
    if not airdrop then
        clicked = false -- reset when crate despawns
        return
    end

    -- find the closest BasePart in the airdrop to check distance
    local closestDist = math.huge
    for _, desc in ipairs(airdrop:GetDescendants()) do
        if desc:IsA("BasePart") then
            local dist = (desc.Position - root.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
            end
        end
    end
    if closestDist > CLICK_RANGE then return end
    if clicked then return end

    -- try ProximityPrompt first (modern games)
    for _, desc in ipairs(airdrop:GetDescendants()) do
        if desc:IsA("ProximityPrompt") then
            pcall(function()
                if fireproximityprompt then
                    fireproximityprompt(desc)
                    clicked = true
                end
            end)
            return
        end
    end

    -- try ClickDetector
    for _, desc in ipairs(airdrop:GetDescendants()) do
        if desc:IsA("ClickDetector") then
            pcall(function()
                if fireclickdetector then
                    fireclickdetector(desc)
                    clicked = true
                end
            end)
            return
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Crate", "[Spec]evil_plate_crate", cleanup, "spec")
end
