-- [Spec] Evil Plate Game - Auto Crate
-- Instantly fires airdrop prompts/click detectors
-- Searches workspace + ActiveEvents, reacts to new prompts via DescendantAdded

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true
local clickRange = 60

local function getRoot()
    local char = localPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function isAirdropDescendant(inst)
    local current = inst.Parent
    while current and current ~= workspace do
        local name = current.Name:lower()
        if name:find("airdrop") or name:find("crate") or name:find("supply") then
            return true
        end
        current = current.Parent
    end
    return false
end

local function tryFire(inst)
    if not active then return end
    local root = getRoot()
    if not root then return end

    if inst:IsA("ProximityPrompt") and fireproximityprompt then
        local adornee = inst.Parent
        if adornee and adornee:IsA("BasePart") then
            if (adornee.Position - root.Position).Magnitude > clickRange then return end
        end
        pcall(fireproximityprompt, inst, inst.HoldDuration + 0.1)
        pcall(fireproximityprompt, inst, 0)
    elseif inst:IsA("ClickDetector") and fireclickdetector then
        local adornee = inst.Parent
        if adornee and adornee:IsA("BasePart") then
            if (adornee.Position - root.Position).Magnitude > clickRange then return end
        end
        pcall(fireclickdetector, inst)
    end
end

-- Instant reaction: fire any new prompt/detector that appears in an airdrop
local addedConn = workspace.DescendantAdded:Connect(function(desc)
    if not active then return end
    if (desc:IsA("ProximityPrompt") or desc:IsA("ClickDetector")) and isAirdropDescendant(desc) then
        task.defer(function() tryFire(desc) end)
    end
end)
table.insert(connections, addedConn)

-- Heartbeat loop: continuously scan and retry firing
local conn = RunService.Heartbeat:Connect(function()
    if not active then return end
    local root = getRoot()
    if not root then return end

    local containers = { workspace }
    local ae = workspace:FindFirstChild("ActiveEvents")
    if ae then table.insert(containers, ae) end

    for _, container in ipairs(containers) do
        for _, child in ipairs(container:GetChildren()) do
            local name = child.Name:lower()
            if name:find("airdrop") or name:find("crate") or name:find("supply") then
                for _, desc in ipairs(child:GetDescendants()) do
                    if desc:IsA("ProximityPrompt") or desc:IsA("ClickDetector") then
                        tryFire(desc)
                    end
                end
            end
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Auto Crate", "[Spec]evil_plate_crate", cleanup, "spec")
end

task.delay(2, function()
    if _G.SixZeroHubRegisterSettings then
        _G.SixZeroHubRegisterSettings("[Spec]evil_plate_crate", {
            _title = "Auto Crate",
            {
                name = "click_range",
                label = "Click Distance",
                type = "slider",
                default = 60,
                min = 5,
                max = 100,
                step = 1,
                onChange = function(val)
                    clickRange = val
                end,
            },
        })
    end
end)
