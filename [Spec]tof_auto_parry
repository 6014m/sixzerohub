---------- Horizontal Density Burst ----------

local hdActive = false

local function burstHorizontalDensity()
	if hdActive or not myHRP or not myHum then return end
	hdActive = true

	local att = Instance.new("Attachment")
	att.Name = "HDParryAttach"
	att.Parent = myHRP

	local linVel = Instance.new("LinearVelocity")
	linVel.Name = "HDParryForce"
	linVel.Attachment0 = att
	linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Plane
	linVel.PrimaryTangentAxis = Vector3.new(1, 0, 0)
	linVel.SecondaryTangentAxis = Vector3.new(0, 0, 1)
	linVel.RelativeTo = Enum.ActuatorRelativeTo.World
	linVel.ForceLimitMode = Enum.ForceLimitMode.Magnitude
	linVel.MaxForce = math.huge
	linVel.PlaneVelocity = Vector2.new(0, 0)
	linVel.Parent = myHRP

	local hdConn
	hdConn = RunService.Heartbeat:Connect(function()
		if not myHRP or not myHum or not myHRP.Parent then return end
		local moveDir = myHum.MoveDirection
		local ws = myHum.WalkSpeed
		linVel.PlaneVelocity = Vector2.new(moveDir.X * ws, moveDir.Z * ws)
		local vel = myHRP.AssemblyLinearVelocity
		myHRP.AssemblyLinearVelocity = Vector3.new(
			moveDir.X * ws, vel.Y, moveDir.Z * ws
		)
	end)

	task.delay(1, function()
		hdConn:Disconnect()
		pcall(function() linVel:Destroy() end)
		pcall(function() att:Destroy() end)
		hdActive = false
	end)
end

---------- Core parry (as fast as possible) ----------

local function fireParry()
	if not parryTool or not myHum then
		cacheLocal()
		if not parryTool or not myHum then return false end
	end
	myHum:EquipTool(parryTool)
	parryTool:Activate()
	task.delay(0.15, function()
		pcall(function() myHum:UnequipTools() end)
	end)
	return true
end

-- Inline range/direction check — no function call overhead
local function shouldParry(theirHRP)
	if not myHRP then return false end
	-- Skip ragdolled players — they can't push
	local theirHum = theirHRP.Parent and theirHRP.Parent:FindFirstChildOfClass("Humanoid")
	if theirHum then
		local state = theirHum:GetState()
		if state == Enum.HumanoidStateType.Ragdoll or state == Enum.HumanoidStateType.FallingDown then
			return false
		end
	end
	local ox = myHRP.Position.X - theirHRP.Position.X
	local oy = myHRP.Position.Y - theirHRP.Position.Y
	local oz = myHRP.Position.Z - theirHRP.Position.Z
	local distSq = ox*ox + oy*oy + oz*oz

	local vel = theirHRP.AssemblyLinearVelocity
	local vMag = vel.Magnitude
	local maxRange = sensitivity.range
	if vMag > 1 then
		local dist = math.sqrt(distSq)
		local dirX, dirZ = ox / dist, oz / dist
		local dot = vel.X * dirX + vel.Z * dirZ
		if dot > 0.3 * vMag then
			maxRange = sensitivity.rangeApproach
		end
	end

	if distSq > maxRange * maxRange then return false end

	local look = theirHRP.CFrame.LookVector
	local dist = math.sqrt(distSq)
	return (look.X * ox + look.Y * oy + look.Z * oz) / dist >= sensitivity.dirThreshold
end

local function doParry(player, theirHRP)
	local now = tick()
	if now - recentParry < 0.3 then return end
	-- Respect actual game cooldown from UI
	if isParryOnCooldown() then return end
	if not shouldParry(theirHRP) then return end
	-- Record conditions at parry time
	local ox = myHRP.Position.X - theirHRP.Position.X
	local oy = myHRP.Position.Y - theirHRP.Position.Y
	local oz = myHRP.Position.Z - theirHRP.Position.Z
	lastParryDist = math.sqrt(ox*ox + oy*oy + oz*oz)
	local look = theirHRP.CFrame.LookVector
	lastParryDir = (look.X * ox + look.Y * oy + look.Z * oz) / lastParryDist

	recentParry = now
	burstHorizontalDensity()
	if fireParry() then
		flashLabel.Text = "PARRIED " .. player.Name .. string.format(" [%.0f studs]", lastParryDist)
		flashLabel.Visible = true
		task.delay(1.5, function() flashLabel.Visible = false end)

		parryPending = true
		task.delay(2, function()
			if parryPending then
				parryPending = false
				onMissfire()
			end
		end)
	end
end

