-- Adaptive sensitivity (saved to file)
local sensitivity = {
	range = 20,
	rangeApproach = 30,
	closeRange = 5,
	dirThreshold = 0, -- 0 = facing toward, negative = even back-turned
	missfires = 0,
	hits = 0,
	misses = 0,
}

-- Load saved sensitivity
pcall(function()
	if isfile and isfile(SETTINGS_FILE) then
		local saved = HttpService:JSONDecode(readfile(SETTINGS_FILE))
		for k, v in pairs(saved) do
			if sensitivity[k] ~= nil then sensitivity[k] = v end
		end
	end
end)

local function saveSensitivity()
	pcall(function()
		if writefile then
			writefile(SETTINGS_FILE, HttpService:JSONEncode(sensitivity))
		end
	end)
end

-- Tuning: tighten on REPEATED missfires, loosen on miss
local consecutiveMissfires = 0

local function onMissfire()
	sensitivity.missfires = sensitivity.missfires + 1
	consecutiveMissfires = consecutiveMissfires + 1
	-- Only tighten after 3+ consecutive missfires
	if consecutiveMissfires >= 3 then
		-- Use recorded conditions to tune precisely
		-- If missfires keep happening at long range, tighten range
		if lastParryDist > sensitivity.range * 0.7 then
			sensitivity.range = math.max(8, sensitivity.range - 1)
			sensitivity.rangeApproach = math.max(12, sensitivity.rangeApproach - 1)
		end
		-- If missfires happen with low direction dot, tighten direction
		if lastParryDir < 0.3 then
			sensitivity.dirThreshold = math.min(0.5, sensitivity.dirThreshold + 0.05)
		end
		consecutiveMissfires = 0
		saveSensitivity()
	end
	if sensLabel then
		sensLabel.Text = string.format("Missfire %d/3 | D:%.0f Dir:%.2f", consecutiveMissfires, lastParryDist, lastParryDir)
		sensLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
	end
end

local function onConfirmedHit()
	sensitivity.hits = sensitivity.hits + 1
	consecutiveMissfires = 0 -- reset missfire streak on confirmed hit
	saveSensitivity()
	if sensLabel then
		sensLabel.Text = "Parried! | R:" .. math.floor(sensitivity.range) .. " H:" .. sensitivity.hits
		sensLabel.TextColor3 = Color3.fromRGB(87, 242, 135)
	end
end

local function onMiss()
	sensitivity.misses = sensitivity.misses + 1
	consecutiveMissfires = 0

	-- Find how far the nearest player with Push was when we got hit
	local nearestDist = math.huge
	local nearestDir = 0
	if myHRP then
		for _, p in ipairs(playerCache) do
			local char = p.Character
			if char and char:FindFirstChild("Push") then
				local hrp = char:FindFirstChild("HumanoidRootPart")
				if hrp then
					local d = (myHRP.Position - hrp.Position).Magnitude
					if d < nearestDist then
						nearestDist = d
						local offset = (myHRP.Position - hrp.Position).Unit
						nearestDir = hrp.CFrame.LookVector:Dot(offset)
					end
				end
			end
		end
	end

	-- Loosen based on how far the attacker was
	if nearestDist < math.huge then
		-- They were beyond our range — need to expand
		if nearestDist > sensitivity.range then
			sensitivity.range = math.min(35, nearestDist + 3)
			sensitivity.rangeApproach = math.min(45, nearestDist + 8)
		end
		-- They were facing away from our threshold — need to relax direction
		if nearestDir < sensitivity.dirThreshold then
			sensitivity.dirThreshold = math.max(-0.3, nearestDir - 0.1)
		end
	else
		-- Couldn't find attacker, loosen generally
		sensitivity.range = math.min(35, sensitivity.range + 2)
		sensitivity.rangeApproach = math.min(45, sensitivity.rangeApproach + 3)
		sensitivity.dirThreshold = math.max(-0.3, sensitivity.dirThreshold - 0.1)
	end
	sensitivity.closeRange = math.min(10, sensitivity.closeRange + 0.5)
	saveSensitivity()

	if sensLabel then
		sensLabel.Text = string.format("MISSED! Nearest:%.0f Dir:%.2f | R:%.0f", nearestDist, nearestDir, sensitivity.range)
		sensLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
end

