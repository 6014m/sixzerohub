---------- FEEDBACK: PushStuff confirms hit / miss ----------

local function isMe(name)
	return name == lp.Name or name == lp.DisplayName or (myChar and name == myChar.Name)
end

local function watchPushStuffFeedback(pushStuff)
	local c = pushStuff.ChildAdded:Connect(function(child)
		if isMe(child.Name) then
			-- We got pushed
			if parryPending then
				parryPending = false
				onConfirmedHit()
			elseif not isParryOnCooldown() then
				-- Only a miss if parry was available
				onMiss()
			end
		end
	end)
	table.insert(connections, c)

	local c2 = pushStuff.DescendantAdded:Connect(function(desc)
		local current = desc
		for i = 1, 4 do
			if not current then break end
			if isMe(current.Name) then
				if parryPending then
					parryPending = false
					onConfirmedHit()
				elseif not isParryOnCooldown() then
					onMiss()
				end
				return
			end
			current = current.Parent
		end
	end)
	table.insert(connections, c2)
end

local ps = workspace:FindFirstChild("PushStuff")
if ps then watchPushStuffFeedback(ps) end
table.insert(connections, workspace.ChildAdded:Connect(function(child)
	if child.Name == "PushStuff" then watchPushStuffFeedback(child) end
end))

---------- FEEDBACK: Parry cooldown from UI ----------

local function isParryOnCooldown()
	local onCD = false
	pcall(function()
		local current = playerGui
		for _, name in ipairs(PARRY_CD_PATH) do
			current = current:FindFirstChild(name)
			if not current then return end
		end
		onCD = current.AbsoluteSize.X > 1
	end)
	return onCD
end

---------- FEEDBACK: Track other players' push cooldowns via animation ----------

local function onEnemyPushAnim(player)
	-- They just pushed — mark them on cooldown so we don't react to stale tool equips
	pushCooldownPlayers[player] = tick() + 5 -- assume ~5s push cooldown, self-adjusts
end

local function isEnemyOnPushCooldown(player)
	local cd = pushCooldownPlayers[player]
	return cd and tick() < cd
end

---------- FEEDBACK: Ragdoll detection ----------
-- Only counts as a miss if we ragdoll AND we didn't recently parry
-- (ragdoll after parry = they got parried, that's a success)

local function hookRagdoll(char)
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	local c = hum.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Ragdoll
			or newState == Enum.HumanoidStateType.FallingDown then
			-- Only a miss if we haven't parried recently AND parry wasn't on cooldown
			if tick() - recentParry > 3 and not isParryOnCooldown() then
				onMiss()
			end
		end
	end)
	table.insert(connections, c)
end

if myChar then hookRagdoll(myChar) end
lp.CharacterAdded:Connect(function(char)
	task.wait(0.5)
	hookRagdoll(char)
end)

---------- Auto Delete Ropes ----------

local function isAttachedToMe(rope)
	if not myChar then return false end
	local a0, a1 = rope.Attachment0, rope.Attachment1
	return (a0 and a0:IsDescendantOf(myChar)) or (a1 and a1:IsDescendantOf(myChar))
end

local function checkRope(obj)
	if obj:IsA("RopeConstraint") or obj:IsA("RodConstraint") then
		pcall(function() if isAttachedToMe(obj) then obj:Destroy() end end)
	end
end

for _, v in ipairs(workspace:GetDescendants()) do checkRope(v) end
workspace.DescendantAdded:Connect(checkRope)

