---------- Push Distance Logger ----------

local LOG_FILE = "AutoParry_distances.txt"
local DATA_FILE = "AutoParry_data.json"
local HttpService = game:GetService("HttpService")

-- Persistent learned data
local learnedData = { pushes = {}, parries = {}, ranges = {}, methods = {} }
pcall(function()
	if isfile and isfile(DATA_FILE) then
		local d = HttpService:JSONDecode(readfile(DATA_FILE))
		if type(d) == "table" then learnedData = d end
	end
end)

local function saveData()
	pcall(function()
		if writefile then writefile(DATA_FILE, HttpService:JSONEncode(learnedData)) end
	end)
end

local function getOrientation(fromHRP, toHRP)
	-- Where was the attacker relative to us?
	local dir = (fromHRP.Position - toHRP.Position).Unit
	local look = toHRP.CFrame.LookVector
	local right = toHRP.CFrame.RightVector
	local fDot = look.X * dir.X + look.Z * dir.Z -- front/back
	local rDot = right.X * dir.X + right.Z * dir.Z -- left/right

	local facing = fDot > 0.5 and "FRONT" or fDot < -0.5 and "BEHIND" or "SIDE"
	local side = rDot > 0.3 and "-RIGHT" or rDot < -0.3 and "-LEFT" or ""
	return facing .. side, fDot, rDot
end

local function logDistance(text, data)
	warn("[AutoParry] " .. text)
	pcall(function()
		if appendfile then
			appendfile(LOG_FILE, text .. "\n")
		elseif writefile and isfile then
			local old = isfile(LOG_FILE) and readfile(LOG_FILE) or ""
			writefile(LOG_FILE, old .. text .. "\n")
		end
	end)
	-- Save structured data
	if data then
		if data.type == "pushed" then
			learnedData.pushes[#learnedData.pushes + 1] = data
			-- Track max push range seen
			if not learnedData.ranges.maxPushDist or data.dist > learnedData.ranges.maxPushDist then
				learnedData.ranges.maxPushDist = data.dist
			end
		elseif data.type == "parried" then
			learnedData.parries[#learnedData.parries + 1] = data
			if not learnedData.ranges.maxParryDist or data.dist > learnedData.ranges.maxParryDist then
				learnedData.ranges.maxParryDist = data.dist
			end
		end
		-- Track which detection methods fire
		if data.method then
			learnedData.methods[data.method] = (learnedData.methods[data.method] or 0) + 1
		end
		saveData()
	end
end

-- Detect ANY form of ragdoll/push on a player
local function watchPushEffects(player, char)
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	local hrp = char:WaitForChild("HumanoidRootPart", 5)
	if not hrp then return end
	local isMe = player == lp

	local function findNearest()
		local nearest, nd = nil, math.huge
		for _, p in ipairs(playerCache) do
			local pc = p.Character; local ph = pc and pc:FindFirstChild("HumanoidRootPart")
			if ph and myHRP then
				local d = (myHRP.Position - ph.Position).Magnitude
				if d < nd then nd = d; nearest = p end
			end
		end
		return nearest, nd
	end

	local function logEvent(method)
		local dist = myHRP and hrp and (myHRP.Position - hrp.Position).Magnitude or 0
		local since = tick() - recentParry
		local orient, fDot, rDot = "", 0, 0

		if isMe then
			local nearest, nd = findNearest()
			local nName = nearest and nearest.Name or "?"
			local nHRP = nearest and nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart")
			if nHRP and myHRP then
				orient, fDot, rDot = getOrientation(nHRP, myHRP)
			end
			local text = string.format("%s | PUSHED by %s at %.1f studs | %s (f:%.2f r:%.2f) | parry %.2fs ago",
				method, nName, nd, orient, fDot, rDot, since)
			logDistance(text, {type="pushed", method=method, dist=nd, orient=orient, fDot=fDot, rDot=rDot, since=since, attacker=nName})
		else
			if myHRP and hrp then
				orient, fDot, rDot = getOrientation(hrp, myHRP)
			end
			local text = string.format("%s | %s at %.1f studs | %s (f:%.2f r:%.2f) | parry %.2fs ago",
				method, player.Name, dist, orient, fDot, rDot, since)
			local tp = since < 2 and "parried" or "other"
			logDistance(text, {type=tp, method=method, dist=dist, orient=orient, fDot=fDot, rDot=rDot, since=since, target=player.Name})
		end
	end

	-- A: Standard humanoid state change
	local c1 = hum.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Ragdoll
			or newState == Enum.HumanoidStateType.FallingDown
			or newState == Enum.HumanoidStateType.Physics then
			logEvent("STATE:" .. newState.Name)
		end
	end)
	table.insert(connections, c1)

	-- B: PlatformStand
	local c2 = hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
		if hum.PlatformStand then logEvent("PLATFORMSTAND") end
	end)
	table.insert(connections, c2)

	-- C: Sit
	local c3 = hum:GetPropertyChangedSignal("Sit"):Connect(function()
		if hum.Sit then logEvent("SIT") end
	end)
	table.insert(connections, c3)

	-- D: Velocity spike
	local lastVel = Vector3.zero
	local spikeDebounce = 0
	local c4 = RunService.Heartbeat:Connect(function()
		if not hrp.Parent then return end
		local vel = hrp.AssemblyLinearVelocity
		local hVel = Vector3.new(vel.X, 0, vel.Z).Magnitude
		local lastH = Vector3.new(lastVel.X, 0, lastVel.Z).Magnitude
		local spike = hVel - lastH
		lastVel = vel
		if spike > 50 and hVel > 30 and tick() - spikeDebounce > 1 then
			spikeDebounce = tick()
			logEvent("VELOCITY:" .. math.floor(hVel))
		end
	end)
	table.insert(connections, c4)

	-- E: Motor6D removed
	local c5 = char.DescendantRemoving:Connect(function(desc)
		if desc:IsA("Motor6D") then logEvent("JOINT_REMOVED:" .. desc.Name) end
	end)
	table.insert(connections, c5)

	-- F: BallSocketConstraint added
	local c6 = char.DescendantAdded:Connect(function(desc)
		if desc:IsA("BallSocketConstraint") then logEvent("BALLSOCKET_ADDED") end
	end)
	table.insert(connections, c6)
end

-- Hook all players (including self)
for _, p in ipairs(Players:GetPlayers()) do
	if p.Character then watchPushEffects(p, p.Character) end
	p.CharacterAdded:Connect(function(char) task.wait(0.5); watchPushEffects(p, char) end)
end
Players.PlayerAdded:Connect(function(p)
	if p.Character then watchPushEffects(p, p.Character) end
	p.CharacterAdded:Connect(function(char) task.wait(0.5); watchPushEffects(p, char) end)
end)

---------- Auto Delete Ropes ----------

local function isAttachedToMe(rope)
	if not myChar then return false end
	local a0, a1 = rope.Attachment0, rope.Attachment1
	return (a0 and a0:IsDescendantOf(myChar)) or (a1 and a1:IsDescendantOf(myChar))
end

local function checkRope(obj)
	if obj:IsA("RopeConstraint") or obj:IsA("RodConstraint") then
		pcall(function() if isAttachedToMe(obj) then obj:Destroy() end end)
	end
end

for _, v in ipairs(workspace:GetDescendants()) do checkRope(v) end
workspace.DescendantAdded:Connect(checkRope)

---------- Handle Blocker ----------

local blockedHandles = {}

local function blockHandle(handle)
	if not handle:IsA("BasePart") then return end
	if blockedHandles[handle] then return end
	-- Skip handles inside backpacks/tools that aren't in workspace characters
	local tool = handle.Parent
	if tool and tool:IsA("Tool") and tool.Parent and tool.Parent:IsA("Backpack") then return end

	blockedHandles[handle] = true

	-- Yeet it far away — unanchored parts give us network ownership
	pcall(function()
		handle.CFrame = CFrame.new(0, -500, 0)
		handle.AssemblyLinearVelocity = Vector3.new(0, -1000, 0)
		handle.CanCollide = false
	end)

	-- If handle is on me, full density lock
	cacheLocal()
	if myChar and handle:IsDescendantOf(myChar) then
		burstFullDensity()
		flashLabel.Text = "HANDLE ON ME — FD"
		flashLabel.Visible = true
		task.delay(1.5, function() flashLabel.Visible = false end)
	end
end

local function checkHandle(obj)
	if obj.Name == "Handle" and obj:IsA("BasePart") then
		blockHandle(obj)
	end
end

for _, v in ipairs(workspace:GetDescendants()) do checkHandle(v) end
workspace.DescendantAdded:Connect(checkHandle)
