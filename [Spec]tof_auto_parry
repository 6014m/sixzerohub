---------- METHOD 1: AnimationPlayed + Tool equip per player ----------

local function watchCharacter(player, char)
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 2)
		if animator then
			local c = animator.AnimationPlayed:Connect(function(track)
				if track.Animation and track.Animation.AnimationId == PUSH_ANIM_ID then
					local hrp = char:FindFirstChild("HumanoidRootPart")
					if hrp then doParryPlayer(player, hrp) end
				end
			end)
			table.insert(connections, c)
		end
	end

	local c = char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") and child.Name == "Push" then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then doParryPlayer(player, hrp) end
		end
	end)
	table.insert(connections, c)
end

local function watchPlayer(player)
	if player == lp then return end
	if player.Character then watchCharacter(player, player.Character) end
	local c = player.CharacterAdded:Connect(function(char)
		task.wait(0.3)
		watchCharacter(player, char)
	end)
	table.insert(connections, c)
end

for _, p in ipairs(Players:GetPlayers()) do watchPlayer(p) end
Players.PlayerAdded:Connect(watchPlayer)

---------- METHOD 2: RenderStepped frame scan ----------

local playerCache = {}

local function rebuildCache()
	playerCache = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp then playerCache[#playerCache+1] = p end
	end
end

rebuildCache()
Players.PlayerAdded:Connect(rebuildCache)
Players.PlayerRemoving:Connect(rebuildCache)

RunService.RenderStepped:Connect(function()
	if tick() - recentParry < 0.5 then return end
	if not myHRP then cacheLocal(); return end
	for i = 1, #playerCache do
		local p = playerCache[i]
		local char = p.Character
		if char then
			local push = char:FindFirstChild("Push")
			if push and push:IsA("Tool") then
				local hrp = char:FindFirstChild("HumanoidRootPart")
				if hrp then doParryPlayer(p, hrp); return end
			end
		end
	end
end)

---------- METHOD 3: PushStuff folder ----------

local function isMe(name)
	return name == lp.Name or name == lp.DisplayName or (myChar and name == myChar.Name)
end

local function watchPushStuff(pushStuff)
	local c = pushStuff.DescendantAdded:Connect(function(desc)
		local current = desc
		for i = 1, 4 do
			if not current then break end
			if isMe(current.Name) then doParryDirect("PushStuff"); return end
			current = current.Parent
		end
		if desc:IsA("BasePart") and myHRP then
			pcall(function()
				if (desc.Position - myHRP.Position).Magnitude < 10 then
					doParryDirect("PushStuff")
				end
			end)
		end
	end)
	table.insert(connections, c)

	local c2 = pushStuff.ChildAdded:Connect(function(child)
		if isMe(child.Name) then doParryDirect("PushStuff") end
	end)
	table.insert(connections, c2)
end

local ps = workspace:FindFirstChild("PushStuff")
if ps then watchPushStuff(ps) end
table.insert(connections, workspace.ChildAdded:Connect(function(child)
	if child.Name == "PushStuff" then watchPushStuff(child) end
end))

---------- METHOD 4: Workspace.Model.Plane ----------

local function watchModelPlane()
	local model = workspace:FindFirstChild("Model")
	if not model then return end
	if model:FindFirstChild("Plane") then doParryDirect("Plane") end
	local c = model.ChildAdded:Connect(function(child)
		if child.Name == "Plane" then doParryDirect("Plane") end
	end)
	table.insert(connections, c)
end

pcall(watchModelPlane)
table.insert(connections, workspace.ChildAdded:Connect(function(child)
	if child.Name == "Model" then task.wait(0.1); watchModelPlane() end
end))

---------- METHOD 5: Touched on character parts ----------

local touchConns = {}

local function hookTouched(char)
	for _, c in ipairs(touchConns) do pcall(function() c:Disconnect() end) end
	touchConns = {}

	local hrp = char:WaitForChild("HumanoidRootPart", 5)
	if not hrp then return end

	for _, part in ipairs(char:GetChildren()) do
		if part:IsA("BasePart") then
			local c = part.Touched:Connect(function(hit)
				if not hit or not hit.Parent then return end
				if hit:IsDescendantOf(char) then return end
				local name = hit.Name:lower()
				if name:find("push") or name:find("hitbox") or name:find("plane")
					or name:find("collision") or name:find("attack") then
					doParryDirect("Touch:" .. hit.Name)
				end
			end)
			touchConns[#touchConns+1] = c
		end
	end
end

if myChar then hookTouched(myChar) end
lp.CharacterAdded:Connect(function(char)
	task.wait(0.5)
	hookTouched(char)
end)

---------- METHOD 6: Velocity spike (reactive parry) ----------

local lastVel = Vector3.zero
local velSpikeCount = 0

RunService.Heartbeat:Connect(function()
	if not myHRP then return end
	local vel = myHRP.AssemblyLinearVelocity
	local hVel = Vector3.new(vel.X, 0, vel.Z)
	local lastH = Vector3.new(lastVel.X, 0, lastVel.Z)
	local spike = (hVel - lastH).Magnitude
	lastVel = vel

	-- Sudden horizontal velocity spike = probably got pushed
	if spike > 40 and hVel.Magnitude > 25 then
		velSpikeCount = velSpikeCount + 1
		if velSpikeCount >= 2 then
			doParryDirect("VelSpike")
			velSpikeCount = 0
		end
	else
		velSpikeCount = 0
	end
end)

---------- Auto Delete Ropes ----------

local function isAttachedToMe(rope)
	if not myChar then return false end
	local a0, a1 = rope.Attachment0, rope.Attachment1
	return (a0 and a0:IsDescendantOf(myChar)) or (a1 and a1:IsDescendantOf(myChar))
end

local function checkRope(obj)
	if obj:IsA("RopeConstraint") or obj:IsA("RodConstraint") then
		pcall(function()
			if isAttachedToMe(obj) then obj:Destroy() end
		end)
	end
end

for _, v in ipairs(workspace:GetDescendants()) do checkRope(v) end
workspace.DescendantAdded:Connect(checkRope)

-- SixZeroHub cleanup
if _G.SixZeroHubRegister then
	_G.SixZeroHubRegister("Auto Parry", "[Spec]tof_auto_parry", function()
		for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
		pcall(function() gui:Destroy() end)
	end, "spec")
end
