-- Auto Parry — maximum speed
-- AnimationPlayed + Tool equip + RenderStepped + Heartbeat + Backpack watch

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer
local playerGui = lp:WaitForChild("PlayerGui")

local RANGE = 20
local RANGE_APPROACHING = 30
local CLOSE_RANGE = 5
local PUSH_ANIM_ID = "rbxassetid://134933487900882"

local connections = {}
local recentParry = 0

---------- Pre-cached refs ----------

local myChar, myHRP, myHum, myBackpack, parryTool

local function cacheLocal()
	myChar = lp.Character
	myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
	myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")
	myBackpack = lp:FindFirstChild("Backpack")
	parryTool = myBackpack and myBackpack:FindFirstChild("Parry")
end

cacheLocal()
lp.CharacterAdded:Connect(function() task.wait(0.2); cacheLocal() end)

task.spawn(function()
	while true do
		myBackpack = lp:FindFirstChild("Backpack")
		parryTool = myBackpack and myBackpack:FindFirstChild("Parry")
		task.wait(0.3)
	end
end)

---------- Player cache ----------

local playerCache = {}

local function rebuildPlayerCache()
	playerCache = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp then playerCache[#playerCache+1] = p end
	end
end

rebuildPlayerCache()
Players.PlayerAdded:Connect(rebuildPlayerCache)
Players.PlayerRemoving:Connect(rebuildPlayerCache)

---------- Density Bursts ----------

local hdActive = false

local function burstHorizontalDensity()
	if hdActive or not myHRP or not myHum then return end
	hdActive = true

	local att = Instance.new("Attachment")
	att.Name = "HDParryAttach"
	att.Parent = myHRP

	local linVel = Instance.new("LinearVelocity")
	linVel.Name = "HDParryForce"
	linVel.Attachment0 = att
	linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Plane
	linVel.PrimaryTangentAxis = Vector3.new(1, 0, 0)
	linVel.SecondaryTangentAxis = Vector3.new(0, 0, 1)
	linVel.RelativeTo = Enum.ActuatorRelativeTo.World
	linVel.ForceLimitMode = Enum.ForceLimitMode.Magnitude
	linVel.MaxForce = math.huge
	linVel.PlaneVelocity = Vector2.new(0, 0)
	linVel.Parent = myHRP

	local hdConn
	hdConn = RunService.Heartbeat:Connect(function()
		if not myHRP or not myHum or not myHRP.Parent then return end
		local moveDir = myHum.MoveDirection
		local ws = myHum.WalkSpeed
		linVel.PlaneVelocity = Vector2.new(moveDir.X * ws, moveDir.Z * ws)
		local vel = myHRP.AssemblyLinearVelocity
		local pushX = vel.X - (moveDir.X * ws)
		local pushZ = vel.Z - (moveDir.Z * ws)
		myHRP.AssemblyLinearVelocity = Vector3.new(vel.X - pushX, vel.Y, vel.Z - pushZ)
	end)

	task.delay(1, function()
		hdConn:Disconnect()
		pcall(function() linVel:Destroy() end)
		pcall(function() att:Destroy() end)
		hdActive = false
	end)
end

local fdActive = false

local function burstFullDensity()
	if fdActive or not myHRP or not myHum then return end
	fdActive = true

	local att = Instance.new("Attachment")
	att.Name = "FDAttach"
	att.Parent = myHRP

	local linVel = Instance.new("LinearVelocity")
	linVel.Name = "FDForce"
	linVel.Attachment0 = att
	linVel.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
	linVel.RelativeTo = Enum.ActuatorRelativeTo.World
	linVel.ForceLimitMode = Enum.ForceLimitMode.Magnitude
	linVel.MaxForce = math.huge
	linVel.VectorVelocity = Vector3.zero
	linVel.Parent = myHRP

	local fdConn
	fdConn = RunService.Heartbeat:Connect(function()
		if not myHRP or not myHum or not myHRP.Parent then return end
		local moveDir = myHum.MoveDirection
		local ws = myHum.WalkSpeed
		linVel.VectorVelocity = Vector3.new(moveDir.X * ws, 0, moveDir.Z * ws)
		myHRP.AssemblyLinearVelocity = Vector3.new(moveDir.X * ws, myHRP.AssemblyLinearVelocity.Y, moveDir.Z * ws)
	end)

	task.delay(1, function()
		fdConn:Disconnect()
		pcall(function() linVel:Destroy() end)
		pcall(function() att:Destroy() end)
		fdActive = false
	end)
end

---------- Core parry ----------

local function fireParry()
	if not parryTool or not myHum then
		cacheLocal()
		if not parryTool or not myHum then return false end
	end
	myHum:EquipTool(parryTool)
	parryTool:Activate()
	task.delay(0.15, function()
		pcall(function() myHum:UnequipTools() end)
	end)
	return true
end

local function shouldParry(theirHRP)
	if not myHRP then return false end
	-- Skip ragdolled or 1hp players
	local theirHum = theirHRP.Parent and theirHRP.Parent:FindFirstChildOfClass("Humanoid")
	if theirHum then
		if theirHum.Health <= 1 then return false end
		local state = theirHum:GetState()
		if state == Enum.HumanoidStateType.Ragdoll or state == Enum.HumanoidStateType.FallingDown then
			return false
		end
	end
	local ox = myHRP.Position.X - theirHRP.Position.X
	local oy = myHRP.Position.Y - theirHRP.Position.Y
	local oz = myHRP.Position.Z - theirHRP.Position.Z
	local distSq = ox*ox + oy*oy + oz*oz

	if distSq <= CLOSE_RANGE * CLOSE_RANGE then return true end

	local vel = theirHRP.AssemblyLinearVelocity
	local vMag = vel.Magnitude
	local maxRange = RANGE
	if vMag > 1 then
		local dist = math.sqrt(distSq)
		local dirX, dirZ = ox / dist, oz / dist
		local dot = vel.X * dirX + vel.Z * dirZ
		if dot > 0.3 * vMag then
			maxRange = RANGE_APPROACHING
		end
	end

	if distSq > maxRange * maxRange then return false end

	local look = theirHRP.CFrame.LookVector
	local dist = math.sqrt(distSq)
	return (look.X * ox + look.Y * oy + look.Z * oz) / dist >= 0
end

local function doParry(player, theirHRP)
	local now = tick()
	if now - recentParry < 0.5 then return end
	if not shouldParry(theirHRP) then return end
	recentParry = now
	burstHorizontalDensity()
	if fireParry() then
		flashLabel.Text = "PARRIED " .. player.Name
		flashLabel.Visible = true
		task.delay(1.5, function() flashLabel.Visible = false end)
	end
end

