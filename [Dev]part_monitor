---------- DRAGGABLE ----------

do
    local dragging, dragStart, frameStart
    header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            frameStart = main.Position
        end
    end)
    header.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)
end

---------- HELPERS ----------

local function getFullPath(inst)
    local parts = {}
    local current = inst
    while current and current ~= game do
        table.insert(parts, 1, current.Name)
        current = current.Parent
    end
    return table.concat(parts, ".")
end

local function isPlayerDescendant(inst)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and inst:IsDescendantOf(plr.Character) then
            return true
        end
    end
    if inst:IsDescendantOf(playerGui) then return true end
    local inCoreGui = false
    pcall(function()
        inCoreGui = inst:IsDescendantOf(game:GetService("CoreGui"))
    end)
    return inCoreGui
end

local entryCount = 0

local function addEntry(inst)
    if paused then return end

    entryCount = entryCount + 1
    local idx = entryCount

    local row = Instance.new("Frame")
    row.Name = "Entry_" .. idx
    row.Size = UDim2.new(1, 0, 0, 22)
    row.BackgroundColor3 = (idx % 2 == 0) and COLORS.rowAlt or COLORS.row
    row.BackgroundTransparency = 0.3
    row.BorderSizePixel = 0
    row.LayoutOrder = -idx
    row.Parent = scroll

    local typeLbl = Instance.new("TextLabel")
    typeLbl.Size = UDim2.new(0, 80, 1, 0)
    typeLbl.BackgroundTransparency = 1
    typeLbl.Text = inst.ClassName
    typeLbl.TextColor3 = COLORS.type
    typeLbl.TextSize = 11
    typeLbl.Font = Enum.Font.GothamBold
    typeLbl.TextXAlignment = Enum.TextXAlignment.Left
    typeLbl.TextTruncate = Enum.TextTruncate.AtEnd
    typeLbl.Parent = row

    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size = UDim2.new(0, 100, 1, 0)
    nameLbl.Position = UDim2.new(0, 82, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = inst.Name
    nameLbl.TextColor3 = COLORS.text
    nameLbl.TextSize = 11
    nameLbl.Font = Enum.Font.Gotham
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.TextTruncate = Enum.TextTruncate.AtEnd
    nameLbl.Parent = row

    local fullPath = getFullPath(inst)

    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 22, 0, 18)
    copyBtn.Position = UDim2.new(0, 184, 0, 2)
    copyBtn.BackgroundColor3 = COLORS.row
    copyBtn.BorderSizePixel = 0
    copyBtn.Text = "\xF0\x9F\x93\x8B"
    copyBtn.TextSize = 10
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.TextColor3 = COLORS.muted
    copyBtn.AutoButtonColor = false
    copyBtn.Parent = row
    Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 3)

    copyBtn.MouseButton1Click:Connect(function()
        pcall(function()
            if setclipboard then
                setclipboard(fullPath)
            elseif toclipboard then
                toclipboard(fullPath)
            end
        end)
        copyBtn.Text = "\xE2\x9C\x93"
        copyBtn.TextColor3 = Color3.fromRGB(87, 242, 135)
        task.delay(1, function()
            if copyBtn and copyBtn.Parent then
                copyBtn.Text = "\xF0\x9F\x93\x8B"
                copyBtn.TextColor3 = COLORS.muted
            end
        end)
    end)

    local pathLbl = Instance.new("TextLabel")
    pathLbl.Size = UDim2.new(1, -212, 1, 0)
    pathLbl.Position = UDim2.new(0, 210, 0, 0)
    pathLbl.BackgroundTransparency = 1
    pathLbl.Text = fullPath
    pathLbl.TextColor3 = COLORS.path
    pathLbl.TextSize = 11
    pathLbl.Font = Enum.Font.Gotham
    pathLbl.TextXAlignment = Enum.TextXAlignment.Left
    pathLbl.TextTruncate = Enum.TextTruncate.AtEnd
    pathLbl.Parent = row

    table.insert(entries, row)
    if #entries > MAX_ENTRIES then
        local old = table.remove(entries, 1)
        old:Destroy()
    end

    countLbl.Text = tostring(#entries)
end

---------- MONITOR ----------

local function startMonitoring()
    local conn = workspace.DescendantAdded:Connect(function(desc)
        if desc:IsA("BasePart") and not isPlayerDescendant(desc) then
            addEntry(desc)
        end
    end)
    table.insert(connections, conn)
end

startMonitoring()

---------- BUTTON EVENTS ----------

pauseBtn.MouseButton1Click:Connect(function()
    paused = not paused
    pauseBtn.Text = paused and "Resume" or "Pause"
    pauseBtn.BackgroundColor3 = paused and Color3.fromRGB(200, 60, 60) or COLORS.row
end)

clearBtn.MouseButton1Click:Connect(function()
    for _, row in ipairs(entries) do
        row:Destroy()
    end
    entries = {}
    entryCount = 0
    countLbl.Text = "0"
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    for _, conn in ipairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
    pcall(function() gui:Destroy() end)
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Part Monitor", "[Dev]part_monitor", cleanup, "dev")
end
