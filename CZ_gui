cmdBar:GetPropertyChangedSignal("Text"):Connect(function()
    local text = cmdBar.Text:lower():gsub("^%s+", "")
    if text == "" then
        autocompleteLabel.Visible = false
        currentSuggestion = ""
        return
    end
    -- find best matching command
    for _, cmd in ipairs(cmds) do
        if cmd.NAME:sub(1, #text) == text then
            currentSuggestion = cmd.NAME
            autocompleteLabel.Text = "  Tab: " .. cmd.NAME .. (cmd.DESC ~= "" and ("  —  " .. cmd.DESC) or "")
            autocompleteLabel.Visible = true
            return
        end
        for _, a in ipairs(cmd.ALIAS) do
            if a:sub(1, #text) == text then
                currentSuggestion = a
                autocompleteLabel.Text = "  Tab: " .. a .. " (" .. cmd.NAME .. ")"
                autocompleteLabel.Visible = true
                return
            end
        end
    end
    autocompleteLabel.Visible = false
    currentSuggestion = ""
end)

-- Tab to autocomplete, Up/Down for history
connect(UserInputService.InputBegan, function(input, gpe)
    if not cmdBar:IsFocused() then return end
    if input.KeyCode == Enum.KeyCode.Tab then
        if currentSuggestion ~= "" then
            cmdBar.Text = currentSuggestion .. " "
            cmdBar.CursorPosition = #cmdBar.Text + 1
        end
    elseif input.KeyCode == Enum.KeyCode.Up then
        if #cmdHistory > 0 then
            historyIdx = math.min(historyIdx + 1, #cmdHistory)
            cmdBar.Text = cmdHistory[historyIdx]
            cmdBar.CursorPosition = #cmdBar.Text + 1
        end
    elseif input.KeyCode == Enum.KeyCode.Down then
        historyIdx = math.max(historyIdx - 1, 0)
        cmdBar.Text = historyIdx > 0 and cmdHistory[historyIdx] or ""
        cmdBar.CursorPosition = #cmdBar.Text + 1
    end
end)

