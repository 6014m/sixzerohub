        -- pressing ; opens GUI and focuses command bar
        if not cmdBar:IsFocused() then
            guiOpen = true
            main.Visible = true
            suppressText = cmdBar.Text
            suppressNextChar = true
            cmdBar:CaptureFocus()
        end
    end
end)

