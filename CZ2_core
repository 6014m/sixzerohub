        if p:IsA("BasePart") and p.Transparency < 1 then
            p:SetAttribute("CZ_OrigTransparency", p.Transparency)
            p.Transparency = 0.7
        end
    end
    notify("X-Ray", "Enabled")
end)

addcmd("unxray", {"noxray", "unx"}, "Restore part transparency", function(args)
    for _, p in ipairs(workspace:GetDescendants()) do
        if p:IsA("BasePart") then
            local orig = p:GetAttribute("CZ_OrigTransparency")
            if orig then
                p.Transparency = orig
                p:SetAttribute("CZ_OrigTransparency", nil)
            end
        end
    end
    notify("X-Ray", "Disabled")
end)

