addcmd("serverhop", {"shp", "shop"}, "Join a different server", function(args)
    notify("ServerHop", "Finding server...")
    task.spawn(function()
        local ok, servers = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(
                "https://games.roblox.com/v1/games/" .. game.GameId .. "/servers/0?sortOrder=2&excludeFullGames=true&limit=10"
            ))
        end)
        if ok and servers and servers.data then
            for _, s in ipairs(servers.data) do
                if s.id ~= game.JobId and s.playing < s.maxPlayers then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, player)
                    return
                end
            end
        end
        notify("ServerHop", "No available server found")
    end)
end)

