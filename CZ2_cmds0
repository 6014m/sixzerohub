addcmd("spin", {"beyblade"}, "Spin character with BodyAngularVelocity (replicates to others)", function(args)
    local speed = parseNumber(args[1], 20)
    -- remove old
    pcall(function()
        local root = myRoot()
        if root then
            local old = root:FindFirstChild("CZ_Spin")
            if old then old:Destroy() end
        end
    end)
    local root = myRoot()
    if not root then return end
    local bav = Instance.new("BodyAngularVelocity")
    bav.Name = "CZ_Spin"
    bav.AngularVelocity = Vector3.new(0, speed, 0)
    bav.MaxTorque = Vector3.new(0, math.huge, 0)
    bav.P = 1000000
    bav.Parent = root
    loopStates["spin"] = true
    notify("Spin", "Spinning at speed " .. speed)
end)

addcmd("unspin", {}, "Stop spinning", function(args)
    loopStates["spin"] = nil
    local root = myRoot()
    if root then
        local s = root:FindFirstChild("CZ_Spin")
        if s then s:Destroy() end
    end
    notify("Spin", "Stopped")
end)

addcmd("fling", {"fl"}, "Fling a player (IY method — spin into them to launch)", function(args)
    local targets = getPlayers(args[1])
    if #targets == 0 then return end
    local target = targets[1]
    local char = getChar()
    local root = myRoot()
    local hum = myHumanoid()
    if not root or not hum or not char then return end
    local tRoot = getRoot(target.Character)
    if not tRoot then return end

    -- make self massless so we push them not ourselves
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            p.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
            p.CanCollide = true
        end
    end

    local oldPos = root.CFrame

    -- create angular velocity to spin rapidly
    local bav = Instance.new("BodyAngularVelocity")
    bav.AngularVelocity = Vector3.new(0, 9999, 0)
    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bav.P = 1000000
    bav.Parent = root

    -- teleport onto target and stay there briefly
    notify("Fling", "Flinging " .. target.Name .. "...")
    local startTime = tick()
    while tick() - startTime < 1.5 and flyActive ~= "fling_cancel" do
        local tr = getRoot(target.Character)
        if tr and root.Parent then
            root.CFrame = tr.CFrame
        else
            break
        end
        RunService.Heartbeat:Wait()
    end

    -- cleanup
    pcall(function() bav:Destroy() end)
    -- restore physics
    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            p.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 0.5)
        end
    end
    root.CFrame = oldPos
    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    notify("Fling", "Done")
end)

