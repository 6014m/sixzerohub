addcmd("antifling", {"antiflingg", "afling"}, "Disable collisions on other players to prevent flings (IY method)", function(args)
    stopLoop("antifling")
    startLoop("antifling", 0, function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                for _, v in ipairs(p.Character:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end
        end
    end)
    notify("Anti-Fling", "Enabled — other player collisions disabled")
end)

addcmd("unantifling", {}, "Disable anti-fling", function(args)
    stopLoop("antifling")
    notify("Anti-Fling", "Disabled")
end)

addcmd("antilag", {"boostfps", "lowgraphics"}, "Full lag reduction: effects, shadows, fog, quality, materials (IY method)", function(args)
    local Terrain = workspace:FindFirstChildWhichIsA("Terrain")
    if Terrain then
        Terrain.WaterWaveSize = 0
        Terrain.WaterWaveSpeed = 0
        Terrain.WaterReflectance = 0
        Terrain.WaterTransparency = 0
    end
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
            v.Enabled = false
        elseif v:IsA("Explosion") then
            v.BlastPressure = 0
            v.BlastRadius = 0
        elseif v:IsA("MeshPart") or v:IsA("UnionOperation") then
            pcall(function() v.RenderFidelity = Enum.RenderFidelity.Performance end)
        end
        if v:IsA("BasePart") then
            v.CastShadow = false
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
        end
    end
    for _, v in ipairs(Lighting:GetDescendants()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
            v.Enabled = false
        end
    end
    notify("Anti-Lag", "Full lag reduction applied")
end)

