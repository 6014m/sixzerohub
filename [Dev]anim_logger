local function refreshList()
    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local filter = filterBox.Text:lower()
    local shown = 0
    for i = #logged, 1, -1 do
        local entry = logged[i]
        local searchStr = (entry.name .. " " .. entry.id .. " " .. entry.player):lower()
        if filter == "" or searchStr:find(filter, 1, true) then
            shown = shown + 1
            local row = Instance.new("TextButton")
            row.Size = UDim2.new(1, 0, 0, 36)
            row.BackgroundColor3 = (shown % 2 == 0) and Color3.fromRGB(32, 32, 38) or Color3.fromRGB(26, 26, 30)
            row.BorderSizePixel = 0
            row.Text = ""
            row.AutoButtonColor = false
            row.Parent = scroll

            local idLbl = Instance.new("TextLabel")
            idLbl.Size = UDim2.new(1, -8, 0, 16)
            idLbl.Position = UDim2.new(0, 6, 0, 2)
            idLbl.BackgroundTransparency = 1
            idLbl.Text = entry.id .. "  |  " .. string.format("%.1fs", entry.length) .. "  |  " .. entry.player
            idLbl.TextColor3 = Color3.fromRGB(0, 170, 255)
            idLbl.TextSize = 10
            idLbl.Font = Enum.Font.GothamBold
            idLbl.TextXAlignment = Enum.TextXAlignment.Left
            idLbl.Parent = row

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size = UDim2.new(1, -8, 0, 14)
            nameLbl.Position = UDim2.new(0, 6, 0, 18)
            nameLbl.BackgroundTransparency = 1
            nameLbl.Text = entry.name
            nameLbl.TextColor3 = Color3.fromRGB(160, 160, 170)
            nameLbl.TextSize = 9
            nameLbl.Font = Enum.Font.Gotham
            nameLbl.TextXAlignment = Enum.TextXAlignment.Left
            nameLbl.Parent = row

            -- Click to copy ID
            row.MouseButton1Click:Connect(function()
                pcall(function()
                    if setclipboard then setclipboard(entry.id)
                    elseif toclipboard then toclipboard(entry.id) end
                end)
                idLbl.Text = "Copied!"
                task.delay(1, function()
                    if idLbl.Parent then
                        idLbl.Text = entry.id .. "  |  " .. string.format("%.1fs", entry.length) .. "  |  " .. entry.player
                    end
                end)
            end)
        end
    end
    countLbl.Text = tostring(#logged)
end

clearBtn.MouseButton1Click:Connect(function()
    logged = {}
    seen = {}
    refreshList()
end)

filterBox:GetPropertyChangedSignal("Text"):Connect(refreshList)

-- Animation tracking
local function onAnimPlayed(track, playerName)
    if not active then return end
    local animObj = track.Animation
    if not animObj then return end
    local rawId = animObj.AnimationId or ""
    local id = rawId:match("%d+") or "?"
    if id == "?" or id == "0" then return end

    -- Dedup per player
    local key = id .. "_" .. playerName
    if seen[key] then return end
    seen[key] = true

    -- Wait briefly for length to populate
    task.spawn(function()
        local waited = 0
        while track.Length <= 0 and waited < 2 do task.wait(0.1); waited = waited + 0.1 end
        local entry = {
            id = id,
            name = track.Name ~= "" and track.Name or animObj.Name,
            player = playerName,
            length = track.Length,
            time = os.clock(),
        }
        if #logged >= MAX_LOG then table.remove(logged, 1) end
        table.insert(logged, entry)
        refreshList()
    end)
end

local function hookAnimator(animator, playerName)
    local conn = animator.AnimationPlayed:Connect(function(track)
        onAnimPlayed(track, playerName)
    end)
    table.insert(connections, conn)
    -- Catch already-playing tracks
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        onAnimPlayed(track, playerName)
    end
end

local function hookCharacter(char, playerName)
    task.spawn(function()
        local hum = char:WaitForChild("Humanoid", 10)
        if not hum or not active then return end
        local animator = hum:FindFirstChildOfClass("Animator")
        if not animator then animator = hum:WaitForChild("Animator", 5) end
        if animator and active then hookAnimator(animator, playerName) end
    end)
end

local function hookPlayer(plr)
    if plr.Character then hookCharacter(plr.Character, plr.Name) end
    local conn = plr.CharacterAdded:Connect(function(char)
        hookCharacter(char, plr.Name)
    end)
    table.insert(connections, conn)
end

for _, plr in ipairs(Players:GetPlayers()) do hookPlayer(plr) end
local joinConn = Players.PlayerAdded:Connect(function(plr) hookPlayer(plr) end)
table.insert(connections, joinConn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    pcall(function() gui:Destroy() end)
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Anim Logger", "[Dev]anim_logger", cleanup, "dev")
end
