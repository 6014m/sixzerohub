-- Daily Spin GUI (same style, below token spin)
local label2 = Instance.new("TextLabel")
label2.Size = UDim2.new(0, 130, 0, 26)
label2.Position = UDim2.new(1, -130, 0, 105)
label2.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
label2.BackgroundTransparency = 0.1
label2.BorderSizePixel = 0
label2.Text = "Daily Spin: ON"
label2.TextColor3 = Color3.fromRGB(87, 242, 135)
label2.Font = Enum.Font.GothamBold
label2.TextSize = 13
label2.Parent = gui

local toggleBtn2 = Instance.new("TextButton")
toggleBtn2.Size = UDim2.new(0, 30, 0, 26)
toggleBtn2.Position = UDim2.new(1, -161, 0, 105)
toggleBtn2.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
toggleBtn2.BackgroundTransparency = 0.1
toggleBtn2.BorderSizePixel = 0
toggleBtn2.Text = "ON"
toggleBtn2.TextColor3 = Color3.fromRGB(87, 242, 135)
toggleBtn2.Font = Enum.Font.GothamBold
toggleBtn2.TextSize = 10
toggleBtn2.Parent = gui
Instance.new("UICorner", toggleBtn2).CornerRadius = UDim.new(0, 6)

local SETTINGS_FILE = "AutoSpin_settings.json"

local active = true
local dailyActive = true
pcall(function()
	if isfile and isfile(SETTINGS_FILE) then
		local data = HttpService:JSONDecode(readfile(SETTINGS_FILE))
		if data.active == false then active = false end
		if data.dailyActive == false then dailyActive = false end
	end
end)

local function saveSettings()
	pcall(function()
		if writefile then
			writefile(SETTINGS_FILE, HttpService:JSONEncode({active = active, dailyActive = dailyActive}))
		end
	end)
end

local function updateVisual()
	if active then
		toggleBtn.Text = "ON"
		toggleBtn.TextColor3 = Color3.fromRGB(87, 242, 135)
		label.TextColor3 = Color3.fromRGB(87, 242, 135)
	else
		toggleBtn.Text = "OFF"
		toggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
		label.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
	if dailyActive then
		toggleBtn2.Text = "ON"
		toggleBtn2.TextColor3 = Color3.fromRGB(87, 242, 135)
		label2.TextColor3 = Color3.fromRGB(87, 242, 135)
	else
		toggleBtn2.Text = "OFF"
		toggleBtn2.TextColor3 = Color3.fromRGB(255, 100, 100)
		label2.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
end

updateVisual()

toggleBtn.MouseButton1Click:Connect(function()
	active = not active
	updateVisual()
	saveSettings()
end)

toggleBtn2.MouseButton1Click:Connect(function()
	dailyActive = not dailyActive
	updateVisual()
	saveSettings()
end)

-- Token spin loop
task.spawn(function()
	while spinning do
		local btn, tokensLabel = getButton()
		if btn and tokensLabel then
			local tokens = getTokenCount(tokensLabel)
			label.Text = (active and "Auto Spin: " or "Paused: ") .. tokens .. " tokens"
			if tokens > 0 and active then
				pcall(function()
					fireclickdetector(btn.ClickDetector)
				end)
				pcall(function()
					firesignal(btn.MouseButton1Click)
				end)
				pcall(function()
					if btn:IsA("GuiButton") then
						btn.MouseButton1Click:Fire()
					end
				end)
			end
		else
			label.Text = "Auto Spin: Waiting..."
		end
		task.wait(0.5)
	end
end)

-- Daily spin loop
task.spawn(function()
	while spinning do
		local spinBtn, amountLabel = getDailySpin()
		if spinBtn and amountLabel then
			local count = getDailySpinCount(amountLabel)
			label2.Text = (dailyActive and "Daily Spin: " or "Paused: ") .. count .. " spins"
			if count > 0 and dailyActive then
				pcall(function()
					fireclickdetector(spinBtn.ClickDetector)
				end)
				pcall(function()
					firesignal(spinBtn.MouseButton1Click)
				end)
				pcall(function()
					if spinBtn:IsA("GuiButton") then
						spinBtn.MouseButton1Click:Fire()
					end
				end)
			end
		else
			label2.Text = "Daily Spin: Waiting..."
		end
		task.wait(0.5)
	end
end)
