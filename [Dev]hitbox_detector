---------- DETECTION ----------

local touchConnections = {}

local function hookCharacter(char)
    -- Disconnect old touch connections
    for _, c in ipairs(touchConnections) do pcall(function() c:Disconnect() end) end
    touchConnections = {}

    -- Wait for character to load
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end

    -- Hook Touched on all character parts
    for _, part in ipairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            local conn = part.Touched:Connect(function(hit)
                if not hit or not hit.Parent then return end
                if isMyCharPart(hit) then return end
                if hit:IsDescendantOf(char) then return end
                -- Skip other player characters
                local isOtherPlayer = false
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.Character and hit:IsDescendantOf(plr.Character) then
                        isOtherPlayer = true; break
                    end
                end
                if isOtherPlayer then return end
                addEntry(hit)
            end)
            table.insert(touchConnections, conn)
        end
    end

    -- Hook new parts added to character
    local addConn = char.ChildAdded:Connect(function(child)
        if child:IsA("BasePart") then
            local conn = child.Touched:Connect(function(hit)
                if not hit or not hit.Parent then return end
                if isMyCharPart(hit) then return end
                if hit:IsDescendantOf(char) then return end
                local isOtherPlayer = false
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.Character and hit:IsDescendantOf(plr.Character) then
                        isOtherPlayer = true; break
                    end
                end
                if isOtherPlayer then return end
                addEntry(hit)
            end)
            table.insert(touchConnections, conn)
        end
    end)
    table.insert(connections, addConn)
end

-- Initial hook
if localPlayer.Character then hookCharacter(localPlayer.Character) end
local charConn = localPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    hookCharacter(char)
end)
