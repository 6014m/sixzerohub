    copyBtn.MouseButton1Click:Connect(function()
        pcall(function()
            if setclipboard then setclipboard(fullPath)
            elseif toclipboard then toclipboard(fullPath) end
        end)
        copyBtn.Text = "\xE2\x9C\x93"
        copyBtn.TextColor3 = Color3.fromRGB(87, 242, 135)
        task.delay(1, function()
            if copyBtn and copyBtn.Parent then
                copyBtn.Text = "\xF0\x9F\x93\x8B"
                copyBtn.TextColor3 = COLORS.muted
            end
        end)
    end)

    local pathLbl = Instance.new("TextLabel")
