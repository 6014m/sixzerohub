---------- VISUAL MODE ----------

local visualMode = false
local highlights = {} -- track highlights we've added so we can clean up

local function makeVisible(part)
    if not part or not part.Parent then return end
    if part:FindFirstChild("_HitboxHighlight") then return end

    -- Make the part visible
    pcall(function()
        if part.Transparency >= 0.5 then
            part:SetAttribute("_HBD_OrigTransparency", part.Transparency)
            part.Transparency = 0.3
        end
    end)

    -- Add red highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = "_HitboxHighlight"
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 50, 50)
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = part
    highlight.Parent = part
    table.insert(highlights, {part = part, highlight = highlight})
end

local function clearVisuals()
    for _, h in ipairs(highlights) do
        pcall(function()
            if h.highlight and h.highlight.Parent then h.highlight:Destroy() end
        end)
        pcall(function()
            local orig = h.part:GetAttribute("_HBD_OrigTransparency")
            if orig then h.part.Transparency = orig; h.part:SetAttribute("_HBD_OrigTransparency", nil) end
        end)
    end
    highlights = {}
end

visualBtn.MouseButton1Click:Connect(function()
    visualMode = not visualMode
    visualBtn.Text = visualMode and "Hide" or "Visual"
    visualBtn.BackgroundColor3 = visualMode and COLORS.accent or COLORS.row

    if not visualMode then
        clearVisuals()
    end
end)

---------- CLEANUP ----------

local function cleanup()
    for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
    for _, c in ipairs(touchConnections) do pcall(function() c:Disconnect() end) end
    connections = {}; touchConnections = {}
    clearVisuals()
    pcall(function() gui:Destroy() end)
end

