-- Populate command list
local function populateCommands(filter)
    local page = tabPages["Commands"]
    for _, child in ipairs(page:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    filter = filter and filter:lower() or ""
    local order = 0

    for _, cmd in ipairs(cmds) do
        local aliases = table.concat(cmd.ALIAS, ", ")
        local searchStr = cmd.NAME .. " " .. aliases .. " " .. (cmd.DESC or "")
        if filter ~= "" and not searchStr:lower():find(filter, 1, true) then continue end

        order = order + 1
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -4, 0, 26)
        btn.BackgroundColor3 = THEME.hover
        btn.BackgroundTransparency = 0.5
        btn.BorderSizePixel = 0
        btn.TextColor3 = THEME.text
        btn.TextSize = 12
        btn.Font = Enum.Font.Gotham
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.AutoButtonColor = false
        btn.LayoutOrder = order
        btn.Parent = page
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

        local displayText = "  " .. cmd.NAME
        if #cmd.ALIAS > 0 then
            displayText = displayText .. "  [" .. aliases .. "]"
        end
        btn.Text = displayText

        btn.MouseButton1Click:Connect(function()
            cmdBar.Text = cmd.NAME .. " "
            cmdBar:CaptureFocus()
        end)

        btn.MouseEnter:Connect(function()
            btn.BackgroundTransparency = 0
            if cmd.DESC and cmd.DESC ~= "" then
                hoverLabel.Text = cmd.NAME .. "\n" .. cmd.DESC
                hoverLabel.Visible = true
            end
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundTransparency = 0.5
            hoverLabel.Visible = false
        end)
    end
end

searchBar:GetPropertyChangedSignal("Text"):Connect(function()
