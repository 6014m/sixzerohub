addcmd("animsync", {}, "Sync your animation with another player", function(args)
    local targets = getPlayers(args[1])
    if #targets == 0 then return end
    local target = targets[1]
    startLoop("animsync", 0.5, function()
        local tHum = getHumanoid(target.Character)
        local mHum = myHumanoid()
        if not tHum or not mHum then return end
        local tAnimator = tHum:FindFirstChildOfClass("Animator")
        local mAnimator = mHum:FindFirstChildOfClass("Animator")
        if not tAnimator or not mAnimator then return end
        for _, track in ipairs(mAnimator:GetPlayingAnimationTracks()) do
            track:Stop()
        end
        for _, track in ipairs(tAnimator:GetPlayingAnimationTracks()) do
            local anim = Instance.new("Animation")
            anim.AnimationId = track.Animation.AnimationId
            local newTrack = mAnimator:LoadAnimation(anim)
            newTrack:Play()
            newTrack:AdjustSpeed(track.Speed)
        end
    end)
    notify("AnimSync", "Syncing with " .. target.Name)
end)

