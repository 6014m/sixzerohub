addcmd("seizure", {"juicewrld"}, "Make character have a seizure (BodyAngularVelocity, replicates)", function(args)
    local root = myRoot()
    if not root then return end
    pcall(function() local s = root:FindFirstChild("CZ_Seizure") if s then s:Destroy() end end)
    local bav = Instance.new("BodyAngularVelocity")
    bav.Name = "CZ_Seizure"
    bav.AngularVelocity = Vector3.new(math.random(-50, 50), math.random(-50, 50), math.random(-50, 50))
    bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bav.P = 1000000
    bav.Parent = root
    -- randomize direction rapidly
    startLoop("seizure", 0.08, function()
        if bav.Parent then
            bav.AngularVelocity = Vector3.new(math.random(-80, 80), math.random(-80, 80), math.random(-80, 80))
        end
    end)
    notify("Seizure", "Started")
end)

