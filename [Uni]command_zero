addcmd("reanimate", {"reanim", "feanim"}, "FE Reanimate — appear dead, control limbs (R6 only)", function(args)
    local char = getChar()
    local hum = myHumanoid()
    local rootP = myRoot()
    if not char or not hum or not rootP then notify("Reanimate", "No character"); return end
    if hum.RigType ~= Enum.HumanoidRigType.R6 then notify("Reanimate", "R6 only"); return end

    char.Archivable = true
    local shp = sethiddenproperty or set_hidden_property or function() end

    if char:FindFirstChild("Animate") then
        char.Animate.Disabled = true
        for _, t in pairs(hum:GetPlayingAnimationTracks()) do t:Stop() end
    end
    hum:ChangeState("Physics")

    pcall(function()
        player.ReplicationFocus = workspace
        settings().Physics.AllowSleep = false
        shp(workspace, "PhysicsSteppingMethod", Enum.PhysicsSteppingMethod.Fixed)
    end)

    local fakeRig = char:Clone()
    fakeRig.Name = "CZReanimate"
    for _, v in pairs(fakeRig:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("Decal") then v.Transparency = 1
        elseif v:IsA("SpecialMesh") then v.MeshId = ""
        elseif v:IsA("LocalScript") or v:IsA("Script") then v:Destroy() end
    end
    fakeRig.HumanoidRootPart.CFrame = rootP.CFrame
    fakeRig.Parent = workspace

    local fakeHum = fakeRig:FindFirstChildOfClass("Humanoid")
    fakeHum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    fakeHum.BreakJointsOnDeath = false
    fakeHum.PlatformStand = false
    fakeHum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    fakeHum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    fakeHum:ChangeState(Enum.HumanoidStateType.GettingUp)

    char.Parent = fakeRig
    workspace.CurrentCamera.CameraSubject = fakeHum
    hum.PlatformStand = true

    local vel = Vector3.new(0, 0, -25.8)
    local bvs = {}
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
            v.Massless = true
            v.RootPriority = 127
            local abv = Instance.new("BodyAngularVelocity")
            abv.P = math.huge; abv.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            abv.AngularVelocity = Vector3.zero; abv.Parent = v
            local bv = Instance.new("BodyVelocity")
            bv.P = math.huge; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.Velocity = Vector3.zero; bv.Parent = v
            table.insert(bvs, bv)
        end
    end

    local offsets = {
        ["Torso"] = fakeRig:FindFirstChild("Torso"),
        ["Right Arm"] = fakeRig:FindFirstChild("Right Arm"),
        ["Left Arm"] = fakeRig:FindFirstChild("Left Arm"),
        ["Right Leg"] = fakeRig:FindFirstChild("Right Leg"),
        ["Left Leg"] = fakeRig:FindFirstChild("Left Leg"),
    }

    local rootOff = 0.02
    task.spawn(function() while task.wait(0.05) do rootOff = rootOff * -1 end end)

    local rEvents = {}
    local charDesc = char:GetDescendants()

    table.insert(rEvents, RunService.PreSimulation:Connect(function()
        for _, v in pairs(charDesc) do
            if v:IsA("BasePart") and v.Parent then v.CanCollide = false; v.CanQuery = false; v.CanTouch = false end
        end
        pcall(function() fakeRig.Head.CanCollide = false; fakeRig.Torso.CanCollide = false end)
    end))

    table.insert(rEvents, RunService.Heartbeat:Connect(function()
        pcall(function()
            settings().Physics.AllowSleep = false
            shp(player, "MaximumSimulationRadius", math.huge)
            shp(player, "SimulationRadius", math.huge)
        end)
        pcall(function()
            local t = char:FindFirstChild("Torso")
            if t then t.AssemblyLinearVelocity = vel end
        end)
        for _, bv in pairs(bvs) do bv.Velocity = vel end
        for name, fakePart in pairs(offsets) do
            local realPart = char:FindFirstChild(name)
            if realPart and fakePart and realPart.Parent and fakePart.Parent then
                realPart.CFrame = fakePart.CFrame
            end
        end
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Accessory") and v:FindFirstChild("Handle") then
                local fa = fakeRig:FindFirstChild(v.Name)
                if fa and fa:FindFirstChild("Handle") then v.Handle.CFrame = fa.Handle.CFrame end
            end
        end
        rootP.CFrame = (char:FindFirstChild("Torso") or rootP).CFrame * CFrame.new(0, rootOff, 0)
    end))

    local function rDeath()
        _G.czReanimateActive = false
        _G.czReanimateFakeRig = nil
