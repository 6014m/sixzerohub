addcmd("esp", {"playeresp"}, "Toggle player ESP boxes", function()
    if #espObjects > 0 then
        clearESP()
        notify("ESP", "Disabled")
        stopLoop("esp")
        return
    end

    local function createESP(p)
        if p == player then return end
        local highlight = Instance.new("Highlight")
        highlight.Name = "CZ_ESP"
        highlight.FillTransparency = 0.7
        highlight.OutlineTransparency = 0
        highlight.FillColor = Color3.fromRGB(0, 170, 255)
        highlight.OutlineColor = Color3.fromRGB(0, 170, 255)
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

        local bb = Instance.new("BillboardGui")
        bb.Name = "CZ_ESP_Name"
        bb.Size = UDim2.new(0, 200, 0, 30)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = 10000

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 1, 0)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextColor3 = Color3.new(1, 1, 1)
        nameLabel.TextStrokeTransparency = 0.5
        nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 14
        nameLabel.Parent = bb

        table.insert(espObjects, highlight)
        table.insert(espObjects, bb)

        local function apply()
            if p.Character then
                highlight.Adornee = p.Character
                highlight.Parent = p.Character
                local head = p.Character:FindFirstChild("Head")
                if head then bb.Adornee = head; bb.Parent = head end
                nameLabel.Text = p.DisplayName .. " [" .. math.floor((getRoot(p.Character) and myRoot() and (getRoot(p.Character).Position - myRoot().Position).Magnitude) or 0) .. "]"
            end
        end

        apply()
        local conn = p.CharacterAdded:Connect(function() task.wait(0.5); apply() end)
        table.insert(allConnections, conn)
    end

    for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
    connect(Players.PlayerAdded, createESP)

    startLoop("esp", 0.5, function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p == player then continue end
            if p.Character then
                local bb = p.Character:FindFirstChild("Head") and p.Character.Head:FindFirstChild("CZ_ESP_Name")
                if bb then
                    local dist = (getRoot(p.Character) and myRoot()) and math.floor((getRoot(p.Character).Position - myRoot().Position).Magnitude) or 0
                    local lbl = bb:FindFirstChildOfClass("TextLabel")
                    if lbl then lbl.Text = p.DisplayName .. " [" .. dist .. "]" end
                end
            end
        end
    end)

    notify("ESP", "Enabled")
end)

