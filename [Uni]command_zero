addcmd("float", {"plat", "platform"}, "Float on invisible platform — Q down, E up", function(args)
    local root = myRoot()
    if not root then return end
    local p = Instance.new("Part")
    p.Name = "CZ_Float"
    p.Size = Vector3.new(6, 1, 6)
    p.Position = root.Position - Vector3.new(0, 3.5, 0)
    p.Anchored = true
    p.Transparency = 1
    p.Parent = workspace
    local floatY = p.Position.Y
    local floatSpeed = parseNumber(args[1], 1)
    startLoop("float", 0, function()
        local r = myRoot()
        if not r or not p.Parent then return end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then floatY = floatY + floatSpeed end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then floatY = floatY - floatSpeed end
        p.Position = Vector3.new(r.Position.X, floatY, r.Position.Z)
    end)
    notify("Float", "Floating — Q down, E up")
end)

