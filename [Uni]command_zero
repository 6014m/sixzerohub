                    beam.CFrame = CFrame.new(mRoot.Position, tRoot.Position) * CFrame.new(0, 0, -dist / 2)
                    beam.Parent = workspace
                    task.wait(0.1)
                    beam:Destroy()
                else
                    task.wait(0.5)
                end
            end
        end)
    end
end)

