        nameLbl.TextColor3 = THEME.text
        nameLbl.TextSize = 10
        nameLbl.Font = Enum.Font.GothamBold
        nameLbl.Parent = btn

        -- Icon hint at top
        local iconLbl = Instance.new("TextLabel")
