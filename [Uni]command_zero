        iconLbl.Text = "♪"
        iconLbl.TextColor3 = THEME.accent
        iconLbl.TextSize = 20
        iconLbl.Font = Enum.Font.GothamBold
        iconLbl.Parent = btn

        -- Playing indicator
        local playingDot = Instance.new("Frame")
        playingDot.Size = UDim2.new(0, 8, 0, 8)
        playingDot.Position = UDim2.new(1, -12, 0, 4)
        playingDot.BackgroundColor3 = THEME.success
        playingDot.BorderSizePixel = 0
        playingDot.Visible = currentEmote == entry.name
        playingDot.Parent = btn
        Instance.new("UICorner", playingDot).CornerRadius = UDim.new(0.5, 0)

        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
            btnStroke.Color = THEME.accent
            centerLbl.Text = entry.name
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
            btnStroke.Color = currentEmote == entry.name and THEME.success or Color3.fromRGB(50, 50, 65)
            centerLbl.Text = "Emotes"
        end)

        btn.MouseButton1Click:Connect(function()
            if currentEmote == entry.name then
                currentEmote = nil
                playingDot.Visible = false
                btnStroke.Color = Color3.fromRGB(50, 50, 65)
                notify("Emote", entry.name .. " stopped")
                return
            end

            -- Stop any current emote
            currentEmote = nil
            task.wait()

            -- Load if needed
            local data = loadEmote(entry)
            if not data then notify("Emote", "Failed to load " .. entry.name); return end

            playingDot.Visible = true
            btnStroke.Color = THEME.success
            notify("Emote", entry.name .. " — move to stop")
            destroyEmoteWheel()

            task.spawn(function()
                playEmote(data, entry.name)
                -- Emote ended
                if emoteWheelGui and playingDot.Parent then
                    playingDot.Visible = false
                    btnStroke.Color = Color3.fromRGB(50, 50, 65)
                end
            end)
        end)
    end
end

