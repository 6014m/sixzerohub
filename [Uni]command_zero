        local function hookCharEvents(plr)
            task.spawn(function()
                local char = plr.Character
                if not char then return end
                local hum = char:WaitForChild("Humanoid", 10)
                if not hum then return end

                local oldHealth = hum.Health
                hum.HealthChanged:Connect(function(health)
                    if oldHealth > health then
                        fireEvent("OnDamage", plr.Name, tostring(math.floor(health)))
                    end
                    oldHealth = health
                end)

                hum.Died:Connect(function()
                    fireEvent("OnDied", plr.Name)
                    local creator = hum:FindFirstChild("creator")
                    if creator and creator.Value and creator.Value.Parent then
                        fireEvent("OnKilled", plr.Name, creator.Value.Name)
                    end
                end)
            end)
        end

        -- Hook all game events
        local function hookAllEvents()
            connect(Players.PlayerAdded, function(p)
                fireEvent("OnJoin", p.Name)
                p.CharacterAdded:Connect(function()
                    fireEvent("OnSpawn", p.Name)
                    hookCharEvents(p)
                end)
                p.Chatted:Connect(function(msg) fireEvent("OnChatted", p.Name, msg) end)
            end)
            connect(Players.PlayerRemoving, function(p) fireEvent("OnLeave", p.Name) end)
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character then hookCharEvents(p) end
                p.CharacterAdded:Connect(function()
                    fireEvent("OnSpawn", p.Name)
                    hookCharEvents(p)
                end)
                p.Chatted:Connect(function(msg) fireEvent("OnChatted", p.Name, msg) end)
            end
            pcall(function()
                local channel = TextChatService:FindFirstChild("TextChannels") and TextChatService.TextChannels:FindFirstChild("RBXGeneral")
                if channel then
                    connect(channel.MessageReceived, function(msg)
                        local sender = msg.TextSource and Players:GetPlayerByUserId(msg.TextSource.UserId)
                        if sender then fireEvent("OnChatted", sender.Name, msg.Text) end
                    end)
                end
            end)

            -- Fire OnExecute once
            task.defer(function() fireEvent("OnExecute") end)
        end
        hookAllEvents()
    end
end

