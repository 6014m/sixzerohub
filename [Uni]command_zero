addcmd("aimbot", {}, "Basic aimbot (snaps camera to nearest player)", function(args)
    local on = toggleLoop("aimbot", 0, function()
        local cam = workspace.CurrentCamera
        local closest, closestDist = nil, math.huge
        local myPos = myRoot() and myRoot().Position

        if not myPos then return end

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local head = p.Character:FindFirstChild("Head")
                if head then
                    local dist = (head.Position - myPos).Magnitude
                    if dist < closestDist then
                        closest = head
                        closestDist = dist
                    end
                end
            end
        end

        if closest and cam then
            cam.CFrame = CFrame.new(cam.CFrame.Position, closest.Position)
        end
    end)
    notify("Aimbot", on and "Enabled" or "Disabled")
end)

addcmd("unaimbot", {}, "Disable aimbot", function(args)
    stopLoop("aimbot")
    notify("Aimbot", "Disabled")
end)

