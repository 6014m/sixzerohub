addcmd("clickteleport", {"clicktp", "ctp"}, "Click to teleport (handles seated, proper height, IY method)", function(args)
    local on = toggleLoop("clicktp", 0.05, function() end)
    if on then
        notify("ClickTP", "Enabled — click anywhere to teleport")
        local conn
        conn = connect(UserInputService.InputBegan, function(input)
            if not loopStates["clicktp"] then conn:Disconnect(); return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 and not UserInputService:GetFocusedTextBox() then
                local mouse = player:GetMouse()
                local char = getChar()
                local root = myRoot()
                local hum = myHumanoid()
                if not root or not hum or not mouse.Hit then return end
                -- handle seated
                if hum.SeatPart then
                    local seat = hum.SeatPart
                    local weld = seat:FindFirstChildOfClass("Weld")
                    if weld then weld:Destroy() end
                    hum.Sit = false
                    task.wait(0.1)
                end
                -- proper height: hip height + rootpart half height
                local hipHeight = hum.HipHeight
                local rootHeight = root.Size.Y / 2
                local targetPos = mouse.Hit.Position + Vector3.new(0, hipHeight + rootHeight + 0.1, 0)
                -- preserve look direction, rotate to face away from camera
                local cam = workspace.CurrentCamera
                local lookDir = cam.CFrame.LookVector
                local flatLook = Vector3.new(lookDir.X, 0, lookDir.Z)
                if flatLook.Magnitude > 0 then
                    root.CFrame = CFrame.lookAt(targetPos, targetPos + flatLook)
                else
                    root.CFrame = CFrame.new(targetPos)
                end
            end
        end)
    else
        notify("ClickTP", "Disabled")
    end
end)

