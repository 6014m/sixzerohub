        if not tHum or not mHum then return end
        local tAnimator = tHum:FindFirstChildOfClass("Animator")
        local mAnimator = mHum:FindFirstChildOfClass("Animator")
        if not tAnimator or not mAnimator then return end
        for _, track in ipairs(mAnimator:GetPlayingAnimationTracks()) do
