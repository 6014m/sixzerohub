addcmd("pathfindwalkto", {"pfwalk", "pathfindfollow"}, "Pathfind walk to a player", function(args)
    local targets = getPlayers(args[1])
    if #targets == 0 then return end
    local target = targets[1]
    local tRoot = getRoot(target.Character)
    local mRoot = myRoot()
    if not tRoot or not mRoot then return end
    local path = game:GetService("PathfindingService"):CreatePath()
    path:ComputeAsync(mRoot.Position, tRoot.Position)
    if path.Status == Enum.PathStatus.Success then
        for _, wp in ipairs(path:GetWaypoints()) do
            local hum = myHumanoid()
            if hum then
                hum:MoveTo(wp.Position)
                if wp.Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
                hum.MoveToFinished:Wait()
            end
        end
    end
end)

