local function tweenMove(root, targetCF, duration)
    duration = duration or 1
    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), { CFrame = targetCF })
    tween:Play()
    tween.Completed:Wait()
end

-- togglable loops
local loopStates = {}

local function startLoop(name, interval, func)
    loopStates[name] = true
    task.spawn(function()
        while loopStates[name] do
            pcall(func)
            task.wait(interval)
        end
    end)
end

local function stopLoop(name)
    loopStates[name] = nil
end

local function toggleLoop(name, interval, func)
    if loopStates[name] then
        stopLoop(name)
        return false
    else
        startLoop(name, interval, func)
        return true
    end
end

