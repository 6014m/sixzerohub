-- Freecam with mouse look (proper implementation)
local freecamRotX, freecamRotY = 0, 0
local freecamMouseConn = nil

addcmd("freecam", {"fc"}, "Enter freecam with mouse look (WASD move, mouse rotate, Shift=fast)", function(args), "camera")
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

    -- init rotation from current camera
    local look = cam.CFrame.LookVector
    freecamRotY = math.atan2(-look.X, -look.Z)
    freecamRotX = math.asin(look.Y)

    -- mouse delta for rotation
    if freecamMouseConn then freecamMouseConn:Disconnect() end
    freecamMouseConn = connect(UserInputService.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            local sens = 0.003
            freecamRotY = freecamRotY - input.Delta.X * sens
            freecamRotX = math.clamp(freecamRotX - input.Delta.Y * sens, -math.pi / 2 + 0.1, math.pi / 2 - 0.1)
        end
    end)

    local fcSpeed = parseNumber(args[1], 2)

    startLoop("freecam", 0, function()
        local c = workspace.CurrentCamera
        if c.CameraType ~= Enum.CameraType.Scriptable then return end
        local speed = fcSpeed
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then speed = speed * 3 end

        local rot = CFrame.fromEulerAnglesYXZ(freecamRotX, freecamRotY, 0)
        local move = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + rot.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - rot.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - rot.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + rot.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then move = move + Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move = move - Vector3.yAxis end

        local pos = c.CFrame.Position
        if move.Magnitude > 0 then
            pos = pos + move.Unit * speed
        end
        c.CFrame = CFrame.new(pos) * rot
    end)

    notify("Freecam", "WASD move, mouse look, Shift=fast, E/Q up/down")
end)

addcmd("unfreecam", {"unfc", "nofreecam"}, "Exit freecam", function(args), "camera")
    stopLoop("freecam")
    if freecamMouseConn then freecamMouseConn:Disconnect(); freecamMouseConn = nil end
