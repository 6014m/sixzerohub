addcmd("spinhats", {}, "Spin your hats around your head", function(args)
    local speed = parseNumber(args[1], 5)
    local char = getChar()
    if not char then return end
    local hats = {}
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Accessory") then table.insert(hats, v) end
    end
    if #hats == 0 then return end
    startLoop("spinhats", 0, function()
        local root = myRoot()
        if not root then return end
        for i, hat in ipairs(hats) do
            local handle = hat:FindFirstChild("Handle")
            if handle then
                local t = tick() * speed + (i / #hats) * math.pi * 2
                local offset = Vector3.new(math.cos(t) * 3, 2, math.sin(t) * 3)
                handle.CFrame = CFrame.new(root.Position + offset)
            end
        end
    end)
    notify("SpinHats", "Spinning " .. #hats .. " hats")
end)

