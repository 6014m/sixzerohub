    local function hookHumanoid(hum)
        local c = hum.Running:Connect(function(speed)
            if not loopStates["autoobby"] then return end
            if speed > 0 and hum.FloorMaterial == Enum.Material.Air then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
        table.insert(autoObbyConns, c)
    end

    local hum = myHumanoid()
    if hum then hookHumanoid(hum) end

    local charConn = player.CharacterAdded:Connect(function(newChar)
        if not loopStates["autoobby"] then return end
        local newHum = newChar:WaitForChild("Humanoid", 10)
        if newHum then hookHumanoid(newHum) end
    end)
    table.insert(autoObbyConns, charConn)

    notify("AutoObby", "Enabled — jumps at block edges while walking")
end)

