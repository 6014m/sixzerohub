-- Freecam with mouse look (proper implementation)
local freecamRotX, freecamRotY = 0, 0
local freecamMouseConn = nil
local freecamRMB = false

addcmd("freecam", {"fc"}, "Scriptable camera — WASD move, mouse look, Q/E up/down, Shift speed", function(args)
    local cam = workspace.CurrentCamera
    cam.CameraType = Enum.CameraType.Scriptable
    local speed = parseNumber(args[1], 1)

    -- Init rotation from current camera
    local _, yaw, _ = cam.CFrame:ToEulerAnglesYXZ()
    local look = cam.CFrame.LookVector
    freecamRotX = -math.asin(math.clamp(look.Y, -1, 1))
    freecamRotY = yaw

    -- Mouse delta for look
    if freecamMouseConn then pcall(function() freecamMouseConn:Disconnect() end) end
    freecamMouseConn = connect(UserInputService.InputChanged, function(input)
        if not loopStates["freecam"] then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement and freecamRMB then
            local sens = 0.003
            freecamRotY = freecamRotY - input.Delta.X * sens
            freecamRotX = math.clamp(freecamRotX - input.Delta.Y * sens, -math.rad(89), math.rad(89))
        end
    end)

    -- RMB tracking
    local rmbDown = connect(UserInputService.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then freecamRMB = true; UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition end
    end)
    local rmbUp = connect(UserInputService.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then freecamRMB = false; UserInputService.MouseBehavior = Enum.MouseBehavior.Default end
    end)

    startLoop("freecam", 0, function()
        local c = workspace.CurrentCamera
        if c.CameraType ~= Enum.CameraType.Scriptable then stopLoop("freecam"); return end
        local moveVec = Vector3.zero
        local rot = CFrame.fromEulerAnglesYXZ(freecamRotX, freecamRotY, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + rot.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec - rot.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec - rot.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + rot.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then moveVec = moveVec + Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then moveVec = moveVec - Vector3.yAxis end
        local spd = speed * (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 3 or 1)
        if moveVec.Magnitude > 0 then
            c.CFrame = CFrame.new(c.CFrame.Position + moveVec.Unit * spd) * rot
        else
            c.CFrame = CFrame.new(c.CFrame.Position) * rot
        end
    end)
    notify("Freecam", "WASD move, Q/E up/down, RMB look, Shift fast. ;unfc to exit")
end)

addcmd("unfreecam", {"unfc", "nofreecam", "nofc"}, "Exit freecam", function(args)
    stopLoop("freecam")
