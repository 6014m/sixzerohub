    stopLoop("clicktp")
    notify("ClickTP", "Disabled")
end)

addcmd("orbit", {"orb"}, "Orbit a player", function(args)
    local targets = getPlayers(args[1])
    local radius = parseNumber(args[2], 10)
    local speed = parseNumber(args[3], 2)
    if #targets == 0 then return end
    local target = targets[1]

    startLoop("orbit", 0, function()
        local tRoot = getRoot(target.Character)
        local mRoot = myRoot()
        if tRoot and mRoot then
            local t = tick() * speed
            mRoot.CFrame = CFrame.new(
                tRoot.Position + Vector3.new(math.cos(t) * radius, 0, math.sin(t) * radius),
                tRoot.Position
            )
        end
    end)
    notify("Orbit", "Orbiting " .. target.Name)
end)

