local function getPlayersByName(name)
    name = name:lower()
    local found = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if name:sub(1, 1) == "@" then
            if p.Name:lower():sub(1, #name - 1) == name:sub(2) then
                table.insert(found, p)
            end
        else
            if p.Name:lower():sub(1, #name) == name or p.DisplayName:lower():sub(1, #name) == name then
                table.insert(found, p)
            end
        end
    end
    return found
end

local function getPlayers(list, speaker)
    speaker = speaker or player
    if not list or list == "" then return { speaker } end

    local results = {}
    for _, token in ipairs(list:split(",")) do
        token = token:gsub("^%s+", ""):gsub("%s+$", ""):lower()

        if token == "me" then
            table.insert(results, speaker)
        elseif token == "all" then
            for _, p in ipairs(Players:GetPlayers()) do table.insert(results, p) end
        elseif token == "others" then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= speaker then table.insert(results, p) end
            end
        elseif token == "random" then
            local plrs = Players:GetPlayers()
            if #plrs > 0 then table.insert(results, plrs[math.random(#plrs)]) end
        elseif token == "nearest" or token == "closest" then
            local myRoot = speaker.Character and speaker.Character:FindFirstChild("HumanoidRootPart")
            if myRoot then
                local best, bestDist = nil, math.huge
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= speaker and p.Character then
                        local root = p.Character:FindFirstChild("HumanoidRootPart")
                        if root then
                            local d = (root.Position - myRoot.Position).Magnitude
                            if d < bestDist then best, bestDist = p, d end
                        end
                    end
                end
                if best then table.insert(results, best) end
            end
        elseif token == "friends" then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= speaker and speaker:IsFriendsWith(p.UserId) then
                    table.insert(results, p)
                end
            end
        elseif token == "nonfriends" or token == "enemies" then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= speaker and not speaker:IsFriendsWith(p.UserId) then
                    table.insert(results, p)
                end
            end
        elseif token:match("^%%(.+)$") then
            local teamName = token:sub(2):lower()
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Team and p.Team.Name:lower():find(teamName) then
                    table.insert(results, p)
                end
            end
        else
            for _, p in ipairs(getPlayersByName(token)) do
                table.insert(results, p)
            end
        end
    end

    -- deduplicate
    local seen, unique = {}, {}
    for _, p in ipairs(results) do
        if not seen[p] then
            seen[p] = true
            table.insert(unique, p)
        end
    end
    return unique
end

--================================================================
-- COMMAND SYSTEM
--================================================================

local cmds = {}
local cmdDescriptions = {}

local function addcmd(name, aliases, desc, func)
    local entry = {
        NAME = name:lower(),
        ALIAS = {},
        DESC = desc or "",
        FUNC = func,
    }
    if type(aliases) == "table" then
        for _, a in ipairs(aliases) do
            table.insert(entry.ALIAS, a:lower())
        end
    end
    table.insert(cmds, entry)
    cmdDescriptions[name:lower()] = desc
    for _, a in ipairs(entry.ALIAS) do
        cmdDescriptions[a] = desc
    end
end

local function findCmd(name)
    name = name:lower()
    -- check custom aliases first
    if customAliases[name] then
        return findCmd(customAliases[name]:split(" ")[1])
    end
    for _, cmd in ipairs(cmds) do
        if cmd.NAME == name then return cmd end
        for _, a in ipairs(cmd.ALIAS) do
            if a == name then return cmd end
        end
    end
    return nil
end

local cargs = {}
local lastBreakTime = 0
local lastCmds = {}

local function getstring(begin, args)
    args = args or cargs
    return table.concat(args, " ", begin)
end

local function execCmd(cmdStr, speaker, store)
    cmdStr = cmdStr:gsub("%s+$", "")
    task.spawn(function()
        local rawCmdStr = cmdStr
        cmdStr = cmdStr:gsub("\\\\", "%%BACKSLASH%%")
        local commandsToRun = cmdStr:split("\\")

        for _, v in ipairs(commandsToRun) do
            v = v:gsub("%%BACKSLASH%%", "\\")

            -- parse repeat count: 5^command or inf^delay^command
            local num, cmdDelay, infTimes = 1, 0, false
            local x, y, n = v:find("^(%d+)%^")
            if n then
                num = tonumber(n) or 1
                v = v:sub(y + 1)
                local _, y2, del = v:find("^([%d%.]+)%^")
                if del then
                    v = v:sub(y2 + 1)
                    cmdDelay = tonumber(del) or 0
                end
            else
                local x2, y2 = v:find("^inf%^")
                if x2 then
                    infTimes = true
                    v = v:sub(y2 + 1)
                    local _, y3, del = v:find("^([%d%.]+)%^")
                    if del then
                        v = v:sub(y3 + 1)
                        cmdDelay = math.max(tonumber(del) or 1, 0.1)
                    else
                        cmdDelay = 1
                    end
                end
            end

            -- parse last command shortcut
            if v:sub(1, 1) == "!" then
                local key = v:sub(2):split(" ")[1]
                if lastCmds[key] then v = lastCmds[key] end
            end

            local args = v:split(" ")
            local cmdName = args[1]
            if not cmdName then continue end

            -- resolve custom alias
            if customAliases[cmdName:lower()] then
                local expanded = customAliases[cmdName:lower()]
                for i = 2, #args do expanded = expanded .. " " .. args[i] end
                args = expanded:split(" ")
                cmdName = args[1]
            end

            local cmd = findCmd(cmdName)
            if cmd then
                table.remove(args, 1)
                cargs = args
                speaker = speaker or player

                if store then
                    if speaker == player and rawCmdStr ~= cmdHistory[1] then
                        table.insert(cmdHistory, 1, rawCmdStr)
                        if #cmdHistory > 50 then table.remove(cmdHistory) end
                    end
                    lastCmds[cmd.NAME] = v
                end

                local startTime = tick()
                if infTimes then
                    while activeLoops[rawCmdStr] ~= false and lastBreakTime < startTime do
                        activeLoops[rawCmdStr] = true
                        pcall(cmd.FUNC, args, speaker)
                        task.wait(cmdDelay)
                    end
                    activeLoops[rawCmdStr] = nil
                else
                    for rep = 1, num do
                        if lastBreakTime > startTime then break end
                        pcall(cmd.FUNC, args, speaker)
                        if cmdDelay > 0 then task.wait(cmdDelay) end
                    end
                end
            else
                notify("Unknown Command", cmdName .. " is not a valid command")
            end
        end
    end)
end

