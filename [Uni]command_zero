local EMOTE_REPO = "https://raw.githubusercontent.com/6014m/sixzerohub/main/"
local emoteRegistry = {
    { name = "Hakari", file = "[Data]emote_hakari", icon = "dance" },
}

local loadedEmotes = {} -- name -> { tween, frames }
local currentEmote = nil -- name of currently playing emote (nil = none)
local emoteWheelOpen = false

-- Detect any active reanimate (CZ or external) by finding the fakeRig
local function findFakeRig()
    -- CZ's own reanimate
    if _G.czReanimateActive and _G.czReanimateFakeRig and _G.czReanimateFakeRig.Parent then
        return _G.czReanimateFakeRig
    end
    local char = player.Character
    if not char or not char:FindFirstChild("Torso") then return nil end
    -- Method 1: nested Model with a Humanoid inside (real char parented in fakeRig)
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Model") and child:FindFirstChildOfClass("Humanoid") then
            return char
        end
    end
    -- Method 2: character name differs from player name (compiled reanimates rename it)
    if char.Name ~= player.Name and char.Name ~= player.DisplayName then
        return char
    end
    -- Method 3: fakeRig has all-transparent visible parts (head + torso both invisible)
    local head = char:FindFirstChild("Head")
    local torso = char:FindFirstChild("Torso")
    if head and torso and head.Transparency >= 0.99 and torso.Transparency >= 0.99 then
        return char
    end
    -- Method 4: descendant BasePart has BodyVelocity (real char physics setup)
    for _, v in ipairs(char:GetDescendants()) do
        if v:IsA("BodyVelocity") and v.Parent and v.Parent:IsA("BasePart") then
            return char
        end
    end
    return nil
end

local function loadEmote(entry)
    if loadedEmotes[entry.name] then return loadedEmotes[entry.name] end
    local ok, data = pcall(function()
        local raw = game:HttpGet(EMOTE_REPO .. entry.file)
        return loadstring(raw)()
    end)
    if ok and data and data.frames then
        loadedEmotes[entry.name] = data
        return data
    end
    return nil
end

local function playEmote(emoteData, emoteName)
    local fakeRig = findFakeRig()
    if not fakeRig then return end
    local fakeTorso = fakeRig:FindFirstChild("Torso")
    local fakeHRP = fakeRig:FindFirstChild("HumanoidRootPart")
    local fakeHum = fakeRig:FindFirstChildOfClass("Humanoid")
    if not fakeTorso or not fakeHRP then return end

    local jMap = {}
    for _, m in ipairs(fakeTorso:GetChildren()) do
        if m:IsA("Motor6D") then jMap[m.Name] = m end
    end
    local rj = fakeHRP:FindFirstChild("RootJoint")
    if rj then jMap["RootJoint"] = rj end

    currentEmote = emoteName
    while currentEmote == emoteName do
        for i = 1, #emoteData.frames - 1 do
            if currentEmote ~= emoteName then return end
            if fakeHum and fakeHum.MoveDirection.Magnitude > 0.1 then currentEmote = nil; return end
            local from, to = emoteData.frames[i], emoteData.frames[i + 1]
            local st = tick()
            while tick() - st < emoteData.tween do
                if currentEmote ~= emoteName then return end
                if fakeHum and fakeHum.MoveDirection.Magnitude > 0.1 then currentEmote = nil; return end
                local a = math.clamp((tick() - st) / emoteData.tween, 0, 1)
                for name, motor in pairs(jMap) do
                    if from[name] and to[name] then motor.C0 = from[name]:Lerp(to[name], a) end
                end
                RunService.Heartbeat:Wait()
            end
            for name, motor in pairs(jMap) do if to[name] then motor.C0 = to[name] end end
        end
    end
end

