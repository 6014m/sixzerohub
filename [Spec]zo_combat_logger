---------- Health Tracking ----------

local playerHealth = {} -- [playerName] = currentHealth

local function snapshotHealth()
	for _, p in ipairs(Players:GetPlayers()) do
		local char = p.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if hum then
			playerHealth[p.Name] = hum.Health
		end
	end
end

local function checkDamage(attacker, attackerHRP, animInfo)
	-- Compare current health to snapshot — anyone who lost health got hit
	for _, target in ipairs(Players:GetPlayers()) do
		if target ~= attacker then
			local char = target.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local tHRP = char and char:FindFirstChild("HumanoidRootPart")
			if hum and tHRP and attackerHRP then
				local prevHP = playerHealth[target.Name] or hum.MaxHealth
				local curHP = hum.Health
				local dmg = prevHP - curHP
				if dmg > 0.5 then
					local dist = (tHRP.Position - attackerHRP.Position).Magnitude
					local orient = getOrientation(attackerHRP, tHRP)
					local killed = curHP <= 0

					local hit = {
						weapon = animInfo.weapon,
						move = animInfo.move,
						attacker = attacker.Name,
						target = target.Name,
						dist = math.floor(dist * 10) / 10,
						damage = math.floor(dmg * 10) / 10,
						killed = killed,
						targetToAttacker = orient.theyAreToMy,
						attackerToTarget = orient.iAmToTheir,
						fDot = math.floor(orient.fDot * 100) / 100,
						rDot = math.floor(orient.rDot * 100) / 100,
						time = os.clock(),
					}

					data.hits[#data.hits + 1] = hit

					-- Per-weapon hit ranges
					local wpnKey = animInfo.weapon .. "_" .. animInfo.move
					if not data.perWeapon[animInfo.weapon] then data.perWeapon[animInfo.weapon] = {} end
					if not data.perWeapon[animInfo.weapon][animInfo.move] then
						data.perWeapon[animInfo.weapon][animInfo.move] = { dists = {}, orientations = {}, hitDists = {}, hitOrients = {} }
					end
					local wpnMove = data.perWeapon[animInfo.weapon][animInfo.move]
					if not wpnMove.hitDists then wpnMove.hitDists = {} end
					if not wpnMove.hitOrients then wpnMove.hitOrients = {} end
					wpnMove.hitDists[#wpnMove.hitDists + 1] = hit.dist
					wpnMove.hitOrients[#wpnMove.hitOrients + 1] = hit.attackerToTarget

					saveData()

					local killTag = killed and " KILLED" or ""
					local meTag = target == lp and " [ME]" or ""
					addRow(string.format("HIT %s %s→%s | %.1f studs | %.0f dmg%s%s",
						animInfo.weapon, attacker.Name, target.Name, dist, dmg, killTag, meTag),
						killed and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(255, 200, 50))
				end
			end
		end
	end
	-- Re-snapshot after checking
	snapshotHealth()
end

---------- Event Logging ----------

local function logSingleTarget(attacker, attackerHRP, target, targetHRP, animInfo, eventType)
	local dist = (targetHRP.Position - attackerHRP.Position).Magnitude
	local orient = getOrientation(attackerHRP, targetHRP)
	local yDiff = targetHRP.Position.Y - attackerHRP.Position.Y

	local entry = {
		type = eventType,
		weapon = animInfo.weapon,
		move = animInfo.move,
		dist = math.floor(dist * 10) / 10,
		yDiff = math.floor(yDiff * 10) / 10,
		iAmToTheir = orient.iAmToTheir,
		theyAreToMy = orient.theyAreToMy,
		fDot = math.floor(orient.fDot * 100) / 100,
		rDot = math.floor(orient.rDot * 100) / 100,
		myFDot = math.floor(orient.myFDot * 100) / 100,
		myRDot = math.floor(orient.myRDot * 100) / 100,
		attacker = attacker.Name,
		target = target.Name,
		time = os.clock(),
	}

	-- Per-weapon stats
	if not data.perWeapon[animInfo.weapon] then
		data.perWeapon[animInfo.weapon] = {}
	end
	if not data.perWeapon[animInfo.weapon][animInfo.move] then
		data.perWeapon[animInfo.weapon][animInfo.move] = { dists = {}, orientations = {} }
	end
	local wpnMove = data.perWeapon[animInfo.weapon][animInfo.move]
	wpnMove.dists[#wpnMove.dists + 1] = entry.dist
	wpnMove.orientations[#wpnMove.orientations + 1] = orient.iAmToTheir

	data.events[#data.events + 1] = entry
	return entry, dist, orient
end

local function logCombatEvent(player, animInfo, eventType)
	cacheLocal()
	local attackerChar = player.Character
	local attackerHRP = attackerChar and attackerChar:FindFirstChild("HumanoidRootPart")
	if not attackerHRP then return end

	local color
	if eventType == "ATTACK" then color = Color3.fromRGB(255, 100, 100)
	elseif eventType == "BLOCK" then color = Color3.fromRGB(87, 242, 135)
	elseif eventType == "FEINT" then color = Color3.fromRGB(0, 170, 255)
	elseif eventType == "EQUIP" then color = Color3.fromRGB(255, 170, 0)
	elseif eventType == "IDLE" then color = Color3.fromRGB(140, 140, 140)
	end

	local logged = 0

	if allPlayers then
		-- Log relative to every other player in the server
		for _, target in ipairs(Players:GetPlayers()) do
			if target ~= player then
				local tChar = target.Character
				local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
				if tHRP then
					local _, dist, orient = logSingleTarget(player, attackerHRP, target, tHRP, animInfo, eventType)
					logged = logged + 1
					local tag = target == lp and " [ME]" or ""
					addRow(string.format("%s %s %s | %s%.1f | %s→%s%s",
						eventType, animInfo.weapon, animInfo.move, tag, dist,
						orient.iAmToTheir, orient.theyAreToMy, tag), color)
				end
			end
		end
	else
		-- Log relative to local player only
		if myHRP then
			local _, dist, orient = logSingleTarget(player, attackerHRP, lp, myHRP, animInfo, eventType)
			logged = 1
			addRow(string.format("%s %s %s | %.1f studs | I'm %s | They're %s",
				eventType, animInfo.weapon, animInfo.move, dist, orient.iAmToTheir, orient.theyAreToMy), color)
		end
	end

	if logged > 0 then saveData() end

	-- For attacks: snapshot health now, check for damage shortly after
	if eventType == "ATTACK" then
		snapshotHealth()
		local atkHRP = attackerHRP
		local atkInfo = animInfo
		local atkPlayer = player
		task.delay(0.3, function() checkDamage(atkPlayer, atkHRP, atkInfo) end)
		task.delay(0.6, function() checkDamage(atkPlayer, atkHRP, atkInfo) end)
	end
end

---------- Kick Timing Tracker ----------

-- blockStarts[playerName] = tick() when they started blocking
-- kickAttempts tracks: who kicked, when relative to block start, did it break
local blockStarts = {}
local lastKickTime = {}

local terrain = workspace:FindFirstChild("Terrain")
if terrain then
	local kickConn = terrain.ChildAdded:Connect(function(child)
		if child.Name == "BLOCK BROKEN BY KICK" and child:IsA("BasePart") then
			-- Find which blocker is nearest to the part
			local partPos = child.Position
			local nearest, bestDist = nil, math.huge
			for bName, bTime in pairs(blockStarts) do
				local bPlayer = Players:FindFirstChild(bName)
				local bChar = bPlayer and bPlayer.Character
				local bHRP = bChar and bChar:FindFirstChild("HumanoidRootPart")
				if bHRP then
					local d = (bHRP.Position - partPos).Magnitude
					if d < bestDist then bestDist = d; nearest = bName end
				end
			end

			if nearest and lastKickTime[nearest] then
				local blockStart = blockStarts[nearest]
				local kickTime = lastKickTime[nearest]
				local blockToKick = kickTime - blockStart
				local kickToBreak = tick() - kickTime

				local entry = {
					target = nearest,
					blockToKick = math.floor(blockToKick * 1000),  -- ms from block start to kick
					kickToBreak = math.floor(kickToBreak * 1000),  -- ms from kick to break confirm
					result = "BREAK",
					time = os.clock(),
				}
				data.kickData[#data.kickData + 1] = entry
				saveData()
				addRow(string.format("KICK BREAK %s | block→kick %dms | kick→break %dms",
					nearest, entry.blockToKick, entry.kickToBreak), Color3.fromRGB(255, 50, 255))
			end
		end
	end)
	table.insert(connections, kickConn)
end

---------- Watch Players ----------

local function watchPlayer(player, char)
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 3)
	if not animator then return end

	local c = animator.AnimationPlayed:Connect(function(track)
		if not track.Animation then return end
		local id = track.Animation.AnimationId:match("%d+")
		if not id then return end
		local info = animDB[id]
		if not info then return end

		local pName = player.Name
		local eventType

		if info.type == ATTACK then
			eventType = "ATTACK"
		elseif info.type == BLOCK then
			eventType = "BLOCK"
			blockStarts[pName] = tick()
			track.Stopped:Connect(function()
				-- Block ended — if we kicked and it didn't break, it got parried
				if lastKickTime[pName] and lastKickTime[pName] > (blockStarts[pName] or 0) then
					local blockToKick = lastKickTime[pName] - (blockStarts[pName] or lastKickTime[pName])
					local entry = {
						target = pName,
						blockToKick = math.floor(blockToKick * 1000),
						result = "PARRIED",
						time = os.clock(),
					}
					data.kickData[#data.kickData + 1] = entry
					saveData()
					addRow(string.format("KICK PARRIED by %s | block→kick %dms",
						pName, entry.blockToKick), Color3.fromRGB(255, 100, 100))
				end
				blockStarts[pName] = nil
				lastKickTime[pName] = nil
			end)
		elseif info.type == FEINT then
			eventType = "FEINT"
		elseif info.type == EQUIP then
			eventType = "EQUIP"
		elseif info.type == IDLE then
			eventType = "IDLE"
		elseif info.type == KICK then
			-- Someone kicked — record timing
			-- Find who they kicked (nearest blocker)
			local kickerChar = player.Character
			local kickerHRP = kickerChar and kickerChar:FindFirstChild("HumanoidRootPart")
			if kickerHRP then
				local nearest, bestDist = nil, math.huge
				for bName in pairs(blockStarts) do
					local bPlayer = Players:FindFirstChild(bName)
					local bChar = bPlayer and bPlayer.Character
					local bHRP = bChar and bChar:FindFirstChild("HumanoidRootPart")
					if bHRP then
						local d = (kickerHRP.Position - bHRP.Position).Magnitude
						if d < bestDist then bestDist = d; nearest = bName end
					end
				end
				if nearest then
					local now = tick()
					-- Measure cooldown between consecutive kicks on same target
					if lastKickTime[nearest] then
						local cd = now - lastKickTime[nearest]
						if cd < 5 then -- only track if reasonable (not across fights)
							if not data.kickCooldowns then data.kickCooldowns = {} end
							data.kickCooldowns[#data.kickCooldowns + 1] = math.floor(cd * 1000)
							addRow(string.format("KICK CD: %dms", math.floor(cd * 1000)), Color3.fromRGB(200, 200, 50))
						end
					end
					lastKickTime[nearest] = now
					local delay = now - (blockStarts[nearest] or now)
					addRow(string.format("KICK %s→%s | %.0fms after block | %.1f studs",
						pName, nearest, delay * 1000, bestDist), Color3.fromRGB(255, 170, 0))
				end
			end
			eventType = "KICK"
		elseif info.type == 6 then
			-- Stagger
			eventType = "STAGGER"
			addRow("STAGGER " .. pName, Color3.fromRGB(255, 50, 255))
		end

		if eventType and info.type ~= KICK and info.type ~= 6 then
			logCombatEvent(player, info, eventType)
		end
	end)
	table.insert(connections, c)
end

local function hookPlayer(player)
	-- Watch ALL players including self (need to see our own kicks + everyone's blocks)
	if player.Character then task.spawn(watchPlayer, player, player.Character) end
	local c = player.CharacterAdded:Connect(function(char)
		task.wait(0.3)
		task.spawn(watchPlayer, player, char)
	end)
	table.insert(connections, c)
end

for _, p in ipairs(Players:GetPlayers()) do task.spawn(hookPlayer, p) end
Players.PlayerAdded:Connect(function(p) task.spawn(hookPlayer, p) end)

