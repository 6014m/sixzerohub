---------- Orientation ----------

local function getOrientation(attackerHRP, targetHRP)
	-- Direction from attacker to target
	local dir = (targetHRP.Position - attackerHRP.Position).Unit
	local look = attackerHRP.CFrame.LookVector
	local right = attackerHRP.CFrame.RightVector

	local fDot = look.X * dir.X + look.Z * dir.Z -- +1 = directly in front, -1 = behind
	local rDot = right.X * dir.X + right.Z * dir.Z -- +1 = to their right, -1 = to their left

	-- Where am I relative to the attacker?
	local facing
	if fDot > 0.7 then facing = "FRONT"
	elseif fDot < -0.7 then facing = "BEHIND"
	elseif rDot > 0.5 then facing = "RIGHT"
	elseif rDot < -0.5 then facing = "LEFT"
	elseif fDot > 0 and rDot > 0 then facing = "FRONT-RIGHT"
	elseif fDot > 0 and rDot < 0 then facing = "FRONT-LEFT"
	elseif fDot < 0 and rDot > 0 then facing = "BEHIND-RIGHT"
	else facing = "BEHIND-LEFT"
	end

	-- Where is attacker relative to ME?
	local dir2 = (attackerHRP.Position - targetHRP.Position).Unit
	local myLook = targetHRP.CFrame.LookVector
	local myRight = targetHRP.CFrame.RightVector
	local myFDot = myLook.X * dir2.X + myLook.Z * dir2.Z
	local myRDot = myRight.X * dir2.X + myRight.Z * dir2.Z

	local myFacing
	if myFDot > 0.7 then myFacing = "FRONT"
	elseif myFDot < -0.7 then myFacing = "BEHIND"
	elseif myRDot > 0.5 then myFacing = "RIGHT"
	elseif myRDot < -0.5 then myFacing = "LEFT"
	elseif myFDot > 0 and myRDot > 0 then myFacing = "FRONT-RIGHT"
	elseif myFDot > 0 and myRDot < 0 then myFacing = "FRONT-LEFT"
	elseif myFDot < 0 and myRDot > 0 then myFacing = "BEHIND-RIGHT"
	else myFacing = "BEHIND-LEFT"
	end

	return {
		iAmToTheir = facing,      -- where I am relative to attacker
		theyAreToMy = myFacing,   -- where attacker is relative to me
		fDot = fDot, rDot = rDot, -- raw dots (attacker perspective)
		myFDot = myFDot, myRDot = myRDot, -- raw dots (my perspective)
	}
end

