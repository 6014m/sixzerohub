---------- State ----------

local blocking = false
local blockSource = nil
local lastKick = 0
local lastPunish = 0
local myChar, myHRP

local function cache()
	myChar = lp.Character
	myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
end
cache()
lp.CharacterAdded:Connect(function() task.wait(0.3); cache() end)

local function dist(hrp)
	if not myHRP or not hrp then return 999 end
	return (myHRP.Position - hrp.Position).Magnitude
end

---------- Core: GLINT = BLOCK ----------

local function onGlint(player)
	cache()
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if dist(hrp) > RANGE then return end

	m2down()
	blocking = true
	blockSource = player.Name
	flash("BLOCK — " .. player.Name, Color3.fromRGB(87, 242, 135))

	-- Hold block for up to 2s
	task.delay(2, function()
		if blocking and blockSource == player.Name then
			m2up()
			blocking = false
			blockSource = nil
			flash("Block released", Color3.fromRGB(140, 140, 140))
		end
	end)
end

---------- Core: responses to animations ----------

local function onAnim(player, id)
	cache()
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local d = dist(hrp)

	-- ATTACK — block via GLINT instead, but fallback if no GLINT
	if ATTACKS[id] then
		if d <= RANGE then
			flash("SAW ATTACK " .. player.Name .. " [" .. ATTACKS[id] .. "] " .. math.floor(d) .. "s", Color3.fromRGB(255, 255, 255))
		end
		return
	end

	-- BLOCK — they're blocking, kick them
	if BLOCKS[id] then
		if d <= RANGE and tick() - lastKick > 0.5 then
			lastKick = tick()
			task.delay(0.7, function()
				-- Recheck they're still nearby
				cache()
				local chr2 = player.Character
				local hrp2 = chr2 and chr2:FindFirstChild("HumanoidRootPart")
				if dist(hrp2) <= RANGE then
					pressF()
					flash("KICK " .. player.Name, Color3.fromRGB(255, 100, 100))
				end
			end)
		end
		return
	end

	-- FEINT — release block and punish
	if FEINTS[id] then
		if blocking and blockSource == player.Name then
			m2up()
			blocking = false
			blockSource = nil
		end
		if d <= RANGE and tick() - lastPunish > 0.3 then
			lastPunish = tick()
			m1tap()
			flash("PUNISH FEINT " .. player.Name, Color3.fromRGB(0, 170, 255))
		end
		return
	end

	-- KICK — they're kicking, dodge if we're blocking
	if KICKS[id] then
		if blocking and d <= RANGE then
			blocking = false
			blockSource = nil
			backDash()
			flash("DODGE KICK " .. player.Name, Color3.fromRGB(255, 255, 0))
		end
		return
	end

	-- STAGGER — execute
	if STAGGERS[id] then
		if d <= RANGE then
			pressE()
			flash("EXECUTE " .. player.Name, Color3.fromRGB(255, 50, 255))
		end
		return
	end

	-- EQUIP
	if EQUIPS[id] then
		if d <= RANGE then
			flash("EQUIP " .. player.Name .. " " .. EQUIPS[id], Color3.fromRGB(255, 170, 0))
		end
		return
	end
end

---------- Hook players ----------

local hooked = {}

local function hookChar(player, char)
	if not char then return end
	local key = player.Name .. "_" .. tostring(char)
	if hooked[key] then return end
	hooked[key] = true

	-- Hook animator
	task.spawn(function()
		local hum = char:WaitForChild("Humanoid", 10)
		if not hum then warn("[ZoAP] no hum: " .. player.Name); return end
		local animator = hum:FindFirstChildOfClass("Animator")
		if not animator then animator = hum:WaitForChild("Animator", 5) end
		if not animator then warn("[ZoAP] no animator: " .. player.Name); return end

		flash("Hooked " .. player.Name, Color3.fromRGB(100, 100, 100))

		local c = animator.AnimationPlayed:Connect(function(track)
			if not track.Animation then return end
			local id = track.Animation.AnimationId:match("%d+")
			if id then onAnim(player, id) end
		end)
		table.insert(connections, c)
	end)

	-- Hook GLINT
	local g = char.DescendantAdded:Connect(function(desc)
		if desc.Name == "GLINT" then
			onGlint(player)
		end
	end)
	table.insert(connections, g)
end

local function hookPlayer(player)
	if player == lp then return end
	if player.Character then hookChar(player, player.Character) end
	local c = player.CharacterAdded:Connect(function(char)
		task.wait(0.3)
		hookChar(player, char)
	end)
	table.insert(connections, c)
end

for _, p in ipairs(Players:GetPlayers()) do hookPlayer(p) end
Players.PlayerAdded:Connect(hookPlayer)

-- Also rehook on respawns we might miss
task.spawn(function()
	while true do
		task.wait(5)
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= lp and p.Character then
				hookChar(p, p.Character)
			end
		end
	end
end)

