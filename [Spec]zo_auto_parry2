---------- Input ----------

local function m2down()
	pcall(function() if mouse2press then mouse2press() else game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton2, true, game, 1) end end)
end
local function m2up()
	pcall(function() if mouse2release then mouse2release() else game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton2, false, game, 1) end end)
end
local function m1tap()
	pcall(function()
		if mouse1press then mouse1press(); task.delay(0.15, mouse1release)
		else local V = game:GetService("VirtualInputManager"); V:SendMouseButtonEvent(0,0,Enum.UserInputType.MouseButton1,true,game,1); task.delay(0.15,function() V:SendMouseButtonEvent(0,0,Enum.UserInputType.MouseButton1,false,game,1) end) end
	end)
end
local function ktap(code)
	pcall(function()
		if keypress then keypress(code); task.delay(0.15, function() keyrelease(code) end)
		else local V = game:GetService("VirtualInputManager"); V:SendKeyEvent(true, code, false, game); task.delay(0.15, function() V:SendKeyEvent(false, code, false, game) end) end
	end)
end
local function pressF() ktap(0x46) end
local function pressE() ktap(0x45) end
local function backDash()
	m2up()
	pcall(function()
		if keypress then
			keypress(0x53)
			task.delay(0.05, function() keypress(0x52); task.delay(0.15, function() keyrelease(0x52) end) end)
			task.delay(0.4, function() keyrelease(0x53) end)
		end
	end)
end

