            blockedAudios[capturedKey] = { id = capturedId, name = capturedName, rapidOnly = true }
            saveBlocked()
            refreshActiveList()
            refreshBlockedList()
        end)
    end
end

---------- PERIODIC REFRESH ----------

task.spawn(function()
    task.wait(1)
    scanForSounds()
    while active and screenGui and screenGui.Parent do
        scanForSounds()
        -- enforce blocks on all currently playing sounds
        for _, desc in ipairs(workspace:GetDescendants()) do
            if desc:IsA("Sound") and desc.IsPlaying then
                enforceBlock(desc)
            end
        end
        -- refresh GUI if open
        if guiOpen and main.Visible then
            refreshActiveList()
            refreshBlockedList()
        end
        task.wait(SCAN_INTERVAL)
    end
end)

---------- RE-EXECUTE: REOPEN GUI ----------

do
    local genv = getgenv and getgenv() or _G
    if genv.AUDIO_BLOCKER_GUI then
        pcall(function() genv.AUDIO_BLOCKER_GUI:Destroy() end)
    end
    genv.AUDIO_BLOCKER_GUI = screenGui

    -- if re-executed, just show the GUI and return
    if genv.AUDIO_BLOCKER_ACTIVE then
        main.Visible = true
        guiOpen = true
        return
    end
    genv.AUDIO_BLOCKER_ACTIVE = true
end

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    if previewSound and previewSound.Parent then
        previewSound:Stop()
        previewSound:Destroy()
    end
    pcall(function() screenGui:Destroy() end)
    local genv = getgenv and getgenv() or _G
    genv.AUDIO_BLOCKER_ACTIVE = nil
    genv.AUDIO_BLOCKER_GUI = nil
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Audio Blocker", "[Uni]audio_blocker", cleanup, "uni")
end
