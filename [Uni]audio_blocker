---------- PERSISTENCE ----------

-- blockedAudios: { [tostring(soundId)] = { id=number, name=string, rapidOnly=bool } }
local blockedAudios = {}
pcall(function()
    if isfile and isfile(BLOCKED_FILE) then
        local raw = readfile(BLOCKED_FILE)
        local decoded = HttpService:JSONDecode(raw)
        if type(decoded) == "table" then
            blockedAudios = decoded
        end
    end
end)

local function saveBlocked()
    pcall(function()
        if writefile then
            writefile(BLOCKED_FILE, HttpService:JSONEncode(blockedAudios))
        end
    end)
end

---------- RAPID PLAY TRACKING ----------

-- tracks recent play timestamps per sound id
local playHistory = {} -- [soundId] = { timestamp, timestamp, ... }

local function recordPlay(soundId)
    local key = tostring(soundId)
    if not playHistory[key] then playHistory[key] = {} end
    table.insert(playHistory[key], os.clock())
end

local function isRapidPlaying(soundId)
    local key = tostring(soundId)
    local history = playHistory[key]
    if not history then return false end

    local now = os.clock()
    -- clean old entries
    local recent = {}
    for _, t in ipairs(history) do
        if now - t < RAPID_WINDOW then
            table.insert(recent, t)
        end
    end
    playHistory[key] = recent
    return #recent >= RAPID_THRESHOLD
end

---------- AUDIO MONITORING ----------

local knownSounds = {} -- [Sound instance] = true
local activeSounds = {} -- [tostring(soundId)] = { sound=Sound, name=string, path=string }
local previewSound = nil

local function getSoundDisplayName(sound)
    local name = sound.Name
    if name == "Sound" or name == "" then
        name = "Audio " .. tostring(sound.SoundId):match("%d+") or "?"
    end
    local parent = sound.Parent
    local path = parent and parent:GetFullName() or "?"
    return name, path
end

local function getSoundIdNum(sound)
    local id = tostring(sound.SoundId)
    return tonumber(id:match("%d+")) or 0
end

local function shouldBlock(sound)
    local idNum = getSoundIdNum(sound)
    if idNum == 0 then return false end
    local key = tostring(idNum)
    local entry = blockedAudios[key]
    if not entry then return false end
    if entry.rapidOnly then
        return isRapidPlaying(idNum)
    end
    return true
end

local function enforceBlock(sound)
    if shouldBlock(sound) then
        sound.Volume = 0
        pcall(function() sound:Stop() end)
    end
end

local function hookSound(sound)
    if knownSounds[sound] then return end
    knownSounds[sound] = true

    local conn = sound.Played:Connect(function()
        if not active then return end
        local idNum = getSoundIdNum(sound)
        if idNum == 0 then return end
        recordPlay(idNum)

        local key = tostring(idNum)
        if not activeSounds[key] then
            local name, path = getSoundDisplayName(sound)
            activeSounds[key] = { sound = sound, name = name, path = path, id = idNum }
        end

        enforceBlock(sound)
    end)
    table.insert(connections, conn)

    -- also check if already playing
    if sound.IsPlaying then
        local idNum = getSoundIdNum(sound)
        if idNum ~= 0 then
            recordPlay(idNum)
            local key = tostring(idNum)
            if not activeSounds[key] then
                local name, path = getSoundDisplayName(sound)
                activeSounds[key] = { sound = sound, name = name, path = path, id = idNum }
            end
            enforceBlock(sound)
        end
    end
end

local function scanForSounds()
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("Sound") then hookSound(desc) end
    end
    pcall(function()
        for _, desc in ipairs(game:GetService("SoundService"):GetDescendants()) do
            if desc:IsA("Sound") then hookSound(desc) end
        end
    end)
    pcall(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.Character then
                for _, desc in ipairs(plr.Character:GetDescendants()) do
                    if desc:IsA("Sound") then hookSound(desc) end
                end
            end
        end
    end)
end

-- watch for new sounds
local wsConn = workspace.DescendantAdded:Connect(function(desc)
    if active and desc:IsA("Sound") then hookSound(desc) end
end)
table.insert(connections, wsConn)

pcall(function()
    local ssConn = game:GetService("SoundService").DescendantAdded:Connect(function(desc)
        if active and desc:IsA("Sound") then hookSound(desc) end
    end)
    table.insert(connections, ssConn)
end)

