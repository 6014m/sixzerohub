        if raw == "" then statusLbl.Text = "Paste animation data first"; return end

        statusLbl.Text = "Parsing..."

        -- Extract tweenDuration and keyframes from the pasted script
        local ok2, result = pcall(function()
            -- The pasted script has `local tweenDuration = X` and `local keyframes = {...}`
            -- Wrap it to return both values
            local wrapped = raw
                :gsub("^.-(local%s+tweenDuration)", "%1") -- strip anything before tweenDuration
                :gsub("local%s+function%s+playAnim.+$", "") -- strip playAnim function
                :gsub("%-%-[^\n]*", "") -- strip comments
                :gsub("local%s+RunService.-\n", "") -- strip RunService line

            local fn = loadstring(wrapped .. "\nreturn {tween = tweenDuration, frames = keyframes}")
            if not fn then error("Failed to parse") end
            return fn()
        end)

        if not ok2 or not result or not result.frames or #result.frames == 0 then
            statusLbl.Text = "Failed to parse — make sure you pasted the full script"
            print("[Compiler] Parse error: " .. tostring(result))
            return
        end

        local animName = nameBox.Text ~= "" and nameBox.Text or (slot .. " " .. (#animations + 1))
        local entry = {
            slot = slot,
            name = animName,
            tween = result.tween or 0.016,
            frames = result.frames,
            hitRange = 10,
            hitFrame = math.floor(#result.frames / 3),
        }
        table.insert(animations, entry)
        popup:Destroy()
        refreshList()
        print("[Compiler] Added " .. slot .. " with " .. #result.frames .. " frames")
    end)
end

---------- SAMPLE ANIMATION (same Animator method as poser) ----------

function sampleAnimation(animId, statusLbl)
    local real = player.Character
    if not real then if statusLbl then statusLbl.Text = "No character" end; return nil end
    local hum = real:FindFirstChildOfClass("Humanoid")
    if not hum or hum.RigType ~= Enum.HumanoidRigType.R6 then if statusLbl then statusLbl.Text = "R6 only" end; return nil end

    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then animator = Instance.new("Animator"); animator.Parent = hum end

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animId)

    local ok2, track = pcall(function() return animator:LoadAnimation(anim) end)
    if not ok2 or not track then if statusLbl then statusLbl.Text = "Failed: " .. tostring(track) end; return nil end

    for _, t in ipairs(animator:GetPlayingAnimationTracks()) do t:Stop(0) end
    task.wait(0.1)

    track.Priority = Enum.AnimationPriority.Action4
    track:Play()

    local waited = 0
    while track.Length <= 0 and waited < 5 do task.wait(0.1); waited = waited + 0.1 end

    if track.Length <= 0 then track:Stop(); if statusLbl then statusLbl.Text = "Animation failed to load" end; return nil end

    local length = track.Length
    if statusLbl then statusLbl.Text = "Sampling " .. string.format("%.2f", length) .. "s..." end

    local torso = real:FindFirstChild("Torso")
    local hrpReal = real:FindFirstChild("HumanoidRootPart")
    local sampledFrames = {}

    local startTime = tick()
    while tick() - startTime < length + 0.03 do
        local pose = {}
        if torso then
            for _, m in ipairs(torso:GetChildren()) do
                if m:IsA("Motor6D") then pose[m.Name] = m.C0 * m.Transform end
            end
        end
        if hrpReal then
            local rj = hrpReal:FindFirstChild("RootJoint")
            if rj then pose["RootJoint"] = rj.C0 * rj.Transform end
        end
        table.insert(sampledFrames, pose)
        RunService.Heartbeat:Wait()
    end

    track:Stop(0)

    -- Exact-match dedup + loop detection
    local function framesEqual(a, b)
        for name, cfA in pairs(a) do
            local cfB = b[name]
            if not cfB or cfA ~= cfB then return false end
        end
        for name in pairs(b) do if not a[name] then return false end end
        return true
    end

    local cutPoint = nil
    for i = 2, #sampledFrames do
        for j = 1, i - 1 do
            if framesEqual(sampledFrames[i], sampledFrames[j]) then cutPoint = i; break end
        end
        if cutPoint then break end
    end

    if cutPoint and cutPoint > 2 then
        local trimmed = {}
        for i = 1, cutPoint - 1 do table.insert(trimmed, sampledFrames[i]) end
        sampledFrames = trimmed
    end

    local tw = length / math.max(#sampledFrames - 1, 1)
    if statusLbl then statusLbl.Text = "Done: " .. #sampledFrames .. " frames" end
    return sampledFrames, tw
end

---------- COMPILE OUTPUT ----------

local function compileScript()
    if #animations == 0 then print("[Compiler] No animations added"); return end

    local out = {}
    local function w(s) table.insert(out, s) end

    w("--[[ Reanimate Script — Generated by Reanim Compiler ]]")
    w("")
    w("local Players = game:GetService('Players')")
    w("local RunService = game:GetService('RunService')")
    w("local UIS = game:GetService('UserInputService')")
    w("local player = Players.LocalPlayer")
    w("local char = player.Character")
    w("if not char then return end")
    w("local hum = char:FindFirstChildOfClass('Humanoid')")
    w("local rootP = char:FindFirstChild('HumanoidRootPart')")
    w("if not hum or not rootP then return end")
    w("if hum.RigType ~= Enum.HumanoidRigType.R6 then warn('R6 only'); return end")
    w("")
    w("local active = true")
    w("local rEvents = {}")
    w("local shp = sethiddenproperty or set_hidden_property or function() end")
    w("")

    -- Output animation data
    for idx, anim in ipairs(animations) do
        local varName = (anim.name or anim.slot):gsub("[^%w]", "_"):gsub("_+", "_"):gsub("^_", ""):gsub("_$", "")
        w("-- " .. (anim.name or anim.slot) .. " (" .. anim.slot .. ", " .. #anim.frames .. " frames)")
        w("local " .. varName .. "Tween = " .. anim.tween)
        w("local " .. varName .. "Frames = {")
        for _, frame in ipairs(anim.frames) do
            local parts = {}
            for name, cf in pairs(frame) do
                local c = {cf:GetComponents()}
                local nums = {}
                for _, n in ipairs(c) do table.insert(nums, string.format("%.4f", n)) end
                table.insert(parts, '["' .. name .. '"]=CFrame.new(' .. table.concat(nums, ",") .. ")")
            end
            w("    {" .. table.concat(parts, ",") .. "},")
        end
        w("}")
        w("")
    end

    -- Reanimate setup
    w("---------- FE REANIMATE ----------")
    w("")
    w("char.Archivable = true")
    w("if char:FindFirstChild('Animate') then char.Animate.Disabled = true; for _,t in pairs(hum:GetPlayingAnimationTracks()) do t:Stop() end end")
    w("hum:ChangeState('Physics')")
    w("pcall(function() player.ReplicationFocus = workspace; settings().Physics.AllowSleep = false; shp(workspace, 'PhysicsSteppingMethod', Enum.PhysicsSteppingMethod.Fixed) end)")
    w("")
    w("local fakeRig = char:Clone(); fakeRig.Name = 'CompiledReanim'")
    w("for _,v in pairs(fakeRig:GetDescendants()) do if v:IsA('BasePart') or v:IsA('Decal') then v.Transparency=1 elseif v:IsA('SpecialMesh') then v.MeshId='' elseif v:IsA('LocalScript') or v:IsA('Script') then v:Destroy() end end")
    w("fakeRig.HumanoidRootPart.CFrame = rootP.CFrame; fakeRig.Parent = workspace")
    w("")
    w("local fakeHum = fakeRig:FindFirstChildOfClass('Humanoid')")
    w("fakeHum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None")
    w("fakeHum.BreakJointsOnDeath = false; fakeHum.PlatformStand = false")
    w("fakeHum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)")
    w("fakeHum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)")
    w("fakeHum:ChangeState(Enum.HumanoidStateType.GettingUp)")
    w("")
    w("char.Parent = fakeRig; workspace.CurrentCamera.CameraSubject = fakeHum; hum.PlatformStand = true")
    w("")
    w("local vel = Vector3.new(0, 0, -25.8); local bvs = {}")
    w("for _,v in pairs(char:GetDescendants()) do if v:IsA('BasePart') then v.CustomPhysicalProperties=PhysicalProperties.new(0,0,0,0,0); v.Massless=true; v.RootPriority=127; local abv=Instance.new('BodyAngularVelocity'); abv.P=math.huge; abv.MaxTorque=Vector3.new(math.huge,math.huge,math.huge); abv.AngularVelocity=Vector3.zero; abv.Parent=v; local bv=Instance.new('BodyVelocity'); bv.P=math.huge; bv.MaxForce=Vector3.new(math.huge,math.huge,math.huge); bv.Velocity=Vector3.zero; bv.Parent=v; table.insert(bvs,bv) end end")
    w("")
    w("local offsets = {['Torso']=fakeRig:FindFirstChild('Torso'),['Right Arm']=fakeRig:FindFirstChild('Right Arm'),['Left Arm']=fakeRig:FindFirstChild('Left Arm'),['Right Leg']=fakeRig:FindFirstChild('Right Leg'),['Left Leg']=fakeRig:FindFirstChild('Left Leg')}")
    w("local rootOff = 0.02; task.spawn(function() while active do task.wait(0.05); rootOff=rootOff*-1 end end)")
    w("local charDesc = char:GetDescendants()")
    w("")
    w("local flingTargetHRP = nil; local FLING_POWER = 250")
    w("")
    w("table.insert(rEvents, RunService.PreSimulation:Connect(function() if not active then return end; for _,v in pairs(charDesc) do if v:IsA('BasePart') and v.Parent then v.CanCollide=false; v.CanQuery=false; v.CanTouch=false end end; pcall(function() fakeRig.Head.CanCollide=false; fakeRig.Torso.CanCollide=false end) end))")
    w("")
    w("table.insert(rEvents, RunService.Heartbeat:Connect(function() if not active then return end; pcall(function() settings().Physics.AllowSleep=false; shp(player,'MaximumSimulationRadius',math.huge); shp(player,'SimulationRadius',math.huge) end); pcall(function() local t=char:FindFirstChild('Torso'); if t then t.AssemblyLinearVelocity=vel end end)")
    w("    if flingTargetHRP and flingTargetHRP.Parent then local dir=(flingTargetHRP.Position-rootP.Position); if dir.Magnitude>1 then dir=dir.Unit end; local fv=dir*FLING_POWER+Vector3.new(0,FLING_POWER*0.4,0); for _,bv in pairs(bvs) do bv.Velocity=fv end; rootP.CFrame=flingTargetHRP.CFrame*CFrame.new(0,0,-1); return end")
    w("    for _,bv in pairs(bvs) do bv.Velocity=vel end; for name,fakePart in pairs(offsets) do local realPart=char:FindFirstChild(name); if realPart and fakePart and realPart.Parent and fakePart.Parent then realPart.CFrame=fakePart.CFrame end end")
    w("    for _,v in pairs(char:GetChildren()) do if v:IsA('Accessory') and v:FindFirstChild('Handle') then local fa=fakeRig:FindFirstChild(v.Name); if fa and fa:FindFirstChild('Handle') then v.Handle.CFrame=fa.Handle.CFrame end end end")
    w("    rootP.CFrame=(char:FindFirstChild('Torso') or rootP).CFrame*CFrame.new(0,rootOff,0) end))")
    w("")
    w("local function onDeath() active=false; char.Parent=workspace; player.Character=workspace:FindFirstChild(char.Name); hum:ChangeState(15); pcall(function() hum.PlatformStand=false end); if fakeRig then fakeRig:Destroy() end; for _,e in pairs(rEvents) do pcall(function() e:Disconnect() end) end end")
    w("table.insert(rEvents, fakeHum.Died:Connect(onDeath))")
    w("player.Character = fakeRig")
    w("task.spawn(function() task.wait(Players.RespawnTime+0.5); pcall(function() local h=char:FindFirstChild('Head'); if h then h:BreakJoints() end end); offsets['Head']=fakeRig:FindFirstChild('Head') end)")
    w("")
    w("task.wait(0.3)")
    w("")

    -- Animation player setup
    w("---------- ANIMATION PLAYER ----------")
    w("")
    w("local fakeTorso = fakeRig:FindFirstChild('Torso')")
    w("local fakeHRP = fakeRig:FindFirstChild('HumanoidRootPart')")
    w("if not fakeTorso or not fakeHRP then return end")
    w("local jMap = {}; for _,m in ipairs(fakeTorso:GetChildren()) do if m:IsA('Motor6D') then jMap[m.Name]=m end end")
    w("local fakeRJ = fakeHRP:FindFirstChild('RootJoint'); if fakeRJ then jMap['RootJoint']=fakeRJ end")
    w("")
    w("local currentAnim = 'idle'")
    w("local attacking = false")
    w("")
    w("local function playCycle(frames, tween, animName)")
    w("    for i = 1, #frames - 1 do")
    w("        if not active or currentAnim ~= animName then return end")
    w("        local from, to = frames[i], frames[i+1]")
    w("        local st = tick()")
    w("        while tick() - st < tween do")
    w("            if not active or currentAnim ~= animName then return end")
    w("            local a = math.clamp((tick()-st)/tween, 0, 1)")
    w("            for name, motor in pairs(jMap) do if from[name] and to[name] then motor.C0 = from[name]:Lerp(to[name], a) end end")
    w("            RunService.Heartbeat:Wait()")
    w("        end")
    w("        for name, motor in pairs(jMap) do if to[name] then motor.C0 = to[name] end end")
    w("    end")
    w("end")
    w("")

    -- Fling helper for attacks
    local hasAttacks = false
    for _, a in ipairs(animations) do if a.slot:find("attack") then hasAttacks = true; break end end

    if hasAttacks then
        w("local function findTargets(radius)")
        w("    if not fakeHRP then return {} end")
        w("    local pos, look = fakeHRP.Position, fakeHRP.CFrame.LookVector")
        w("    local targets = {}")
        w("    for _, p in ipairs(Players:GetPlayers()) do")
        w("        if p ~= player and p.Character then")
        w("            local tHRP = p.Character:FindFirstChild('HumanoidRootPart')")
        w("            if tHRP then local off = tHRP.Position - pos; if off.Magnitude < radius and look:Dot(off.Unit) > 0.2 then table.insert(targets, tHRP) end end")
        w("        end")
        w("    end")
        w("    return targets")
        w("end")
        w("")
    end

    -- Build attacks list
    local m1Attacks = {}
    local keybindAnims = {}
    for _, a in ipairs(animations) do
        if a.slot == "attack" then table.insert(m1Attacks, a) end
        if a.slot == "keybind attack" or a.slot == "keybind animation" then table.insert(keybindAnims, a) end
    end

    -- M1 combo system
    if #m1Attacks > 0 then
        w("local m1Attacks = {")
        for i, a in ipairs(m1Attacks) do
            local varName = "attack_" .. (i + ({} and 0 or 0)) -- find actual index
            for idx2, a2 in ipairs(animations) do if a2 == a then varName = a2.slot:gsub(" ", "_") .. "_" .. idx2; break end end
            w("    { frames=" .. varName .. "Frames, tween=" .. varName .. "Tween, hitFrame=" .. (a.hitFrame or 4) .. ", hitRange=" .. (a.hitRange or 10) .. " },")
        end
        w("}")
        w("local comboIndex = 1; local lastAttackTime = 0; local COMBO_WINDOW = 0.8")
        w("")
        w("local function playAttack(atk)")
        w("    attacking = true; currentAnim = 'attack'")
        w("    for i = 1, #atk.frames - 1 do")
        w("        if not active then break end")
        w("        if i == atk.hitFrame then local targets = findTargets(atk.hitRange); for _,tHRP in ipairs(targets) do task.spawn(function() flingTargetHRP=tHRP; task.wait(0.15); flingTargetHRP=nil end) end end")
        w("        local from, to = atk.frames[i], atk.frames[i+1]; local st = tick()")
        w("        while tick()-st < atk.tween do if not active then break end; local a=math.clamp((tick()-st)/atk.tween,0,1); for name,motor in pairs(jMap) do if from[name] and to[name] then motor.C0=from[name]:Lerp(to[name],a) end end; RunService.Heartbeat:Wait() end")
        w("        for name,motor in pairs(jMap) do if to[name] then motor.C0=to[name] end end")
        w("    end")
        w("    lastAttackTime = tick(); attacking = false")
        w("end")
        w("")
        w("table.insert(rEvents, UIS.InputBegan:Connect(function(input, gpe) if gpe or not active then return end; if input.UserInputType == Enum.UserInputType.MouseButton1 then if attacking then return end; if tick()-lastAttackTime > COMBO_WINDOW then comboIndex=1 end; playAttack(m1Attacks[comboIndex]); comboIndex=(comboIndex%#m1Attacks)+1 end end))")
        w("")
    end

    -- Keybind attacks/animations
    for _, a in ipairs(keybindAnims) do
        if a.keybind then
            local varName
            for idx2, a2 in ipairs(animations) do if a2 == a then varName = a2.slot:gsub(" ", "_") .. "_" .. idx2; break end end
            if a.slot == "keybind attack" then
                w("table.insert(rEvents, UIS.InputBegan:Connect(function(input, gpe) if gpe or not active or attacking then return end")
                w("    if input.KeyCode == Enum.KeyCode." .. a.keybind .. " then")
                w("        attacking = true; currentAnim = 'attack'")
                w("        for i = 1, #" .. varName .. "Frames - 1 do")
                w("            if not active then break end")
                w("            if i == " .. (a.hitFrame or 4) .. " then local targets = findTargets(" .. (a.hitRange or 10) .. "); for _,tHRP in ipairs(targets) do task.spawn(function() flingTargetHRP=tHRP; task.wait(0.15); flingTargetHRP=nil end) end end")
                w("            local from, to = " .. varName .. "Frames[i], " .. varName .. "Frames[i+1]; local st = tick()")
                w("            while tick()-st < " .. varName .. "Tween do if not active then break end; local a=math.clamp((tick()-st)/" .. varName .. "Tween,0,1); for name,motor in pairs(jMap) do if from[name] and to[name] then motor.C0=from[name]:Lerp(to[name],a) end end; RunService.Heartbeat:Wait() end")
                w("            for name,motor in pairs(jMap) do if to[name] then motor.C0=to[name] end end")
                w("        end")
                w("        attacking = false")
                w("    end")
                w("end))")
            else
                w("table.insert(rEvents, UIS.InputBegan:Connect(function(input, gpe) if gpe or not active or attacking then return end")
                w("    if input.KeyCode == Enum.KeyCode." .. a.keybind .. " then")
                w("        attacking = true; currentAnim = 'keybind'")
                w("        playCycle(" .. varName .. "Frames, " .. varName .. "Tween, 'keybind')")
                w("        attacking = false")
                w("    end")
                w("end))")
            end
            w("")
        end
    end

    -- Movement detection
    w("table.insert(rEvents, RunService.Heartbeat:Connect(function() if not active or attacking then return end; local moving = fakeHum.MoveDirection.Magnitude > 0.1; currentAnim = moving and 'walk' or 'idle' end))")
    w("")

    -- Main animation loop
    w("task.spawn(function()")
    w("    while active do")
    w("        if attacking then RunService.Heartbeat:Wait()")

    -- Walk
    local walkAnim = nil; local idleAnim = nil
    for _, a in ipairs(animations) do
        if a.slot == "idle" then idleAnim = a end
        if a.slot == "walk" then walkAnim = a end
    end

    if walkAnim then
        local varName; for idx2, a2 in ipairs(animations) do if a2 == walkAnim then varName = "walk_" .. idx2; break end end
        w("        elseif currentAnim == 'walk' then playCycle(" .. varName .. "Frames, " .. varName .. "Tween, 'walk')")
    end
    if idleAnim then
        local varName; for idx2, a2 in ipairs(animations) do if a2 == idleAnim then varName = "idle_" .. idx2; break end end
        w("        else playCycle(" .. varName .. "Frames, " .. varName .. "Tween, 'idle')")
    else
        w("        else RunService.Heartbeat:Wait()")
    end

    w("        end")
    w("    end")
    w("end)")
    w("")
    w("print('[Reanim] Compiled script loaded — ' .. " .. #animations .. " .. ' animations')")

    local result = table.concat(out, "\n")

    -- Copy to clipboard
    pcall(function()
        if setclipboard then setclipboard(result)
        elseif toclipboard then toclipboard(result) end
    end)

    -- Also save to file
    pcall(function()
        if writefile then writefile("CompiledReanim.lua", result) end
    end)

    print("[Compiler] Script compiled (" .. #result .. " chars, " .. #animations .. " animations) — copied to clipboard + saved to CompiledReanim.lua")
    return result
end

