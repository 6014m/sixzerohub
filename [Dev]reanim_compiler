---------- ANIMATION SLOT CATEGORIES ----------

local SINGLE_SLOTS = { "idle", "walk", "run", "jump", "fall" }
local MULTI_SLOTS = { "attack", "ranged attack", "keybind attack", "keybind animation" }
local SPECIAL_SLOTS = { "near ledge", "near wall", "fly" }
local ALL_SLOTS = {}
for _, s in ipairs(SINGLE_SLOTS) do table.insert(ALL_SLOTS, s) end
for _, s in ipairs(SPECIAL_SLOTS) do table.insert(ALL_SLOTS, s) end
for _, s in ipairs(MULTI_SLOTS) do table.insert(ALL_SLOTS, s) end

local function isMultiSlot(slot)
    for _, s in ipairs(MULTI_SLOTS) do if s == slot then return true end end
    return false
end

local function isSingleSlot(slot)
    for _, s in ipairs(SINGLE_SLOTS) do if s == slot then return true end end
    for _, s in ipairs(SPECIAL_SLOTS) do if s == slot then return true end end
    return false
end

local function hasSlot(slot)
    for _, a in ipairs(animations) do if a.slot == slot then return true end end
    return false
end

