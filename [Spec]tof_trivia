---------- Q&A Log ----------

local qaLog = {}
pcall(function()
	if isfile and isfile(LOG_FILE) then
		local decoded = HttpService:JSONDecode(readfile(LOG_FILE))
		if type(decoded) == "table" then
			qaLog = decoded
		end
	end
end)

local function saveLog()
	pcall(function()
		if writefile then
			writefile(LOG_FILE, HttpService:JSONEncode(qaLog))
		end
	end)
end

-- Image question log: {question, imageId, answer} for location/AI-generated questions
local imageLog = {}
pcall(function()
	if isfile and isfile(IMAGE_LOG_FILE) then
		local decoded = HttpService:JSONDecode(readfile(IMAGE_LOG_FILE))
		if type(decoded) == "table" then
			imageLog = decoded
		end
	end
end)

local function saveImageLog()
	pcall(function()
		if writefile then
			writefile(IMAGE_LOG_FILE, HttpService:JSONEncode(imageLog))
		end
	end)
end

local function logImageQuestion(question, imageId, answer)
	if not imageId then return end
	-- Extract just TRUE or FALSE from the answer
	local tf = nil
	if answer then
		local upper = answer:upper()
		if upper:find("^TRUE") then tf = "TRUE"
		elseif upper:find("^FALSE") then tf = "FALSE" end
	end
	-- Update existing entry or add new one (keyed by imageId)
	imageLog[imageId] = {question = question, answer = tf}
	saveImageLog()
end

-- History log: every question + answer for review
local HISTORY_FILE = "TriviaSolver_history.txt"

local function logHistory(question, answer)
	pcall(function()
		if not writefile or not appendfile then return end
		local line = "Q: " .. question .. "\nA: " .. answer .. "\n---\n"
		if isfile and isfile(HISTORY_FILE) then
			appendfile(HISTORY_FILE, line)
		else
			writefile(HISTORY_FILE, line)
		end
	end)
end

