-- [Spec] True or False — Trivia Answer Cache
-- Answers questions from cached Q&A log (built by standalone trivia solver)
-- Falls back to math solver for equations. No AI worker needed.

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")

local LOG_FILE = "TriviaSolver_log.json"
local ANNOUNCEMENT_PARENT = "Announcement"
local TEXT_LABEL_NAME = "TextLabelEXAMPLE"

local connections = {}
local lastQuestion = ""

---------- Q&A Log ----------

local qaLog = {}
pcall(function()
	if isfile and isfile(LOG_FILE) then
		local decoded = HttpService:JSONDecode(readfile(LOG_FILE))
		if type(decoded) == "table" then qaLog = decoded end
	end
end)

local function saveLog()
	pcall(function()
		if writefile then writefile(LOG_FILE, HttpService:JSONEncode(qaLog)) end
	end)
end

