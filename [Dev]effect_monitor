---------- Helpers ----------

local function getFullPath(inst)
	local parts = {}
	local current = inst
	while current and current ~= game do
		table.insert(parts, 1, current.Name)
		current = current.Parent
	end
	return table.concat(parts, ".")
end

local function isPlayerDescendant(inst)
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character and inst:IsDescendantOf(plr.Character) then return true end
	end
	if inst:IsDescendantOf(playerGui) then return true end
	local inCoreGui = false
	pcall(function() inCoreGui = inst:IsDescendantOf(game:GetService("CoreGui")) end)
	return inCoreGui
end

local function recreateEffect(inst)
	local char = localPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local clone = inst:Clone()
	if not clone then return end

	-- Create an anchored part in front of us to host the effect
	local host = Instance.new("Part")
	host.Name = "EffectPreview"
	host.Size = Vector3.new(2, 2, 2)
	host.CFrame = hrp.CFrame * CFrame.new(0, 0, -6)
	host.Anchored = true
	host.CanCollide = false
	host.Transparency = 0.5
	host.Material = Enum.Material.Neon
	host.Color = Color3.fromRGB(0, 200, 150)
	host.Parent = workspace

	-- Beams need attachments
	if clone:IsA("Beam") then
		local a0 = Instance.new("Attachment")
		a0.Position = Vector3.new(-1, 0, 0)
		a0.Parent = host
		local a1 = Instance.new("Attachment")
		a1.Position = Vector3.new(1, 0, 0)
		a1.Parent = host
		clone.Attachment0 = a0
		clone.Attachment1 = a1
	end

	-- Trails need attachments too
	if clone:IsA("Trail") then
		local a0 = Instance.new("Attachment")
		a0.Position = Vector3.new(0, 1, 0)
		a0.Parent = host
		local a1 = Instance.new("Attachment")
		a1.Position = Vector3.new(0, -1, 0)
		a1.Parent = host
		clone.Attachment0 = a0
		clone.Attachment1 = a1
	end

	clone.Parent = host

	-- Auto-cleanup after 10s
	task.delay(10, function()
		pcall(function() host:Destroy() end)
	end)
end

---------- Add Entry ----------

local function addEntry(inst)
	if paused then return end

	entryCount = entryCount + 1
	local idx = entryCount
	local fullPath = getFullPath(inst)
	local storedInst = inst

	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 26)
	row.BackgroundColor3 = (idx % 2 == 0) and COLORS.rowAlt or COLORS.row
	row.BackgroundTransparency = 0.3
	row.BorderSizePixel = 0
	row.LayoutOrder = -idx
	row.Parent = scroll

	local typeLbl = Instance.new("TextLabel")
	typeLbl.Size = UDim2.new(0, 90, 1, 0)
	typeLbl.Position = UDim2.new(0, 2, 0, 0)
	typeLbl.BackgroundTransparency = 1
	typeLbl.Text = inst.ClassName
	typeLbl.TextColor3 = COLORS.typeLbl
	typeLbl.TextSize = 10
	typeLbl.Font = Enum.Font.GothamBold
	typeLbl.TextXAlignment = Enum.TextXAlignment.Left
	typeLbl.TextTruncate = Enum.TextTruncate.AtEnd
	typeLbl.Parent = row

	local pathLbl = Instance.new("TextLabel")
	pathLbl.Size = UDim2.new(1, -152, 1, 0)
	pathLbl.Position = UDim2.new(0, 94, 0, 0)
	pathLbl.BackgroundTransparency = 1
	pathLbl.Text = fullPath
	pathLbl.TextColor3 = COLORS.path
	pathLbl.TextSize = 10
	pathLbl.Font = Enum.Font.Gotham
	pathLbl.TextXAlignment = Enum.TextXAlignment.Left
	pathLbl.TextTruncate = Enum.TextTruncate.AtEnd
	pathLbl.Parent = row

	-- Copy path button
	local copyBtn = Instance.new("TextButton")
	copyBtn.Size = UDim2.new(0, 22, 0, 20)
	copyBtn.Position = UDim2.new(1, -56, 0, 3)
	copyBtn.BackgroundColor3 = COLORS.row
	copyBtn.BorderSizePixel = 0
	copyBtn.Text = "CP"
	copyBtn.TextSize = 8
	copyBtn.Font = Enum.Font.GothamBold
	copyBtn.TextColor3 = COLORS.muted
	copyBtn.AutoButtonColor = false
	copyBtn.Parent = row
	Instance.new("UICorner", copyBtn).CornerRadius = UDim.new(0, 3)

	copyBtn.MouseButton1Click:Connect(function()
		pcall(function()
			if setclipboard then setclipboard(fullPath)
			elseif toclipboard then toclipboard(fullPath) end
		end)
		copyBtn.Text = "OK"
		copyBtn.TextColor3 = Color3.fromRGB(87, 242, 135)
		task.delay(1, function()
			if copyBtn.Parent then copyBtn.Text = "CP"; copyBtn.TextColor3 = COLORS.muted end
		end)
	end)

	-- Recreate button
	local reBtn = Instance.new("TextButton")
	reBtn.Size = UDim2.new(0, 28, 0, 20)
	reBtn.Position = UDim2.new(1, -28, 0, 3)
	reBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 110)
	reBtn.BorderSizePixel = 0
	reBtn.Text = "RE"
	reBtn.TextSize = 8
	reBtn.Font = Enum.Font.GothamBold
	reBtn.TextColor3 = Color3.new(1, 1, 1)
	reBtn.AutoButtonColor = false
	reBtn.Parent = row
	Instance.new("UICorner", reBtn).CornerRadius = UDim.new(0, 3)

	reBtn.MouseButton1Click:Connect(function()
		if storedInst and storedInst.Parent then
			recreateEffect(storedInst)
			reBtn.Text = "OK"
			task.delay(1, function()
				if reBtn.Parent then reBtn.Text = "RE" end
			end)
		else
			reBtn.Text = "X"
			reBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
			task.delay(1, function()
				if reBtn.Parent then reBtn.Text = "RE"; reBtn.TextColor3 = Color3.new(1, 1, 1) end
			end)
		end
	end)

	table.insert(entries, row)
	if #entries > MAX_ENTRIES then
		local old = table.remove(entries, 1)
		old:Destroy()
	end
	countLbl.Text = tostring(#entries)
end

---------- Monitor ----------

local function startMonitoring()
	local conn = game.DescendantAdded:Connect(function(desc)
		if isEffect(desc) and not isPlayerDescendant(desc) then
			addEntry(desc)
		end
	end)
	table.insert(connections, conn)
end

startMonitoring()

---------- Button Events ----------

pauseBtn.MouseButton1Click:Connect(function()
	paused = not paused
	pauseBtn.Text = paused and "Resume" or "Pause"
	pauseBtn.BackgroundColor3 = paused and Color3.fromRGB(200, 60, 60) or COLORS.row
end)

clearBtn.MouseButton1Click:Connect(function()
	for _, row in ipairs(entries) do row:Destroy() end
	entries = {}
	entryCount = 0
	countLbl.Text = "0"
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
	for _, conn in ipairs(connections) do pcall(function() conn:Disconnect() end) end
	connections = {}
	pcall(function() gui:Destroy() end)
end

if _G.SixZeroHubRegister then
	_G.SixZeroHubRegister("Effect Monitor", "[Dev]effect_monitor", cleanup, "dev")
end
