---------- Animation Database ----------

local ATTACK = 1
local BLOCK = 2
local FEINT = 3
local IDLE = 4
local EQUIP = 5
local STAGGER = 6

local animDB = {}

local function registerWeapon(name, ids)
	for i = 1, 4 do
		if ids["Attack" .. i] then
			animDB[tostring(ids["Attack" .. i])] = { type = ATTACK, weapon = name, move = "Attack" .. i }
		end
	end
	if ids.Block then animDB[tostring(ids.Block)] = { type = BLOCK, weapon = name, move = "Block" } end
	if ids.Feint then animDB[tostring(ids.Feint)] = { type = FEINT, weapon = name, move = "Feint" } end
	if ids.Idle then animDB[tostring(ids.Idle)] = { type = IDLE, weapon = name, move = "Idle" } end
	if ids.Equip then animDB[tostring(ids.Equip)] = { type = EQUIP, weapon = name, move = "Equip" } end
end

