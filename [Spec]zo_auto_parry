-- Track which weapon each player has equipped
local playerWeapons = {} -- [playerName] = { weapon, equipTime }

---------- State ----------

local mySwinging = false
local mySwingTime = 0
local myBlocking = false
local myKicking = false
local lastParryTime = 0
local lastFeintTime = 0
local lastGuardBreakTime = 0
local lastSwingTime = 0
local PARRY_CD = 0.3
local FEINT_CD = 0.3
local GUARDBREAK_CD = 0.3
local SWING_CD = 0.3
local RANGE = 25 -- fallback for unknown weapons

-- Per-weapon attack ranges from combat data (max confirmed hit distance + buffer)
local WEAPON_RANGE = {
	Scythe = 14,      -- max hit 11.2, +buffer
	Katana = 16,      -- max hit 13.5, +buffer
	Odachi = 10,      -- max hit 7.2, +buffer
	Kanabo = 8,       -- limited data, max hit 2.9, generous buffer
	Kick = 10,        -- max hit 8.5, +buffer
	Tanto = 8,        -- no data yet, short weapon
	Naginata = 16,    -- no close data yet, long weapon assumed similar to katana
	Kusarigama = 16,  -- no data yet, chain weapon assumed mid-long
	Caestus = 8,      -- no data yet, fist weapon assumed short
}

-- Track who's currently blocking
local enemyBlocking = {} -- [playerName] = true

-- Feint window: wait this long after seeing an attack before blocking
-- If opponent feints during this window, we punish instead of wasting a block
local FEINT_WINDOW = 0.25 -- baseline (seconds)
local FEINT_WINDOW_MIN = 0.10
local FEINT_WINDOW_MAX = 0.50
local pendingAttacks = {} -- [playerName] = { time, info, cancelled }

---------- Sensitivity Tuning ----------

local HttpService = game:GetService("HttpService")
local TUNE_FILE = "ZoParry_tuning.json"
local tuneData = { feintWindow = FEINT_WINDOW, blockedDuringFeint = 0, correctBlocks = 0, correctPunishes = 0 }

pcall(function()
	if isfile and isfile(TUNE_FILE) then
		local d = HttpService:JSONDecode(readfile(TUNE_FILE))
		if type(d) == "table" then
			tuneData = d
			FEINT_WINDOW = d.feintWindow or FEINT_WINDOW
		end
	end
end)

local function saveTuning()
	tuneData.feintWindow = FEINT_WINDOW
	pcall(function()
		if writefile then writefile(TUNE_FILE, HttpService:JSONEncode(tuneData)) end
	end)
end

local function tuneUp()
	-- We blocked during a feint — window too short, increase it
	FEINT_WINDOW = math.min(FEINT_WINDOW + 0.02, FEINT_WINDOW_MAX)
	tuneData.blockedDuringFeint = (tuneData.blockedDuringFeint or 0) + 1
	saveTuning()
end

local function tuneDown()
	-- We blocked successfully — window might be too long, tighten slightly
	FEINT_WINDOW = math.max(FEINT_WINDOW - 0.005, FEINT_WINDOW_MIN)
	tuneData.correctBlocks = (tuneData.correctBlocks or 0) + 1
	saveTuning()
end

---------- Input Emulation ----------

local function rightClick()
	VIM:SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton2, true, game, 1)
	task.delay(0.15, function()
		VIM:SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton2, false, game, 1)
	end)
end

local function rightClickDown()
	VIM:SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton2, true, game, 1)
end

local function rightClickUp()
	VIM:SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton2, false, game, 1)
end

local function leftClick()
	VIM:SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton1, true, game, 1)
	task.delay(0.15, function()
		VIM:SendMouseButtonEvent(0, 0, Enum.UserInputType.MouseButton1, false, game, 1)
	end)
end

local function pressF()
	VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
	task.delay(0.15, function()
		VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
	end)
end

local function pressE()
	VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	task.delay(0.15, function()
		VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
	end)
end

---------- Threat Priority ----------

-- Lower threat score = more dangerous (closer relative to weapon range)
local currentThreat = nil -- { name, score, time }

local function getThreatScore(hrp, weapon)
	if not myHRP or not hrp then return math.huge end
	local dx = myHRP.Position.X - hrp.Position.X
	local dz = myHRP.Position.Z - hrp.Position.Z
	local dist = math.sqrt(dx * dx + dz * dz)
	local r = (weapon and WEAPON_RANGE[weapon]) or RANGE
	return dist / r -- 0.5 = halfway into range, 1.0 = edge of range
end

local function isHigherThreat(newScore)
	if not currentThreat then return true end
	if tick() - currentThreat.time > 1.5 then return true end -- old threat expired
	return newScore < currentThreat.score
end

---------- GLINT Detection ----------

local holdingBlock = false
local glintSource = nil -- which player triggered our block hold

local function onGlint(player)
	cacheLocal()
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not myHRP or not hrp then return end
	local pWeapon = playerWeapons[player.Name]
	local wpnName = pWeapon and pWeapon.weapon
	local r = (wpnName and WEAPON_RANGE[wpnName]) or RANGE
	local dx = myHRP.Position.X - hrp.Position.X
	local dz = myHRP.Position.Z - hrp.Position.Z
	if dx * dx + dz * dz > r * r then return end

	-- Check threat priority — only react to the most dangerous player
	local score = getThreatScore(hrp, wpnName)
	if not isHigherThreat(score) then return end
	currentThreat = { name = player.Name, score = score, time = tick() }

	-- If already holding block for someone else, release first
	if holdingBlock and glintSource ~= player.Name then
		rightClickUp()
		holdingBlock = false
	end

	-- If we're mid-swing, feint first
	if mySwinging and tick() - mySwingTime < 0.8 then
		rightClick() -- feint our swing
		task.delay(0.1, function()
			rightClickDown()
			holdingBlock = true
			glintSource = player.Name
			flash("FEINT+HOLD BLOCK — " .. player.Name, Color3.fromRGB(255, 200, 50))
		end)
	else
		rightClickDown()
		holdingBlock = true
		glintSource = player.Name
		flash("GLINT BLOCK — " .. player.Name, Color3.fromRGB(87, 242, 135))
	end

	-- Safety release after 1s in case we miss the feint/stop
	task.delay(1, function()
		if holdingBlock and glintSource == player.Name then
			rightClickUp()
			holdingBlock = false
			glintSource = nil
		end
	end)
end

local function releaseBlockForFeint(playerName)
	if holdingBlock and glintSource == playerName then
		rightClickUp()
		holdingBlock = false
		glintSource = nil
		-- Punish
		if tick() - lastSwingTime > SWING_CD then
			lastSwingTime = tick()
			leftClick()
			flash("FEINT PUNISH — " .. playerName, Color3.fromRGB(0, 170, 255))
		end
	end
end

