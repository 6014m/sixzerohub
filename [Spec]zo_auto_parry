---------- Self Tracking ----------

local function watchSelf(char)
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 3)
	if not animator then return end

	local c = animator.AnimationPlayed:Connect(function(track)
		if not track.Animation then return end
		local id = track.Animation.AnimationId:match("%d+")
		if not id then return end
		local info = animDB[id]
		if info then
			if info.type == ATTACK then
				mySwinging = true
				mySwingTime = tick()
				track.Stopped:Connect(function()
					mySwinging = false
				end)
			elseif info.type == BLOCK then
				myBlocking = true
				track.Stopped:Connect(function()
					myBlocking = false
				end)
			elseif info.type == KICK then
				myKicking = true
				track.Stopped:Connect(function()
					myKicking = false
					-- Kick finished — if someone nearby is still blocking, kick again
					for bName in pairs(enemyBlocking) do
						local bPlayer = Players:FindFirstChild(bName)
						if bPlayer then
							local bChar = bPlayer.Character
							local bHRP = bChar and bChar:FindFirstChild("HumanoidRootPart")
							if bHRP and inRange(bHRP) then
								task.delay(0.3, function()
									if enemyBlocking[bName] then
										pressF()
										flash("RE-KICK " .. bName, Color3.fromRGB(255, 100, 100))
									end
								end)
								break
							end
						end
					end
				end)
			end
		end
	end)
	table.insert(connections, c)
end

if lp.Character then task.spawn(watchSelf, lp.Character) end
lp.CharacterAdded:Connect(function(char) task.wait(0.3); task.spawn(watchSelf, char) end)

---------- Distance Check ----------

local function inRange(theirHRP, weapon)
	if not myHRP or not theirHRP then return false end
	local dx = myHRP.Position.X - theirHRP.Position.X
	local dz = myHRP.Position.Z - theirHRP.Position.Z
	local r = (weapon and WEAPON_RANGE[weapon]) or RANGE
	return dx * dx + dz * dz <= r * r
end

---------- Core Response ----------

local function onEnemyAnimation(player, animInfo, track)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not inRange(hrp, animInfo.weapon) then return end

	local now = tick()
	local pName = player.Name

	if animInfo.type == ATTACK then
		-- Check threat priority
		local score = getThreatScore(hrp, animInfo.weapon)
		if not isHigherThreat(score) then return end
		currentThreat = { name = pName, score = score, time = now }
		-- Don't block instantly — wait for feint window to pass
		pendingAttacks[pName] = { time = now, info = animInfo, cancelled = false }

		task.delay(FEINT_WINDOW, function()
			local pending = pendingAttacks[pName]
			if not pending or pending.cancelled or pending.time ~= now then return end
			pendingAttacks[pName] = nil

			-- Feint window passed, they committed — block
			local blockNow = tick()
			if mySwinging and blockNow - mySwingTime < 0.8 then
				if blockNow - lastFeintTime > FEINT_CD then
					lastFeintTime = blockNow
					rightClick()
					task.delay(0.1, function() rightClick() end)
					flash("FEINT+BLOCK " .. pName .. " [" .. animInfo.weapon .. "]", Color3.fromRGB(255, 200, 50))
				end
			else
				if blockNow - lastParryTime > PARRY_CD then
					lastParryTime = blockNow
					rightClick()
					tuneDown()
					flash(string.format("BLOCK %s [%s %s] (%.0fms)", pName, animInfo.weapon, animInfo.move, FEINT_WINDOW * 1000), Color3.fromRGB(87, 242, 135))
				end
			end
		end)

	elseif animInfo.type == BLOCK then
		-- Track that they're blocking
		enemyBlocking[pName] = true
		track.Stopped:Connect(function()
			enemyBlocking[pName] = nil
		end)
		-- Delay kick so they can't parry it
		if now - lastGuardBreakTime > GUARDBREAK_CD then
			lastGuardBreakTime = now
			task.delay(0.3, function()
				if enemyBlocking[pName] then
					pressF()
					flash("GUARD BREAK " .. pName, Color3.fromRGB(255, 100, 100))
				end
			end)
		end

	elseif animInfo.type == STAGGER then
		-- They're staggered from broken guard — execute with E
		pressE()
		flash("EXECUTE " .. pName, Color3.fromRGB(255, 50, 255))

	elseif animInfo.type == FEINT then
		-- They feinted — release our held block and punish
		releaseBlockForFeint(pName)

		-- Also cancel any pending delayed block
		local pending = pendingAttacks[pName]
		if pending and not pending.cancelled then
			pending.cancelled = true
		end
		pendingAttacks[pName] = nil
		if currentThreat and currentThreat.name == pName then currentThreat = nil end

	elseif animInfo.type == EQUIP then
		-- They just pulled out their weapon — high threat, attack imminent
		playerWeapons[pName] = { weapon = animInfo.weapon, equipTime = now }
		flash(pName .. " EQUIP " .. animInfo.weapon, Color3.fromRGB(255, 170, 0), 0.8)

	elseif animInfo.type == IDLE then
		-- Weapon identification
		playerWeapons[pName] = { weapon = animInfo.weapon, equipTime = playerWeapons[pName] and playerWeapons[pName].equipTime or 0 }
	end
end

---------- Enemy Watching ----------

local function watchEnemy(player, char)
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 3)
	if not animator then return end

	local c = animator.AnimationPlayed:Connect(function(track)
		if not track.Animation then return end
		local id = track.Animation.AnimationId:match("%d+")
		if not id then return end
		local info = animDB[id]
		if info then
			onEnemyAnimation(player, info, track)
		else
			flash(player.Name .. " UNK:" .. id, Color3.fromRGB(180, 180, 180), 0.5)
		end
	end)
	table.insert(connections, c)

	-- GLINT detection — watch for "GLINT" descendant appearing in their character
	local g = char.DescendantAdded:Connect(function(desc)
		if desc.Name == "GLINT" then
			onGlint(player)
		end
	end)
	table.insert(connections, g)
end

local function watchPlayer(player)
	if player == lp then return end
	if player.Character then task.spawn(watchEnemy, player, player.Character) end
	local c = player.CharacterAdded:Connect(function(char)
		task.wait(0.3)
		task.spawn(watchEnemy, player, char)
	end)
	table.insert(connections, c)
end

for _, p in ipairs(Players:GetPlayers()) do task.spawn(watchPlayer, p) end
Players.PlayerAdded:Connect(function(p) task.spawn(watchPlayer, p) end)

---------- RenderStepped Polling — catches animations between event firings ----------

local polledAnims = {} -- [trackInstance] = true, prevent double-processing

local rsConn = RunService.RenderStepped:Connect(function()
	if not myHRP then cacheLocal(); return end
	local myPos = myHRP.Position

	for i = 1, #playerCache do
		local p = playerCache[i]
		local char = p.Character
		if char then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp then
				local dx = myPos.X - hrp.Position.X
				local dz = myPos.Z - hrp.Position.Z
				if dx * dx + dz * dz <= RANGE * RANGE then
					local hum = char:FindFirstChildOfClass("Humanoid")
					local animator = hum and hum:FindFirstChildOfClass("Animator")
					if animator then
						for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
							if not polledAnims[track] and track.Animation then
								local id = track.Animation.AnimationId:match("%d+")
								if id then
									local info = animDB[id]
									if info and (info.type == ATTACK or info.type == FEINT or info.type == STAGGER) then
										polledAnims[track] = true
										onEnemyAnimation(p, info, track)
									end
								end
							end
						end
					end
				end
			end
		end
	end

	-- Clean up stopped tracks
	for track in pairs(polledAnims) do
		if not track.IsPlaying then
			polledAnims[track] = nil
		end
	end
end)
table.insert(connections, rsConn)

---------- Feint Detection via Workspace.Ignore.Handle ----------

local ignoreFolder = workspace:FindFirstChild("Ignore")
if ignoreFolder then
	local handleFolder = ignoreFolder:FindFirstChild("Handle")
	if handleFolder then
		local feintConn = handleFolder.ChildAdded:Connect(function(child)
			-- Something landed in Ignore.Handle = someone feinted
			-- Find nearest player to the child to figure out who feinted
			cacheLocal()
			if not myHRP then return end
			local pos = nil
			pcall(function() pos = child.Position or child.CFrame.Position end)
			if not pos then return end

			local nearest, bestDist = nil, math.huge
			for i = 1, #playerCache do
				local p = playerCache[i]
				local char = p.Character
				local hrp = char and char:FindFirstChild("HumanoidRootPart")
				if hrp then
					local d = (hrp.Position - pos).Magnitude
					if d < bestDist then bestDist = d; nearest = p end
				end
			end

			if nearest and bestDist < RANGE then
				releaseBlockForFeint(nearest.Name)
			end
		end)
		table.insert(connections, feintConn)
	end
end

