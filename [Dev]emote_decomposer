local defaultAnimIds = {}

local function collectDefaults()
    pcall(function()
        local char = player.Character
        if not char then return end
        local animate = char:FindFirstChild("Animate")
        if not animate then return end
        for _, desc in ipairs(animate:GetDescendants()) do
            if desc:IsA("Animation") then
                local id = tostring(desc.AnimationId):match("%d+")
                if id then defaultAnimIds[id] = true end
            end
        end
    end)
    local known = {
        "507766666","507766951","507766388","507765644","507765000",
        "507765764","507767714","619528412","619524662","2510196951",
        "2510197257","742637942","742638445","507768375",
        "180435571","180435792","125750702",
    }
    for _, id in ipairs(known) do defaultAnimIds[id] = true end
end

---------- REMOTE TRACKING ----------

local recentRemotes = {}
local oldNamecall
local namecallHooked = false

local function hookRemotes()
    if namecallHooked or not hookmetamethod then return end
    namecallHooked = true
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if active and (method == "FireServer" or method == "InvokeServer") then
            if self:IsA("RemoteEvent") or self:IsA("RemoteFunction") then
                local args = {...}
                table.insert(recentRemotes, {
                    time = os.clock(),
                    remote = self:GetFullName(),
                    method = method,
                    args = args,
                })
                if #recentRemotes > 50 then table.remove(recentRemotes, 1) end
            end
        end
        return oldNamecall(self, ...)
    end)
end

local function argsToStr(args)
    local parts = {}
    for _, v in ipairs(args) do
        local t = typeof(v)
        if t == "string" then
            table.insert(parts, '"' .. v .. '"')
        elseif t == "number" or t == "boolean" then
            table.insert(parts, tostring(v))
        elseif t == "Instance" then
            table.insert(parts, v:GetFullName())
        elseif t == "EnumItem" then
            table.insert(parts, tostring(v))
        elseif t == "table" then
            local inner = {}
            for k, val in pairs(v) do
                local kS = type(k) == "string" and ('["'..k..'"]') or ("["..tostring(k).."]")
                local vS = typeof(val) == "string" and ('"'..val..'"') or tostring(val)
                table.insert(inner, kS.." = "..vS)
            end
            table.insert(parts, "{"..table.concat(inner, ", ").."}")
        else
            table.insert(parts, tostring(v))
        end
    end
    return table.concat(parts, ", ")
end

---------- EMOTE DETECTION ----------

local detectedEmotes = {}
local seenAnimIds = {}
local detectedCount = 0

local function makeDirectCode(idNum)
    return 'local anim = Instance.new("Animation")\n'
        .. 'anim.AnimationId = "rbxassetid://' .. idNum .. '"\n'
        .. 'local track = game.Players.LocalPlayer.Character\n'
        .. '  :FindFirstChildOfClass("Humanoid")\n'
        .. '  :FindFirstChildOfClass("Animator"):LoadAnimation(anim)\n'
        .. 'track:Play()'
end

local function processTrack(track, forceAdd)
    if not active then return end
    local anim = track.Animation
    if not anim then return end

    local animId = tostring(anim.AnimationId)
    local idNum = animId:match("%d+")
    if not idNum then return end

    if not forceAdd and defaultAnimIds[idNum] then return end
    if seenAnimIds[idNum] then return end
    seenAnimIds[idNum] = true

    local animName = anim.Name
    if animName == "Animation" or animName == "" then
        animName = "Emote_" .. idNum
    end

    local remoteCode = nil
    local now = os.clock()
    for i = #recentRemotes, 1, -1 do
        local r = recentRemotes[i]
        if now - r.time < 0.5 then
            remoteCode = r.remote .. ":" .. r.method .. "(" .. argsToStr(r.args) .. ")"
            break
        end
    end

    table.insert(detectedEmotes, 1, {
        animId = idNum,
        name = animName,
        directCode = makeDirectCode(idNum),
        remoteCode = remoteCode,
    })

    warn("[EmoteDecomposer] Detected: " .. animName .. " (ID: " .. idNum .. ")")
end

local hookedObjs = {}

local function hookHumanoid(hum)
    if hookedObjs[hum] then return end
    hookedObjs[hum] = true
    local c = hum.AnimationPlayed:Connect(function(track) processTrack(track, false) end)
    table.insert(connections, c)
end

local function hookAnimator(animator)
    if hookedObjs[animator] then return end
    hookedObjs[animator] = true
    local c = animator.AnimationPlayed:Connect(function(track) processTrack(track, false) end)
    table.insert(connections, c)
end

local function hookCharacter(char)
    if not active or not char then return end
    local hum = char:WaitForChild("Humanoid", 10)
    if not hum then return end
    hookHumanoid(hum)
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then hookAnimator(animator) end
    local c = hum.ChildAdded:Connect(function(child)
        if child:IsA("Animator") then hookAnimator(child) end
    end)
    table.insert(connections, c)
end

local function scanPlaying()
    pcall(function()
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local animator = hum:FindFirstChildOfClass("Animator")
        if not animator then return end
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            processTrack(track, false)
        end
    end)
end

local function scanAllForce()
    local char = player.Character
    if not char then warn("[EmoteDecomposer] No character") return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then warn("[EmoteDecomposer] No humanoid") return end
    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then warn("[EmoteDecomposer] No animator") return end

    local tracks = animator:GetPlayingAnimationTracks()
    warn("[EmoteDecomposer] === SHOW ALL: " .. #tracks .. " tracks ===")

    for _, track in ipairs(tracks) do
        local anim = track.Animation
        if anim then
            local id = tostring(anim.AnimationId):match("%d+")
            if id then
                local n = (anim.Name ~= "Animation" and anim.Name ~= "") and anim.Name or ("Anim_" .. id)
                local isDef = defaultAnimIds[id] == true
                warn("  " .. n .. " | ID: " .. id .. " | " .. tostring(track.Priority) .. (isDef and " [DEFAULT]" or " [CUSTOM]"))
                if not isDef then
                    processTrack(track, true)
                end
            end
        end
    end
end

---------- INVENTORY SCANNER ----------

local function scanInventory()
    local results = {}
    pcall(function()
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local desc = hum:GetAppliedDescription()
        if not desc then return end
        local emotes = desc:GetEmotes()
        for eName, ids in pairs(emotes) do
            for _, id in ipairs(ids) do
                table.insert(results, {
                    source = "HumanoidDescription",
                    name = eName,
                    animId = tostring(id),
                    code = 'game.Players.LocalPlayer.Character.Humanoid:PlayEmote("' .. eName .. '")',
                })
            end
        end
    end)
    pcall(function()
        local char = player.Character
        if not char then return end
        local animate = char:FindFirstChild("Animate")
        if not animate then return end
        for _, child in ipairs(animate:GetChildren()) do
            for _, a in ipairs(child:GetChildren()) do
                if a:IsA("Animation") then
                    local id = tostring(a.AnimationId):match("%d+")
                    if id and not defaultAnimIds[id] then
                        table.insert(results, {
                            source = "Animate Script",
                            name = child.Name .. "/" .. a.Name,
                            animId = id,
                            code = makeDirectCode(id),
                        })
                    end
                end
            end
        end
    end)
    return results
end

