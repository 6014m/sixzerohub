        makeCodeRow(invList, "Tip: Find emote remotes", 'for _, v in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do\n    if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction"))\n       and v.Name:lower():find("emote") then\n        print(v:GetFullName())\n    end\nend', COLORS.accent, 1)
