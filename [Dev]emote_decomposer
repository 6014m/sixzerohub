---------- DEFAULT ANIMATION BLACKLIST ----------

-- collect all animation IDs from the Animate script so we can ignore them
local defaultAnimIds = {}

local function collectDefaultAnims()
    pcall(function()
        local char = player.Character
        if not char then return end
        local animate = char:FindFirstChild("Animate")
        if not animate then return end
        for _, child in ipairs(animate:GetDescendants()) do
            if child:IsA("Animation") then
                local id = tostring(child.AnimationId):match("%d+")
                if id then defaultAnimIds[id] = true end
            end
        end
    end)
    -- also add well-known Roblox default animation IDs
    local knownDefaults = {
        -- R15 defaults
        "507766666", "507766951", "507766388", -- walk, run, idle
        "507765644", "507765000", -- jump, fall
        "507765764", "507767714", -- climb, swim
        "619528412", "619524662", -- swimidle, fall
        "2510196951", "2510197257", -- new idle
        "742637942", "742638445", -- tool none, slash
        "507768375", -- sitting
        -- R6 defaults
        "180435571", "180435792", -- walk, run
        "180435792", "125750702", -- idle
    }
    for _, id in ipairs(knownDefaults) do
        defaultAnimIds[id] = true
    end
end

local function isDefaultAnim(animId)
    return defaultAnimIds[animId] == true
end

---------- REMOTE TRACKING ----------

local recentRemotes = {}
local REMOTE_WINDOW = 0.5

local oldNamecall
local namecallHooked = false

local function hookRemotes()
    if namecallHooked then return end
    if not hookmetamethod then return end
    namecallHooked = true

    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if active and (method == "FireServer" or method == "InvokeServer") then
            if self:IsA("RemoteEvent") or self:IsA("RemoteFunction") then
                local args = {...}
                table.insert(recentRemotes, {
                    time = os.clock(),
                    remote = self:GetFullName(),
                    method = method,
                    args = args,
                })
                if #recentRemotes > 50 then
                    table.remove(recentRemotes, 1)
                end
            end
        end
        return oldNamecall(self, ...)
    end)
end

local function getRecentRemotes(since)
    local results = {}
    for _, entry in ipairs(recentRemotes) do
        if entry.time >= since then
            table.insert(results, entry)
        end
    end
    return results
end

local function argsToString(args)
    local parts = {}
    for _, v in ipairs(args) do
        local t = typeof(v)
        if t == "string" then
            table.insert(parts, '"' .. v .. '"')
        elseif t == "number" or t == "boolean" then
            table.insert(parts, tostring(v))
        elseif t == "Instance" then
            table.insert(parts, v:GetFullName())
        elseif t == "EnumItem" then
            table.insert(parts, tostring(v))
        elseif t == "table" then
            local inner = {}
            for k, val in pairs(v) do
                local kStr = type(k) == "string" and ('["' .. k .. '"]') or ("[" .. tostring(k) .. "]")
                local vStr = typeof(val) == "string" and ('"' .. val .. '"') or tostring(val)
                table.insert(inner, kStr .. " = " .. vStr)
            end
            table.insert(parts, "{" .. table.concat(inner, ", ") .. "}")
        else
            table.insert(parts, tostring(v))
        end
    end
    return table.concat(parts, ", ")
end

---------- EMOTE DETECTION ----------

local detectedEmotes = {}
local seenAnimIds = {}

local function onAnimationPlayed(track)
    if not active then return end
    local anim = track.Animation
    if not anim then return end

    local animId = tostring(anim.AnimationId)
    local idNum = animId:match("%d+")
    if not idNum then return end

    -- skip default roblox animations
    if isDefaultAnim(idNum) then return end

    -- skip if already logged
    if seenAnimIds[idNum] then return end
    seenAnimIds[idNum] = true

    local animName = anim.Name
    if animName == "Animation" or animName == "" then
        animName = "Emote_" .. idNum
    end
    local captureTime = os.clock()

    local directCode = string.format(
        [[local anim = Instance.new("Animation")
anim.AnimationId = "rbxassetid://%s"
local track = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):FindFirstChildOfClass("Animator"):LoadAnimation(anim)
track:Play()]],
        idNum
    )

    local remoteCode = nil
    local remotes = getRecentRemotes(captureTime - REMOTE_WINDOW)
    if #remotes > 0 then
        local r = remotes[#remotes]
        local argStr = argsToString(r.args)
        remoteCode = r.remote .. ":" .. r.method .. "(" .. argStr .. ")"
    end

    table.insert(detectedEmotes, 1, {
        animId = idNum,
        name = animName,
        directCode = directCode,
        remoteCode = remoteCode,
        time = captureTime,
    })

    warn("[EmoteDecomposer] Detected: " .. animName .. " (ID: " .. idNum .. ")")
end

local hookedHumanoids = {}

local function hookHumanoid(hum)
    if hookedHumanoids[hum] then return end
    hookedHumanoids[hum] = true

    local conn = hum.AnimationPlayed:Connect(onAnimationPlayed)
    table.insert(connections, conn)
end

local function hookAnimator(animator)
    if hookedHumanoids[animator] then return end
    hookedHumanoids[animator] = true

    local conn = animator.AnimationPlayed:Connect(onAnimationPlayed)
    table.insert(connections, conn)
end

local function hookCharacter(char)
    if not active then return end
    local hum = char:WaitForChild("Humanoid", 10)
    if not hum or not active then return end
    hookHumanoid(hum)

    -- also hook Animator directly as backup
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then hookAnimator(animator) end
    local animConn = hum.ChildAdded:Connect(function(child)
        if child:IsA("Animator") then hookAnimator(child) end
    end)
    table.insert(connections, animConn)
end

-- also watch OTHER characters in case game plays emotes server-side on local player
-- via a different mechanism
local function hookAllCharacters()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            task.spawn(function()
                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                if hum and plr == player then
                    hookHumanoid(hum)
                end
            end)
        end
    end
end

---------- EMOTE INVENTORY SCANNER ----------

local function scanEmoteInventory()
    local results = {}

    pcall(function()
        local char = player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                local desc = hum:GetAppliedDescription()
                if desc then
                    local emotes = desc:GetEmotes()
                    for name, ids in pairs(emotes) do
                        for _, id in ipairs(ids) do
                            table.insert(results, {
                                source = "HumanoidDescription",
                                name = name,
                                animId = tostring(id),
                                code = string.format(
                                    'game.Players.LocalPlayer.Character.Humanoid:PlayEmote("%s")',
                                    name
                                ),
                            })
                        end
                    end
                end
            end
        end
    end)

    pcall(function()
        local char = player.Character
        if char then
            local animate = char:FindFirstChild("Animate")
            if animate then
                for _, child in ipairs(animate:GetChildren()) do
                    for _, anim in ipairs(child:GetChildren()) do
                        if anim:IsA("Animation") then
                            local id = tostring(anim.AnimationId):match("%d+")
                            if id and not isDefaultAnim(id) then
                                table.insert(results, {
                                    source = "Animate Script",
                                    name = child.Name .. "/" .. anim.Name,
                                    animId = id,
                                    code = string.format(
                                        'local anim = Instance.new("Animation")\nanim.AnimationId = "rbxassetid://%s"\ngame.Players.LocalPlayer.Character.Humanoid.Animator:LoadAnimation(anim):Play()',
                                        id
                                    ),
                                })
                            end
                        end
                    end
                end
            end
        end
    end)

    return results
end

