local function refreshDetectedList()
    if #detectedEmotes == lastDetectedCount then return end
    lastDetectedCount = #detectedEmotes

    for _, child in ipairs(detectedList:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    if #detectedEmotes == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 40)
        empty.BackgroundTransparency = 1
        empty.Text = "Click an emote in-game to detect it"
        empty.TextColor3 = COLORS.textMuted
        empty.TextSize = 13
        empty.Font = Enum.Font.Gotham
        empty.Parent = detectedList
        return
    end

    statusBar.Text = "  " .. #detectedEmotes .. " emote(s) detected"

    for i, emote in ipairs(detectedEmotes) do
        createCodeRow(
            detectedList,
            emote.name .. "  (ID: " .. emote.animId .. ")  [Direct Play]",
            emote.directCode,
            COLORS.green,
            i * 2 - 1
        )

        if emote.remoteCode then
            createCodeRow(
                detectedList,
                emote.name .. "  [Remote Method]",
                emote.remoteCode,
                COLORS.orange,
                i * 2
            )
        end
    end
end

local function refreshInventoryList()
    for _, child in ipairs(inventoryList:GetChildren()) do
        if child:IsA("Frame") or (child:IsA("TextLabel") and child.Name == "Empty") then child:Destroy() end
    end

    local inventory = scanEmoteInventory()

    if #inventory == 0 then
        local empty = Instance.new("TextLabel")
        empty.Name = "Empty"
        empty.Size = UDim2.new(1, 0, 0, 60)
        empty.BackgroundTransparency = 1
        empty.Text = "No emotes found in HumanoidDescription or Animate script.\nThis game may use custom emote systems."
        empty.TextColor3 = COLORS.textMuted
        empty.TextSize = 12
        empty.Font = Enum.Font.Gotham
        empty.TextWrapped = true
        empty.Parent = inventoryList

        createCodeRow(
            inventoryList,
            "Tip: Find custom emote remotes",
            '-- Search ReplicatedStorage for emote-related remotes:\nfor _, v in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do\n    if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and v.Name:lower():find("emote") then\n        print(v:GetFullName())\n    end\nend',
            COLORS.accent,
            1
        )

        createCodeRow(
            inventoryList,
            "Tip: List all current AnimationTracks",
            '-- See what animations are loaded on your character:\nlocal animator = game.Players.LocalPlayer.Character.Humanoid:FindFirstChildOfClass("Animator")\nfor _, track in ipairs(animator:GetPlayingAnimationTracks()) do\n    print(track.Name, track.Animation.AnimationId, track.IsPlaying and "PLAYING" or "stopped")\nend',
            COLORS.accent,
            2
        )

        return
    end

    local bySource = {}
    for _, item in ipairs(inventory) do
        if not bySource[item.source] then bySource[item.source] = {} end
        table.insert(bySource[item.source], item)
    end

    local order = 0
    for source, items in pairs(bySource) do
        order = order + 1
        local divider = Instance.new("Frame")
        divider.Size = UDim2.new(1, -4, 0, 22)
        divider.BackgroundTransparency = 1
        divider.LayoutOrder = order
        divider.Parent = inventoryList

        local line = Instance.new("Frame")
        line.Size = UDim2.new(1, 0, 0, 1)
        line.Position = UDim2.new(0, 0, 0.5, 0)
        line.BackgroundColor3 = COLORS.accent
        line.BackgroundTransparency = 0.5
        line.BorderSizePixel = 0
        line.Parent = divider

        local srcLabel = Instance.new("TextLabel")
        srcLabel.Size = UDim2.new(0, 0, 1, 0)
        srcLabel.AutomaticSize = Enum.AutomaticSize.X
        srcLabel.Position = UDim2.new(0, 6, 0, 0)
        srcLabel.BackgroundColor3 = COLORS.sidebar
        srcLabel.BorderSizePixel = 0
        srcLabel.Text = "  " .. source .. "  "
        srcLabel.TextColor3 = COLORS.accent
        srcLabel.TextSize = 11
        srcLabel.Font = Enum.Font.GothamBold
        srcLabel.Parent = divider

        for _, item in ipairs(items) do
            order = order + 1
            createCodeRow(
                inventoryList,
                item.name .. "  (ID: " .. item.animId .. ")",
                item.code,
                COLORS.green,
                order
            )
        end
    end
end

