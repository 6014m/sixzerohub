-- actively scan playing animations (catches what AnimationPlayed misses)
local function scanPlayingAnims()
    pcall(function()
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local animator = hum:FindFirstChildOfClass("Animator")
        if not animator then return end

        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            onAnimationPlayed(track)
        end
    end)
end

-- periodic refresh + active scanning
task.spawn(function()
    while active and screenGui and screenGui.Parent do
        -- keep hooking
        if player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then
                hookHumanoid(hum)
                local animator = hum:FindFirstChildOfClass("Animator")
                if animator then hookAnimator(animator) end
            end
        end
        -- active scan for playing animations
        scanPlayingAnims()
        -- refresh gui
        if screenGui.Visible and currentTab == "detected" then
            refreshDetectedList()
        end
        task.wait(1)
    end
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    pcall(function()
        if oldNamecall and hookmetamethod then
            hookmetamethod(game, "__namecall", oldNamecall)
        end
    end)
    pcall(function() screenGui:Destroy() end)
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Emote Decomposer", "[Dev]emote_decomposer", cleanup, "dev")
end
