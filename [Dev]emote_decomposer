                            name = animName,
                            directCode = directCode,
                            remoteCode = nil,
                            time = os.clock(),
                        })
                    end
                end
            end
        end

        if found == 0 then
            warn("[EmoteDecomposer] No animation tracks found at all")
        end

        lastDetectedCount = -1 -- force refresh
        refreshDetectedList()
    end)
end)

