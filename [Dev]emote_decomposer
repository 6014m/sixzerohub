function refreshDetected()
    if #detectedEmotes == detectedCount then return end
    detectedCount = #detectedEmotes

    for _, ch in ipairs(detList:GetChildren()) do
        if ch:IsA("Frame") then ch:Destroy() end
    end

    if #detectedEmotes == 0 then
        local e = Instance.new("TextLabel")
        e.Size = UDim2.new(1, 0, 0, 40)
        e.BackgroundTransparency = 1
        e.Text = "Click an emote in-game to detect it\nor press Show All while playing one"
        e.TextColor3 = COLORS.muted
        e.TextSize = 13
        e.Font = Enum.Font.Gotham
        e.TextWrapped = true
        e.Parent = detList
        return
    end

    statusBar.Text = "  " .. #detectedEmotes .. " emote(s) detected"

    for i, em in ipairs(detectedEmotes) do
        makeCodeRow(detList, em.name .. "  (ID: " .. em.animId .. ")  [Direct]", em.directCode, COLORS.green, i * 2 - 1)
        if em.remoteCode then
            makeCodeRow(detList, em.name .. "  [Remote]", em.remoteCode, COLORS.orange, i * 2)
        end
    end
end

