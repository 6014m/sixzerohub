addcmd("cameraspin", {"camspin"}, "Spin the camera around player", function(args)
    local speed = parseNumber(args[1], 2)
    startLoop("camspin", 0, function()
        local cam = workspace.CurrentCamera
        local root = myRoot()
        if cam and root then
            local t = tick() * speed
            local dist = (cam.CFrame.Position - root.Position).Magnitude
            cam.CFrame = CFrame.new(
                root.Position + Vector3.new(math.cos(t) * dist, cam.CFrame.Position.Y - root.Position.Y, math.sin(t) * dist),
                root.Position
            )
        end
    end)
end)

