local function refreshList()
	for _, c in ipairs(scroll:GetChildren()) do
		if c:IsA("TextButton") then c:Destroy() end
	end
	local filter = filterBox.Text:lower()
	local shown = 0
	for i = #logged, 1, -1 do
		local entry = logged[i]
		local searchStr = (entry.id .. " " .. entry.name .. " " .. entry.path):lower()
		if filter == "" or searchStr:find(filter, 1, true) then
			shown = shown + 1
			local row = Instance.new("TextButton")
			row.Size = UDim2.new(1, 0, 0, 36)
			row.BackgroundColor3 = (shown % 2 == 0) and Color3.fromRGB(32, 32, 38) or Color3.fromRGB(26, 26, 30)
			row.BorderSizePixel = 0
			row.Text = ""
			row.AutoButtonColor = false
			row.Parent = scroll

			local idLbl = Instance.new("TextLabel")
			idLbl.Size = UDim2.new(1, -8, 0, 16)
			idLbl.Position = UDim2.new(0, 6, 0, 2)
			idLbl.BackgroundTransparency = 1
			idLbl.Text = entry.id .. "  |  vol " .. string.format("%.1f", entry.volume)
			idLbl.TextColor3 = Color3.fromRGB(255, 170, 0)
			idLbl.TextSize = 10
			idLbl.Font = Enum.Font.GothamBold
			idLbl.TextXAlignment = Enum.TextXAlignment.Left
			idLbl.Parent = row

			local pathLbl = Instance.new("TextLabel")
			pathLbl.Size = UDim2.new(1, -8, 0, 14)
			pathLbl.Position = UDim2.new(0, 6, 0, 18)
			pathLbl.BackgroundTransparency = 1
			pathLbl.Text = entry.path
			pathLbl.TextColor3 = Color3.fromRGB(160, 160, 170)
			pathLbl.TextSize = 9
			pathLbl.Font = Enum.Font.Gotham
			pathLbl.TextXAlignment = Enum.TextXAlignment.Left
			pathLbl.TextTruncate = Enum.TextTruncate.AtEnd
			pathLbl.Parent = row

			row.MouseButton1Click:Connect(function()
				pcall(function()
					if setclipboard then setclipboard("rbxassetid://" .. entry.id)
					elseif toclipboard then toclipboard("rbxassetid://" .. entry.id) end
				end)
				idLbl.Text = "Copied!"
				task.delay(1, function()
					if idLbl.Parent then
						idLbl.Text = entry.id .. "  |  vol " .. string.format("%.1f", entry.volume)
					end
				end)
			end)
		end
	end
	countLbl.Text = tostring(#logged)
end

clearBtn.MouseButton1Click:Connect(function()
	logged = {}
	seen = {}
	refreshList()
end)

filterBox:GetPropertyChangedSignal("Text"):Connect(refreshList)

-- Sound tracking
local function onSoundPlayed(sound)
	if not active then return end
	local rawId = sound.SoundId
	if rawId == "" then return end
	local id = rawId:match("%d+") or "?"
	if id == "?" or id == "0" then return end
	if seen[id] then return end
	seen[id] = true

	local entry = {
		id = id,
		name = sound.Name,
		path = sound:GetFullName(),
		volume = sound.Volume,
		time = os.clock(),
	}
	if #logged >= MAX_LOG then table.remove(logged, 1) end
	table.insert(logged, entry)
	refreshList()
end

local function hookSound(sound)
	if not sound:IsA("Sound") then return end
	if sound.IsPlaying then onSoundPlayed(sound) end
	local conn = sound.Played:Connect(function() onSoundPlayed(sound) end)
	table.insert(connections, conn)
end

for _, v in ipairs(game:GetDescendants()) do hookSound(v) end
local addConn = game.DescendantAdded:Connect(function(v) hookSound(v) end)
table.insert(connections, addConn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
	active = false
	for _, c in ipairs(connections) do
		pcall(function() c:Disconnect() end)
	end
	connections = {}
	pcall(function() gui:Destroy() end)
end

if _G.SixZeroHubRegister then
	_G.SixZeroHubRegister("Audio Logger", "[Dev]audio_logger", cleanup, "dev")
end
