                    local stepped = math.floor(raw / def.step + 0.5) * def.step
                    settingsValues[def.name] = math.clamp(stepped, def.min, def.max)
                    knob.Position = UDim2.new(relX, 0, 0.5, 0)
                    valLbl.Text = tostring(settingsValues[def.name])
                    if def.onChange then def.onChange(settingsValues[def.name]) end
                end
            end)

        elseif def.type == "dropdown" then
            local opts = def.options
            local optIdx = 1
            local dropBtn = Instance.new("TextButton")
            dropBtn.Size = UDim2.new(0.45, 0, 0, 20)
            dropBtn.Position = UDim2.new(0.55, 0, 0, 3)
            dropBtn.BackgroundColor3 = COLORS.input
            dropBtn.BorderSizePixel = 0
            dropBtn.Text = tostring(def.default)
            dropBtn.TextColor3 = COLORS.text
            dropBtn.TextSize = 11
            dropBtn.Font = Enum.Font.Gotham
            dropBtn.AutoButtonColor = false
            dropBtn.Parent = row
            Instance.new("UICorner", dropBtn).CornerRadius = UDim.new(0, 4)

            dropBtn.MouseButton1Click:Connect(function()
                optIdx = optIdx % #opts + 1
                settingsValues[def.name] = opts[optIdx]
                dropBtn.Text = tostring(opts[optIdx])
                if def.onChange then def.onChange(opts[optIdx]) end
            end)
        end
    end

    local targetHeight = 6 + #SETTINGS_DEFS * 30 + (#SETTINGS_DEFS - 1) * 4 + 6

    cogBtn.MouseButton1Click:Connect(function()
        settingsOpen = not settingsOpen
        if settingsOpen then
            settingsFrame.Size = UDim2.new(1, -8, 0, targetHeight)
            messageScroll.Position = UDim2.new(0, 4, 0, targetHeight + 6)
            messageScroll.Size = UDim2.new(1, -8, 1, -38 - targetHeight - 6)
        else
            settingsFrame.Size = UDim2.new(1, -8, 0, 0)
            messageScroll.Position = UDim2.new(0, 4, 0, 2)
            messageScroll.Size = UDim2.new(1, -8, 1, -38)
        end
    end)
end

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    for _, billboard in pairs(activeBubbles) do
        pcall(function() billboard:Destroy() end)
    end
    activeBubbles = {}
    for name, nametag in pairs(customNametags) do
        pcall(function() nametag:Destroy() end)
        pcall(function()
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Name == name and plr.Character then
                    local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                    if hum then hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.Viewer end
                end
            end
        end)
    end
    customNametags = {}
    pcall(function() gui:Destroy() end)
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Cheater Chat", "[Uni]cheater_chat", cleanup, "uni")
end
