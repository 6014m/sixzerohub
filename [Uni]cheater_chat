---------- NETWORKING ----------

local httpRequest = request or http_request or (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request)
local username = localPlayer.Name

local function sendMessage(text)
    if #text == 0 or #SERVER_URL == 0 or not httpRequest then return end
    pcall(function()
        httpRequest({
            Url = SERVER_URL .. "/send",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ username = username, message = text })
        })
    end)
end

local function pollMessages()
    if #SERVER_URL == 0 or not httpRequest then return end
    local ok, response = pcall(function()
        return httpRequest({
            Url = SERVER_URL .. "/messages?since=" .. tostring(lastTimestamp),
            Method = "GET",
        })
    end)
    if ok and response and response.StatusCode == 200 then
        local s, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
        if s and data and data.messages then
            for _, msg in ipairs(data.messages) do
                if msg.timestamp > lastTimestamp then
                    lastTimestamp = msg.timestamp
                    local isSelf = msg.author == username
                    addMessageToUI(msg.author, msg.content, isSelf)
                end
            end
            statusDot.BackgroundColor3 = Color3.fromRGB(87, 242, 135)
        end
    end
end

