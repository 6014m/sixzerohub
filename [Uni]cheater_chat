-- cache avatar thumbnails
local avatarCache = {}
local function getAvatarUrl(playerName)
    if avatarCache[playerName] then return avatarCache[playerName] end
    local url = ""
    pcall(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.Name == playerName then
                local thumbType = Enum.ThumbnailType.HeadShot
                local thumbSize = Enum.ThumbnailSize.Size48x48
                local content, isReady = Players:GetUserThumbnailAsync(plr.UserId, thumbType, thumbSize)
                if isReady then url = content end
                break
            end
        end
    end)
    avatarCache[playerName] = url
    return url
end

-- custom nametags above heads
local customNametags = {}
local activeBubbles = {}

local function applyNametag(playerName)
    if customNametags[playerName] then return end
    if playerName == localPlayer.Name then return end
    pcall(function()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr.Name == playerName and plr.Character then
                local head = plr.Character:FindFirstChild("Head")
                if not head then return end

                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
                end

                local bb = Instance.new("BillboardGui")
                bb.Name = "SZHNametag"
                bb.Adornee = head
                bb.Size = UDim2.new(0, 150, 0, 24)
                bb.StudsOffset = Vector3.new(0, 1.8, 0)
                bb.AlwaysOnTop = false
                bb.MaxDistance = math.huge
                bb.Parent = head

                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, 0, 1, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = hum and hum.DisplayName ~= "" and hum.DisplayName or playerName
                nameLabel.TextColor3 = getPlayerColor(playerName)
                nameLabel.TextSize = 14
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextStrokeTransparency = 0.5
                nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                nameLabel.TextScaled = false
                nameLabel.Parent = bb

                customNametags[playerName] = bb

                plr.CharacterRemoving:Connect(function()
                    customNametags[playerName] = nil
                end)
                plr.CharacterAdded:Connect(function()
                    customNametags[playerName] = nil
                    task.delay(1, function()
                        if active then applyNametag(playerName) end
                    end)
                end)
            end
        end
    end)
end

