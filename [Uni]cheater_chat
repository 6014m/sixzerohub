---------- SETTINGS ----------

local focusKeybind = nil -- nil = no keybind
local chatOpacity = 0 -- 0 = fully visible, 1 = invisible

local function applyOpacity(val)
    chatOpacity = val
    local t = val / 100
    main.BackgroundTransparency = t
    header.BackgroundTransparency = t
    headerFill.BackgroundTransparency = t
    inputFrame.BackgroundTransparency = t
    mainStroke.Transparency = 0.5 + t * 0.5
    titleLbl.TextTransparency = t
    statusDot.BackgroundTransparency = t

    -- messages
    for _, child in ipairs(messageScroll:GetChildren()) do
        if child:IsA("Frame") then
            for _, lbl in ipairs(child:GetChildren()) do
                if lbl:IsA("TextLabel") then
                    lbl.TextTransparency = t
                end
            end
        end
    end
    inputBox.TextTransparency = t
    inputBox.PlaceholderColor3 = COLORS.muted -- placeholder stays
    sendBtn.BackgroundTransparency = t
    sendBtn.TextTransparency = t
end

-- keybind listener
local keybindConn = UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if not active then return end
    if not focusKeybind then return end
    if input.KeyCode == focusKeybind then
        inputBox:CaptureFocus()
    end
end)
table.insert(connections, keybindConn)

-- register settings with hub
task.delay(2, function()
    if not _G.SixZeroHubRegisterSettings then
        warn("[CheaterChat] _G.SixZeroHubRegisterSettings not found")
        return
    end

    warn("[CheaterChat] Registering settings...")
    _G.SixZeroHubRegisterSettings("[Uni]cheater_chat", {
        _title = "Cheater Chat",
        {
            name = "opacity",
            label = "Opacity",
            type = "slider",
            default = 0,
            min = 0,
            max = 80,
            step = 5,
            onChange = function(val)
                applyOpacity(val)
            end,
        },
        {
            name = "keybind",
            label = "Focus Key",
            type = "dropdown",
            default = "None",
            options = {"None", "T", "Y", "U", "Slash", "Semicolon", "Quote", "BackQuote", "F1", "F2", "F3", "F4"},
            onChange = function(val)
                if val == "None" then
                    focusKeybind = nil
                else
                    focusKeybind = Enum.KeyCode[val]
                end
            end,
        },
    })
    warn("[CheaterChat] Settings registered successfully")
end)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    -- destroy chat bubbles
    for name, billboard in pairs(activeBubbles) do
        pcall(function() billboard:Destroy() end)
    end
    activeBubbles = {}
    pcall(function() gui:Destroy() end)
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Cheater Chat", "[Uni]cheater_chat", cleanup, "uni")
end
