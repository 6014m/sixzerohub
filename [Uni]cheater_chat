local playerColorMap = {}

local function getPlayerColor(name)
    if playerColorMap[name] then return playerColorMap[name] end
    -- hash the name to pick a consistent color
    local hash = 0
    for i = 1, #name do
        hash = (hash * 31 + string.byte(name, i)) % 2^24
    end
    local color = NAME_COLORS[(hash % #NAME_COLORS) + 1]
    playerColorMap[name] = color
    return color
end

