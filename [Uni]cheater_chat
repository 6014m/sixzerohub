---------- MESSAGE DISPLAY ----------

local msgCount = 0

local activeBubbles = {} -- [player] = {gui, cleanup_time}

local function showChatBubble(authorName, content)
    -- find the player in the server
    local targetPlayer = nil
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name == authorName then
            targetPlayer = plr
            break
        end
    end
    if not targetPlayer or not targetPlayer.Character then return end
    local head = targetPlayer.Character:FindFirstChild("Head")
    if not head then return end

    -- remove old bubble for this player
    if activeBubbles[authorName] then
        pcall(function() activeBubbles[authorName]:Destroy() end)
        activeBubbles[authorName] = nil
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "SZHChatBubble"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 200, 0, 60)
    billboard.StudsOffset = Vector3.new(2.5, 2, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = head

    local bubble = Instance.new("Frame")
    bubble.Size = UDim2.new(1, 0, 0, 0)
    bubble.AutomaticSize = Enum.AutomaticSize.Y
    bubble.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    bubble.BackgroundTransparency = 0.15
    bubble.BorderSizePixel = 0
    bubble.Parent = billboard
    Instance.new("UICorner", bubble).CornerRadius = UDim.new(0, 8)
    Instance.new("UIPadding", bubble).PaddingLeft = UDim.new(0, 6)
    local pad = bubble.UIPadding
    pad.PaddingRight = UDim.new(0, 6)
    pad.PaddingTop = UDim.new(0, 4)
    pad.PaddingBottom = UDim.new(0, 4)

    local nameLbl = Instance.new("TextLabel")
    nameLbl.Size = UDim2.new(1, 0, 0, 14)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = authorName
    nameLbl.TextColor3 = getPlayerColor(authorName)
    nameLbl.TextSize = 11
    nameLbl.Font = Enum.Font.GothamBold
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left
    nameLbl.Parent = bubble

    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size = UDim2.new(1, 0, 0, 0)
    msgLbl.AutomaticSize = Enum.AutomaticSize.Y
    msgLbl.Position = UDim2.new(0, 0, 0, 14)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text = content
    msgLbl.TextColor3 = Color3.fromRGB(220, 220, 220)
    msgLbl.TextSize = 12
    msgLbl.Font = Enum.Font.Gotham
    msgLbl.TextXAlignment = Enum.TextXAlignment.Left
    msgLbl.TextWrapped = true
    msgLbl.Parent = bubble

    activeBubbles[authorName] = billboard

    -- auto-remove after 6 seconds
    task.delay(6, function()
        if activeBubbles[authorName] == billboard then
            pcall(function() billboard:Destroy() end)
            activeBubbles[authorName] = nil
        end
    end)
end

