    contentLbl.Font = Enum.Font.Gotham
    contentLbl.TextXAlignment = Enum.TextXAlignment.Left
    contentLbl.TextWrapped = true
    contentLbl.Parent = msgFrame

    -- show bubble above player's head if they're in the server
    if author ~= "System" then
        pcall(showChatBubble, author, content)
    end

    -- trim old messages
    local children = messageScroll:GetChildren()
    local frames = {}
    for _, c in ipairs(children) do
        if c:IsA("Frame") then table.insert(frames, c) end
    end
    if #frames > MAX_DISPLAY then
        frames[1]:Destroy()
    end

    -- auto scroll to bottom
    task.defer(function()
        messageScroll.CanvasPosition = Vector2.new(0, messageScroll.AbsoluteCanvasSize.Y)
    end)
end

---------- NETWORKING ----------

local httpRequest = request or http_request or (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request)
local username = localPlayer.Name

local function sendMessage(text)
    if #text == 0 or #SERVER_URL == 0 or not httpRequest then return end
    pcall(function()
        httpRequest({
            Url = SERVER_URL .. "/send",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ username = username, message = text })
        })
    end)
end

local function pollMessages()
    if #SERVER_URL == 0 or not httpRequest then return end
    local ok, response = pcall(function()
        return httpRequest({
            Url = SERVER_URL .. "/messages?since=" .. tostring(lastTimestamp),
            Method = "GET",
        })
    end)
    if ok and response and response.StatusCode == 200 then
        local s, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
        if s and data and data.messages then
            for _, msg in ipairs(data.messages) do
                if msg.timestamp > lastTimestamp then
                    lastTimestamp = msg.timestamp
                    local isSelf = msg.author == username
                    addMessageToUI(msg.author, msg.content, isSelf)
                end
            end
            statusDot.BackgroundColor3 = Color3.fromRGB(87, 242, 135)
        end
    end
end

---------- EVENTS ----------

local function doSend()
    local text = inputBox.Text:gsub("\n", ""):gsub("\r", "")
    if #text == 0 then return end
    inputBox.Text = ""
    sendMessage(text)
end

sendBtn.MouseButton1Click:Connect(doSend)
inputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then doSend() end
end)

-- poll loop
local pollConn = task.spawn(function()
    while active and gui and gui.Parent do
        pcall(pollMessages)
        task.wait(POLL_INTERVAL)
    end
end)

