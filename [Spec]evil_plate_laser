-- [Spec] Evil Plate Game - Laser Dodger
-- Teleports just past incoming lasers for minimal visibility
-- Detects Lasers1, Lasers2, ... LasersN under ActiveEvents/Round

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true

local TRIGGER_DIST = 2.5  -- OBB distance to trigger teleport (lower = stealthier)
local PASS_BEYOND = 2     -- studs past the far edge of the laser
local COOLDOWN = 0.5      -- seconds between teleports
local HEIGHT_RANGE = 7

local character, humanoid, rootPart
local lastPos = {}
local lastTP = 0

local function bindCharacter(char)
    character = char
    humanoid = char:WaitForChild("Humanoid", 10)
    rootPart = char:WaitForChild("HumanoidRootPart", 10)
end

if localPlayer.Character then task.spawn(bindCharacter, localPlayer.Character) end
local charConn = localPlayer.CharacterAdded:Connect(bindCharacter)
table.insert(connections, charConn)

local function findActiveRound()
    local activeEvents = workspace:FindFirstChild("ActiveEvents")
    if not activeEvents then return nil end
    for _, child in ipairs(activeEvents:GetChildren()) do
        if child.Name:find("Round") then
            return child
        end
    end
    return nil
end

-- Collect all BaseParts from children named Lasers1, Lasers2, etc.
local function collectLasers(round)
    local parts = {}
    for _, child in ipairs(round:GetChildren()) do
        if child.Name:match("^Lasers%d+$") then
            if child:IsA("BasePart") then
                table.insert(parts, child)
            else
                for _, desc in ipairs(child:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        table.insert(parts, desc)
                    end
                end
            end
        end
    end
    return parts
end

-- OBB closest-point distance
local function closestDistOBB(cf, halfSize, point)
    local lp = cf:PointToObjectSpace(point)
    local dx = math.max(math.abs(lp.X) - halfSize.X, 0)
    local dy = math.max(math.abs(lp.Y) - halfSize.Y, 0)
    local dz = math.max(math.abs(lp.Z) - halfSize.Z, 0)
    return math.sqrt(dx * dx + dy * dy + dz * dz)
end

-- OBB closest point in world space
local function closestPointOBB(cf, halfSize, point)
    local lp = cf:PointToObjectSpace(point)
    local cx = math.clamp(lp.X, -halfSize.X, halfSize.X)
    local cy = math.clamp(lp.Y, -halfSize.Y, halfSize.Y)
    local cz = math.clamp(lp.Z, -halfSize.Z, halfSize.Z)
    return cf:PointToWorldSpace(Vector3.new(cx, cy, cz))
end

local conn = RunService.Heartbeat:Connect(function(dt)
    if not active then return end
    if not rootPart or not rootPart.Parent then return end
    if not humanoid or humanoid.Health <= 0 then return end

    local round = findActiveRound()
    if not round then return end

    local now = tick()
    if now - lastTP < COOLDOWN then return end

    local pPos = rootPart.Position
    local feetY = pPos.Y - 3
    local lasers = collectLasers(round)

    -- find the closest laser that's within trigger range
    local bestPart, bestDist, bestVel = nil, math.huge, Vector3.zero

    for _, part in ipairs(lasers) do
        local pos = part.Position

        -- velocity tracking
        local vel = Vector3.zero
        if lastPos[part] and dt > 0 then
            vel = (pos - lastPos[part]) / dt
        end
        lastPos[part] = pos

        -- skip stationary (not moving yet or event ended)
        if vel.Magnitude < 1 then continue end

        -- height filter
        if math.abs(pos.Y - feetY) > HEIGHT_RANGE then continue end

        -- OBB distance
        local halfSize = part.Size * 0.5
        local dist = closestDistOBB(part.CFrame, halfSize, pPos)

        if dist < TRIGGER_DIST and dist < bestDist then
            bestPart = part
            bestDist = dist
            bestVel = vel
        end
    end

    if not bestPart then return end

    -- calculate teleport: move through the laser to the other side
    local halfSize = bestPart.Size * 0.5

    -- direction from player toward the nearest point on the laser
    local nearPt = closestPointOBB(bestPart.CFrame, halfSize, pPos)
    local towardLaser = nearPt - pPos
    local horizDir = Vector3.new(towardLaser.X, 0, towardLaser.Z)

    -- if player is inside the laser bounding box, use velocity direction instead
    if horizDir.Magnitude < 0.1 then
        horizDir = Vector3.new(bestVel.X, 0, bestVel.Z)
    end
    if horizDir.Magnitude < 0.1 then return end
    local dir = horizDir.Unit

    -- find the FAR edge of the laser in our teleport direction
    local farProbe = pPos + dir * 200
    local farPt = closestPointOBB(bestPart.CFrame, halfSize, farProbe)

    -- teleport to just past the far edge
    local target = farPt + dir * PASS_BEYOND
    local newPos = Vector3.new(target.X, pPos.Y, target.Z)

    rootPart.CFrame = CFrame.new(newPos) * (rootPart.CFrame - rootPart.CFrame.Position)
    lastTP = now

    -- periodic dead-ref cleanup
    if math.floor(now) % 3 == 0 then
        for p in pairs(lastPos) do
            if not p or not p.Parent then lastPos[p] = nil end
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    lastPos = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Laser Jumper", "[Spec]evil_plate_laser", cleanup, "spec")
end

if _G.SixZeroHubRegisterSettings then
    task.delay(1, function()
        _G.SixZeroHubRegisterSettings("[Spec]evil_plate_laser", {
            _title = "Laser Jumper",
            {
                name = "triggerDist",
                label = "Trigger Distance",
                type = "slider",
                default = 2.5,
                min = 1,
                max = 6,
                step = 0.5,
                onChange = function(val) TRIGGER_DIST = val end,
            },
            {
                name = "passBeyond",
                label = "Pass Distance",
                type = "slider",
                default = 2,
                min = 1,
                max = 5,
                step = 0.5,
                onChange = function(val) PASS_BEYOND = val end,
            },
        })
    end)
end
