-- [Spec] Evil Plate Game - Laser Jumper
-- Heuristic detection: scores parts by shape, material, name, color
-- Jumps automatically when a laser is close

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true

-- Config
local JUMP_DIST    = 13    -- studs: how close a laser must be to trigger jump
local MIN_LENGTH   = 8     -- studs: minimum part length to count as beam-shaped
local HEIGHT_RANGE = 7     -- studs: ignore lasers outside this range of player feet
local SCORE_MIN    = 3     -- minimum heuristic score to track a part
local SCORE_ACTIVE = 5     -- score needed for stationary parts to trigger jumps
local PREDICT_SEC  = 0.15  -- seconds ahead to predict laser position
local RAY_INTERVAL = 4     -- backup raycasts every N frames
local RAY_COUNT    = 8     -- number of backup raycast directions

-- State
local character, humanoid, rootPart
local tracked = {}    -- BasePart -> score
local lastPos = {}    -- BasePart -> Vector3
local frameN = 0

local function bindCharacter(char)
    character = char
    humanoid = char:WaitForChild("Humanoid", 10)
    rootPart = char:WaitForChild("HumanoidRootPart", 10)
end

if localPlayer.Character then task.spawn(bindCharacter, localPlayer.Character) end
local charConn = localPlayer.CharacterAdded:Connect(bindCharacter)
table.insert(connections, charConn)

-- Laser heuristic scoring: shape, material, name, collision, color
local KEYWORDS = {
    "laser", "beam", "sweep", "ray",
    "hazard", "kill", "deadly", "damage",
}

local function scorePart(part)
    if not part:IsA("BasePart") or part:IsA("Terrain") then return 0 end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and part:IsDescendantOf(p.Character) then return 0 end
    end

    local score = 0
    local sx, sy, sz = part.Size.X, part.Size.Y, part.Size.Z
    local longest = math.max(sx, sy, sz)
    local shortest = math.max(math.min(sx, sy, sz), 0.01)

    -- beam shape: one axis much longer than the others
    if longest >= MIN_LENGTH then
        local ratio = longest / shortest
        if ratio >= 5 then score = score + 3
        elseif ratio >= 3 then score = score + 2 end
    end

    -- neon material (very common for lasers)
    if part.Material == Enum.Material.Neon then score = score + 2 end

    -- name contains laser/hazard keywords
    local lo = part.Name:lower()
    for _, kw in ipairs(KEYWORDS) do
        if lo:find(kw) then score = score + 3; break end
    end

    -- non-collidable = touch-to-kill pattern
    if not part.CanCollide then score = score + 1 end

    -- bright saturated color (red, green lasers etc)
    local _, s, v = part.Color:ToHSV()
    if s > 0.5 and v > 0.5 then score = score + 1 end

    return score
end

-- Track all workspace descendants that pass the score threshold
local function tryTrack(part)
    local s = scorePart(part)
    if s >= SCORE_MIN then tracked[part] = s end
end

for _, d in ipairs(workspace:GetDescendants()) do tryTrack(d) end

local addConn = workspace.DescendantAdded:Connect(tryTrack)
table.insert(connections, addConn)

local removeConn = workspace.DescendantRemoving:Connect(function(d)
    tracked[d] = nil
    lastPos[d] = nil
end)
table.insert(connections, removeConn)

-- Grounded check using HumanoidState (FloorMaterial unreliable on Wave)
local function isGrounded()
    if not humanoid then return false end
    local st = humanoid:GetState()
    return st == Enum.HumanoidStateType.Running
        or st == Enum.HumanoidStateType.RunningNoPhysics
        or st == Enum.HumanoidStateType.Landed
end

-- Beam-shape gate: lasers are long and thin — this filters out platforms, walls, etc.
local function isBeamShaped(part)
    local sx, sy, sz = part.Size.X, part.Size.Y, part.Size.Z
    local longest = math.max(sx, sy, sz)
    local shortest = math.max(math.min(sx, sy, sz), 0.01)
    return longest >= MIN_LENGTH and longest / shortest >= 3
end

-- OBB closest-point distance
local function closestDistOBB(cf, halfSize, point)
    local lp = cf:PointToObjectSpace(point)
    local dx = math.max(math.abs(lp.X) - halfSize.X, 0)
    local dy = math.max(math.abs(lp.Y) - halfSize.Y, 0)
    local dz = math.max(math.abs(lp.Z) - halfSize.Z, 0)
    return math.sqrt(dx * dx + dy * dy + dz * dz)
end

-- Main loop
local conn = RunService.Heartbeat:Connect(function(dt)
    if not active then return end
    if not rootPart or not rootPart.Parent then return end
    if not humanoid or humanoid.Health <= 0 then return end

    local pPos = rootPart.Position
    local feetY = pPos.Y - 3
    frameN = frameN + 1

    -- Phase 1: scan tracked lasers
    for part, score in pairs(tracked) do
        if not part or not part.Parent then
            tracked[part] = nil
            lastPos[part] = nil
            continue
        end

        local pos = part.Position

        -- velocity from frame delta
        local vel = Vector3.zero
        if lastPos[part] and dt > 0 then
            vel = (pos - lastPos[part]) / dt
        end
        lastPos[part] = pos

        -- skip stationary low-confidence parts
        if vel.Magnitude < 1 and score < SCORE_ACTIVE then continue end

        -- must be beam-shaped to trigger a jump (filters platforms, walls, etc.)
        if not isBeamShaped(part) then continue end

        -- predict where the laser will be shortly
        local predY = pos.Y + vel.Y * PREDICT_SEC
        if math.abs(predY - feetY) > HEIGHT_RANGE then continue end

        -- closest-point distance on the predicted bounding box
        local predCF = part.CFrame + vel * PREDICT_SEC
        local dist = closestDistOBB(predCF, part.Size * 0.5, pPos)

        if dist < JUMP_DIST and isGrounded() then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            break
        end
    end

    -- Phase 2: backup raycasts at foot level
    if frameN % RAY_INTERVAL == 0 then
        local origin = pPos - Vector3.new(0, 2.5, 0)
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        if character then params.FilterDescendantsInstances = {character} end

        for i = 0, RAY_COUNT - 1 do
            local angle = i * (math.pi * 2 / RAY_COUNT)
            local dir = Vector3.new(math.cos(angle), 0, math.sin(angle)) * JUMP_DIST
            local hit = workspace:Raycast(origin, dir, params)

            if hit and hit.Instance then
                local s = scorePart(hit.Instance)
                if s >= SCORE_MIN then
                    tracked[hit.Instance] = s -- add to tracked; Phase 1 handles jump when it moves
                end
            end
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    tracked = {}
    lastPos = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Laser Jumper", "[Spec]evil_plate_laser", cleanup, "spec")
end

if _G.SixZeroHubRegisterSettings then
    task.delay(1, function()
        _G.SixZeroHubRegisterSettings("[Spec]evil_plate_laser", {
            _title = "Laser Jumper",
            {
                name = "jumpDist",
                label = "Jump Distance",
                type = "slider",
                default = 13,
                min = 5,
                max = 25,
                step = 1,
                onChange = function(val) JUMP_DIST = val end,
            },
            {
                name = "heightRange",
                label = "Height Range",
                type = "slider",
                default = 7,
                min = 3,
                max = 15,
                step = 1,
                onChange = function(val) HEIGHT_RANGE = val end,
            },
            {
                name = "scoreMin",
                label = "Detection Sensitivity",
                type = "slider",
                default = 3,
                min = 1,
                max = 6,
                step = 1,
                onChange = function(val) SCORE_MIN = val end,
            },
        })
    end)
end
