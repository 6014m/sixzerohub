-- [Spec] Evil Plate Game - Laser Jumper
-- Detects laser parts and jumps over them

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true
local JUMP_RANGE = 14
local JUMP_COOLDOWN = 0.6
local lastJump = 0

local function getRootPart()
    local char = localPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = localPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function findActiveRound()
    local activeEvents = workspace:FindFirstChild("ActiveEvents")
    if not activeEvents then return nil end
    for _, child in ipairs(activeEvents:GetChildren()) do
        if child.Name:find("Round") then
            return child
        end
    end
    return nil
end

local function getLaserParts(round)
    local parts = {}
    for _, child in ipairs(round:GetChildren()) do
        local n = child.Name:lower()
        if n:find("laser") then
            if child:IsA("BasePart") then
                -- the laser IS the part
                table.insert(parts, child)
            else
                -- the laser is a model/folder, get all baseparts inside it
                for _, desc in ipairs(child:GetDescendants()) do
                    if desc:IsA("BasePart") then
                        table.insert(parts, desc)
                    end
                end
                -- if model itself has no baseparts, try the model's PrimaryPart
                if #parts == 0 and child:IsA("Model") and child.PrimaryPart then
                    table.insert(parts, child.PrimaryPart)
                end
            end
        end
    end
    -- also check descendants in case lasers are nested deeper
    if #parts == 0 then
        for _, desc in ipairs(round:GetDescendants()) do
            if desc:IsA("BasePart") and desc.Name:lower():find("laser") then
                table.insert(parts, desc)
            end
        end
    end
    return parts
end

-- one-time debug dump
local debugDone = false
local function debugDump(round)
    if debugDone then return end
    debugDone = true
    warn("[LaserJumper] Round found: " .. round:GetFullName())
    warn("[LaserJumper] Direct children of round:")
    for _, child in ipairs(round:GetChildren()) do
        warn("  " .. child.Name .. " [" .. child.ClassName .. "]")
        if not child:IsA("BasePart") then
            for _, sub in ipairs(child:GetChildren()) do
                warn("    " .. sub.Name .. " [" .. sub.ClassName .. "]")
            end
        end
    end
    local found = getLaserParts(round)
    warn("[LaserJumper] Laser parts found: " .. #found)
    for _, p in ipairs(found) do
        warn("  -> " .. p:GetFullName() .. " [" .. p.ClassName .. "] pos=" .. tostring(p.Position))
    end
end

local conn = RunService.Heartbeat:Connect(function()
    if not active then return end
    local root = getRootPart()
    local hum = getHumanoid()
    if not root or not hum then return end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return end

    local now = tick()
    if now - lastJump < JUMP_COOLDOWN then return end

    local round = findActiveRound()
    if not round then return end

    debugDump(round)

    local rootPos = root.Position
    for _, part in ipairs(getLaserParts(round)) do
        local diff = part.Position - rootPos
        local yDiff = diff.Y
        if yDiff < -4 or yDiff > 6 then continue end

        local horizDist = Vector2.new(diff.X, diff.Z).Magnitude
        if horizDist <= JUMP_RANGE then
            hum.Jump = true
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.Jumping) end)
            lastJump = now
            break
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Laser Jumper", "[Spec]evil_plate_laser", cleanup, "spec")
end
