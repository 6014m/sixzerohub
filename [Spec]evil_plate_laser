-- [Spec] Evil Plate Game - Laser Jumper
-- Auto-jumps over lasers with tight timing

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true
local JUMP_RANGE = 12
local JUMP_COOLDOWN = 0.5
local lastJump = 0
local debugPrinted = false

local function getRootPart()
    local char = localPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = localPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function isGrounded(hum)
    return hum.FloorMaterial ~= Enum.Material.Air
end

local function findActiveRound()
    local activeEvents = workspace:FindFirstChild("ActiveEvents")
    if not activeEvents then return nil end
    for _, child in ipairs(activeEvents:GetChildren()) do
        -- match any child that contains "Round" in the name
        if child.Name:find("Round") then
            return child
        end
    end
    return nil
end

local function getAllParts(round)
    local parts = {}
    for _, desc in ipairs(round:GetDescendants()) do
        if desc:IsA("BasePart") then
            table.insert(parts, desc)
        end
    end
    return parts
end

-- debug: print round structure once so we can see what's there
local function debugRound(round)
    if debugPrinted then return end
    debugPrinted = true
    print("[LaserJumper] Found round: " .. round:GetFullName())
    print("[LaserJumper] Children:")
    for _, child in ipairs(round:GetChildren()) do
        print("  " .. child.ClassName .. " - " .. child.Name)
        if not child:IsA("BasePart") then
            for _, sub in ipairs(child:GetChildren()) do
                print("    " .. sub.ClassName .. " - " .. sub.Name)
            end
        end
    end
    local parts = getAllParts(round)
    print("[LaserJumper] Total BaseParts: " .. #parts)
    for i, p in ipairs(parts) do
        if i <= 20 then
            print("  Part: " .. p.Name .. " (" .. p.ClassName .. ") at " .. tostring(p.Position))
        end
    end
end

local conn = RunService.Heartbeat:Connect(function()
    if not active then return end
    local root = getRootPart()
    local hum = getHumanoid()
    if not root or not hum then return end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return end

    local now = tick()
    if now - lastJump < JUMP_COOLDOWN then return end
    if not isGrounded(hum) then return end

    local round = findActiveRound()
    if not round then return end

    debugRound(round)

    local rootPos = root.Position

    -- scan ALL BasePart descendants of the round, not just named ones
    for _, part in ipairs(round:GetDescendants()) do
        if not part:IsA("BasePart") then continue end

        local partPos = part.Position
        local diff = partPos - rootPos
        local horizDist = Vector3.new(diff.X, 0, diff.Z).Magnitude
        local yDiff = partPos.Y - rootPos.Y

        -- skip parts too high or too low
        if yDiff < -4 or yDiff > 6 then continue end

        if horizDist <= JUMP_RANGE then
            hum.Jump = true
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.Jumping) end)
            lastJump = now
            break
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Laser Jumper", "[Spec]evil_plate_laser", cleanup, "spec")
end
