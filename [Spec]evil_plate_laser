-- [Spec] Evil Plate Game - Laser Jumper
-- Auto-jumps over lasers with tight timing

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local connections = {}
local active = true
local JUMP_RANGE = 8
local JUMP_COOLDOWN = 0.6
local lastJump = 0
local lastLaserPositions = {} -- track laser movement to detect approach direction

local function getRootPart()
    local char = localPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = localPlayer.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function isGrounded(hum)
    return hum.FloorMaterial ~= Enum.Material.Air
end

local function findActiveRound()
    local activeEvents = workspace:FindFirstChild("ActiveEvents")
    if not activeEvents then return nil end
    for _, child in ipairs(activeEvents:GetChildren()) do
        if child.Name:match("^Round_%d+$") then
            return child
        end
    end
    return nil
end

local function getLaserParts(round)
    local lasers = {}
    for i = 1, 4 do
        local laser = round:FindFirstChild("Lasers" .. i)
        if not laser then continue end
        if laser:IsA("BasePart") then
            table.insert(lasers, laser)
        else
            for _, part in ipairs(laser:GetDescendants()) do
                if part:IsA("BasePart") then
                    table.insert(lasers, part)
                end
            end
        end
    end
    for _, desc in ipairs(round:GetDescendants()) do
        if desc:IsA("BasePart") and desc.Name:lower():find("laser") then
            local already = false
            for _, l in ipairs(lasers) do
                if l == desc then already = true; break end
            end
            if not already then
                table.insert(lasers, desc)
            end
        end
    end
    return lasers
end

local conn = RunService.Heartbeat:Connect(function()
    if not active then return end
    local root = getRootPart()
    local hum = getHumanoid()
    if not root or not hum then return end
    if hum:GetState() == Enum.HumanoidStateType.Dead then return end

    local now = tick()
    if now - lastJump < JUMP_COOLDOWN then return end

    -- only jump from the ground
    if not isGrounded(hum) then return end

    local round = findActiveRound()
    if not round then return end

    local rootPos = root.Position
    local lasers = getLaserParts(round)

    for _, laser in ipairs(lasers) do
        local laserPos = laser.Position
        local diff = laserPos - rootPos
        local horizDist = Vector3.new(diff.X, 0, diff.Z).Magnitude
        local yDiff = laserPos.Y - rootPos.Y

        -- only care about lasers at body height
        if yDiff < -5 or yDiff > 8 then continue end

        -- check if laser is approaching by comparing to last known position
        local lastPos = lastLaserPositions[laser]
        lastLaserPositions[laser] = laserPos

        if lastPos and horizDist <= JUMP_RANGE then
            local lastDist = Vector3.new(lastPos.X - rootPos.X, 0, lastPos.Z - rootPos.Z).Magnitude
            local closing = lastDist > horizDist -- laser is getting closer

            if closing then
                hum.Jump = true
                pcall(function() hum:ChangeState(Enum.HumanoidStateType.Jumping) end)
                lastJump = now
                break
            end
        end
    end

    -- clean up tracked lasers that no longer exist
    for laser in pairs(lastLaserPositions) do
        if not laser.Parent then
            lastLaserPositions[laser] = nil
        end
    end
end)
table.insert(connections, conn)

---------- SIXZEROHUB REGISTRATION ----------

local function cleanup()
    active = false
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    connections = {}
    lastLaserPositions = {}
end

if _G.SixZeroHubRegister then
    _G.SixZeroHubRegister("Laser Jumper", "[Spec]evil_plate_laser", cleanup, "spec")
end
