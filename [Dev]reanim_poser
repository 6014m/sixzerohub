local function fullCleanup()
    active = false
    stopPlayback()
    clearSel()
    for _,c in pairs(conns) do pcall(function() c:Disconnect() end) end; conns={}
    if proxyPart then proxyPart:Destroy(); proxyPart=nil end
    if moveHandles then moveHandles:Destroy(); moveHandles=nil end
    if arcHandles then arcHandles:Destroy(); arcHandles=nil end
    if gui then gui:Destroy(); gui=nil end
    for _, cd in ipairs(clonesList) do
        if cd.model then pcall(function() cd.model:Destroy() end) end
    end
    clonesList = {}
    clone=nil; joints=nil; defaults=nil
    guiCreated = false
end

---------- RENDER RADIUS ----------
-- Only keep models spawned for frames within RENDER_RADIUS of the player.
-- Despawned frames keep their pose data so they can be rebuilt.

savePose = function(cd)
    if not cd.joints then return end
    cd.pose = {}
    for _, j in ipairs(cd.joints) do
        if j.motor then cd.pose[j.name] = j.motor.C0 end
    end
end

local function despawnFrame(cd)
    if not cd.rendered then return end
    savePose(cd)
    if cd.model then
        local hrp = cd.model:FindFirstChild("HumanoidRootPart")
        if hrp then cd.pos = hrp.CFrame.Position end
        pcall(function() cd.model:Destroy() end)
    end
    cd.model = nil; cd.joints = nil; cd.rendered = false
end

local function respawnFrame(cd, idx)
    if cd.rendered then return end
    local real = player.Character; if not real then return end
    real.Archivable = true
    local c = real:Clone(); c.Name = "PoseFrame_" .. idx
    for _,v in pairs(c:GetDescendants()) do
        if v:IsA("LocalScript") or v:IsA("Script") then v:Destroy()
        elseif v:IsA("BasePart") then v.Anchored=(v.Name=="HumanoidRootPart"); v.CanCollide=false end
    end
    local ch = c:FindFirstChildOfClass("Humanoid")
    if ch then ch.PlatformStand=true; for _,t in pairs(ch:GetPlayingAnimationTracks()) do t:Stop() end end

    local pos = cd.pos or Vector3.new(0, 10, 0)
    local groundRay = workspace:Raycast(pos + Vector3.new(0, 50, 0), Vector3.new(0, -200, 0))
    local groundY = groundRay and (groundRay.Position.Y + 5) or pos.Y
    c:SetPrimaryPartCFrame(CFrame.new(pos.X, groundY, pos.Z) * CFrame.Angles(0, math.pi, 0))
    c.Parent = workspace

    -- Frame label
    local bGui = Instance.new("BillboardGui")
    bGui.Name = "FrameLabel"; bGui.Size = UDim2.new(0, 60, 0, 24)
    bGui.StudsOffset = Vector3.new(0, 3, 0); bGui.AlwaysOnTop = true
    bGui.Adornee = c:FindFirstChild("Head") or c:FindFirstChild("HumanoidRootPart")
    bGui.Parent = c
    local fLbl = Instance.new("TextLabel")
    fLbl.Size = UDim2.new(1, 0, 1, 0)
    fLbl.BackgroundColor3 = Color3.fromRGB(0, 170, 255); fLbl.BackgroundTransparency = 0.3
    fLbl.TextColor3 = Color3.new(1, 1, 1); fLbl.TextSize = 14; fLbl.Font = Enum.Font.GothamBold
    fLbl.Text = "F" .. idx; fLbl.Parent = bGui
    Instance.new("UICorner", fLbl).CornerRadius = UDim.new(0, 6)

    local j, d = buildJoints(c)
    cd.model = c; cd.joints = j; cd.defaults = d; cd.rendered = true

    -- Apply saved pose
    if cd.pose then
        for _, jt in ipairs(j) do
            if jt.motor and cd.pose[jt.name] then jt.motor.C0 = cd.pose[jt.name] end
        end
    end
end

local function updateRenderRadius()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local playerPos = root.Position

    for idx, cd in ipairs(clonesList) do
        local framePos = cd.pos or Vector3.new(0, 0, 0)
        local dist = (playerPos - framePos).Magnitude

        if dist > RENDER_RADIUS and cd.rendered then
            -- Don't despawn the currently selected clone
            if cd.model ~= clone then
                despawnFrame(cd)
            end
        elseif dist <= RENDER_RADIUS and not cd.rendered then
            respawnFrame(cd, idx)
        end
    end
end

table.insert(conns, RunService.Heartbeat:Connect(function()
    if not active then return end
    updateRenderRadius()
end))

