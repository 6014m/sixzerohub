-- Forward declare for render radius (defined later)
local savePose

local function buildJoints(c)
    local j, d = {}, {}
    local tor = c:FindFirstChild("Torso")
    for _,jd in ipairs({
        {n="RootJoint",m=c.HumanoidRootPart:FindFirstChild("RootJoint")},
        {n="Neck",m=tor and tor:FindFirstChild("Neck")},
        {n="Right Shoulder",m=tor and tor:FindFirstChild("Right Shoulder")},
        {n="Left Shoulder",m=tor and tor:FindFirstChild("Left Shoulder")},
        {n="Right Hip",m=tor and tor:FindFirstChild("Right Hip")},
        {n="Left Hip",m=tor and tor:FindFirstChild("Left Hip")},
    }) do if jd.m then table.insert(j,{name=jd.n,motor=jd.m}); d[jd.n]=jd.m.C0 end end
    return j, d
end

local function spawnClone()
    local real = player.Character; if not real then return end
    local hum = real:FindFirstChildOfClass("Humanoid")
    if not hum or hum.RigType ~= Enum.HumanoidRigType.R6 then print("[Pose] R6 only"); return end
    real.Archivable = true
    local c = real:Clone(); c.Name = "PoseFrame_" .. (#clonesList + 1)
    for _,v in pairs(c:GetDescendants()) do
        if v:IsA("LocalScript") or v:IsA("Script") then v:Destroy()
        elseif v:IsA("BasePart") then v.Anchored=(v.Name=="HumanoidRootPart"); v.CanCollide=false end
    end
    local ch = c:FindFirstChildOfClass("Humanoid")
    if ch then ch.PlatformStand=true; for _,t in pairs(ch:GetPlayingAnimationTracks()) do t:Stop() end end

    -- Position: first clone 10 studs in front, subsequent 20 studs right of last
    local root = real:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local spawnPos
    if #clonesList == 0 then
        spawnPos = root.CFrame.Position + root.CFrame.LookVector * 10
    else
        -- Use stored position of last frame (works even if model is despawned)
        local lastData = clonesList[#clonesList]
        local lastPos = lastData.pos or (root.CFrame.Position + root.CFrame.LookVector * 10)
        spawnPos = lastPos + root.CFrame.RightVector * 6
    end
    local groundRay = workspace:Raycast(spawnPos + Vector3.new(0, 50, 0), Vector3.new(0, -200, 0))
    local groundY = groundRay and (groundRay.Position.Y + 5) or spawnPos.Y
    c:SetPrimaryPartCFrame(CFrame.new(spawnPos.X, groundY, spawnPos.Z) * CFrame.Angles(0, math.pi, 0))
    c.Parent = workspace

    -- Frame number label above head
    local bGui = Instance.new("BillboardGui")
    bGui.Name = "FrameLabel"
    bGui.Size = UDim2.new(0, 60, 0, 24)
    bGui.StudsOffset = Vector3.new(0, 3, 0)
    bGui.AlwaysOnTop = true
    bGui.Adornee = c:FindFirstChild("Head") or c.HumanoidRootPart
    bGui.Parent = c
    local fLbl = Instance.new("TextLabel")
    fLbl.Size = UDim2.new(1, 0, 1, 0)
    fLbl.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    fLbl.BackgroundTransparency = 0.3
    fLbl.TextColor3 = Color3.new(1, 1, 1)
    fLbl.TextSize = 14
    fLbl.Font = Enum.Font.GothamBold
    fLbl.Text = "F" .. (#clonesList + 1)
    fLbl.Parent = bGui
    Instance.new("UICorner", fLbl).CornerRadius = UDim.new(0, 6)

    local j, d = buildJoints(c)
    -- Store pose data (C0 values) so we can rebuild the model if despawned
    local poseData = {}
    for _, jt in ipairs(j) do if jt.motor then poseData[jt.name] = jt.motor.C0 end end
    local data = { model = c, joints = j, defaults = d, pose = poseData, pos = spawnPos, rendered = true }
    table.insert(clonesList, data)
    switchToClone(data)
    print("[Pose] Frame " .. #clonesList .. " spawned")
end

function switchToClone(data)
    if not data then return end
    clearSel()
    clone = data.model
    joints = data.joints
    defaults = data.defaults
    undoStack = {}
    redoStack = {}
    -- Highlight active clone
    if cloneHighlight then
        cloneHighlight.Adornee = clone
    end
    if refreshPartsList then refreshPartsList() end
    if refreshFramesList then refreshFramesList() end
end

local function findCloneDataForPart(part)
    for _, cd in ipairs(clonesList) do
        if cd.model and part:IsDescendantOf(cd.model) then return cd end
    end
    return nil
end

local function deleteClone(data)
    if not data then return end
    for i, cd in ipairs(clonesList) do
        if cd == data then table.remove(clonesList, i); break end
    end
    if data.model then pcall(function() data.model:Destroy() end) end
    -- Renumber frame labels
    for i, cd in ipairs(clonesList) do
        if cd.model then
            local bg = cd.model:FindFirstChild("FrameLabel")
            if bg then
                local lbl = bg:FindFirstChildOfClass("TextLabel")
                if lbl then lbl.Text = "F" .. i end
            end
        end
    end
    if clone == data.model then
        if #clonesList > 0 then
            switchToClone(clonesList[#clonesList])
        else
            clone = nil; joints = nil; defaults = nil
            clearSel()
            if refreshPartsList then refreshPartsList() end
            if refreshFramesList then refreshFramesList() end
        end
    else
        if refreshFramesList then refreshFramesList() end
    end
end

--================================================================
-- PLAY ANIMATION (temp clone that lerps through keyframes)
--================================================================

local function stopPlayback()
    playing = false
    if tempClone then pcall(function() tempClone:Destroy() end); tempClone = nil end
end

local function playAnimation()
    if #clonesList < 2 then print("[Pose] Need at least 2 frames"); return end
    if playing then stopPlayback(); return end

    -- Create temp clone from first keyframe
    local firstModel = clonesList[1].model
    firstModel.Archivable = true
    tempClone = firstModel:Clone()
    tempClone.Name = "PoseAnim_Preview"

    -- Remove frame label, add "PLAYING" label
    local oldLabel = tempClone:FindFirstChild("FrameLabel")
    if oldLabel then oldLabel:Destroy() end
    local bGui = Instance.new("BillboardGui")
    bGui.Name = "PlayLabel"
    bGui.Size = UDim2.new(0, 80, 0, 24)
    bGui.StudsOffset = Vector3.new(0, 3, 0)
    bGui.AlwaysOnTop = true
    bGui.Adornee = tempClone:FindFirstChild("Head") or tempClone:FindFirstChild("HumanoidRootPart")
    bGui.Parent = tempClone
    local pLbl = Instance.new("TextLabel")
    pLbl.Size = UDim2.new(1, 0, 1, 0)
    pLbl.BackgroundColor3 = Color3.fromRGB(60, 200, 80)
    pLbl.BackgroundTransparency = 0.3
    pLbl.TextColor3 = Color3.new(1, 1, 1)
    pLbl.TextSize = 12
    pLbl.Font = Enum.Font.GothamBold
    pLbl.Text = "PLAYING"
    pLbl.Parent = bGui
    Instance.new("UICorner", pLbl).CornerRadius = UDim.new(0, 6)

    -- Position in front of player
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if root then
        local pos = root.CFrame.Position + root.CFrame.LookVector * 10 + Vector3.new(0, 0, 0)
        local groundRay = workspace:Raycast(pos + Vector3.new(0, 50, 0), Vector3.new(0, -200, 0))
        local groundY = groundRay and (groundRay.Position.Y + 5) or pos.Y
        local hrp = tempClone:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(pos.X, groundY, pos.Z) * CFrame.Angles(0, math.pi, 0) end
    end
    tempClone.Parent = workspace

    local tempJoints = buildJoints(tempClone)
    playing = true

    task.spawn(function()
        -- Gather all keyframe poses
        local keyframes = {}
        for _, cd in ipairs(clonesList) do
            table.insert(keyframes, captureFrom(cd.joints))
        end

        while playing do
            for i = 1, #keyframes - 1 do
                if not playing then break end
                local from, to = keyframes[i], keyframes[i + 1]
                local startTime = tick()
                while tick() - startTime < tweenDuration do
                    if not playing then break end
                    local alpha = math.clamp((tick() - startTime) / tweenDuration, 0, 1)
                    for _, tj in ipairs(tempJoints) do
                        if tj.motor and from[tj.name] and to[tj.name] then
                            tj.motor.C0 = from[tj.name]:Lerp(to[tj.name], alpha)
                        end
                    end
                    RunService.Heartbeat:Wait()
                end
                -- Snap to target
                if playing then applyTo(tempJoints, to) end
            end
            -- Loop: pause at end briefly then restart
            if playing then task.wait(0.2) end
        end

        if tempClone then pcall(function() tempClone:Destroy() end); tempClone = nil end
        if refreshFramesList then refreshFramesList() end
    end)

    if refreshFramesList then refreshFramesList() end
end

--================================================================
-- IMPORT ANIMATION BY ID
--================================================================

local function importAnimation(animId)
    local real = player.Character
    if not real then print("[Pose] No character"); return end
    local hum = real:FindFirstChildOfClass("Humanoid")
    if not hum or hum.RigType ~= Enum.HumanoidRigType.R6 then print("[Pose] R6 only"); return end

    local animator = hum:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = hum
    end

    print("[Pose] Loading animation " .. animId .. "...")

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animId)

    local ok, track = pcall(function() return animator:LoadAnimation(anim) end)
    if not ok or not track then
        print("[Pose] LoadAnimation failed: " .. tostring(track))
        return
    end

    -- Stop other animations so our sample is clean
    for _, t in ipairs(animator:GetPlayingAnimationTracks()) do t:Stop(0) end
    task.wait(0.1)

    track.Priority = Enum.AnimationPriority.Action4
    track:Play()

    -- Wait for length to populate
    local waited = 0
    while track.Length <= 0 and waited < 5 do
        task.wait(0.1)
        waited = waited + 0.1
    end

    if track.Length <= 0 then
        track:Stop()
        print("[Pose] Animation failed to load (ID: " .. animId .. ")")
        return
    end

    local length = track.Length
    print("[Pose] Playing and sampling, length: " .. string.format("%.2f", length) .. "s")

    -- Sample the actual rendered poses every heartbeat as the engine plays it
    local torso = real:FindFirstChild("Torso")
    local hrpReal = real:FindFirstChild("HumanoidRootPart")
    local sampledFrames = {}

    local startTime = tick()
    while tick() - startTime < length + 0.03 do
        local pose = {}
        if torso then
            for _, m in ipairs(torso:GetChildren()) do
                if m:IsA("Motor6D") then
                    pose[m.Name] = m.C0 * m.Transform
                end
            end
        end
        if hrpReal then
            local rj = hrpReal:FindFirstChild("RootJoint")
            if rj then pose["RootJoint"] = rj.C0 * rj.Transform end
        end
        table.insert(sampledFrames, pose)
        RunService.Heartbeat:Wait()
    end

    track:Stop(0)
    print("[Pose] Sampled " .. #sampledFrames .. " raw frames")

    if #sampledFrames == 0 then
        print("[Pose] No frames captured")
        return
    end

    -- Deduplicate: only remove EXACT duplicate frames and detect exact loop restart
    local function framesEqual(a, b)
        for name, cfA in pairs(a) do
            local cfB = b[name]
            if not cfB then return false end
            if cfA ~= cfB then return false end
        end
        for name in pairs(b) do
            if not a[name] then return false end
        end
        return true
    end

    -- 1. Remove consecutive exact duplicate frames
    local deduped = { sampledFrames[1] }
    for i = 2, #sampledFrames do
        if not framesEqual(sampledFrames[i], sampledFrames[i - 1]) then
            table.insert(deduped, sampledFrames[i])
        end
    end

    -- 2. Detect exact loop: if the animation restarts (end frames match start frames exactly)
    if #deduped > 10 then
        local halfLen = math.floor(#deduped / 2)
        for loopLen = 4, halfLen do
            local match = true
            for k = 0, math.min(loopLen - 1, 3) do
                if not framesEqual(deduped[#deduped - loopLen + 1 + k], deduped[1 + k]) then
                    match = false; break
                end
            end
            if match then
                local trimmed = {}
                for i = 1, #deduped - loopLen do
                    table.insert(trimmed, deduped[i])
                end
                table.insert(trimmed, deduped[1])
                print("[Pose] Loop detected at frame " .. (#deduped - loopLen) .. ", trimmed from " .. #deduped .. " to " .. #trimmed)
                deduped = trimmed
                break
            end
        end
    end

    sampledFrames = deduped
    print("[Pose] After dedup: " .. #sampledFrames .. " frames")

    -- Set tween duration (one heartbeat per frame, ~1/60s)
    tweenDuration = length / math.max(#sampledFrames - 1, 1)
    if tweenBoxRef then tweenBoxRef.Text = string.format("%.4f", tweenDuration) end

    -- Create keyframe clones sequentially (one per frame, yields to prevent crash)
    print("[Pose] Spawning " .. #sampledFrames .. " frames sequentially...")
    for i, pose in ipairs(sampledFrames) do
        if not active then break end
        spawnClone()
        local cd = clonesList[#clonesList]
        if cd then
            for _, j in ipairs(cd.joints) do
                if j.motor and pose[j.name] then
                    j.motor.C0 = pose[j.name]
                end
            end
            -- Save pose data immediately for render radius
            savePose(cd)
        end
        -- Yield every frame to prevent crash
        if i % 3 == 0 then task.wait() end
    end

    if #clonesList > 0 then switchToClone(clonesList[1]) end
    print("[Pose] Imported " .. #sampledFrames .. " frames (tween: " .. string.format("%.4f", tweenDuration) .. "s)")
end

