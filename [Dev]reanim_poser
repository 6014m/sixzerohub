--================================================================
-- POSE HELPERS
--================================================================

local function captureFrom(jts)
    if not jts then return nil end
    local p = {}
    for _,j in ipairs(jts) do if j.motor then p[j.name] = j.motor.C0 end end
    return p
end

local function capture() return captureFrom(joints) end

local function applyTo(jts, pose)
    if not jts or not pose then return end
    for _,j in ipairs(jts) do if j.motor and pose[j.name] then j.motor.C0 = pose[j.name] end end
end

local function apply(pose) applyTo(joints, pose) end

local function copyAnimCode()
    if #clonesList < 1 then return end
    local out = "-- R6 Animation — " .. #clonesList .. " keyframes, " .. tweenDuration .. "s tween\n"
    out = out .. "local RunService = game:GetService('RunService')\n"
    out = out .. "local tweenDuration = " .. tweenDuration .. "\n\n"
    out = out .. "local keyframes = {\n"
    for i, cd in ipairs(clonesList) do
        out = out .. "    { -- Frame " .. i .. "\n"
        for _, j in ipairs(cd.joints) do
            if j.motor then
                local cs = {j.motor.C0:GetComponents()}
                local pts = {}
                for _, v in ipairs(cs) do table.insert(pts, string.format("%.4f", v)) end
                out = out .. string.format('        ["%s"] = CFrame.new(%s),\n', j.name, table.concat(pts, ", "))
            end
        end
        out = out .. "    },\n"
    end
    out = out .. "}\n\n"
    out = out .. "local function playAnim(character, loop)\n"
    out = out .. "    local torso = character:FindFirstChild('Torso')\n"
    out = out .. "    local hrp = character:FindFirstChild('HumanoidRootPart')\n"
    out = out .. "    if not torso or not hrp then return end\n"
    out = out .. "    local jMap = {}\n"
    out = out .. "    for _, m in ipairs(torso:GetChildren()) do if m:IsA('Motor6D') then jMap[m.Name] = m end end\n"
    out = out .. "    local rj = hrp:FindFirstChild('RootJoint'); if rj then jMap['RootJoint'] = rj end\n"
    out = out .. "    repeat\n"
    out = out .. "        for i = 1, #keyframes - 1 do\n"
    out = out .. "            local from, to = keyframes[i], keyframes[i+1]\n"
    out = out .. "            local start = tick()\n"
    out = out .. "            while tick() - start < tweenDuration do\n"
    out = out .. "                local a = math.clamp((tick() - start) / tweenDuration, 0, 1)\n"
    out = out .. "                for name, motor in pairs(jMap) do\n"
    out = out .. "                    if from[name] and to[name] then motor.C0 = from[name]:Lerp(to[name], a) end\n"
    out = out .. "                end\n"
    out = out .. "                RunService.Heartbeat:Wait()\n"
    out = out .. "            end\n"
    out = out .. "            for name, motor in pairs(jMap) do if to[name] then motor.C0 = to[name] end end\n"
    out = out .. "        end\n"
    out = out .. "    until not loop\n"
    out = out .. "end\n\n"
    out = out .. "-- Usage: playAnim(game.Players.LocalPlayer.Character, false)\n"
    print("=== ANIMATION ==="); print(out); print("=================")
    pcall(function() if setclipboard then setclipboard(out) elseif toclipboard then toclipboard(out) end end)
end

local function copySinglePose()
    if not joints or not defaults then return end
    local out = "-- R6 Pose Output\n"
    for _,j in ipairs(joints) do if j.motor then
        local offset = defaults[j.name]:Inverse() * j.motor.C0
        local ox,oy,oz = offset.X, offset.Y, offset.Z
        local rx,ry,rz = offset:ToEulerAnglesXYZ()
        rx,ry,rz = math.deg(rx),math.deg(ry),math.deg(rz)
        local hp = math.abs(ox)>0.01 or math.abs(oy)>0.01 or math.abs(oz)>0.01
        local hr = math.abs(rx)>0.5 or math.abs(ry)>0.5 or math.abs(rz)>0.5
        if hp or hr then
            local v=j.name:gsub(" ",""); local s=v:sub(1,2):lower()..v:sub(3)
            local ps=hp and string.format("CFrame.new(%.2f, %.2f, %.2f) * ",ox,oy,oz) or ""
            local rs=hr and string.format("CFrame.Angles(math.rad(%.1f), math.rad(%.1f), math.rad(%.1f))",rx,ry,rz) or "CFrame.new()"
            out=out..string.format("if %s then %s.C0 = %s.C0:Lerp(%sDefault * %s%s, 0.12) end\n",s,s,s,v,ps,rs)
        end
    end end
    out=out.."\n-- Defaults:\n"
    for _,j in ipairs(joints) do if j.motor then
        local cs={defaults[j.name]:GetComponents()};local pts={}
        for _,vv in ipairs(cs) do table.insert(pts,string.format("%.4f",vv)) end
        out=out..string.format("-- local %sDefault = CFrame.new(%s)\n",j.name:gsub(" ",""),table.concat(pts,", "))
    end end
    print("=== POSE ===");print(out);print("============")
    pcall(function() if setclipboard then setclipboard(out) elseif toclipboard then toclipboard(out) end end)
end

--================================================================
-- HANDLE / SELECTION HELPERS
--================================================================

local function getHandleAdornee()
    if not selected or not selected.motor then return nil end
    if axisMode == "global" then
        if not proxyPart then
            proxyPart = Instance.new("Part")
            proxyPart.Name = "PoseProxy"
            proxyPart.Size = selected.motor.Part1.Size
            proxyPart.Transparency = 1
            proxyPart.Anchored = true
            proxyPart.CanCollide = false
            proxyPart.Parent = workspace
        end
        proxyPart.Size = selected.motor.Part1.Size
        proxyPart.CFrame = CFrame.new(selected.motor.Part1.Position)
        return proxyPart
    else
        return selected.motor.Part1
    end
end

local function clearSel()
    selected = nil
    selectedList = {}
    for _, sb in pairs(selBoxes) do sb:Destroy() end
    selBoxes = {}
    if moveHandles then moveHandles.Adornee = nil end
    if arcHandles then arcHandles.Adornee = nil end
end

local function addToSel(j)
    for _, s in ipairs(selectedList) do if s.name == j.name then return end end
    table.insert(selectedList, j)
    local sb = Instance.new("SelectionBox")
    sb.Color3 = #selectedList == 1 and Color3.fromRGB(0,170,255) or Color3.fromRGB(230,190,40)
    sb.LineThickness = 0.05
    sb.SurfaceTransparency = 0.8
    sb.SurfaceColor3 = sb.Color3
    sb.Parent = gui
    if j.motor and j.motor.Part1 then sb.Adornee = j.motor.Part1; sb.Visible = true end
    selBoxes[j.name] = sb
end

local function removeFromSel(j)
    for i, s in ipairs(selectedList) do
        if s.name == j.name then
            table.remove(selectedList, i)
            if selBoxes[j.name] then selBoxes[j.name]:Destroy(); selBoxes[j.name] = nil end
            break
        end
    end
end

local function selectPart(part, multi)
    if not part or not joints then return nil end
    local jn = partMap[part.Name]
    if not jn and part.Parent and part.Parent:IsA("Accessory") then jn = "Acc_"..part.Parent.Name end
    if not jn then return nil end
    for _,j in ipairs(joints) do
        if j.name == jn then
            if multi then
                local found = false
                for _, s in ipairs(selectedList) do if s.name == j.name then found = true; break end end
                if found then removeFromSel(j) else addToSel(j) end
                selected = #selectedList > 0 and selectedList[#selectedList] or nil
            else
                clearSel()
                selected = j
                addToSel(j)
            end
            local adornee = getHandleAdornee()
            if moveHandles then moveHandles.Adornee = mode=="Move" and adornee or nil end
            if arcHandles then arcHandles.Adornee = mode=="Rotate" and adornee or nil end
            return true
        end
    end
    return nil
end

local function updateHandleMode()
    if not selected then return end
    local adornee = getHandleAdornee()
    if moveHandles then moveHandles.Adornee = mode=="Move" and adornee or nil end
    if arcHandles then arcHandles.Adornee = mode=="Rotate" and adornee or nil end
end

-- Undo/Redo
local undoStack, redoStack = {}, {}

local function saveState()
    if not joints then return end
    local state = {}
    for _,j in ipairs(joints) do if j.motor then state[j.name] = j.motor.C0 end end
    table.insert(undoStack, state)
    if #undoStack > 50 then table.remove(undoStack, 1) end
    redoStack = {}
end

local function undo()
    if #undoStack == 0 or not joints then return end
    local cur = {}
    for _,j in ipairs(joints) do if j.motor then cur[j.name] = j.motor.C0 end end
    table.insert(redoStack, cur)
    local prev = table.remove(undoStack)
    for _,j in ipairs(joints) do if j.motor and prev[j.name] then j.motor.C0 = prev[j.name] end end
end

local function redo()
    if #redoStack == 0 or not joints then return end
    local cur = {}
    for _,j in ipairs(joints) do if j.motor then cur[j.name] = j.motor.C0 end end
    table.insert(undoStack, cur)
    local next2 = table.remove(redoStack)
    for _,j in ipairs(joints) do if j.motor and next2[j.name] then j.motor.C0 = next2[j.name] end end
end

-- Accessory adder
local function addAcc(acc)
    if not acc:IsA("Accessory") or not acc:FindFirstChild("Handle") or not clone or not joints then return end
    for _,j in ipairs(joints) do if j.name=="Acc_"..acc.Name then return end end
    local h = acc.Handle
    local par = nil
    for _,w in ipairs(h:GetChildren()) do if w:IsA("Weld") or w:IsA("WeldConstraint") then par=(w.Part0==h) and w.Part1 or w.Part0; break end end
    if not par then for _,w in ipairs(clone:GetDescendants()) do if (w:IsA("Weld") or w:IsA("WeldConstraint")) and (w.Part0==h or w.Part1==h) then par=(w.Part0==h) and w.Part1 or w.Part0; break end end end
    if not par then par = clone:FindFirstChild("Head") or clone:FindFirstChild("Torso") end
    for _,w in ipairs(h:GetChildren()) do if w:IsA("Weld") or w:IsA("WeldConstraint") then w:Destroy() end end
    local m = Instance.new("Motor6D"); m.Name="CZ_Acc"; m.Part0=par; m.Part1=h
    m.C0 = par.CFrame:ToObjectSpace(h.CFrame); m.Parent=h
    local jd = {name="Acc_"..acc.Name, motor=m}
    table.insert(joints, jd)
    defaults[jd.name] = m.C0
    partMap[h.Name] = jd.name
end

local refreshPartsList, refreshFramesList

