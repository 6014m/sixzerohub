local function populateCommands(filter)
    local page = tabPages["Commands"]
    for _, child in ipairs(page:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    filter = filter and filter:lower() or ""
    local tagFilter = nil
    if filter:sub(1, 1) == "#" then
        tagFilter = filter:sub(2)
        filter = ""
    end

    local order = 0

    for _, cmd in ipairs(cmds) do
        -- tag filter
        if tagFilter and tagFilter ~= "" then
            if not cmd.TAG:lower():find(tagFilter, 1, true) then continue end
        end

        -- text filter
        if filter ~= "" then
            local aliases = table.concat(cmd.ALIAS, ", ")
            local searchStr = cmd.NAME .. " " .. aliases .. " " .. (cmd.DESC or "") .. " " .. cmd.TAG
            if not searchStr:lower():find(filter, 1, true) then continue end
        end

        order = order + 1
        local aliases = table.concat(cmd.ALIAS, ", ")

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, -4, 0, 26)
        btn.BackgroundColor3 = THEME.hover
        btn.BackgroundTransparency = 0.5
        btn.BorderSizePixel = 0
        btn.TextColor3 = THEME.text
        btn.TextSize = 12
        btn.Font = Enum.Font.Gotham
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.AutoButtonColor = false
        btn.LayoutOrder = order
        btn.Parent = page
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

        local displayText = "  " .. cmd.NAME
        if #cmd.ALIAS > 0 then
            displayText = displayText .. "  [" .. aliases .. "]"
        end
        btn.Text = displayText

        -- tag badge
        if cmd.TAG ~= "" then
            local tagLbl = Instance.new("TextLabel")
            tagLbl.Size = UDim2.new(0, 0, 0, 16)
            tagLbl.AutomaticSize = Enum.AutomaticSize.X
            tagLbl.Position = UDim2.new(1, -8, 0, 5)
            tagLbl.AnchorPoint = Vector2.new(1, 0)
            tagLbl.BackgroundColor3 = TAG_COLORS[cmd.TAG] or THEME.muted
            tagLbl.BackgroundTransparency = 0.7
            tagLbl.BorderSizePixel = 0
            tagLbl.Text = " " .. cmd.TAG .. " "
            tagLbl.TextColor3 = TAG_COLORS[cmd.TAG] or THEME.muted
            tagLbl.TextSize = 9
            tagLbl.Font = Enum.Font.GothamBold
            tagLbl.Parent = btn
            Instance.new("UICorner", tagLbl).CornerRadius = UDim.new(0, 3)
        end

        btn.MouseButton1Click:Connect(function()
            cmdBar.Text = cmd.NAME .. " "
            cmdBar:CaptureFocus()
        end)

        btn.MouseEnter:Connect(function()
            btn.BackgroundTransparency = 0
            local hover = cmd.NAME
            if cmd.TAG ~= "" then hover = hover .. "  #" .. cmd.TAG end
            hover = hover .. "\n" .. (cmd.DESC ~= "" and cmd.DESC or "No description")
            if #cmd.ALIAS > 0 then hover = hover .. "\nAliases: " .. aliases end
            hoverLabel.Text = hover
            hoverLabel.Visible = true
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundTransparency = 0.5
            hoverLabel.Visible = false
        end)
    end
end

