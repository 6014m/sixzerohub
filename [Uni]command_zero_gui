local function onChat(msg)
    if not chatCmdEnabled then return end
    msg = msg:gsub("^/e ", "")
    if msg:sub(1, #prefix) == prefix then
        execCmd(msg:sub(#prefix + 1), player, true)
    end
end

connect(player.Chatted, onChat)

-- TextChatService hook
pcall(function()
    if TextChatService and RBXGeneral then
        connect(RBXGeneral.ShouldDeliverCallback and RBXGeneral.MessageReceived or RBXGeneral.MessageReceived, function(msg)
            if msg.TextSource and msg.TextSource.UserId == player.UserId then
                task.defer(function() onChat(msg.Text) end)
            end
        end)
    end
end)


