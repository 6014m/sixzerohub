-- Keybind to toggle GUI (Right Ctrl) or focus command bar (prefix key)
local suppressNextChar = false
local suppressText = ""

connect(UserInputService.InputBegan, function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightControl then
        guiOpen = not guiOpen
        main.Visible = guiOpen
    elseif input.KeyCode == Enum.KeyCode.Semicolon and prefix == ";" then
        -- pressing ; opens GUI and focuses command bar
        if not cmdBar:IsFocused() then
            guiOpen = true
            main.Visible = true
            suppressText = cmdBar.Text
            suppressNextChar = true
            cmdBar:CaptureFocus()
        end
    end
end)

-- suppress the semicolon character that gets typed when focusing
