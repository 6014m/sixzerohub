---------- Track own attacks for feinting ----------

local function hookSelf(char)
	if not char then return end
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	hum.AnimationPlayed:Connect(function(track)
		if not track.Animation then return end
		local id = track.Animation.AnimationId:match("%d+")
		if id and ATTACK_IDS[id] then
			swinging = true
			track.Ended:Connect(function() swinging = false end)
			track.Stopped:Connect(function() swinging = false end)
		end
	end)
end

task.spawn(function()
	if lp.Character then hookSelf(lp.Character) end
	lp.CharacterAdded:Connect(function(char) task.wait(0.3); hookSelf(char) end)
end)

local function isFacingMe(theirRoot)
	if not myRoot or not theirRoot then return false end
	local toMe = (myRoot.Position - theirRoot.Position)
	local myDot = toMe.Unit:Dot(theirRoot.CFrame.LookVector)
	if myDot <= 0 then return false end -- not facing me at all

	-- Check if they're facing someone else MORE than me within the same range
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp and p.Character then
			local otherRoot = p.Character:FindFirstChild("HumanoidRootPart")
			if otherRoot and otherRoot ~= theirRoot then
				local toOther = (otherRoot.Position - theirRoot.Position)
				if toOther.Magnitude <= RANGE then
					local otherDot = toOther.Unit:Dot(theirRoot.CFrame.LookVector)
					if otherDot > myDot then
						return false -- they're aiming at someone else more than me
					end
				end
			end
		end
	end
	return true
end

---------- Track active animations per player ----------

local allAnims = {} -- { {track, player, root} }

local function hookPlayer(player)
	if player == lp then return end
	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local c = hum.AnimationPlayed:Connect(function(track)
		if not track.Animation then return end
		local id = track.Animation.AnimationId:match("%d+")
		local entry = { track = track, player = player, root = char:FindFirstChild("HumanoidRootPart") }
		table.insert(allAnims, entry)

		-- Instant feint: if we're swinging and they start blocking, feint NOW
		if id and BLOCK_IDS[id] and swinging and tick() - lastFeint > 0.5 then
			local root = char:FindFirstChild("HumanoidRootPart")
			if root and myRoot and (myRoot.Position - root.Position).Magnitude <= RANGE then
				lastFeint = tick()
				blockDown()
				task.delay(0.15, function() blockUp() end)
				flash("INSTANT FEINT — " .. player.Name, Color3.fromRGB(255, 150, 50))
			end
		end

		track.Ended:Connect(function()
			for i = #allAnims, 1, -1 do
				if allAnims[i] == entry then
					table.remove(allAnims, i)
					break
				end
			end
		end)
	end)
	table.insert(connections, c)

	-- GLINT
	local g = char.DescendantAdded:Connect(function(desc)
		if desc.Name == "GLINT" and myRoot and not blocking then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp and isFacingMe(hrp) and (myRoot.Position - hrp.Position).Magnitude <= RANGE and hasTool() then
				lastBlock = tick()
				blocking = true
				blockTarget = player
				blockConfirmed = false
				blockDown()
				flash("GLINT BLOCK " .. player.Name, Color3.fromRGB(0, 255, 150))
				-- Safety release 2s
				task.delay(2, function()
					if blocking and blockTarget == player then
						blockUp(); blocking = false; blockTarget = nil
					end
				end)
			end
		end
	end)
	table.insert(connections, g)
end

local function hookAll()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp and p.Character then
			hookPlayer(p)
		end
	end
end

-- Hook existing + new players + respawns
hookAll()
