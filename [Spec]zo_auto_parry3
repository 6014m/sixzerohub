---------- State ----------

local blocking = false
local blockTarget = nil -- player we're blocking against
local blockConfirmed = false -- NORMAL BLOCK appeared = our block caught a hit
local swinging = false -- are we mid-attack
local lastBlock = 0
local lastKick = 0
local lastPunish = 0
local lastDodge = 0
local lastSwing = 0
local lastFeint = 0
local lastHitBlock = 0 -- when our attack hit their block (NORMAL BLOCK while we're swinging)
local lastPerfectBlocked = 0 -- when we got perfect blocked (stunned, can't act)
local STUN_DURATION = 0.4 -- brief stun after getting perfect blocked
local blockedAnims = {} -- [track] = true, don't double-block same attack

---------- Auto Attack Logic ----------
-- Attack when safe: nobody nearby is blocking (they'd parry us),
-- nobody is mid-attack (we should be blocking not swinging),
-- and we're not currently blocking

local SWING_CD = 0.5
local SWING_RANGE = 12 -- only swing when close enough to actually hit

local function isPlayerDoingAnim(root, idTable)
	for _, entry in ipairs(allAnims) do
		if entry.root == root and entry.track.IsPlaying and entry.track.Animation then
			local id = entry.track.Animation.AnimationId:match("%d+")
			if id and idTable[id] then return true end
		end
	end
	return false
end

local function canSwingSafely()
	if blocking then return false end
	if not myRoot then return false end
	local now = tick()
	if now - lastBlock < 0.3 then return false end -- just blocked, wait
	if now - lastSwing < SWING_CD then return false end

	-- Check all nearby players
	local hasTarget = false
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp then
			local char = p.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			local root = char and char:FindFirstChild("HumanoidRootPart")
			if root and hum and hum.Health > 0 and (myRoot.Position - root.Position).Magnitude <= SWING_RANGE then
				-- Someone alive is in swing range
				hasTarget = true

				-- Don't swing if they're blocking — they'll parry us
				if isPlayerDoingAnim(root, BLOCK_IDS) then return false end

				-- Don't swing if they're mid-attack — we should be blocking
				if isPlayerDoingAnim(root, ATTACK_IDS) then return false end

				-- Don't swing if they're mid-kick — dodge instead
				if isPlayerDoingAnim(root, KICK_IDS) then return false end
			end
		end
	end

	return hasTarget -- only swing if someone is actually in range
end

---------- Main Poll Loop ----------

flash("v4 loaded | " .. attackCount .. " attacks | " .. #Players:GetPlayers() - 1 .. " players", Color3.fromRGB(87, 242, 135))

task.spawn(function()
	while true do
		if myRoot and hasTool() then
			local now = tick()

			-- Skip everything if stunned from perfect block
			if now - lastPerfectBlocked < STUN_DURATION then task.wait(POLL_RATE); continue end

			-- Find nearest threat
			local bestTrack, bestPlayer, bestDist, bestId, bestPct = nil, nil, 999, nil, 0

			for i = #allAnims, 1, -1 do
				local entry = allAnims[i]
				local track = entry.track
				local root = entry.root

				if track.IsPlaying and root and root.Parent then
					-- Skip dead players
					local hum = root.Parent and root.Parent:FindFirstChildOfClass("Humanoid")
					if not hum or hum.Health <= 0 then continue end

					local dist = (myRoot.Position - root.Position).Magnitude
					if dist <= RANGE then
						local id = track.Animation and track.Animation.AnimationId:match("%d+")
						if id and ATTACK_IDS[id] and not blockedAnims[track] then
							local pct = track.Length > 0 and (track.TimePosition / track.Length) * 100 or 0
							if pct >= BLOCK_PERCENT and pct <= BLOCK_PERCENT_MAX then
								if isFacingMe(root) and dist < bestDist then
									bestTrack = track
									bestPlayer = entry.player
									bestDist = dist
									bestId = id
									bestPct = pct
								end
							end
						end

						-- Feint detection
						if id and FEINT_IDS[id] then
							if blocking then
								blockUp()
								blocking = false
							end
							if now - lastPunish > 0.3 then
								lastPunish = now
								swing()
								flash("PUNISH FEINT " .. entry.player.Name, Color3.fromRGB(0, 170, 255))
							end
						end

						-- Block detection — kick
						if id and BLOCK_IDS[id] and now - lastKick > 1 and not swinging then
							if isFacingMe(root) then
								lastKick = now
								local targetPlayer = entry.player
								task.delay(0.5, function()
									local r2 = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
									if r2 and myRoot and (myRoot.Position - r2.Position).Magnitude <= RANGE then
										kick()
										flash("KICK " .. targetPlayer.Name, Color3.fromRGB(255, 100, 100))
									end
								end)
							end
						end

						-- Kick detection — dodge
						if id and KICK_IDS[id] and blocking and now - lastDodge > 1 then
							lastDodge = now
							blocking = false
							backDash()
							flash("DODGE KICK " .. entry.player.Name, Color3.fromRGB(255, 255, 0))
						end

						-- Stagger — execute
						if id and STAGGER_IDS[id] and dist <= 10 then
							execute()
							flash("EXECUTE " .. entry.player.Name, Color3.fromRGB(255, 50, 255))
						end
					end
				end
			end

			-- Block the nearest committed attack
			if bestTrack and not blocking and now - lastBlock > 0.3 then
				lastBlock = now
				blocking = true
				blockTarget = bestPlayer
				blockConfirmed = false
				blockedAnims[bestTrack] = true
				blockDown()
				flash(string.format("BLOCK %s [%s] %.0f%% %.0fs",
					bestPlayer.Name, ATTACK_IDS[bestId], bestPct, bestDist), Color3.fromRGB(87, 242, 135))

				-- Safety release after 2s max
				task.delay(2, function()
					if blocking and blockTarget == bestPlayer then
						blockUp()
						blocking = false
						blockTarget = nil
					end
				end)
			end

			-- Smart block release: if we're blocking, check if attacker is still threatening
			if blocking and blockTarget and now - lastBlock > 0.3 then
				local stillThreat = false
				local tChar = blockTarget.Character
				local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
				if tRoot and myRoot and (myRoot.Position - tRoot.Position).Magnitude <= RANGE then
					-- Check if they're still playing any attack animation
					for _, entry in ipairs(allAnims) do
						if entry.player == blockTarget and entry.track.IsPlaying and entry.track.Animation then
							local aid = entry.track.Animation.AnimationId:match("%d+")
							if aid and ATTACK_IDS[aid] then
								stillThreat = true
								break
							end
						end
					end
				end

				-- Release block if: confirmed block hit and no more attacks, or they moved away
				if not stillThreat and (blockConfirmed or now - lastBlock > 0.6) then
					blockUp()
					blocking = false
					blockTarget = nil
					flash("Block released", Color3.fromRGB(140, 140, 140))
				end
			end

			-- Auto feint: if we're swinging and nearest enemy starts blocking, feint
			if swinging and tick() - lastFeint > 0.5 then
				for _, p in ipairs(Players:GetPlayers()) do
					if p ~= lp then
						local pChar = p.Character
						local pRoot = pChar and pChar:FindFirstChild("HumanoidRootPart")
						if pRoot and myRoot and (myRoot.Position - pRoot.Position).Magnitude <= RANGE then
							if isPlayerDoingAnim(pRoot, BLOCK_IDS) then
								lastFeint = tick()
								blockDown()
								task.delay(0.15, function() blockUp() end)
								flash("AUTO FEINT — " .. p.Name .. " blocking", Color3.fromRGB(255, 150, 50))
								break
							end
						end
					end
				end
			end

			-- Auto attack when safe
			if canSwingSafely() then
				lastSwing = tick()
				swing()
				flash("ATTACK", Color3.fromRGB(255, 200, 50))
			end
		end
		task.wait(POLL_RATE)
	end
end)

-- Clean stale blocked anims
task.spawn(function()
	while true do
		task.wait(2)
		for track in pairs(blockedAnims) do
			if not track.IsPlaying then blockedAnims[track] = nil end
		end
	end
end)

