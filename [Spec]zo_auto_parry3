---------- Input ----------

local function blockDown()
	VIM:SendMouseButtonEvent(0, 0, 1, true, game, 0)
end
local function blockUp()
	VIM:SendMouseButtonEvent(0, 0, 1, false, game, 0)
end
local function swing()
	VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
	task.delay(0.15, function() VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0) end)
end
local function kick()
	keyDown(0x46, Enum.KeyCode.F)
	task.delay(0.15, function() keyUp(0x46, Enum.KeyCode.F) end)
end
local function execute()
	keyDown(0x45, Enum.KeyCode.E)
	task.delay(0.15, function() keyUp(0x45, Enum.KeyCode.E) end)
end
local function keyDown(vk, enumKey)
	if keypress then keypress(vk)
	else VIM:SendKeyEvent(true, enumKey, false, game) end
end
local function keyUp(vk, enumKey)
	if keyrelease then keyrelease(vk)
	else VIM:SendKeyEvent(false, enumKey, false, game) end
end
local function backDash()
	blockUp()
	task.delay(0.1, function()
		keyDown(0x53, Enum.KeyCode.S)
		task.delay(0.15, function()
			keyDown(0x52, Enum.KeyCode.R)
			task.delay(0.15, function() keyUp(0x52, Enum.KeyCode.R) end)
		end)
		task.delay(1, function() keyUp(0x53, Enum.KeyCode.S) end)
	end)
end

