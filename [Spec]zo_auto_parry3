---------- Helpers ----------

local myRoot
task.spawn(function()
	while true do
		local char = lp.Character
		myRoot = char and char:FindFirstChild("HumanoidRootPart")
		task.wait()
	end
end)

local function hasTool()
	local char = lp.Character
	return char and char:FindFirstChildOfClass("Tool")
end

local function isFacingMe(theirRoot)
	if not myRoot or not theirRoot then return false end
	local dot = (myRoot.Position - theirRoot.Position):Dot(theirRoot.CFrame.LookVector)
	return dot > 0
end

---------- Track active animations per player ----------

local allAnims = {} -- { {track, player, root} }

local function hookPlayer(player)
	if player == lp then return end
	local char = player.Character
	if not char then return end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum then return end

	local c = hum.AnimationPlayed:Connect(function(track)
		if not track.Animation then return end
		local entry = { track = track, player = player, root = char:FindFirstChild("HumanoidRootPart") }
		table.insert(allAnims, entry)

		track.Ended:Connect(function()
			for i = #allAnims, 1, -1 do
				if allAnims[i] == entry then
					table.remove(allAnims, i)
					break
				end
			end
		end)
	end)
	table.insert(connections, c)

	-- GLINT
	local g = char.DescendantAdded:Connect(function(desc)
		if desc.Name == "GLINT" and myRoot then
			local hrp = char:FindFirstChild("HumanoidRootPart")
			if hrp and (myRoot.Position - hrp.Position).Magnitude <= RANGE and hasTool() then
				blockDown()
				flash("GLINT BLOCK " .. player.Name, Color3.fromRGB(0, 255, 150))
				task.delay(BLOCK_HOLD, function() blockUp() end)
			end
		end
	end)
	table.insert(connections, g)
end

local function hookAll()
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= lp and p.Character then
			hookPlayer(p)
		end
	end
end

-- Hook existing + new players + respawns
hookAll()
Players.PlayerAdded:Connect(function(p)
	p.CharacterAdded:Connect(function() task.wait(0.5); hookPlayer(p) end)
end)
for _, p in ipairs(Players:GetPlayers()) do
	if p ~= lp then
		p.CharacterAdded:Connect(function() task.wait(0.5); hookPlayer(p) end)
	end
end

-- Rehook periodically to catch missed players
task.spawn(function()
	while true do
		task.wait(5)
		hookAll()
	end
end)

---------- State ----------

local blocking = false
local lastBlock = 0
local lastKick = 0
local lastPunish = 0
local lastDodge = 0
local blockedAnims = {} -- [track] = true, don't double-block same attack

---------- Main Poll Loop ----------

flash("v4 loaded | " .. attackCount .. " attacks | " .. #Players:GetPlayers() - 1 .. " players", Color3.fromRGB(87, 242, 135))

task.spawn(function()
	while true do
		if myRoot and hasTool() then
			local now = tick()

			-- Find nearest threat
			local bestTrack, bestPlayer, bestDist, bestId, bestPct = nil, nil, 999, nil, 0

			for i = #allAnims, 1, -1 do
				local entry = allAnims[i]
				local track = entry.track
				local root = entry.root

				if track.IsPlaying and root and root.Parent then
					local dist = (myRoot.Position - root.Position).Magnitude
					if dist <= RANGE then
						local id = track.Animation and track.Animation.AnimationId:match("%d+")
						if id and ATTACK_IDS[id] and not blockedAnims[track] then
							local pct = track.Length > 0 and (track.TimePosition / track.Length) * 100 or 0
							if pct >= BLOCK_PERCENT and pct <= BLOCK_PERCENT_MAX then
								if isFacingMe(root) and dist < bestDist then
									bestTrack = track
									bestPlayer = entry.player
									bestDist = dist
									bestId = id
									bestPct = pct
								end
							end
						end

						-- Feint detection
						if id and FEINT_IDS[id] then
							if blocking then
								blockUp()
								blocking = false
							end
							if now - lastPunish > 0.3 then
								lastPunish = now
								swing()
								flash("PUNISH FEINT " .. entry.player.Name, Color3.fromRGB(0, 170, 255))
							end
						end

						-- Block detection — kick
						if id and BLOCK_IDS[id] and now - lastKick > 1 then
							if isFacingMe(root) then
								lastKick = now
								local targetPlayer = entry.player
								task.delay(0.7, function()
									local r2 = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
									if r2 and myRoot and (myRoot.Position - r2.Position).Magnitude <= RANGE then
										kick()
										flash("KICK " .. targetPlayer.Name, Color3.fromRGB(255, 100, 100))
									end
								end)
							end
						end

						-- Kick detection — dodge
						if id and KICK_IDS[id] and blocking and now - lastDodge > 1 then
							lastDodge = now
							blocking = false
							backDash()
							flash("DODGE KICK " .. entry.player.Name, Color3.fromRGB(255, 255, 0))
						end

						-- Stagger — execute
						if id and STAGGER_IDS[id] and dist <= 10 then
							execute()
							flash("EXECUTE " .. entry.player.Name, Color3.fromRGB(255, 50, 255))
						end
					end
				end
			end

			-- Block the nearest committed attack
			if bestTrack and not blocking and now - lastBlock > 0.3 then
				lastBlock = now
				blocking = true
				blockedAnims[bestTrack] = true
				blockDown()
				flash(string.format("BLOCK %s [%s] %.0f%% %.0fs",
					bestPlayer.Name, ATTACK_IDS[bestId], bestPct, bestDist), Color3.fromRGB(87, 242, 135))
				task.delay(BLOCK_HOLD, function()
					if blocking then
						blockUp()
						blocking = false
					end
				end)
			end
		end
		task.wait(POLL_RATE)
	end
end)

-- Clean stale blocked anims
task.spawn(function()
	while true do
		task.wait(2)
		for track in pairs(blockedAnims) do
			if not track.IsPlaying then blockedAnims[track] = nil end
		end
	end
end)

