-- Zo Samurai Auto Parry v4
-- Animation percentage timing + ReplicatedStorage scan + dot product facing

task.spawn(function()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VIM = game:GetService("VirtualInputManager")
local lp = Players.LocalPlayer
local playerGui = lp:WaitForChild("PlayerGui")
local connections = {}

---------- Settings ----------

local RANGE = 20
local BLOCK_PERCENT = 30    -- block when attack animation reaches this % (after feint window)
local BLOCK_PERCENT_MAX = 50 -- stop checking after this %
local BLOCK_HOLD = 0.4
local POLL_RATE = 0.02 -- ~50hz

---------- Scan animations from ReplicatedStorage ----------

local ATTACK_IDS = {}
local BLOCK_IDS = {}
local FEINT_IDS = {}
local KICK_IDS = { ["6907975812"] = true }
local STAGGER_IDS = { ["15612208633"] = true }
local IGNORE_IDS = {} -- idle, walk, dash, etc

local function scanGameAnimations()
	pcall(function()
		-- Try to find combat animations in ReplicatedStorage
		local function scanFolder(folder, depth)
			if depth > 6 then return end
			for _, obj in ipairs(folder:GetChildren()) do
				if obj:IsA("Animation") then
					local id = obj.AnimationId:match("%d+")
					if id then
						local name = obj.Name:lower()
						local parentName = obj.Parent and obj.Parent.Name:lower() or ""
						if name:find("attack") or name:find("slash") or name:find("swing")
							or name:find("uppercut") or name:find("crit") then
							ATTACK_IDS[id] = obj.Parent and obj.Parent.Name or "Unknown"
						elseif name:find("block") or name:find("guard") then
							BLOCK_IDS[id] = obj.Parent and obj.Parent.Name or "Unknown"
						elseif name:find("feint") or name:find("cancel") then
							FEINT_IDS[id] = obj.Parent and obj.Parent.Name or "Unknown"
						elseif name:find("kick") then
							KICK_IDS[id] = true
						elseif name:find("idle") or name:find("walk") or name:find("sprint")
							or name:find("dash") or name:find("grip") or name:find("equip") then
							IGNORE_IDS[id] = true
						end
					end
				end
				if obj:IsA("Folder") or obj:IsA("ModuleScript") or obj:IsA("Configuration") then
					scanFolder(obj, depth + 1)
				end
			end
		end
		scanFolder(ReplicatedStorage, 0)
	end)
end

-- Hardcoded fallback IDs
local function registerHardcoded()
	local function reg(name, a1, a2, a3, a4, block, feint)
		if a1 then ATTACK_IDS[tostring(a1)] = name end
		if a2 then ATTACK_IDS[tostring(a2)] = name end
		if a3 then ATTACK_IDS[tostring(a3)] = name end
		if a4 then ATTACK_IDS[tostring(a4)] = name end
		if block then BLOCK_IDS[tostring(block)] = name end
		if feint then FEINT_IDS[tostring(feint)] = name end
	end
	reg("Katana",     6678908798, 6678909967, 6678913068, 6678914641, 6678915740, 13522514295)
	reg("Naginata",   6708118912, 6835409260, 6708121991, 6708121121, 6708116223, 13521669139)
	reg("Tanto",      7845695759, 7845695236, 7845696985, 7845696360, 7845348044, 13521591312)
	reg("Kanabo",     14483365680, 6995853850, 6996771877, 7011157033, 6986985774, 13521582897)
	reg("Kusarigama", 11941288362, 11941292174, 11941309395, 11941314458, 11941247104, 13521767819)
	reg("Caestus",    11752087150, 11752098805, 11752104735, 11752111783, 11579873330, 13521763633)
	reg("Odachi",     13537213350, 13537219514, 13537224645, 13537230809, 13537206453, 13540496277)
	reg("Scythe",     14349499924, 14349501923, 14349504049, 14349506078, 6708116223, 13521669139)
	ATTACK_IDS["11753430563"] = "Katana" -- from reference script
end

registerHardcoded()
scanGameAnimations()

local attackCount = 0
for _ in pairs(ATTACK_IDS) do attackCount = attackCount + 1 end

---------- Input ----------

local function blockDown()
	VIM:SendMouseButtonEvent(0, 0, 1, true, game, 0)
end
local function blockUp()
	VIM:SendMouseButtonEvent(0, 0, 1, false, game, 0)
end
local function swing()
	VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
	task.delay(0.15, function() VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0) end)
end
local function kick()
	if keypress then keypress(0x46); task.delay(0.15, function() keyrelease(0x46) end)
	else VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game); task.delay(0.15, function() VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game) end) end
end
local function execute()
	if keypress then keypress(0x45); task.delay(0.15, function() keyrelease(0x45) end)
	else VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game); task.delay(0.15, function() VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game) end) end
end
local function backDash()
	blockUp()
	if keypress then
		keypress(0x53)
		task.delay(0.05, function() keypress(0x52); task.delay(0.15, function() keyrelease(0x52) end) end)
		task.delay(0.4, function() keyrelease(0x53) end)
	end
end

