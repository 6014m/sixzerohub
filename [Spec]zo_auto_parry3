---------- Input ----------

local function blockDown()
	VIM:SendMouseButtonEvent(0, 0, 1, true, game, 0)
end

local function blockUp()
	VIM:SendMouseButtonEvent(0, 0, 1, false, game, 0)
end

local function swing()
	VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
	task.delay(0.15, function()
		VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
	end)
end

local function kick()
	if keypress then
		keypress(0x46)
		task.delay(0.15, function() keyrelease(0x46) end)
	else
		VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
		task.delay(0.15, function() VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game) end)
	end
end

local function execute()
	if keypress then
		keypress(0x45)
		task.delay(0.15, function() keyrelease(0x45) end)
	else
		VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
