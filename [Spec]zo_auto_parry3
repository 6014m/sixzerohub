---------- Settings ----------

local RANGE = 16
local BLOCK_PERCENT = 30    -- block when attack animation reaches this % (after feint window)
local BLOCK_PERCENT_MAX = 50 -- stop checking after this %
local BLOCK_HOLD = 0.4
local POLL_RATE = 0.02 -- ~50hz

---------- Scan animations from ReplicatedStorage ----------

local ATTACK_IDS = {}
local BLOCK_IDS = {}
local FEINT_IDS = {}
local KICK_IDS = { ["6907975812"] = true }
local STAGGER_IDS = { ["15612208633"] = true }
local IGNORE_IDS = {} -- idle, walk, dash, etc

local function scanGameAnimations()
	pcall(function()
		-- Try to find combat animations in ReplicatedStorage
		local function scanFolder(folder, depth)
			if depth > 6 then return end
			for _, obj in ipairs(folder:GetChildren()) do
				if obj:IsA("Animation") then
					local id = obj.AnimationId:match("%d+")
					if id then
						local name = obj.Name:lower()
						local parentName = obj.Parent and obj.Parent.Name:lower() or ""
						if name:find("attack") or name:find("slash") or name:find("swing")
							or name:find("uppercut") or name:find("crit") then
							ATTACK_IDS[id] = obj.Parent and obj.Parent.Name or "Unknown"
						elseif name:find("block") or name:find("guard") then
							BLOCK_IDS[id] = obj.Parent and obj.Parent.Name or "Unknown"
						elseif name:find("feint") or name:find("cancel") then
							FEINT_IDS[id] = obj.Parent and obj.Parent.Name or "Unknown"
						elseif name:find("kick") then
							KICK_IDS[id] = true
						elseif name:find("idle") or name:find("walk") or name:find("sprint")
							or name:find("dash") or name:find("grip") or name:find("equip") then
							IGNORE_IDS[id] = true
						end
					end
				end
				if obj:IsA("Folder") or obj:IsA("ModuleScript") or obj:IsA("Configuration") then
					scanFolder(obj, depth + 1)
				end
			end
		end
		scanFolder(ReplicatedStorage, 0)
	end)
end

