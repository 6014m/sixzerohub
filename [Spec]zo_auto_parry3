		if child.Name == "BLOCK BROKEN BY KICK" then
			flash("KICK LANDED", Color3.fromRGB(255, 170, 0))
		elseif child.Name == "NORMAL BLOCK" then
			if blocking then
				blockConfirmed = true
				flash("BLOCK CONFIRMED", Color3.fromRGB(87, 242, 135))
			elseif swinging then
				-- Our attack hit their block — expect counter, don't kick
				lastHitBlock = tick()
				flash("HIT THEIR BLOCK — WAIT", Color3.fromRGB(255, 200, 100))
			end
		elseif child.Name == "PERFECT BLOCK" then
			pcall(function()
				if myRoot and child:IsA("BasePart") and (myRoot.Position - child.Position).Magnitude <= RANGE then
					if blocking then blocking = false; blockTarget = nil; blockUp() end
					lastPerfectBlocked = tick()
					backDash()
					flash("GOT PERFECT BLOCKED — DASH", Color3.fromRGB(255, 0, 255))
				end
			end)
		end
	end)
end

