---------- Helpers ----------

local function getHRP(player)
	local char = player and player.Character
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function myHRP()
	local char = lp.Character
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function myTool()
	local char = lp.Character
	return char and char:FindFirstChildOfClass("Tool")
end

local function distTo(player)
	local a, b = myHRP(), getHRP(player)
	if not a or not b then return 999 end
	return (a.Position - b.Position).Magnitude
end

local function isFacing(player)
	local a, b = myHRP(), getHRP(player)
	if not a or not b then return false end
	local look = b.CFrame.LookVector
	local dir = (a.Position - b.Position).Unit
	local val = ((look - dir).Magnitude / 2) ^ 2
	return val < FOV
end

local function getAnimTracks(player)
	local char = player and player.Character
	local hum = char and char:FindFirstChild("Humanoid")
	local animator = hum and hum:FindFirstChildOfClass("Animator")
	if not animator then return {} end
	return animator:GetPlayingAnimationTracks()
end

local function isPlayingAnim(player, idTable)
	for _, track in ipairs(getAnimTracks(player)) do
		if track.Animation then
			local id = track.Animation.AnimationId:match("%d+")
			if id and idTable[id] then return true, idTable[id] end
		end
	end
	return false
end

---------- State ----------

local blocking = false
local lastBlock = 0
local lastKick = 0
local lastPunish = 0
local lastDodge = 0

---------- Main Poll Loop ----------

flash("Auto Parry v3 — polling", Color3.fromRGB(87, 242, 135))

task.spawn(function()
	while true do
		local root = myHRP()
		if root then
			for _, player in ipairs(Players:GetPlayers()) do
				if player ~= lp then
					local d = distTo(player)
					if d <= RANGE then
						local now = tick()

						-- Check ATTACK — block
						local attacking, wpn = isPlayingAnim(player, ATTACK_IDS)
						if attacking and isFacing(player) and myTool() and not blocking then
							if now - lastBlock > 0.3 then
								lastBlock = now
								blocking = true
								blockDown()
								flash("BLOCK " .. player.Name .. " [" .. (wpn or "?") .. "] " .. math.floor(d) .. "s", Color3.fromRGB(87, 242, 135))
								task.delay(BLOCK_HOLD, function()
									if blocking then
										blockUp()
										blocking = false
									end
								end)
							end
						end

						-- Check FEINT — release block + punish
						local feinting = isPlayingAnim(player, FEINT_IDS)
						if feinting then
							if blocking then
								blockUp()
								blocking = false
							end
							if now - lastPunish > 0.3 then
								lastPunish = now
								swing()
								flash("PUNISH FEINT " .. player.Name, Color3.fromRGB(0, 170, 255))
							end
						end

						-- Check BLOCK — kick them
						local isBlocking = isPlayingAnim(player, BLOCK_IDS)
						if isBlocking and now - lastKick > 1 then
							lastKick = now
							task.delay(0.7, function()
								if distTo(player) <= RANGE and isPlayingAnim(player, BLOCK_IDS) then
									kick()
									flash("KICK " .. player.Name, Color3.fromRGB(255, 100, 100))
								end
							end)
						end

						-- Check KICK on us — dodge
						local kicking = isPlayingAnim(player, KICK_IDS)
						if kicking and blocking and now - lastDodge > 1 then
							lastDodge = now
							blocking = false
							backDash()
							flash("DODGE KICK " .. player.Name, Color3.fromRGB(255, 255, 0))
						end

						-- Check STAGGER — execute
						local staggered = isPlayingAnim(player, STAGGER_IDS)
						if staggered and d <= 10 then
							execute()
							flash("EXECUTE " .. player.Name, Color3.fromRGB(255, 50, 255))
						end
					end
				end
			end
		end
		task.wait(POLL_RATE)
	end
end)

---------- GLINT Detection (fastest path, supplements polling) ----------

local function hookGlint(player, char)
	if not char or player == lp then return end
	local c = char.DescendantAdded:Connect(function(desc)
		if desc.Name == "GLINT" then
			local d = distTo(player)
			if d <= RANGE and not blocking and myTool() then
				local now = tick()
				if now - lastBlock > 0.3 then
					lastBlock = now
					blocking = true
					blockDown()
					flash("GLINT BLOCK " .. player.Name .. " " .. math.floor(d) .. "s", Color3.fromRGB(0, 255, 150))
					task.delay(BLOCK_HOLD, function()
						if blocking then
							blockUp()
							blocking = false
						end
					end)
				end
			end
		end
	end)
	table.insert(connections, c)
end

for _, p in ipairs(Players:GetPlayers()) do
	if p.Character then hookGlint(p, p.Character) end
	p.CharacterAdded:Connect(function(char) task.wait(0.3); hookGlint(p, char) end)
end
Players.PlayerAdded:Connect(function(p)
	if p.Character then hookGlint(p, p.Character) end
	p.CharacterAdded:Connect(function(char) task.wait(0.3); hookGlint(p, char) end)
end)

